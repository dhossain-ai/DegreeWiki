---
import PublicLayout from '../../layouts/PublicLayout.astro'
import Container from '../../components/ui/Container.astro'
import Badge from '../../components/ui/Badge.astro'
import SourceBox from '../../components/public/SourceBox.astro'
import MediaImage from '../../components/public/MediaImage.astro'
import FitFinderMiniPanel from '../../components/public/FitFinderMiniPanel.astro'
import ProgramCard from '../../components/public/cards/ProgramCard.astro'
import SavedProgramEnhancement from '../../components/public/SavedProgramEnhancement.astro'
import { createClient } from '../../lib/supabase/server'
import { SITE_URL } from '../../lib/site'
import { getPublicId, getAlt, getOgImageUrl } from '../../lib/public/media'

const { slug } = Astro.params
const supabase = createClient(Astro.cookies, Astro.request)

const { data: university } = await supabase
  .from('universities')
  .select(`
    id, name, slug, official_url, short_name, native_name, institution_type,
    ownership_type, founded_year, student_count, ranking_summary, ranking_source_url,
    overview, campus_summary, admission_overview, application_overview,
    application_portal_url, international_admissions_url, admission_email,
    language_requirement_overview, scholarship_overview, housing_overview,
    student_life_overview, international_student_overview, career_support_overview,
    verification_status, last_verified_at, source_confidence_score, updated_at,
    seo_title, seo_description, seo_h1, canonical_url, og_title, og_description,
    countries(name), cities(name),
    logo:media_assets!universities_logo_id_fkey(cloudinary_public_id, alt_text, display_name),
    cover_image:media_assets!universities_cover_image_id_fkey(cloudinary_public_id, alt_text, display_name),
    og_image:media_assets!universities_og_image_id_fkey(cloudinary_public_id, alt_text, display_name)
  `)
  .eq('slug', slug!)
  .eq('content_status', 'published')
  .single()

if (!university) {
  return new Response(null, { status: 404 })
}

const u = university as any

const VERIFICATION_MAP: Record<string, { label: string; variant: 'verified' | 'neutral' }> = {
  verified: { label: 'Verified', variant: 'verified' },
  partially_verified: { label: 'Partially verified', variant: 'neutral' },
  source_conflict: { label: 'Under review', variant: 'neutral' },
  outdated: { label: 'May need updating', variant: 'neutral' },
  needs_review: { label: 'Needs review', variant: 'neutral' },
  unverified: { label: 'Not yet verified', variant: 'neutral' },
}

function normalizeText(value: string | null | undefined): string {
  return typeof value === 'string' ? value.trim() : ''
}

function splitPlainTextParagraphs(value: string | null | undefined): string[] {
  return normalizeText(value)
    .split(/\n\s*\n+/)
    .map((paragraph) => paragraph.replace(/\s*\n\s*/g, ' ').trim())
    .filter(Boolean)
}

function teaserFromText(value: string | null | undefined, maxLength = 180): string | null {
  const firstParagraph = splitPlainTextParagraphs(value)[0] ?? ''
  if (!firstParagraph) return null
  if (firstParagraph.length <= maxLength) return firstParagraph
  const slice = firstParagraph.slice(0, maxLength)
  const trimmed = slice.includes(' ') ? slice.slice(0, slice.lastIndexOf(' ')) : slice
  return `${trimmed.trimEnd()}...`
}

function formatDate(value: string | null | undefined): string | null {
  if (!value) return null
  return new Date(value).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
}

function formatShortDate(value: string | null | undefined): string | null {
  if (!value) return null
  return new Date(value).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
}

function uniInitials(name: string): string {
  const caps = name.split(/\s+/).map((word: string) => word[0]?.toUpperCase() ?? '').filter(Boolean)
  return caps.slice(0, 2).join('') || name.slice(0, 2).toUpperCase()
}

function abbreviateDegree(code: string | null | undefined, name: string | null | undefined): string | null {
  if (!code && !name) return null
  const c = (code ?? '').toLowerCase()
  const n = (name ?? '').toLowerCase()
  if (c === 'phd' || c === 'doctorate' || n.includes('phd') || n.includes('doctor')) return 'PhD'
  if (c === 'mba' || n.includes('mba')) return 'MBA'
  if (c === 'master' || n.includes('master')) return 'MSc'
  if (c === 'bachelor' || n.includes('bachelor')) return 'BSc'
  if (c === 'postgraduate' || n.includes('postgraduate')) return 'PG'
  return name ?? null
}

function formatDuration(months: number | null | undefined): string | null {
  if (!months) return null
  if (months === 12) return '1 year'
  if (months % 12 === 0) return `${months / 12} years`
  return `${months} months`
}

function moneyPrefix(currency: string | null | undefined): string {
  const cur = (currency ?? '').toUpperCase()
  if (cur === 'EUR') return '€'
  if (cur === 'USD') return '$'
  if (cur === 'GBP') return '£'
  return cur ? `${cur} ` : ''
}

function tuitionDisplay(program: any): { display: string | null; per: string | null } {
  const min = program.tuition_min_amount
  const max = program.tuition_max_amount
  if (min == null && max == null) return { display: null, per: null }
  const fmt = (amount: number) => `${moneyPrefix(program.tuition_currency)}${Number(amount).toLocaleString()}`
  const display = min != null && max != null && min !== max ? `${fmt(min)}–${fmt(max)}` : fmt(min ?? max)
  const per = program.tuition_period ? `per ${program.tuition_period.replace(/_/g, ' ')}` : 'per year'
  return { display, per }
}

const verInfo = VERIFICATION_MAP[u.verification_status] ?? null
const verificationLabel = verInfo?.label ?? 'Not yet verified'
const location = [u.cities?.name, u.countries?.name].filter(Boolean).join(', ')
const initials = uniInitials(u.name)
const shortName = normalizeText(u.short_name)
const nativeName = normalizeText(u.native_name)
const overviewParagraphs = splitPlainTextParagraphs(u.overview)
const rankingParagraphs = splitPlainTextParagraphs(u.ranking_summary)
const campusParagraphs = splitPlainTextParagraphs(u.campus_summary)
const admissionParagraphs = splitPlainTextParagraphs(u.admission_overview)
const applicationParagraphs = splitPlainTextParagraphs(u.application_overview)
const languageParagraphs = splitPlainTextParagraphs(u.language_requirement_overview)
const scholarshipParagraphs = splitPlainTextParagraphs(u.scholarship_overview)
const housingParagraphs = splitPlainTextParagraphs(u.housing_overview)
const studentLifeParagraphs = splitPlainTextParagraphs(u.student_life_overview)
const internationalParagraphs = splitPlainTextParagraphs(u.international_student_overview)
const careerParagraphs = splitPlainTextParagraphs(u.career_support_overview)
const lastVerifiedAt = formatDate(u.last_verified_at)
const lastVerifiedShort = formatShortDate(u.last_verified_at)
const updatedAt = formatDate(u.updated_at)

const pageTitle = normalizeText(u.seo_title) || u.name
const pageHeading = normalizeText(u.seo_h1) || u.name
const pageDesc = normalizeText(u.seo_description)
  || teaserFromText(u.overview, 160)
  || teaserFromText(u.ranking_summary, 160)
  || [u.name, location].filter(Boolean).join(' · ')
  || undefined
const canonical = normalizeText(u.canonical_url) || `${SITE_URL}/universities/${slug}`
const ogTitle = normalizeText(u.og_title) || pageTitle
const ogDesc = normalizeText(u.og_description) || pageDesc

const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME ?? ''
const logoPublicId = getPublicId(u.logo)
const logoAlt = getAlt(u.logo, u.name)
const coverPublicId = getPublicId(u.cover_image)
const coverAlt = getAlt(u.cover_image, `${u.name} campus`)
const ogImageUrl = getOgImageUrl(cloudName, u.og_image, u.cover_image ?? u.logo)

const { data: relatedProgramsData, error: relatedProgramsError } = await supabase
  .from('programs')
  .select(`
    id, title, slug, duration_months, language_of_instruction,
    tuition_min_amount, tuition_max_amount, tuition_currency, tuition_period,
    verification_status, last_verified_at,
    universities(
      name, slug,
      logo:media_assets!universities_logo_id_fkey(cloudinary_public_id, alt_text, display_name)
    ),
    degree_levels(name, code),
    countries(name, iso2),
    cities(name),
    subjects!programs_primary_subject_id_fkey(name)
  `)
  .eq('content_status', 'published')
  .eq('university_id', u.id)
  .order('title')
  .limit(3)

if (relatedProgramsError) console.error('university related programs error:', relatedProgramsError.message)
const relatedPrograms = relatedProgramsData ?? []

const hasOverviewSection = overviewParagraphs.length > 0
const hasRankingSection = rankingParagraphs.length > 0 || normalizeText(u.ranking_source_url)
const hasAdmissionsSection = admissionParagraphs.length > 0
  || applicationParagraphs.length > 0
  || normalizeText(u.application_portal_url)
  || normalizeText(u.international_admissions_url)
  || normalizeText(u.admission_email)
const hasCampusSection = campusParagraphs.length > 0 || studentLifeParagraphs.length > 0
const hasInternationalSection = internationalParagraphs.length > 0 || careerParagraphs.length > 0
const hasSupportSection = scholarshipParagraphs.length > 0 || housingParagraphs.length > 0 || languageParagraphs.length > 0
const hasProfileContent = hasOverviewSection || hasRankingSection || hasAdmissionsSection || hasCampusSection || hasInternationalSection || hasSupportSection
---
<PublicLayout
  title={`${pageTitle} — DegreeWiki`}
  description={pageDesc}
  canonical={canonical}
  ogTitle={ogTitle}
  ogDescription={ogDesc}
  ogImage={ogImageUrl ?? undefined}
>
  <div class="bg-surface border-b border-edge">
    <Container width="wide" class="py-7 sm:py-9">
      <a href="/universities" class="inline-flex items-center gap-1 text-sm text-primary hover:text-primary-hover mb-5">
        ← All Universities
      </a>

      <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_320px] lg:items-start">
        <div class="flex items-start gap-4">
          {logoPublicId ? (
            <div class="flex-none w-16 h-16 rounded-xl overflow-hidden border border-edge bg-surface">
              <MediaImage publicId={logoPublicId} alt={logoAlt} width={96} height={96} crop="fill" loading="eager" class="w-full h-full object-cover" />
            </div>
          ) : (
            <div class="flex-none w-16 h-16 rounded-xl bg-primary-surface border border-primary-border flex items-center justify-center font-mono text-base font-bold text-primary">
              {initials}
            </div>
          )}

          <div class="min-w-0">
            <h1 class="text-[30px] sm:text-[38px] font-bold text-ink tracking-[-0.03em] leading-tight">{pageHeading}</h1>
            {(shortName || nativeName) && (
              <p class="mt-2 text-sm text-ink-secondary">
                {[shortName, nativeName].filter(Boolean).join(' · ')}
              </p>
            )}
            {location && <p class="mt-2 text-base text-ink-secondary">{location}</p>}
            <div class="mt-3 flex flex-wrap items-center gap-2">
              {verInfo && <Badge variant={verInfo.variant}>{verInfo.label}</Badge>}
              {lastVerifiedShort && <Badge variant="neutral">Source checked {lastVerifiedShort}</Badge>}
              {relatedPrograms.length > 0 && <Badge variant="info">Featured programs below</Badge>}
            </div>
          </div>
        </div>

        <div class="rounded-2xl border border-edge bg-canvas p-5">
          <p class="text-[11px] font-semibold uppercase tracking-[0.06em] text-muted mb-3">Plan your next step</p>
          <div class="flex flex-col gap-3">
            <a href={`/programs?university=${u.id}`} class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-primary text-white text-sm font-semibold rounded-[10px] hover:bg-primary-hover transition-colors">
              Browse programs
            </a>
            {u.official_url && (
              <a href={u.official_url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 border border-edge bg-surface text-ink-secondary text-sm font-semibold rounded-[10px] hover:border-primary/40 hover:text-ink transition-colors">
                Official website ↗
              </a>
            )}
            <p class="text-xs text-muted leading-relaxed">
              Confirm admissions, fees, deadlines, and campus details directly with the university before applying.
            </p>
          </div>
        </div>
      </div>
    </Container>
  </div>

  {coverPublicId && (
    <div class="bg-canvas border-b border-edge">
      <Container width="wide" class="pt-6">
        <MediaImage publicId={coverPublicId} alt={coverAlt} width={1600} height={640} crop="fill" loading="eager" class="w-full rounded-2xl object-cover" />
      </Container>
    </div>
  )}

  <div class="bg-canvas">
    <Container width="wide" class="py-7 sm:py-8">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_320px]">
        <div>
          {hasProfileContent ? (
            <div class="space-y-7">
              {hasOverviewSection && (
                <section class="rounded-2xl border border-edge bg-surface p-5">
                  <h2 class="text-lg font-semibold text-ink mb-3">Overview</h2>
                  <div class="space-y-3">
                    {overviewParagraphs.map((paragraph) => (
                      <p class="text-sm text-ink-secondary leading-relaxed">{paragraph}</p>
                    ))}
                  </div>
                </section>
              )}

              {hasRankingSection && (
                <section class="rounded-2xl border border-edge bg-surface p-5">
                  <h2 class="text-lg font-semibold text-ink mb-3">Rankings and reputation</h2>
                  {rankingParagraphs.length > 0 && (
                    <div class="space-y-3">
                      {rankingParagraphs.map((paragraph) => (
                        <p class="text-sm text-ink-secondary leading-relaxed">{paragraph}</p>
                      ))}
                    </div>
                  )}
                  {u.ranking_source_url && (
                    <a href={u.ranking_source_url} target="_blank" rel="noopener noreferrer" class="inline-flex mt-4 text-sm font-semibold text-primary hover:text-primary-hover">
                      Ranking source ↗
                    </a>
                  )}
                </section>
              )}

              {hasAdmissionsSection && (
                <section class="rounded-2xl border border-edge bg-surface p-5">
                  <h2 class="text-lg font-semibold text-ink mb-4">Admissions &amp; application</h2>
                  <div class="space-y-5">
                    {admissionParagraphs.length > 0 && (
                      <div>
                        <h3 class="text-sm font-semibold text-ink mb-2">Admissions overview</h3>
                        <div class="space-y-3">
                          {admissionParagraphs.map((paragraph) => (
                            <p class="text-sm text-ink-secondary leading-relaxed">{paragraph}</p>
                          ))}
                        </div>
                      </div>
                    )}
                    {applicationParagraphs.length > 0 && (
                      <div>
                        <h3 class="text-sm font-semibold text-ink mb-2">Application overview</h3>
                        <div class="space-y-3">
                          {applicationParagraphs.map((paragraph) => (
                            <p class="text-sm text-ink-secondary leading-relaxed">{paragraph}</p>
                          ))}
                        </div>
                      </div>
                    )}
                    {(u.application_portal_url || u.international_admissions_url || u.admission_email) && (
                      <div class="grid gap-3 sm:grid-cols-2">
                        {u.application_portal_url && (
                          <a href={u.application_portal_url} target="_blank" rel="noopener noreferrer" class="rounded-xl border border-edge-subtle bg-canvas px-4 py-3 text-sm font-medium text-primary hover:border-primary/40">
                            Application portal ↗
                          </a>
                        )}
                        {u.international_admissions_url && (
                          <a href={u.international_admissions_url} target="_blank" rel="noopener noreferrer" class="rounded-xl border border-edge-subtle bg-canvas px-4 py-3 text-sm font-medium text-primary hover:border-primary/40">
                            International admissions ↗
                          </a>
                        )}
                        {u.admission_email && (
                          <a href={`mailto:${u.admission_email}`} class="rounded-xl border border-edge-subtle bg-canvas px-4 py-3 text-sm font-medium text-primary hover:border-primary/40">
                            {u.admission_email}
                          </a>
                        )}
                      </div>
                    )}
                  </div>
                </section>
              )}

              {hasCampusSection && (
                <section class="rounded-2xl border border-edge bg-surface p-5">
                  <h2 class="text-lg font-semibold text-ink mb-4">Campus &amp; student life</h2>
                  <div class="space-y-5">
                    {campusParagraphs.length > 0 && (
                      <div>
                        <h3 class="text-sm font-semibold text-ink mb-2">Campus summary</h3>
                        <div class="space-y-3">
                          {campusParagraphs.map((paragraph) => (
                            <p class="text-sm text-ink-secondary leading-relaxed">{paragraph}</p>
                          ))}
                        </div>
                      </div>
                    )}
                    {studentLifeParagraphs.length > 0 && (
                      <div>
                        <h3 class="text-sm font-semibold text-ink mb-2">Student life</h3>
                        <div class="space-y-3">
                          {studentLifeParagraphs.map((paragraph) => (
                            <p class="text-sm text-ink-secondary leading-relaxed">{paragraph}</p>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                </section>
              )}

              {hasInternationalSection && (
                <section class="rounded-2xl border border-edge bg-surface p-5">
                  <h2 class="text-lg font-semibold text-ink mb-4">International students &amp; career support</h2>
                  <div class="space-y-5">
                    {internationalParagraphs.length > 0 && (
                      <div>
                        <h3 class="text-sm font-semibold text-ink mb-2">International students</h3>
                        <div class="space-y-3">
                          {internationalParagraphs.map((paragraph) => (
                            <p class="text-sm text-ink-secondary leading-relaxed">{paragraph}</p>
                          ))}
                        </div>
                      </div>
                    )}
                    {careerParagraphs.length > 0 && (
                      <div>
                        <h3 class="text-sm font-semibold text-ink mb-2">Career support</h3>
                        <div class="space-y-3">
                          {careerParagraphs.map((paragraph) => (
                            <p class="text-sm text-ink-secondary leading-relaxed">{paragraph}</p>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                </section>
              )}

              {hasSupportSection && (
                <section class="rounded-2xl border border-edge bg-surface p-5">
                  <h2 class="text-lg font-semibold text-ink mb-4">Scholarships, housing, and language requirements</h2>
                  <div class="space-y-5">
                    {scholarshipParagraphs.length > 0 && (
                      <div>
                        <h3 class="text-sm font-semibold text-ink mb-2">Scholarships</h3>
                        <div class="space-y-3">
                          {scholarshipParagraphs.map((paragraph) => (
                            <p class="text-sm text-ink-secondary leading-relaxed">{paragraph}</p>
                          ))}
                        </div>
                      </div>
                    )}
                    {housingParagraphs.length > 0 && (
                      <div>
                        <h3 class="text-sm font-semibold text-ink mb-2">Housing</h3>
                        <div class="space-y-3">
                          {housingParagraphs.map((paragraph) => (
                            <p class="text-sm text-ink-secondary leading-relaxed">{paragraph}</p>
                          ))}
                        </div>
                      </div>
                    )}
                    {languageParagraphs.length > 0 && (
                      <div>
                        <h3 class="text-sm font-semibold text-ink mb-2">Language requirements</h3>
                        <div class="space-y-3">
                          {languageParagraphs.map((paragraph) => (
                            <p class="text-sm text-ink-secondary leading-relaxed">{paragraph}</p>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                </section>
              )}
            </div>
          ) : (
            <div class="rounded-2xl border border-edge bg-surface p-6">
              <h2 class="text-lg font-semibold text-ink mb-2">Published university information</h2>
              <p class="text-sm text-muted leading-relaxed">
                This profile is live, but detailed public notes have not been added yet. Use the official website and program listings to verify admissions, fees, deadlines, and campus details.
              </p>
            </div>
          )}

          {updatedAt && <p class="text-xs text-muted mt-6">Last updated: {updatedAt}</p>}

          <a href="/universities" class="inline-flex mt-6 text-sm text-primary hover:text-primary-hover">
            ← All Universities
          </a>
        </div>

        <aside class="space-y-5 lg:sticky lg:top-[88px] lg:self-start">
          <div class="rounded-2xl border border-edge bg-surface p-5">
            <h2 class="text-[11px] font-semibold uppercase tracking-[0.06em] text-muted mb-4">Key facts</h2>
            <dl class="space-y-3">
              {u.institution_type && (
                <div>
                  <dt class="text-[11px] font-semibold uppercase tracking-[0.05em] text-muted mb-1">Institution type</dt>
                  <dd class="text-sm font-medium text-ink">{u.institution_type}</dd>
                </div>
              )}
              {u.ownership_type && (
                <div>
                  <dt class="text-[11px] font-semibold uppercase tracking-[0.05em] text-muted mb-1">Ownership</dt>
                  <dd class="text-sm font-medium text-ink">{u.ownership_type}</dd>
                </div>
              )}
              {u.countries?.name && (
                <div>
                  <dt class="text-[11px] font-semibold uppercase tracking-[0.05em] text-muted mb-1">Country</dt>
                  <dd class="text-sm font-medium text-ink">{u.countries.name}</dd>
                </div>
              )}
              {u.cities?.name && (
                <div>
                  <dt class="text-[11px] font-semibold uppercase tracking-[0.05em] text-muted mb-1">City</dt>
                  <dd class="text-sm font-medium text-ink">{u.cities.name}</dd>
                </div>
              )}
              {u.founded_year != null && (
                <div>
                  <dt class="text-[11px] font-semibold uppercase tracking-[0.05em] text-muted mb-1">Founded</dt>
                  <dd class="text-sm font-medium text-ink">{u.founded_year}</dd>
                </div>
              )}
              {u.student_count != null && (
                <div>
                  <dt class="text-[11px] font-semibold uppercase tracking-[0.05em] text-muted mb-1">Students</dt>
                  <dd class="text-sm font-medium text-ink">{(u.student_count as number).toLocaleString()}</dd>
                </div>
              )}
              {verificationLabel && (
                <div>
                  <dt class="text-[11px] font-semibold uppercase tracking-[0.05em] text-muted mb-1">Verification</dt>
                  <dd class="text-sm font-medium text-ink">{verificationLabel}</dd>
                </div>
              )}
              {relatedPrograms.length > 0 && (
                <div>
                  <dt class="text-[11px] font-semibold uppercase tracking-[0.05em] text-muted mb-1">Featured programs</dt>
                  <dd class="text-sm font-medium text-ink">{relatedPrograms.length} sample listings shown below</dd>
                </div>
              )}
              {lastVerifiedAt && (
                <div>
                  <dt class="text-[11px] font-semibold uppercase tracking-[0.05em] text-muted mb-1">Last verified</dt>
                  <dd class="text-sm font-medium text-ink">{lastVerifiedAt}</dd>
                </div>
              )}
            </dl>
          </div>

          <SourceBox
            verificationStatus={u.verification_status}
            lastVerifiedAt={lastVerifiedAt}
            officialUrl={u.official_url ?? null}
            sourceConfidenceScore={u.source_confidence_score ?? null}
          />

          <FitFinderMiniPanel />
        </aside>
      </div>
    </Container>
  </div>

  {relatedPrograms.length > 0 && (
    <div class="border-t border-edge bg-surface">
      <Container width="wide" class="py-8 sm:py-10">
        <div class="mb-4 flex items-end justify-between gap-3">
          <div>
            <h2 class="text-lg font-semibold text-ink">Featured programs at {u.name}</h2>
            <p class="mt-1 text-sm text-muted">This is a small sample from the public program directory, not a complete program catalog.</p>
          </div>
          <a href={`/programs?university=${u.id}`} class="hidden sm:inline-flex text-sm font-semibold text-primary hover:text-primary-hover">
            View all programs
          </a>
        </div>
        <div class="flex flex-col gap-4">
          {relatedPrograms.map((program: any) => {
            const tuition = tuitionDisplay(program)
            return (
              <ProgramCard
                href={`/programs/${program.slug}`}
                programId={program.id}
                title={program.title}
                universityName={program.universities?.name ?? u.name}
                universityHref={program.universities?.slug ? `/universities/${program.universities.slug}` : null}
                degreeLevel={abbreviateDegree(program.degree_levels?.code, program.degree_levels?.name)}
                field={program.subjects?.name ?? null}
                countryCode={program.countries?.iso2 ?? null}
                location={[program.cities?.name, program.countries?.name].filter(Boolean).join(', ') || null}
                duration={formatDuration(program.duration_months)}
                language={program.language_of_instruction ?? null}
                tuitionDisplay={tuition.display}
                tuitionPer={tuition.per}
                verificationLabel={
                  program.verification_status === 'verified'
                    ? 'Verified'
                    : program.verification_status === 'partially_verified'
                      ? 'Partially verified'
                      : null
                }
                verificationTone={program.verification_status === 'partially_verified' ? 'neutral' : 'verified'}
                sourceChecked={formatShortDate(program.last_verified_at)}
                logoPublicId={program.universities?.logo?.cloudinary_public_id ?? logoPublicId}
                logoAlt={program.universities?.logo?.alt_text || program.universities?.logo?.display_name || program.universities?.name || logoAlt}
              />
            )
          })}
        </div>
      </Container>
    </div>
  )}

  <SavedProgramEnhancement />
</PublicLayout>
