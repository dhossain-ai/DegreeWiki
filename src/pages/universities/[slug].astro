---
import PublicLayout from '../../layouts/PublicLayout.astro'
import Container from '../../components/ui/Container.astro'
import Badge from '../../components/ui/Badge.astro'
import SourceBox from '../../components/public/SourceBox.astro'
import MediaImage from '../../components/public/MediaImage.astro'
import { createClient } from '../../lib/supabase/server'
import { SITE_URL } from '../../lib/site'
import { getPublicId, getAlt, getOgImageUrl } from '../../lib/public/media'

const { slug } = Astro.params
const supabase = createClient(Astro.cookies, Astro.request)

const { data: university } = await supabase
  .from('universities')
  .select(`
    id, name, slug, official_url, founded_year, student_count,
    ranking_summary, overview,
    verification_status, last_verified_at, source_confidence_score, updated_at,
    seo_title, seo_description,
    canonical_url, og_title, og_description,
    countries(name), cities(name),
    logo:media_assets!universities_logo_id_fkey(cloudinary_public_id, alt_text, display_name),
    cover_image:media_assets!universities_cover_image_id_fkey(cloudinary_public_id, alt_text, display_name),
    og_image:media_assets!universities_og_image_id_fkey(cloudinary_public_id, alt_text, display_name)
  `)
  .eq('slug', slug!)
  .eq('content_status', 'published')
  .single()

if (!university) {
  return new Response(null, { status: 404 })
}

const u = university as any

const VERIFICATION_MAP: Record<string, { label: string; variant: 'verified' | 'neutral' }> = {
  verified:           { label: 'Verified',           variant: 'verified' },
  partially_verified: { label: 'Partially Verified', variant: 'neutral'  },
  source_conflict:    { label: 'Under Review',       variant: 'neutral'  },
  outdated:           { label: 'Under Review',       variant: 'neutral'  },
  needs_review:       { label: 'Under Review',       variant: 'neutral'  },
}
const verInfo = VERIFICATION_MAP[u.verification_status] ?? null

function formatDate(d: string | null): string | null {
  if (!d) return null
  return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
}

function uniInitials(name: string): string {
  const caps = name.split(/\s+/).map((w: string) => w[0]?.toUpperCase() ?? '').filter(Boolean)
  return caps.slice(0, 2).join('') || name.slice(0, 2).toUpperCase()
}

const location      = [u.countries?.name, u.cities?.name].filter(Boolean).join(', ')
const initials      = uniInitials(u.name)
const lastVerifiedAt = formatDate(u.last_verified_at)
const pageTitle     = u.seo_title || u.name
const pageDesc      = u.seo_description || u.ranking_summary || undefined
const canonical     = u.canonical_url || `${SITE_URL}/universities/${slug}`
const ogTitle       = u.og_title || pageTitle
const ogDesc        = u.og_description || pageDesc
const updatedAt     = formatDate(u.updated_at)

const cloudName    = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME ?? ''
const logoPublicId = getPublicId(u.logo)
const logoAlt      = getAlt(u.logo, u.name)
const coverPublicId = getPublicId(u.cover_image)
const coverAlt      = getAlt(u.cover_image, `${u.name} campus`)
const ogImageUrl   = getOgImageUrl(cloudName, u.og_image, u.cover_image ?? u.logo)
---
<PublicLayout title={`${pageTitle} — DegreeWiki`} description={pageDesc} canonical={canonical} ogTitle={ogTitle} ogDescription={ogDesc} ogImage={ogImageUrl ?? undefined}>

  <!-- Page header band -->
  <div class="bg-surface border-b border-edge">
    <Container width="narrow" class="py-7 sm:py-8">
      <a href="/universities"
         class="inline-flex items-center gap-1 text-sm text-primary hover:text-primary-hover mb-4">
        ← All Universities
      </a>

      <div class="flex items-start gap-4">
        <!-- Logo or monogram -->
        {logoPublicId ? (
          <div class="flex-none w-14 h-14 rounded-xl overflow-hidden border border-edge bg-surface">
            <MediaImage
              publicId={logoPublicId}
              alt={logoAlt}
              width={80}
              height={80}
              crop="fill"
              loading="eager"
              class="w-full h-full object-cover"
            />
          </div>
        ) : (
          <div class="flex-none w-14 h-14 rounded-xl bg-primary-surface border border-primary-border
                      flex items-center justify-center font-mono text-sm font-bold text-primary">
            {initials}
          </div>
        )}
        <div class="min-w-0">
          <h1 class="text-2xl sm:text-3xl font-bold text-ink tracking-[-0.02em] leading-tight mb-1">
            {u.name}
          </h1>
          {location && (
            <p class="text-base text-muted">{location}</p>
          )}
          {verInfo && (
            <div class="mt-2">
              <Badge variant={verInfo.variant}>{verInfo.label}</Badge>
            </div>
          )}
        </div>
      </div>
    </Container>
  </div>

  {coverPublicId && (
    <div class="bg-canvas">
      <Container width="narrow" class="pt-6">
        <MediaImage
          publicId={coverPublicId}
          alt={coverAlt}
          width={1600}
          height={600}
          crop="fill"
          loading="eager"
          class="w-full rounded-xl object-cover"
        />
      </Container>
    </div>
  )}

  <!-- Main content -->
  <div class="bg-canvas">
    <Container width="narrow" class="py-7 sm:py-8">

      <!-- Key facts panel -->
      {(u.countries?.name || u.cities?.name || u.founded_year != null || u.student_count != null) && (
        <div class="bg-surface border border-edge rounded-xl p-5 mb-7">
          <h2 class="text-[11px] font-semibold uppercase tracking-[0.06em] text-muted mb-4">
            About this university
          </h2>
          <dl class="grid grid-cols-2 sm:grid-cols-3 gap-x-6 gap-y-4">
            {u.countries?.name && (
              <div>
                <dt class="text-[11px] font-semibold uppercase tracking-[0.05em] text-muted mb-0.5">Country</dt>
                <dd class="text-sm font-medium text-ink">{u.countries.name}</dd>
              </div>
            )}
            {u.cities?.name && (
              <div>
                <dt class="text-[11px] font-semibold uppercase tracking-[0.05em] text-muted mb-0.5">City</dt>
                <dd class="text-sm font-medium text-ink">{u.cities.name}</dd>
              </div>
            )}
            {u.founded_year != null && (
              <div>
                <dt class="text-[11px] font-semibold uppercase tracking-[0.05em] text-muted mb-0.5">Founded</dt>
                <dd class="text-sm font-medium text-ink">{u.founded_year}</dd>
              </div>
            )}
            {u.student_count != null && (
              <div>
                <dt class="text-[11px] font-semibold uppercase tracking-[0.05em] text-muted mb-0.5">Students</dt>
                <dd class="text-sm font-medium text-ink">{(u.student_count as number).toLocaleString()}</dd>
              </div>
            )}
          </dl>
        </div>
      )}

      <!-- Rankings -->
      {u.ranking_summary && (
        <div class="mb-6">
          <h2 class="text-lg font-semibold text-ink mb-2">Rankings</h2>
          <p class="text-sm text-ink-secondary leading-relaxed whitespace-pre-wrap">{u.ranking_summary}</p>
        </div>
      )}

      <!-- Overview -->
      {u.overview && (
        <div class="mb-6">
          <h2 class="text-lg font-semibold text-ink mb-2">Overview</h2>
          <p class="text-sm text-ink-secondary leading-relaxed whitespace-pre-wrap">{u.overview}</p>
        </div>
      )}

      <!-- Browse programs link -->
      <div class="mb-6 py-4 px-5 rounded-xl border border-primary-border bg-primary-surface">
        <a href={`/programs?university=${u.id}`}
           class="text-sm font-medium text-primary hover:text-primary-hover">
          Browse programs at {u.name} →
        </a>
      </div>

      <!-- Official website CTA -->
      {u.official_url && (
        <div class="mb-6">
          <a href={u.official_url} target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 px-5 py-2.5 border border-edge bg-surface text-ink-secondary
                    text-sm font-medium rounded-[9px] hover:border-primary/40 hover:text-ink transition-colors">
            Visit Official Website ↗
          </a>
        </div>
      )}

      <!-- Source & verification -->
      <SourceBox
        verificationStatus={u.verification_status}
        lastVerifiedAt={lastVerifiedAt}
        officialUrl={u.official_url ?? null}
        sourceConfidenceScore={u.source_confidence_score ?? null}
      />

      {updatedAt && (
        <p class="text-xs text-muted mb-6">Last updated: {updatedAt}</p>
      )}

      <a href="/universities" class="text-sm text-primary hover:text-primary-hover">
        ← All Universities
      </a>

    </Container>
  </div>

</PublicLayout>
