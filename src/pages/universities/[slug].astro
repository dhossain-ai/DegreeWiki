---
import PublicLayout from '../../layouts/PublicLayout.astro'
import { createClient } from '../../lib/supabase/server'
import { SITE_URL } from '../../lib/site'

const { slug } = Astro.params
const supabase = createClient(Astro.cookies, Astro.request)

const { data: university } = await supabase
  .from('universities')
  .select(`
    id, name, slug, official_url, founded_year, student_count,
    ranking_summary, overview,
    verification_status, updated_at,
    seo_title, seo_description,
    canonical_url, og_title, og_description,
    countries(name), cities(name)
  `)
  .eq('slug', slug!)
  .eq('content_status', 'published')
  .single()

if (!university) {
  return new Response(null, { status: 404 })
}

const u = university as any

const VERIFICATION_BADGES: Record<string, { label: string; cls: string }> = {
  verified:           { label: 'Verified',           cls: 'bg-green-50 text-green-700 border border-green-200' },
  partially_verified: { label: 'Partially Verified', cls: 'bg-yellow-50 text-yellow-700 border border-yellow-200' },
  source_conflict:    { label: 'Under Review',       cls: 'bg-orange-50 text-orange-700 border border-orange-200' },
  outdated:           { label: 'Under Review',       cls: 'bg-orange-50 text-orange-700 border border-orange-200' },
  needs_review:       { label: 'Under Review',       cls: 'bg-orange-50 text-orange-700 border border-orange-200' },
}
const verBadge = VERIFICATION_BADGES[u.verification_status] ?? null

function formatDate(d: string | null): string | null {
  if (!d) return null
  return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
}

const pageTitle = u.seo_title || u.name
const pageDesc  = u.seo_description || u.ranking_summary || undefined
const canonical = u.canonical_url || `${SITE_URL}/universities/${slug}`
const ogTitle   = u.og_title || pageTitle
const ogDesc    = u.og_description || pageDesc
const updatedAt = formatDate(u.updated_at)
---
<PublicLayout title={`${pageTitle} — DegreeWiki`} description={pageDesc} canonical={canonical} ogTitle={ogTitle} ogDescription={ogDesc}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <a href="/universities" class="text-sm text-blue-600 hover:underline mb-5 inline-block">← All Universities</a>

    <h1 class="text-3xl font-bold text-gray-900 mb-3">{u.name}</h1>

    {verBadge && (
      <div class="mb-5">
        <span class={`inline-flex items-center text-xs font-medium px-2.5 py-0.5 rounded border ${verBadge.cls}`}>
          {verBadge.label}
        </span>
      </div>
    )}

    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4 text-sm mb-8 bg-gray-50 rounded-lg p-5 border border-gray-200">
      {u.countries?.name && (
        <div>
          <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-0.5">Country</dt>
          <dd class="text-gray-900">{u.countries.name}</dd>
        </div>
      )}
      {u.cities?.name && (
        <div>
          <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-0.5">City</dt>
          <dd class="text-gray-900">{u.cities.name}</dd>
        </div>
      )}
      {u.founded_year != null && (
        <div>
          <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-0.5">Founded</dt>
          <dd class="text-gray-900">{u.founded_year}</dd>
        </div>
      )}
      {u.student_count != null && (
        <div>
          <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-0.5">Students</dt>
          <dd class="text-gray-900">{u.student_count.toLocaleString()}</dd>
        </div>
      )}
    </dl>

    {u.ranking_summary && (
      <div class="mb-6">
        <h2 class="text-base font-semibold text-gray-800 mb-2">Rankings</h2>
        <p class="text-gray-700 text-sm whitespace-pre-wrap">{u.ranking_summary}</p>
      </div>
    )}

    {u.overview && (
      <div class="mb-6">
        <h2 class="text-base font-semibold text-gray-800 mb-2">Overview</h2>
        <p class="text-gray-700 text-sm whitespace-pre-wrap">{u.overview}</p>
      </div>
    )}

    <div class="mt-2 mb-6">
      <a href={`/programs?university=${u.id}`} class="text-sm text-blue-600 hover:underline">
        Browse Programs at {u.name} →
      </a>
    </div>

    {u.official_url && (
      <div class="mb-6 flex flex-col sm:flex-row gap-3">
        <a href={u.official_url} target="_blank" rel="noopener noreferrer"
           class="inline-block px-5 py-2.5 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 text-center">
          Visit Official Website ↗
        </a>
      </div>
    )}

    {updatedAt && (
      <p class="text-xs text-gray-400 mb-6">Last updated: {updatedAt}</p>
    )}

    <a href="/universities" class="text-sm text-blue-600 hover:underline">← All Universities</a>
  </div>
</PublicLayout>
