---
import PublicLayout from '../layouts/PublicLayout.astro'
import HomeHero from '../components/public/home/HomeHero.astro'
import Section from '../components/ui/Section.astro'
import SectionHeader from '../components/ui/SectionHeader.astro'
import SearchChip from '../components/public/SearchChip.astro'
import FitFinderMiniPanel from '../components/public/FitFinderMiniPanel.astro'
import ProgramCard from '../components/public/cards/ProgramCard.astro'
import SavedProgramEnhancement from '../components/public/SavedProgramEnhancement.astro'
import DestinationCard from '../components/public/cards/DestinationCard.astro'
import ScholarshipRow from '../components/public/cards/ScholarshipRow.astro'
import GuideCard from '../components/public/cards/GuideCard.astro'
import { createClient } from '../lib/supabase/server'
import { SITE_URL } from '../lib/site'

const supabase = createClient(Astro.cookies, Astro.request)
const { data: { user } } = await supabase.auth.getUser()

/* ── Static subject fallback (used only when subjects table returns 0 rows) ── */
const FALLBACK_SUBJECTS: { id: string; name: string }[] = [
  { id: '', name: 'Computer Science' },
  { id: '', name: 'Business & Management' },
  { id: '', name: 'Engineering' },
  { id: '', name: 'Law' },
  { id: '', name: 'Medicine & Health' },
  { id: '', name: 'Arts & Humanities' },
]

/* ── All homepage queries in one round-trip ── */
const [
  { data: degreeLevelsData, error: degreeLevelsErr },
  { data: destinationsData, error: destinationsErr },
  { data: featuredProgramsData, error: featuredProgramsErr },
  { data: subjectsData, error: subjectsErr },
  { data: scholarshipsData, error: scholarshipsErr },
  { data: guidesData, error: guidesErr },
] = await Promise.all([
  supabase
    .from('degree_levels')
    .select('id, name, code')
    .eq('is_active', true)
    .order('display_order'),
  supabase
    .from('countries')
    .select(`id, name, slug, cover_image:media_assets!countries_cover_image_id_fkey(cloudinary_public_id, alt_text, display_name)`)
    .eq('content_status', 'published')
    .eq('is_destination_enabled', true)
    .order('name')
    .limit(30),
  supabase
    .from('programs')
    .select(`
      id, title, slug,
      duration_months, language_of_instruction,
      tuition_min_amount, tuition_max_amount, tuition_currency, tuition_period,
      verification_status,
      universities(name, slug),
      degree_levels(name, code),
      subjects!programs_primary_subject_id_fkey(name),
      countries(name, iso2),
      cities(name)
    `)
    .eq('content_status', 'published')
    .order('created_at', { ascending: false })
    .limit(4),
  supabase
    .from('subjects')
    .select('id, name')
    .order('name')
    .limit(12),
  supabase
    .from('scholarships')
    .select('id, name, slug, provider_name, amount_min, amount_max, currency, deadline, deadline_text')
    .eq('content_status', 'published')
    .order('deadline', { ascending: true, nullsFirst: false })
    .limit(4),
  supabase
    .from('articles')
    .select('id, title, slug, summary, published_at, article_categories(id, name)')
    .eq('content_status', 'published')
    .order('published_at', { ascending: false, nullsFirst: false })
    .limit(3),
])

/* Log query errors server-side only — do not surface to user */
if (degreeLevelsErr)     console.error('homepage degree_levels error:',      degreeLevelsErr.message)
if (destinationsErr)     console.error('homepage destinations error:',        destinationsErr.message)
if (featuredProgramsErr) console.error('homepage featured programs error:',   featuredProgramsErr.message)
if (subjectsErr)         console.error('homepage subjects error:',            subjectsErr.message)
if (scholarshipsErr)     console.error('homepage scholarships error:',        scholarshipsErr.message)
if (guidesErr)           console.error('homepage guides error:',              guidesErr.message)

/* ── Defensive defaults ── */
const degreeLevels     = degreeLevelsData    ?? []
const destinations     = destinationsData    ?? []
const featuredPrograms = featuredProgramsData ?? []
const subjects         = subjectsData && subjectsData.length > 0 ? subjectsData : FALLBACK_SUBJECTS
const scholarships     = scholarshipsData    ?? []
const guides           = guidesData          ?? []

const featuredProgramIds = featuredPrograms.map((program: any) => program.id).filter(Boolean)
let savedProgramIds = new Set<string>()

if (user && featuredProgramIds.length > 0) {
  const { data: savedRows, error: savedError } = await supabase
    .from('saved_items')
    .select('entity_id')
    .eq('user_id', user.id)
    .eq('entity_type', 'program')
    .in('entity_id', featuredProgramIds)

  if (savedError) {
    console.error('homepage saved_items error:', savedError.message)
  } else {
    savedProgramIds = new Set((savedRows ?? []).map((row: any) => row.entity_id).filter(Boolean))
  }
}

/* Dynamic destination chip: first published destination country */
const dynamicDest = destinations.length > 0 ? destinations[0] : null

/* ── Helper functions ── */

function formatDuration(months: number | null | undefined): string | null {
  if (!months) return null
  if (months === 12) return '1 year'
  if (months % 12 === 0) return `${months / 12} years`
  return `${months} months`
}

function abbreviateDegree(name: string | null | undefined, code: string | null | undefined): string | null {
  if (!code && !name) return null
  const c = (code ?? '').toLowerCase()
  const n = (name ?? '').toLowerCase()
  if (c === 'master'    || n.startsWith('master'))  return 'MSc'
  if (c === 'bachelor'  || n.startsWith('bachelor')) return 'BSc'
  if (c === 'phd'       || n === 'phd' || n.startsWith('doctor')) return 'PhD'
  if (c === 'foundation') return 'Foundation'
  return name ?? null
}

function formatTuition(
  min: number | null | undefined,
  max: number | null | undefined,
  currency: string | null | undefined,
): string | null {
  if (min == null && max == null) return null
  const sym = currency === 'EUR' ? '€' : currency === 'USD' ? '$' : currency === 'GBP' ? '£'
            : (currency ? currency + ' ' : '')
  const fmt = (n: number) => n.toLocaleString('en-US')
  if (min != null && max != null && min !== max) return `${sym}${fmt(min)}–${sym}${fmt(max)}`
  return `${sym}${fmt((min ?? max)!)}`
}

function formatDeadline(d: string | null | undefined, dt: string | null | undefined): string | null {
  if (d) return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
  return dt ?? null
}

function formatDate(d: string | null | undefined): string | null {
  if (!d) return null
  return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
}

function formatAmount(
  min: number | null | undefined,
  max: number | null | undefined,
  cur: string | null | undefined,
): string | null {
  if (min == null && max == null) return null
  const fmt = (n: number) => n.toLocaleString('en-US')
  const range = min != null && max != null
    ? `${fmt(min)}–${fmt(max)}`
    : min != null ? fmt(min) : `Up to ${fmt(max!)}`
  return [cur, range].filter(Boolean).join(' ')
}
---

<PublicLayout
  title="DegreeWiki — Find Study-Abroad Programs & Scholarships"
  description="Search verified bachelor's and master's programs, scholarships, and study-abroad guides for international students. Every listing is source-checked."
  canonical={SITE_URL + '/'}
>

  <!-- ── 1. Hero + search ── -->
  <HomeHero
    degreeLevels={degreeLevels}
    destinations={destinations}
    dynamicDestination={dynamicDest}
  />

  <!-- ── 2. Fit Finder panel (inline, after hero) ── -->
  <Section tone="canvas" width="wide">
    <FitFinderMiniPanel />
  </Section>

  <!-- ── 3. Featured programs (hidden if no published programs) ── -->
  {featuredPrograms.length > 0 && (
    <Section tone="surface" width="wide">
      <SectionHeader
        eyebrow="Top picks"
        title="Featured programs"
        href="/programs"
        linkText="Browse all programs"
      />
      <div class="flex flex-col gap-[14px]">
        {featuredPrograms.map((p: any) => {
          const uniHref = p.universities?.slug ? `/universities/${p.universities.slug}` : null
          const dl = p.degree_levels as { name: string; code: string } | null
          const subj = p.subjects as { name: string } | null
          const countryData = p.countries as { name: string; iso2: string } | null
          const cityData = p.cities as { name: string } | null
          const location = [cityData?.name, countryData?.name].filter(Boolean).join(', ') || null
          return (
            <ProgramCard
              href={`/programs/${p.slug}`}
              programId={p.id}
              title={p.title}
              universityName={p.universities?.name ?? null}
              universityHref={uniHref}
              degreeLevel={abbreviateDegree(dl?.name, dl?.code)}
              field={subj?.name ?? null}
              countryCode={countryData?.iso2 ?? null}
              location={location}
              language={p.language_of_instruction ?? null}
              duration={formatDuration(p.duration_months)}
              tuitionDisplay={formatTuition(p.tuition_min_amount, p.tuition_max_amount, p.tuition_currency)}
              tuitionPer={p.tuition_period ?? 'per year'}
              verified={
                p.verification_status === 'verified' ||
                p.verification_status === 'partially_verified'
              }
              saved={savedProgramIds.has(p.id)}
              isAuthenticated={!!user}
              comparing={false}
            />
          )
        })}
      </div>
    </Section>
  )}

  <!-- ── 4. Browse by study goal ── -->
  <Section tone="canvas" width="wide">
    <SectionHeader
      eyebrow="Explore"
      title="Browse by study goal"
      href="/programs"
    />
    <div class="flex flex-wrap gap-2">
      {subjects.map((s: any) => (
        <SearchChip
          href={s.id ? `/programs?subject=${s.id}` : `/programs?q=${encodeURIComponent(s.name)}`}
          label={s.name}
        />
      ))}
    </div>
  </Section>

  <!-- ── 5. Popular destinations (hidden if none available) ── -->
  {destinations.length > 0 && (
    <Section tone="surface" width="wide">
      <SectionHeader
        eyebrow="Where to study"
        title="Popular destinations"
        href="/universities"
        linkText="All destinations"
      />
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        {destinations.slice(0, 6).map((c: any) => (
          <DestinationCard
            href={c.slug ? `/destinations/${c.slug}` : '/destinations'}
            name={c.name}
            imagePublicId={c.cover_image?.cloudinary_public_id ?? null}
            imageAlt={c.cover_image?.alt_text || c.cover_image?.display_name || c.name}
          />
        ))}
      </div>
    </Section>
  )}

  <!-- ── 6. Scholarships & funding (hidden if none published) ── -->
  {scholarships.length > 0 && (
    <Section tone="canvas" width="wide">
      <SectionHeader
        eyebrow="Funding"
        title="Scholarships & funding"
        href="/scholarships"
        linkText="View all scholarships"
      />
      <div class="flex flex-col gap-2">
        {scholarships.map((s: any) => (
          <ScholarshipRow
            href={`/scholarships/${s.slug}`}
            name={s.name}
            providerName={s.provider_name ?? null}
            amount={formatAmount(s.amount_min, s.amount_max, s.currency)}
            deadline={formatDeadline(s.deadline, s.deadline_text)}
          />
        ))}
      </div>
    </Section>
  )}

  <!-- ── 7. Fit Finder CTA (stronger, bottom placement) ── -->
  <Section tone="surface" width="wide">
    <div class="rounded-xl bg-ink text-white p-8 sm:p-10 text-center">
      <p class="text-xs font-semibold uppercase tracking-wide text-white/60 mb-2">
        Personalised matching
      </p>
      <h2 class="text-2xl font-bold text-white mb-3">Not sure where to start?</h2>
      <p class="text-[15px] text-white/80 mb-6 max-w-md mx-auto leading-relaxed">
        Answer a few questions and get matched to programs that fit your profile, budget, and goals.
      </p>
      <a
        href="/fit-finder"
        class="inline-flex items-center justify-center px-6 py-2.5 rounded-[9px] bg-white
               text-ink text-sm font-semibold hover:bg-[#f1f5f9] transition-colors"
      >
        Find my matches
      </a>
    </div>
  </Section>

  <!-- ── 8. Study abroad guides (hidden if none published) ── -->
  {guides.length > 0 && (
    <Section tone="canvas" width="wide">
      <SectionHeader
        eyebrow="Learn"
        title="Study abroad guides"
        href="/guides"
        linkText="View all guides"
      />
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {guides.map((g: any) => (
          <GuideCard
            href={`/guides/${g.slug}`}
            title={g.title}
            category={g.article_categories?.name ?? null}
            date={formatDate(g.published_at)}
            summary={g.summary ?? null}
          />
        ))}
      </div>
    </Section>
  )}

  <SavedProgramEnhancement />

</PublicLayout>
