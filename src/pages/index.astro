---
import PublicLayout from '../layouts/PublicLayout.astro'
import HomeHero from '../components/public/home/HomeHero.astro'
import Section from '../components/ui/Section.astro'
import SectionHeader from '../components/ui/SectionHeader.astro'
import SearchChip from '../components/public/SearchChip.astro'
import FitFinderMiniPanel from '../components/public/FitFinderMiniPanel.astro'
import ProgramCard from '../components/public/cards/ProgramCard.astro'
import SavedProgramEnhancement from '../components/public/SavedProgramEnhancement.astro'
import DestinationCard from '../components/public/cards/DestinationCard.astro'
import ScholarshipRow from '../components/public/cards/ScholarshipRow.astro'
import GuideCard from '../components/public/cards/GuideCard.astro'
import Badge from '../components/ui/Badge.astro'
import MediaImage from '../components/public/MediaImage.astro'
import { createClient } from '../lib/supabase/server'
import { SITE_URL } from '../lib/site'

const supabase = createClient(Astro.cookies, Astro.request)
const { data: { user } } = await supabase.auth.getUser()

/* ── Static subject fallback (used only when subjects table returns 0 rows) ── */
const FALLBACK_SUBJECTS: { id: string; name: string }[] = [
  { id: '', name: 'Computer Science' },
  { id: '', name: 'Business & Management' },
  { id: '', name: 'Engineering' },
  { id: '', name: 'Law' },
  { id: '', name: 'Medicine & Health' },
  { id: '', name: 'Arts & Humanities' },
]

/* ── All homepage queries in one round-trip ── */
const [
  { data: degreeLevelsData, error: degreeLevelsErr },
  { data: destinationsData, error: destinationsErr },
  { data: featuredProgramsData, error: featuredProgramsErr },
  { data: featuredUniversitiesData, error: featuredUniversitiesErr },
  { data: subjectsData, error: subjectsErr },
  { data: scholarshipsData, error: scholarshipsErr },
  { data: guidesData, error: guidesErr },
] = await Promise.all([
  supabase
    .from('degree_levels')
    .select('id, name, code')
    .eq('is_active', true)
    .order('display_order'),
  supabase
    .from('countries')
    .select(`id, name, slug, cover_image:media_assets!countries_cover_image_id_fkey(cloudinary_public_id, alt_text, display_name)`)
    .eq('content_status', 'published')
    .eq('is_destination_enabled', true)
    .order('name')
    .limit(30),
  supabase
    .from('programs')
    .select(`
      id, title, slug, created_at,
      university_id, country_id, degree_level_id, primary_subject_id,
      duration_months, language_of_instruction,
      tuition_min_amount, tuition_max_amount, tuition_currency, tuition_period,
      verification_status, official_url, application_url,
      universities(name, slug),
      degree_levels(name, code),
      subjects!programs_primary_subject_id_fkey(name),
      countries(name, iso2),
      cities(name)
    `)
    .eq('content_status', 'published')
    .order('created_at', { ascending: false })
    .limit(80),
  supabase
    .from('universities')
    .select(`
      id, name, slug, official_url, overview, ranking_summary,
      country_id, city_id, institution_type, ownership_type,
      data_completeness_score, source_confidence_score,
      verification_status, last_verified_at,
      countries(name), cities(name),
      logo:media_assets!universities_logo_id_fkey(cloudinary_public_id, alt_text, display_name),
      cover_image:media_assets!universities_cover_image_id_fkey(cloudinary_public_id, alt_text, display_name)
    `)
    .eq('content_status', 'published')
    .order('data_completeness_score', { ascending: false })
    .order('source_confidence_score', { ascending: false })
    .order('name')
    .limit(80),
  supabase
    .from('subjects')
    .select('id, name')
    .order('name')
    .limit(12),
  supabase
    .from('scholarships')
    .select('id, name, slug, provider_name, amount_min, amount_max, currency, deadline, deadline_text')
    .eq('content_status', 'published')
    .order('deadline', { ascending: true, nullsFirst: false })
    .limit(4),
  supabase
    .from('articles')
    .select('id, title, slug, summary, published_at, article_categories(id, name)')
    .eq('content_status', 'published')
    .order('published_at', { ascending: false, nullsFirst: false })
    .limit(3),
])

/* Log query errors server-side only — do not surface to user */
if (degreeLevelsErr)     console.error('homepage degree_levels error:',      degreeLevelsErr.message)
if (destinationsErr)     console.error('homepage destinations error:',        destinationsErr.message)
if (featuredProgramsErr) console.error('homepage featured programs error:',   featuredProgramsErr.message)
if (featuredUniversitiesErr) console.error('homepage featured universities error:', featuredUniversitiesErr.message)
if (subjectsErr)         console.error('homepage subjects error:',            subjectsErr.message)
if (scholarshipsErr)     console.error('homepage scholarships error:',        scholarshipsErr.message)
if (guidesErr)           console.error('homepage guides error:',              guidesErr.message)

/* ── Defensive defaults ── */
const degreeLevels     = degreeLevelsData    ?? []
const destinations     = destinationsData    ?? []
const featuredPrograms = diversifyFeaturedPrograms(featuredProgramsData ?? [], 4)
const featuredUniversityCandidates = featuredUniversitiesData ?? []
const subjects         = subjectsData && subjectsData.length > 0 ? subjectsData : FALLBACK_SUBJECTS
const scholarships     = scholarshipsData    ?? []
const guides           = guidesData          ?? []

const featuredUniversityCandidateIds = featuredUniversityCandidates.map((u: any) => u.id).filter(Boolean)
let programCountByUniversity = new Map<string, number>()

if (featuredUniversityCandidateIds.length > 0) {
  const { data: universityProgramRows, error: universityProgramCountError } = await supabase
    .from('programs')
    .select('university_id')
    .eq('content_status', 'published')
    .in('university_id', featuredUniversityCandidateIds)
    .limit(5000)

  if (universityProgramCountError) {
    console.error('homepage featured university program count error:', universityProgramCountError.message)
  } else {
    universityProgramRows?.forEach((row: any) => {
      if (!row.university_id) return
      programCountByUniversity.set(row.university_id, (programCountByUniversity.get(row.university_id) ?? 0) + 1)
    })
  }
}

const featuredUniversities = diversifyFeaturedUniversities(featuredUniversityCandidates, 6, programCountByUniversity)

const featuredProgramIds = featuredPrograms.map((program: any) => program.id).filter(Boolean)
let savedProgramIds = new Set<string>()

if (user && featuredProgramIds.length > 0) {
  const { data: savedRows, error: savedError } = await supabase
    .from('saved_items')
    .select('entity_id')
    .eq('user_id', user.id)
    .eq('entity_type', 'program')
    .in('entity_id', featuredProgramIds)

  if (savedError) {
    console.error('homepage saved_items error:', savedError.message)
  } else {
    savedProgramIds = new Set((savedRows ?? []).map((row: any) => row.entity_id).filter(Boolean))
  }
}

/* Dynamic destination chip: first published destination country */
const dynamicDest = destinations.length > 0 ? destinations[0] : null

/* ── Helper functions ── */

function programCompletenessScore(program: any): number {
  let score = 0
  if (program.title) score += 3
  if (program.slug) score += 3
  if (program.universities?.name) score += 3
  if (program.countries?.name) score += 3
  if (program.degree_levels?.name || program.degree_levels?.code) score += 2
  if (program.subjects?.name || program.primary_subject_id) score += 2
  if (program.language_of_instruction) score += 1
  if (program.duration_months) score += 1
  if (program.tuition_min_amount != null || program.tuition_max_amount != null) score += 1
  if (program.official_url || program.application_url) score += 1
  if (program.verification_status === 'verified') score += 2
  if (program.verification_status === 'partially_verified') score += 1
  return score
}

function normalizeText(value: string | null | undefined): string {
  return typeof value === 'string' ? value.trim() : ''
}

function splitPlainTextParagraphs(value: string | null | undefined): string[] {
  return normalizeText(value)
    .split(/\n\s*\n+/)
    .map((paragraph) => paragraph.replace(/\s*\n\s*/g, ' ').trim())
    .filter(Boolean)
}

function teaserFromText(value: string | null | undefined, maxLength = 150): string | null {
  const firstParagraph = splitPlainTextParagraphs(value)[0] ?? ''
  if (!firstParagraph) return null
  if (firstParagraph.length <= maxLength) return firstParagraph
  const slice = firstParagraph.slice(0, maxLength)
  const trimmed = slice.includes(' ') ? slice.slice(0, slice.lastIndexOf(' ')) : slice
  return `${trimmed.trimEnd()}...`
}

function universityInitials(name: string): string {
  const caps = name
    .split(/\s+/)
    .map((word: string) => word[0]?.toUpperCase() ?? '')
    .filter(Boolean)
  return caps.slice(0, 2).join('') || name.slice(0, 2).toUpperCase()
}

function universityCompletenessScore(university: any, programCounts: Map<string, number>): number {
  let score = 0
  const programCount = programCounts.get(university.id) ?? 0

  if (programCount > 0) score += 50 + Math.min(programCount, 10)
  score += Math.round((university.data_completeness_score ?? 0) / 5)
  score += Math.round((university.source_confidence_score ?? 0) / 10)
  if (university.verification_status === 'verified') score += 12
  if (university.verification_status === 'partially_verified') score += 8
  if (university.countries?.name) score += 5
  if (university.cities?.name) score += 4
  if (university.logo?.cloudinary_public_id) score += 5
  if (university.cover_image?.cloudinary_public_id) score += 3
  if (university.overview) score += 4
  if (university.ranking_summary) score += 2
  if (university.official_url) score += 2
  if (university.institution_type) score += 1
  if (university.ownership_type) score += 1

  return score
}

function diversifyFeaturedUniversities(universities: any[], limit: number, programCounts: Map<string, number>): any[] {
  const sorted = [...universities]
    .filter((university) => university?.id && university?.slug && university?.name)
    .sort((a, b) => {
      const scoreDelta = universityCompletenessScore(b, programCounts) - universityCompletenessScore(a, programCounts)
      if (scoreDelta !== 0) return scoreDelta

      const programDelta = (programCounts.get(b.id) ?? 0) - (programCounts.get(a.id) ?? 0)
      if (programDelta !== 0) return programDelta

      return String(a.name ?? '').localeCompare(String(b.name ?? ''))
    })

  const selected: any[] = []
  const usedUniversities = new Set<string>()
  const usedCountries = new Set<string>()

  const passes = [
    (university: any) => (programCounts.get(university.id) ?? 0) > 0 && !usedCountries.has(university.country_id),
    (university: any) => (programCounts.get(university.id) ?? 0) > 0,
    (university: any) => !usedCountries.has(university.country_id),
    () => true,
  ]

  function addUniversity(university: any) {
    if (!university?.id || usedUniversities.has(university.id) || selected.length >= limit) return
    selected.push(university)
    usedUniversities.add(university.id)
    if (university.country_id) usedCountries.add(university.country_id)
  }

  for (const pass of passes) {
    for (const university of sorted) {
      if (selected.length >= limit) break
      if (pass(university)) addUniversity(university)
    }
    if (selected.length >= limit) break
  }

  return selected
}

function diversifyFeaturedPrograms(programs: any[], limit: number): any[] {
  const sorted = [...programs].sort((a, b) => {
    const scoreDelta = programCompletenessScore(b) - programCompletenessScore(a)
    if (scoreDelta !== 0) return scoreDelta

    const dateDelta = new Date(b.created_at ?? 0).getTime() - new Date(a.created_at ?? 0).getTime()
    if (dateDelta !== 0) return dateDelta

    return String(a.title ?? '').localeCompare(String(b.title ?? ''))
  })

  const selected: any[] = []
  const usedPrograms = new Set<string>()
  const usedUniversities = new Set<string>()
  const usedCountries = new Set<string>()
  const usedDegrees = new Set<string>()

  const passes = [
    (program: any) =>
      !usedUniversities.has(program.university_id) &&
      !usedCountries.has(program.country_id) &&
      !usedDegrees.has(program.degree_level_id),
    (program: any) => !usedUniversities.has(program.university_id),
    (program: any) => !usedCountries.has(program.country_id) && !usedDegrees.has(program.degree_level_id),
    (program: any) => !usedCountries.has(program.country_id) || !usedDegrees.has(program.degree_level_id),
    () => true,
  ]

  function addProgram(program: any) {
    if (!program?.id || usedPrograms.has(program.id) || selected.length >= limit) return
    selected.push(program)
    usedPrograms.add(program.id)
    if (program.university_id) usedUniversities.add(program.university_id)
    if (program.country_id) usedCountries.add(program.country_id)
    if (program.degree_level_id) usedDegrees.add(program.degree_level_id)
  }

  for (const pass of passes) {
    for (const program of sorted) {
      if (selected.length >= limit) break
      if (pass(program)) addProgram(program)
    }
    if (selected.length >= limit) break
  }

  return selected
}

function formatDuration(months: number | null | undefined): string | null {
  if (!months) return null
  if (months === 12) return '1 year'
  if (months % 12 === 0) return `${months / 12} years`
  return `${months} months`
}

function abbreviateDegree(name: string | null | undefined, code: string | null | undefined): string | null {
  if (!code && !name) return null
  const c = (code ?? '').toLowerCase()
  const n = (name ?? '').toLowerCase()
  if (c === 'master'    || n.startsWith('master'))  return 'MSc'
  if (c === 'bachelor'  || n.startsWith('bachelor')) return 'BSc'
  if (c === 'phd'       || n === 'phd' || n.startsWith('doctor')) return 'PhD'
  if (c === 'foundation') return 'Foundation'
  return name ?? null
}

function formatTuition(
  min: number | null | undefined,
  max: number | null | undefined,
  currency: string | null | undefined,
): string | null {
  if (min == null && max == null) return null
  const sym = currency === 'EUR' ? '€' : currency === 'USD' ? '$' : currency === 'GBP' ? '£'
            : (currency ? currency + ' ' : '')
  const fmt = (n: number) => n.toLocaleString('en-US')
  if (min != null && max != null && min !== max) return `${sym}${fmt(min)}–${sym}${fmt(max)}`
  return `${sym}${fmt((min ?? max)!)}`
}

function formatDeadline(d: string | null | undefined, dt: string | null | undefined): string | null {
  if (d) return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
  return dt ?? null
}

function formatDate(d: string | null | undefined): string | null {
  if (!d) return null
  return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
}

function formatAmount(
  min: number | null | undefined,
  max: number | null | undefined,
  cur: string | null | undefined,
): string | null {
  if (min == null && max == null) return null
  const fmt = (n: number) => n.toLocaleString('en-US')
  const range = min != null && max != null
    ? `${fmt(min)}–${fmt(max)}`
    : min != null ? fmt(min) : `Up to ${fmt(max!)}`
  return [cur, range].filter(Boolean).join(' ')
}
---

<PublicLayout
  title="DegreeWiki — Find Study-Abroad Programs & Scholarships"
  description="Search verified bachelor's and master's programs, scholarships, and study-abroad guides for international students. Every listing is source-checked."
  canonical={SITE_URL + '/'}
>

  <!-- ── 1. Hero + search ── -->
  <HomeHero
    degreeLevels={degreeLevels}
    destinations={destinations}
    dynamicDestination={dynamicDest}
  />

  <!-- ── 2. Fit Finder panel (inline, after hero) ── -->
  <Section tone="canvas" width="wide">
    <FitFinderMiniPanel />
  </Section>

  <!-- ── 3. Featured programs (hidden if no published programs) ── -->
  {featuredPrograms.length > 0 && (
    <Section tone="surface" width="wide">
      <SectionHeader
        eyebrow="Top picks"
        title="Featured programs"
        href="/programs"
        linkText="Browse all programs"
      />
      <div class="flex flex-col gap-[14px]">
        {featuredPrograms.map((p: any) => {
          const uniHref = p.universities?.slug ? `/universities/${p.universities.slug}` : null
          const dl = p.degree_levels as { name: string; code: string } | null
          const subj = p.subjects as { name: string } | null
          const countryData = p.countries as { name: string; iso2: string } | null
          const cityData = p.cities as { name: string } | null
          const location = [cityData?.name, countryData?.name].filter(Boolean).join(', ') || null
          return (
            <ProgramCard
              href={`/programs/${p.slug}`}
              programId={p.id}
              title={p.title}
              universityName={p.universities?.name ?? null}
              universityHref={uniHref}
              degreeLevel={abbreviateDegree(dl?.name, dl?.code)}
              field={subj?.name ?? null}
              countryCode={countryData?.iso2 ?? null}
              location={location}
              language={p.language_of_instruction ?? null}
              duration={formatDuration(p.duration_months)}
              tuitionDisplay={formatTuition(p.tuition_min_amount, p.tuition_max_amount, p.tuition_currency)}
              tuitionPer={p.tuition_period ?? 'per year'}
              verified={
                p.verification_status === 'verified' ||
                p.verification_status === 'partially_verified'
              }
              saved={savedProgramIds.has(p.id)}
              isAuthenticated={!!user}
              comparing={false}
            />
          )
        })}
      </div>
    </Section>
  )}

  <!-- ── 4. Featured universities (hidden if no published universities) ── -->
  {featuredUniversities.length > 0 && (
    <Section tone="canvas" width="wide">
      <SectionHeader
        eyebrow="University discovery"
        title="Featured universities"
        href="/universities"
        linkText="Browse all universities"
      />
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {featuredUniversities.map((u: any) => {
          const location = [u.cities?.name, u.countries?.name].filter(Boolean).join(', ')
          const programCount = programCountByUniversity.get(u.id) ?? 0
          const verification =
            u.verification_status === 'verified'
              ? { label: 'Verified', variant: 'verified' as const }
              : u.verification_status === 'partially_verified'
                ? { label: 'Partially verified', variant: 'neutral' as const }
                : null
          const teaser = teaserFromText(u.overview, 150) ?? teaserFromText(u.ranking_summary, 150)

          return (
            <article class="flex h-full flex-col rounded-xl border border-edge bg-surface p-5 transition-all hover:border-[#cbd5e1] hover:shadow-sm">
              <div class="flex items-start gap-4">
                {u.logo?.cloudinary_public_id ? (
                  <div class="h-14 w-14 flex-none overflow-hidden rounded-[10px] border border-edge bg-surface">
                    <MediaImage
                      publicId={u.logo.cloudinary_public_id}
                      alt={u.logo.alt_text || u.logo.display_name || u.name}
                      width={56}
                      height={56}
                      crop="fill"
                      loading="lazy"
                      class="h-full w-full object-cover"
                    />
                  </div>
                ) : (
                  <div class="flex h-14 w-14 flex-none items-center justify-center rounded-[10px] border border-primary-border bg-primary-surface font-mono text-sm font-bold text-primary">
                    {universityInitials(u.name)}
                  </div>
                )}
                <div class="min-w-0 flex-1">
                  <h3 class="text-[18px] font-semibold leading-snug tracking-[-0.01em] text-ink">
                    <a href={`/universities/${u.slug}`} class="hover:text-primary">
                      {u.name}
                    </a>
                  </h3>
                  {location && <p class="mt-1 text-sm text-ink-secondary">{location}</p>}
                </div>
              </div>

              <div class="mt-4 flex flex-wrap gap-2">
                <Badge variant="info">{programCount} {programCount === 1 ? 'program' : 'programs'}</Badge>
                {verification && <Badge variant={verification.variant}>{verification.label}</Badge>}
              </div>

              {teaser && (
                <p class="mt-3 text-sm leading-6 text-muted line-clamp-3">{teaser}</p>
              )}

              <div class="mt-auto flex flex-wrap gap-x-4 gap-y-2 border-t border-edge-subtle pt-4 text-sm">
                <a href={`/universities/${u.slug}`} class="font-semibold text-primary hover:text-primary-hover">
                  View profile
                </a>
                <a href={`/programs?university=${u.id}`} class="font-semibold text-primary hover:text-primary-hover">
                  Browse programs
                </a>
              </div>
            </article>
          )
        })}
      </div>
    </Section>
  )}

  <!-- ── 5. Browse by study goal ── -->
  <Section tone="canvas" width="wide">
    <SectionHeader
      eyebrow="Explore"
      title="Browse by study goal"
      href="/programs"
    />
    <div class="flex flex-wrap gap-2">
      {subjects.map((s: any) => (
        <SearchChip
          href={s.id ? `/programs?subject=${s.id}` : `/programs?q=${encodeURIComponent(s.name)}`}
          label={s.name}
        />
      ))}
    </div>
  </Section>

  <!-- ── 6. Popular destinations (hidden if none available) ── -->
  {destinations.length > 0 && (
    <Section tone="surface" width="wide">
      <SectionHeader
        eyebrow="Where to study"
        title="Popular destinations"
        href="/destinations"
        linkText="All destinations"
      />
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        {destinations.slice(0, 6).map((c: any) => (
          <DestinationCard
            href={c.slug ? `/destinations/${c.slug}` : '/destinations'}
            name={c.name}
            imagePublicId={c.cover_image?.cloudinary_public_id ?? null}
            imageAlt={c.cover_image?.alt_text || c.cover_image?.display_name || c.name}
          />
        ))}
      </div>
    </Section>
  )}

  <!-- ── 7. Scholarships & funding (hidden if none published) ── -->
  {scholarships.length > 0 && (
    <Section tone="canvas" width="wide">
      <SectionHeader
        eyebrow="Funding"
        title="Scholarships & funding"
        href="/scholarships"
        linkText="View all scholarships"
      />
      <div class="flex flex-col gap-2">
        {scholarships.map((s: any) => (
          <ScholarshipRow
            href={`/scholarships/${s.slug}`}
            name={s.name}
            providerName={s.provider_name ?? null}
            amount={formatAmount(s.amount_min, s.amount_max, s.currency)}
            deadline={formatDeadline(s.deadline, s.deadline_text)}
          />
        ))}
      </div>
    </Section>
  )}

  <!-- ── 8. Fit Finder CTA (stronger, bottom placement) ── -->
  <Section tone="surface" width="wide">
    <div class="rounded-xl bg-ink text-white p-8 sm:p-10 text-center">
      <p class="text-xs font-semibold uppercase tracking-wide text-white/60 mb-2">
        Personalised matching
      </p>
      <h2 class="text-2xl font-bold text-white mb-3">Not sure where to start?</h2>
      <p class="text-[15px] text-white/80 mb-6 max-w-md mx-auto leading-relaxed">
        Answer a few questions and get matched to programs that fit your profile, budget, and goals.
      </p>
      <a
        href="/fit-finder"
        class="inline-flex items-center justify-center px-6 py-2.5 rounded-[9px] bg-white
               text-ink text-sm font-semibold hover:bg-[#f1f5f9] transition-colors"
      >
        Find my matches
      </a>
    </div>
  </Section>

  <!-- ── 9. Study abroad guides (hidden if none published) ── -->
  {guides.length > 0 && (
    <Section tone="canvas" width="wide">
      <SectionHeader
        eyebrow="Learn"
        title="Study abroad guides"
        href="/guides"
        linkText="View all guides"
      />
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {guides.map((g: any) => (
          <GuideCard
            href={`/guides/${g.slug}`}
            title={g.title}
            category={g.article_categories?.name ?? null}
            date={formatDate(g.published_at)}
            summary={g.summary ?? null}
          />
        ))}
      </div>
    </Section>
  )}

  <SavedProgramEnhancement />

</PublicLayout>
