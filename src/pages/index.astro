---
import BaseLayout from '../layouts/BaseLayout.astro'
import { createClient } from '../lib/supabase/server'

const supabase = createClient(Astro.cookies, Astro.request)
const { data: { user } } = await supabase.auth.getUser()
---
<BaseLayout title="DegreeWiki">
  <main class="max-w-2xl mx-auto p-8">
    <h1 class="text-3xl font-bold mb-4">DegreeWiki</h1>
    {user ? (
      <div>
        <p class="mb-4">Signed in as <strong>{user.email}</strong></p>
        <div class="flex gap-4">
          <a href="/admin" class="text-blue-600 underline">Admin dashboard</a>
          <form method="post" action="/api/auth/logout">
            <button type="submit" class="text-red-600 underline">Logout</button>
          </form>
        </div>
      </div>
    ) : (
      <a href="/login" class="text-blue-600 underline">Sign in</a>
    )}
  </main>
</BaseLayout>
