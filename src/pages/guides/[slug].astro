---
import PublicLayout from '../../layouts/PublicLayout.astro'
import { createClient } from '../../lib/supabase/server'

const { slug } = Astro.params
const supabase = createClient(Astro.cookies, Astro.request)

const { data: article } = await supabase
  .from('articles')
  .select(`
    id, title, slug, summary, content, published_at,
    seo_title, seo_description,
    article_categories(name, slug)
  `)
  .eq('slug', slug!)
  .eq('content_status', 'published')
  .single()

if (!article) {
  return new Response(null, { status: 404 })
}

const a = article as any

function formatDate(d: string | null): string | null {
  if (!d) return null
  return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
}

const pubDate   = formatDate(a.published_at)
const pageTitle = a.seo_title || a.title
const pageDesc  = a.seo_description || a.summary || undefined

const contentParas: string[] = a.content
  ? a.content.split('\n\n').map((p: string) => p.trim()).filter(Boolean)
  : []
---
<PublicLayout title={`${pageTitle} — DegreeWiki`} description={pageDesc}>
  <div class="max-w-2xl mx-auto px-4 py-8">
    <a href="/guides" class="text-sm text-blue-600 hover:underline mb-5 inline-block">← All Guides</a>

    <div class="flex items-center gap-2 text-xs text-gray-400 mb-3">
      {a.article_categories?.name && (
        <span class="inline-flex items-center rounded px-2 py-0.5 bg-gray-100 text-gray-600 font-medium">
          {a.article_categories.name}
        </span>
      )}
      {pubDate && <span>{pubDate}</span>}
    </div>

    <h1 class="text-3xl font-bold text-gray-900 mb-4">{a.title}</h1>

    {a.summary && (
      <p class="text-gray-500 text-base mb-8 border-l-2 border-gray-200 pl-4">{a.summary}</p>
    )}

    {contentParas.length > 0 ? (
      <div class="space-y-4 text-gray-700 text-sm leading-relaxed">
        {contentParas.map((para: string) => (
          <p>{para}</p>
        ))}
      </div>
    ) : (
      !a.summary && <p class="text-gray-400 text-sm">No content available.</p>
    )}
  </div>
</PublicLayout>
