---
import PublicLayout from '../../layouts/PublicLayout.astro'
import Container from '../../components/ui/Container.astro'
import Badge from '../../components/ui/Badge.astro'
import SourceBox from '../../components/public/SourceBox.astro'
import { createClient } from '../../lib/supabase/server'
import { SITE_URL } from '../../lib/site'

const { slug } = Astro.params
const supabase = createClient(Astro.cookies, Astro.request)

const { data: article } = await supabase
  .from('articles')
  .select(`
    id, title, slug, summary, content, published_at,
    verification_status, source_confidence_score, updated_at,
    seo_title, seo_description,
    canonical_url, og_title, og_description,
    article_categories(id, name, slug)
  `)
  .eq('slug', slug!)
  .eq('content_status', 'published')
  .single()

if (!article) {
  return new Response(null, { status: 404 })
}

const a = article as any

function formatDate(d: string | null): string | null {
  if (!d) return null
  return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
}

const pubDate   = formatDate(a.published_at)
const pageTitle = a.seo_title || a.title
const pageDesc  = a.seo_description || a.summary || undefined
const canonical = a.canonical_url || `${SITE_URL}/guides/${slug}`
const ogTitle   = a.og_title || pageTitle
const ogDesc    = a.og_description || pageDesc
const updatedAt = formatDate(a.updated_at)

const contentParas: string[] = a.content
  ? a.content.split('\n\n').map((p: string) => p.trim()).filter(Boolean)
  : []

const categoryId   = a.article_categories?.id ?? null
const categoryName = a.article_categories?.name ?? null
---
<PublicLayout title={`${pageTitle} — DegreeWiki`} description={pageDesc} canonical={canonical} ogTitle={ogTitle} ogDescription={ogDesc}>

  <!-- Page header band -->
  <div class="bg-surface border-b border-edge">
    <Container width="narrow" class="py-7 sm:py-8">
      <a href="/guides"
         class="inline-flex items-center gap-1 text-sm text-primary hover:text-primary-hover mb-4">
        ← All Guides
      </a>

      <!-- Category + date meta -->
      <div class="flex flex-wrap items-center gap-2 mb-3">
        {categoryName && categoryId && (
          <a href={`/guides?category=${categoryId}`}>
            <Badge variant="info">{categoryName}</Badge>
          </a>
        )}
        {categoryName && !categoryId && (
          <Badge variant="info">{categoryName}</Badge>
        )}
        {pubDate && (
          <span class="text-xs text-muted">{pubDate}</span>
        )}
      </div>

      <h1 class="text-2xl sm:text-3xl font-bold text-ink tracking-[-0.02em] leading-tight">
        {a.title}
      </h1>
    </Container>
  </div>

  <!-- Main content -->
  <div class="bg-canvas">
    <Container width="narrow" class="py-7 sm:py-8">

      <!-- Summary / lead -->
      {a.summary && (
        <p class="text-base text-ink-secondary leading-relaxed border-l-[3px] border-primary-border pl-4 mb-8">
          {a.summary}
        </p>
      )}

      <!-- Article content -->
      {contentParas.length > 0 ? (
        <div class="space-y-4 text-sm text-ink-secondary leading-relaxed mb-8">
          {contentParas.map((para: string) => (
            <p>{para}</p>
          ))}
        </div>
      ) : (
        !a.summary && (
          <p class="text-sm text-muted mb-8">No content available.</p>
        )
      )}

      <!-- Source & verification -->
      <SourceBox
        verificationStatus={a.verification_status}
        lastVerifiedAt={null}
        officialUrl={null}
        sourceConfidenceScore={a.source_confidence_score ?? null}
      />

      {updatedAt && (
        <p class="text-xs text-muted mb-6">Last updated: {updatedAt}</p>
      )}

      <a href="/guides" class="text-sm text-primary hover:text-primary-hover">
        ← All Guides
      </a>

    </Container>
  </div>

</PublicLayout>
