---
import AdminLayout from '../../layouts/AdminLayout.astro'
import { forbiddenAdminResponse, requireSuperAdmin } from '../../lib/admin/guard'
import { IMPORT_STATUS_BADGE, BATCH_TYPE_BADGE, FALLBACK_BADGE } from '../../lib/admin/badges'
import { type FormErrors, validateIn } from '../../lib/admin/validate'

const guard = await requireSuperAdmin(Astro.cookies, Astro.request, Astro.url.pathname)
if (guard.type === 'redirect') return Astro.redirect(guard.to)
if (guard.type === 'forbidden') return forbiddenAdminResponse()

const { user, supabase } = guard

const BATCH_TYPES = ['universities', 'programs', 'scholarships', 'articles', 'mixed'] as const

type Values = { batch_type: string; notes: string }
let values: Values = { batch_type: '', notes: '' }
let formErrors: FormErrors = {}
let serverError = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  values = {
    batch_type: String(form.get('batch_type') ?? '').trim(),
    notes: String(form.get('notes') ?? '').trim(),
  }

  const e: FormErrors = {}
  const typeErr = validateIn(values.batch_type, BATCH_TYPES, 'Batch type')
  if (typeErr) e.batch_type = typeErr
  formErrors = e

  if (Object.keys(formErrors).length === 0) {
    const { data: newBatch, error: insertError } = await supabase
      .from('import_batches')
      .insert({
        batch_type: values.batch_type,
        import_status: 'pending',
        total_records: 0,
        processed_count: 0,
        error_count: 0,
        notes: values.notes || null,
        created_by_user_id: user.id,
      })
      .select('id')
      .single()

    if (insertError || !newBatch) {
      serverError = 'Could not create batch. Please try again.'
    } else {
      return Astro.redirect(`/admin/imports/${newBatch.id}`)
    }
  }
}

const { data, error } = await supabase
  .from('import_batches')
  .select('id, batch_type, import_status, total_records, processed_count, error_count, created_at, notes')
  .order('created_at', { ascending: false })
  .limit(100)

type ImportBatchRow = {
  id: string
  batch_type: string
  import_status: string
  total_records: number
  processed_count: number
  error_count: number
  created_at: string
  notes: string | null
}

const rows = (data ?? []) as ImportBatchRow[]
const LIFECYCLE_LABEL: Record<string, string> = {
  pending: 'No rows yet',
  needs_review: 'Awaiting review',
  processing: 'Processing',
  validated: 'Validated',
  duplicate_detected: 'Duplicates detected',
  approved: 'Approved',
  rejected: 'Rejected',
  error: 'Error',
}
const BATCH_STATUS_BADGE: Record<string, string> = {
  ...IMPORT_STATUS_BADGE,
  needs_review: 'bg-amber-100 text-amber-700',
}
const hasFormError = Object.keys(formErrors).length > 0 || !!serverError
---
<AdminLayout title="Import Hub — DegreeWiki Admin" activePath="/admin/imports" userEmail={user.email ?? ''}>
  <div class="mb-6 flex items-start justify-between gap-4">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-blue-600">Admin Imports</p>
      <h1 class="mt-1 text-2xl font-bold text-gray-900">Import Hub</h1>
      <p class="mt-2 max-w-3xl text-sm text-gray-600">
        Start with the flow that matches what you are importing. Program imports now have a guided staging page that
        links every staged program to a selected production university before review. The older batch workspace stays
        available below for universities, scholarships, articles, mixed research packs, and manual staging work.
      </p>
    </div>
    <span class="shrink-0 text-sm text-gray-400">{rows.length} batch{rows.length !== 1 ? 'es' : ''}</span>
  </div>

  <div class="mb-8 grid gap-4 lg:grid-cols-3">
    <section class="rounded-xl border border-blue-200 bg-blue-50 px-5 py-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-blue-700">Recommended</p>
      <h2 class="mt-2 text-lg font-semibold text-blue-950">Program Import Staging</h2>
      <p class="mt-2 text-sm text-blue-900">
        Choose one production university, paste or load program JSON, preview it in the browser, then stage programs
        into a review batch without writing directly to production.
      </p>
      <ul class="mt-4 space-y-1.5 text-sm text-blue-900">
        <li>Supports <code>[...]</code>, <code>{'{'} "programs": [...] {'}'}</code>, and research-pack JSON.</li>
        <li>Creates a helper staging-university row linked to the selected production university.</li>
        <li>Redirects into the normal batch review and merge screen after staging.</li>
      </ul>
      <a
        href="/admin/imports/programs"
        class="mt-5 inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700"
      >
        Open Program Import
      </a>
    </section>

    <section class="rounded-xl border border-gray-200 bg-white px-5 py-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Existing Workspace</p>
      <h2 class="mt-2 text-lg font-semibold text-gray-900">General Batch Tools</h2>
      <p class="mt-2 text-sm text-gray-600">
        Keep using the generic batch flow when you need manual staging, flat university/scholarship/article imports, or
        a mixed batch that stages both universities and programs together.
      </p>
      <ul class="mt-4 space-y-1.5 text-sm text-gray-600">
        <li>Universities, scholarships, articles, or mixed research-pack imports.</li>
        <li>Manual per-row staging and existing template/prompt tooling.</li>
        <li>Older mixed-batch program support remains unchanged.</li>
      </ul>
      <a href="#general-batch-tools" class="mt-5 inline-flex items-center text-sm font-medium text-blue-600 hover:underline">
        Jump to batch creation
      </a>
    </section>

    <section class="rounded-xl border border-gray-200 bg-white px-5 py-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">History</p>
      <h2 class="mt-2 text-lg font-semibold text-gray-900">Recent Import Batches</h2>
      <p class="mt-2 text-sm text-gray-600">
        Open an existing batch to continue review, run quality checks, or merge approved rows into production.
      </p>
      <div class="mt-4 grid grid-cols-3 gap-2 text-center">
        <div class="rounded-lg border border-gray-200 bg-gray-50 px-3 py-3">
          <p class="text-xl font-bold text-gray-900">{rows.length}</p>
          <p class="mt-1 text-xs text-gray-400">Batches</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 px-3 py-3">
          <p class="text-xl font-bold text-gray-900">{rows.filter((row) => row.import_status === 'needs_review').length}</p>
          <p class="mt-1 text-xs text-gray-400">Awaiting review</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 px-3 py-3">
          <p class="text-xl font-bold text-gray-900">{rows.filter((row) => row.error_count > 0).length}</p>
          <p class="mt-1 text-xs text-gray-400">With errors</p>
        </div>
      </div>
      <a href="#recent-batches" class="mt-5 inline-flex items-center text-sm font-medium text-blue-600 hover:underline">
        Jump to history
      </a>
    </section>
  </div>

  <details
    id="general-batch-tools"
    class="mb-6 rounded-xl border border-gray-200 bg-white"
    {...(hasFormError ? { open: true } : {})}
  >
    <summary class="cursor-pointer select-none rounded-xl px-4 py-3 text-sm font-semibold text-gray-700 hover:bg-gray-50">
      General Batch Creation
    </summary>
    <div class="border-t border-gray-200 px-4 pb-4 pt-3">
      <p class="mb-3 text-xs text-gray-500">
        Choose the type of data you are importing. Use <strong>mixed</strong> when a single batch includes both
        universities and the programs that belong to them.
      </p>
      {serverError && (
        <div class="mb-3 rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700">{serverError}</div>
      )}
      <form method="post" class="max-w-sm space-y-3">
        <div>
          <label for="batch_type" class="mb-1 block text-sm font-medium text-gray-700">Batch Type *</label>
          <select id="batch_type" name="batch_type" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="">Select a type…</option>
            {BATCH_TYPES.map((type) => (
              <option value={type} selected={values.batch_type === type}>{type}</option>
            ))}
          </select>
          {formErrors.batch_type && <p class="mt-1 text-xs text-red-600">{formErrors.batch_type}</p>}
        </div>
        <div>
          <label for="notes" class="mb-1 block text-sm font-medium text-gray-700">Notes</label>
          <textarea
            id="notes"
            name="notes"
            rows="2"
            class="w-full resize-y rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
            placeholder="Optional: describe the source or purpose of this batch"
          >{values.notes}</textarea>
        </div>
        <button type="submit" class="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
          Create Batch
        </button>
      </form>
    </div>
  </details>

  {error ? (
    <p class="py-4 text-sm text-red-600">Could not load data.</p>
  ) : rows.length === 0 ? (
    <div id="recent-batches" class="rounded-lg border border-dashed border-gray-200 py-10 text-center text-sm text-gray-500">
      <p class="mb-1 font-medium text-gray-600">No import batches yet.</p>
      <p>Use the Program Import flow above or create a general batch to get started.</p>
    </div>
  ) : (
    <div id="recent-batches" class="overflow-x-auto rounded-lg border border-gray-200">
      <table class="w-full text-left text-sm">
        <thead class="border-b border-gray-200 bg-gray-50 text-xs uppercase tracking-wide text-gray-500">
          <tr>
            <th class="px-4 py-3">Type</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Lifecycle</th>
            <th class="px-4 py-3">Records staged</th>
            <th class="px-4 py-3">Errors</th>
            <th class="px-4 py-3">Created</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr class="border-b border-gray-100 hover:bg-gray-50">
              <td class="px-4 py-3">
                <span class={`inline-flex items-center rounded px-2 py-0.5 text-xs font-medium ${BATCH_TYPE_BADGE[row.batch_type] ?? FALLBACK_BADGE}`}>
                  {row.batch_type}
                </span>
              </td>
              <td class="px-4 py-3">
                <span class={`inline-flex items-center rounded px-2 py-0.5 text-xs font-medium ${BATCH_STATUS_BADGE[row.import_status] ?? FALLBACK_BADGE}`}>
                  {row.import_status}
                </span>
              </td>
              <td class="px-4 py-3 text-gray-600">
                {LIFECYCLE_LABEL[row.import_status] ?? row.import_status}
              </td>
              <td class="px-4 py-3 text-gray-700">
                {row.processed_count > 0
                  ? `${row.processed_count}${row.total_records > row.processed_count ? ` of ${row.total_records}` : ''}`
                  : <span class="text-gray-400">—</span>}
              </td>
              <td class="px-4 py-3">
                <span class={row.error_count > 0 ? 'font-medium text-red-600' : 'text-gray-400'}>
                  {row.error_count > 0 ? row.error_count : '—'}
                </span>
              </td>
              <td class="px-4 py-3 text-xs text-gray-400">{new Date(row.created_at).toLocaleString()}</td>
              <td class="px-4 py-3">
                <a href={`/admin/imports/${row.id}`} class="text-xs text-blue-600 hover:underline">Open</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</AdminLayout>
