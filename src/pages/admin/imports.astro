---
import AdminLayout from '../../layouts/AdminLayout.astro'
import { forbiddenAdminResponse, requireSuperAdmin } from '../../lib/admin/guard'
import { IMPORT_STATUS_BADGE, BATCH_TYPE_BADGE, FALLBACK_BADGE } from '../../lib/admin/badges'
import { type FormErrors, validateIn } from '../../lib/admin/validate'

const guard = await requireSuperAdmin(Astro.cookies, Astro.request, Astro.url.pathname)
if (guard.type === 'redirect') return Astro.redirect(guard.to)
if (guard.type === 'forbidden') return forbiddenAdminResponse()

const { user, supabase } = guard

const BATCH_TYPES = ['universities', 'programs', 'scholarships', 'articles', 'mixed'] as const
const BATCH_STATUS_FILTERS = ['all', 'pending', 'needs_review', 'processing', 'validated', 'duplicate_detected', 'approved', 'rejected', 'error'] as const
const ACTIVITY_FILTERS = ['all', 'active', 'recent_7', 'recent_30'] as const

type Values = { batch_type: string; notes: string }
let values: Values = { batch_type: '', notes: '' }
let formErrors: FormErrors = {}
let serverError = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  values = {
    batch_type: String(form.get('batch_type') ?? '').trim(),
    notes: String(form.get('notes') ?? '').trim(),
  }

  const e: FormErrors = {}
  const typeErr = validateIn(values.batch_type, BATCH_TYPES, 'Batch type')
  if (typeErr) e.batch_type = typeErr
  formErrors = e

  if (Object.keys(formErrors).length === 0) {
    const { data: newBatch, error: insertError } = await supabase
      .from('import_batches')
      .insert({
        batch_type: values.batch_type,
        import_status: 'pending',
        total_records: 0,
        processed_count: 0,
        error_count: 0,
        notes: values.notes || null,
        created_by_user_id: user.id,
      })
      .select('id')
      .single()

    if (insertError || !newBatch) {
      serverError = 'Could not create batch. Please try again.'
    } else {
      return Astro.redirect(`/admin/imports/${newBatch.id}`)
    }
  }
}

const { data, error } = await supabase
  .from('import_batches')
  .select('id, batch_type, import_status, total_records, processed_count, error_count, created_at, notes')
  .order('created_at', { ascending: false })
  .limit(100)

type ImportBatchRow = {
  id: string
  batch_type: string
  import_status: string
  total_records: number
  processed_count: number
  error_count: number
  created_at: string
  notes: string | null
}

const rows = (data ?? []) as ImportBatchRow[]
const selectedTypeFilter = Astro.url.searchParams.get('type')?.trim() ?? 'all'
const selectedStatusFilter = Astro.url.searchParams.get('status')?.trim() ?? 'all'
const selectedActivityFilter = Astro.url.searchParams.get('activity')?.trim() ?? 'all'
const validTypeFilter = selectedTypeFilter === 'all' || (BATCH_TYPES as readonly string[]).includes(selectedTypeFilter)
const validStatusFilter = (BATCH_STATUS_FILTERS as readonly string[]).includes(selectedStatusFilter)
const validActivityFilter = (ACTIVITY_FILTERS as readonly string[]).includes(selectedActivityFilter)
const nowMs = Date.now()
const activeBatchStatuses = new Set(['pending', 'needs_review', 'processing', 'validated', 'duplicate_detected', 'approved', 'error'])
const filteredRows = rows.filter((row) => {
  const typeMatches = !validTypeFilter || selectedTypeFilter === 'all' || row.batch_type === selectedTypeFilter
  const statusMatches = !validStatusFilter || selectedStatusFilter === 'all' || row.import_status === selectedStatusFilter
  const createdMs = new Date(row.created_at).getTime()
  const ageDays = Number.isFinite(createdMs) ? (nowMs - createdMs) / (1000 * 60 * 60 * 24) : Number.POSITIVE_INFINITY
  const activityMatches = !validActivityFilter || selectedActivityFilter === 'all'
    ? true
    : selectedActivityFilter === 'active'
      ? activeBatchStatuses.has(row.import_status)
      : selectedActivityFilter === 'recent_7'
        ? ageDays <= 7
        : ageDays <= 30

  return typeMatches && statusMatches && activityMatches
})
const cleanupDeleted = Astro.url.searchParams.get('cleanupDeleted') === '1'
const LIFECYCLE_LABEL: Record<string, string> = {
  pending: 'No rows yet',
  needs_review: 'Awaiting review',
  processing: 'Processing',
  validated: 'Validated',
  duplicate_detected: 'Duplicates detected',
  approved: 'Approved',
  rejected: 'Rejected',
  error: 'Error',
}
const BATCH_STATUS_BADGE: Record<string, string> = {
  ...IMPORT_STATUS_BADGE,
  needs_review: 'bg-amber-100 text-amber-700',
}
const hasFormError = Object.keys(formErrors).length > 0 || !!serverError
---
<AdminLayout title="Import Hub — DegreeWiki Admin" activePath="/admin/imports" userEmail={user.email ?? ''}>
  <div class="mb-6 flex items-start justify-between gap-4">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-blue-600">Admin Imports</p>
      <h1 class="mt-1 text-2xl font-bold text-gray-900">Import Hub</h1>
      <p class="mt-2 max-w-3xl text-sm text-gray-600">
        Start with the flow that matches what you are importing. Program imports now have a guided staging page that
        links every staged program to a selected production university before review. The older batch workspace stays
        available below for universities, scholarships, articles, mixed research packs, and manual staging work.
      </p>
    </div>
    <span class="shrink-0 text-sm text-gray-400">{filteredRows.length} shown · {rows.length} total</span>
  </div>

  {cleanupDeleted && (
    <div class="mb-6 rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800">
      Import batch deleted. Only staging and review records were removed; production content was not deleted.
    </div>
  )}

  <div class="mb-8 grid gap-4 lg:grid-cols-[minmax(0,1.4fr),minmax(18rem,0.8fr)]">
    <section class="rounded-xl border-2 border-blue-300 bg-blue-50 px-6 py-6 shadow-sm">
      <p class="text-xs font-semibold uppercase tracking-wide text-blue-700">Recommended primary path</p>
      <h2 class="mt-2 text-lg font-semibold text-blue-950">Program Import Staging</h2>
      <p class="mt-2 text-sm text-blue-900">
        Use this for the normal program workflow. Choose one production university, paste or load program JSON, preview
        it in the browser, then stage programs into a review batch without writing directly to production.
      </p>
      <ul class="mt-4 space-y-1.5 text-sm text-blue-900">
        <li>Supports <code>[...]</code>, <code>{'{'} "programs": [...] {'}'}</code>, and research-pack JSON.</li>
        <li>Creates a helper staging-university row linked to the selected production university.</li>
        <li>Redirects into the normal batch review and merge screen after staging.</li>
      </ul>
      <a
        href="/admin/imports/programs"
        class="mt-5 inline-flex items-center rounded-md bg-blue-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-blue-700"
      >
        Open Program Import
      </a>
    </section>

    <section class="rounded-xl border border-gray-200 bg-white px-5 py-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Advanced / legacy</p>
      <h2 class="mt-2 text-lg font-semibold text-gray-900">General Batch Tools</h2>
      <p class="mt-2 text-sm text-gray-600">
        Use these only for universities, scholarships, articles, mixed research packs, and manual staging. They are not
        the normal guided program workflow.
      </p>
      <ul class="mt-4 space-y-1.5 text-sm text-gray-600">
        <li>Universities, scholarships, articles, or mixed research-pack imports.</li>
        <li>Manual per-row staging and existing template/prompt tooling.</li>
        <li>Older mixed-batch program support remains unchanged.</li>
      </ul>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="#general-batch-tools" class="inline-flex items-center text-sm font-medium text-blue-600 hover:underline">
          Open legacy batch creation
        </a>
        <a href="#recent-batches" class="inline-flex items-center text-sm font-medium text-gray-600 hover:underline">
          Open batch history
        </a>
      </div>
    </section>
  </div>

  <section id="recent-batches" class="mb-6 rounded-xl border border-gray-200 bg-white px-5 py-5">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">History</p>
        <h2 class="mt-1 text-lg font-semibold text-gray-900">Recent Import Batches</h2>
        <p class="mt-2 text-sm text-gray-600">
          Open an existing batch to review staged rows, choose merge or enrichment actions, publish draft programs when needed, or clean up old staging batches.
        </p>
      </div>
      <div class="flex flex-wrap gap-2">
        <a href="/admin/imports/programs" class="rounded bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700">Open Program Import</a>
        <a href="/admin/imports?status=needs_review&activity=active#recent-batches" class="rounded border border-amber-300 bg-amber-50 px-3 py-2 text-sm font-medium text-amber-800 hover:bg-amber-100">Open active batches needing review</a>
        <a href="/admin/imports#recent-batches" class="rounded border border-gray-300 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">Open batch history</a>
      </div>
    </div>
    <div class="mt-4 grid grid-cols-3 gap-2 text-center">
      <div class="rounded-lg border border-gray-200 bg-gray-50 px-3 py-3">
        <p class="text-xl font-bold text-gray-900">{rows.length}</p>
        <p class="mt-1 text-xs text-gray-400">Batches</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-gray-50 px-3 py-3">
        <p class="text-xl font-bold text-gray-900">{rows.filter((row) => row.import_status === 'needs_review').length}</p>
        <p class="mt-1 text-xs text-gray-400">Awaiting review</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-gray-50 px-3 py-3">
        <p class="text-xl font-bold text-gray-900">{rows.filter((row) => row.error_count > 0).length}</p>
        <p class="mt-1 text-xs text-gray-400">With errors</p>
      </div>
    </div>
  </section>

  <details
    id="general-batch-tools"
    class="mb-6 rounded-xl border border-gray-200 bg-white"
    {...(hasFormError ? { open: true } : {})}
  >
    <summary class="cursor-pointer select-none rounded-xl px-4 py-3 text-sm font-semibold text-gray-700 hover:bg-gray-50">
      Advanced / Legacy: General Batch Creation
    </summary>
    <div class="border-t border-gray-200 px-4 pb-4 pt-3">
      <p class="mb-3 text-xs text-gray-500">
        These tools are for universities, scholarships, articles, mixed research packs, and manual staging. For normal
        program imports, use <strong>Program Import Staging</strong> above.
      </p>
      {serverError && (
        <div class="mb-3 rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700">{serverError}</div>
      )}
      <form method="post" class="max-w-sm space-y-3">
        <div>
          <label for="batch_type" class="mb-1 block text-sm font-medium text-gray-700">Batch Type *</label>
          <select id="batch_type" name="batch_type" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="">Select a type…</option>
            {BATCH_TYPES.map((type) => (
              <option value={type} selected={values.batch_type === type}>{type}</option>
            ))}
          </select>
          {formErrors.batch_type && <p class="mt-1 text-xs text-red-600">{formErrors.batch_type}</p>}
        </div>
        <div>
          <label for="notes" class="mb-1 block text-sm font-medium text-gray-700">Notes</label>
          <textarea
            id="notes"
            name="notes"
            rows="2"
            class="w-full resize-y rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
            placeholder="Optional: describe the source or purpose of this batch"
          >{values.notes}</textarea>
        </div>
        <button type="submit" class="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
          Create Batch
        </button>
      </form>
    </div>
  </details>

  {error ? (
    <p class="py-4 text-sm text-red-600">Could not load data.</p>
  ) : rows.length === 0 ? (
    <div id="recent-batches" class="rounded-lg border border-dashed border-gray-200 py-10 text-center text-sm text-gray-500">
      <p class="mb-1 font-medium text-gray-600">No import batches yet.</p>
      <p>Use the Program Import flow above or create a general batch to get started.</p>
    </div>
  ) : (
    <>
    <form method="get" class="mb-3 flex flex-wrap items-end gap-3 rounded-lg border border-gray-200 bg-white px-4 py-3">
      <div>
        <label for="type" class="mb-1 block text-xs font-medium text-gray-600">Type</label>
        <select id="type" name="type" class="rounded-md border border-gray-300 bg-white px-3 py-2 text-sm">
          <option value="all" selected={selectedTypeFilter === 'all'}>All types</option>
          {BATCH_TYPES.map((type) => <option value={type} selected={selectedTypeFilter === type}>{type}</option>)}
        </select>
      </div>
      <div>
        <label for="status" class="mb-1 block text-xs font-medium text-gray-600">Status</label>
        <select id="status" name="status" class="rounded-md border border-gray-300 bg-white px-3 py-2 text-sm">
          {BATCH_STATUS_FILTERS.map((status) => <option value={status} selected={selectedStatusFilter === status}>{status === 'all' ? 'All statuses' : status}</option>)}
        </select>
      </div>
      <div>
        <label for="activity" class="mb-1 block text-xs font-medium text-gray-600">Active / recent</label>
        <select id="activity" name="activity" class="rounded-md border border-gray-300 bg-white px-3 py-2 text-sm">
          <option value="all" selected={selectedActivityFilter === 'all'}>All recent batches</option>
          <option value="active" selected={selectedActivityFilter === 'active'}>Active only</option>
          <option value="recent_7" selected={selectedActivityFilter === 'recent_7'}>Last 7 days</option>
          <option value="recent_30" selected={selectedActivityFilter === 'recent_30'}>Last 30 days</option>
        </select>
      </div>
      <button type="submit" class="rounded bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">Apply filters</button>
      <a href="/admin/imports#recent-batches" class="rounded border border-gray-300 px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50">Clear</a>
      <span class="text-xs text-gray-400">{filteredRows.length} of {rows.length} shown</span>
    </form>

    {filteredRows.length === 0 ? (
      <div class="rounded-lg border border-dashed border-gray-200 bg-white py-8 text-center text-sm text-gray-500">
        No batches match these filters.
      </div>
    ) : (
    <div class="overflow-x-auto rounded-lg border border-gray-200">
      <table class="w-full text-left text-sm">
        <thead class="border-b border-gray-200 bg-gray-50 text-xs uppercase tracking-wide text-gray-500">
          <tr>
            <th class="px-4 py-3">Type</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Lifecycle</th>
            <th class="px-4 py-3">Records staged</th>
            <th class="px-4 py-3">Errors</th>
            <th class="px-4 py-3">Created</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody>
          {filteredRows.map((row) => (
            <tr class="border-b border-gray-100 hover:bg-gray-50">
              <td class="px-4 py-3">
                <span class={`inline-flex items-center rounded px-2 py-0.5 text-xs font-medium ${BATCH_TYPE_BADGE[row.batch_type] ?? FALLBACK_BADGE}`}>
                  {row.batch_type}
                </span>
              </td>
              <td class="px-4 py-3">
                <span class={`inline-flex items-center rounded px-2 py-0.5 text-xs font-medium ${BATCH_STATUS_BADGE[row.import_status] ?? FALLBACK_BADGE}`}>
                  {row.import_status}
                </span>
              </td>
              <td class="px-4 py-3 text-gray-600">
                {LIFECYCLE_LABEL[row.import_status] ?? row.import_status}
              </td>
              <td class="px-4 py-3 text-gray-700">
                {row.processed_count > 0
                  ? `${row.processed_count}${row.total_records > row.processed_count ? ` of ${row.total_records}` : ''}`
                  : <span class="text-gray-400">—</span>}
              </td>
              <td class="px-4 py-3">
                <span class={row.error_count > 0 ? 'font-medium text-red-600' : 'text-gray-400'}>
                  {row.error_count > 0 ? row.error_count : '—'}
                </span>
              </td>
              <td class="px-4 py-3 text-xs text-gray-400">{new Date(row.created_at).toLocaleString()}</td>
              <td class="px-4 py-3">
                <a href={`/admin/imports/${row.id}`} class="text-xs text-blue-600 hover:underline">Open</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    )}
    </>
  )}
</AdminLayout>
