---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import { forbiddenAdminResponse, requireAnyAdminPermission } from '../../../lib/admin/guard'
import MediaPicker from '../../../components/admin/MediaPicker.astro'
import { loadReusableReadyMediaAssets, validateReusableReadyMediaIds } from '../../../lib/admin/media'
import { toSlug } from '../../../lib/admin/slug'
import {
  type FormErrors,
  validateRequired,
  validateIn,
  validateSlug,
} from '../../../lib/admin/validate'

const guard = await requireAnyAdminPermission(
  Astro.cookies,
  Astro.request,
  Astro.url.pathname,
  ['edit_content', 'publish_content', 'manage_settings'],
)
if (guard.type === 'redirect') return Astro.redirect(guard.to)
if (guard.type === 'forbidden') return forbiddenAdminResponse()

const { user, supabase } = guard
const { id } = Astro.params

const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME ?? ''

const CONTENT_STATUS_OPTIONS = ['draft', 'in_review', 'published', 'unpublished', 'archived'] as const

const [{ data: existing, error: loadError }, { data: countriesData }, mediaAssets] = await Promise.all([
  supabase
    .from('cities')
    .select('id, name, slug, country_id, content_status, cover_image_id, og_image_id')
    .eq('id', id)
    .single(),
  supabase.from('countries').select('id, name').order('name', { ascending: true }),
  loadReusableReadyMediaAssets(supabase),
])

if (loadError || !existing) {
  return new Response('City not found.', { status: 404 })
}

type CityRecord = {
  id: string
  name: string
  slug: string
  country_id: string
  content_status: string
  cover_image_id: string | null
  og_image_id: string | null
}
type CountryOption = { id: string; name: string }

const record = existing as CityRecord
const countries = (countriesData ?? []) as CountryOption[]

type Values = {
  name: string
  slug: string
  country_id: string
  content_status: string
  cover_image_id: string
  og_image_id: string
}

let values: Values = {
  name:           record.name,
  slug:           record.slug,
  country_id:     record.country_id,
  content_status: record.content_status,
  cover_image_id: record.cover_image_id ?? '',
  og_image_id:    record.og_image_id ?? '',
}
let errors: FormErrors = {}
let serverError = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  values = {
    name:           String(form.get('name') ?? '').trim(),
    slug:           String(form.get('slug') ?? '').trim(),
    country_id:     String(form.get('country_id') ?? '').trim(),
    content_status: String(form.get('content_status') ?? 'draft').trim(),
    cover_image_id: String(form.get('cover_image_id') ?? '').trim(),
    og_image_id:    String(form.get('og_image_id') ?? '').trim(),
  }

  if (!values.slug && values.name) values.slug = toSlug(values.name)

  const e: FormErrors = {}
  const nameErr = validateRequired(values.name, 'Name')
  if (nameErr) e.name = nameErr
  const countryErr = validateRequired(values.country_id, 'Country')
  if (countryErr) e.country_id = countryErr
  const slugErr = validateRequired(values.slug, 'Slug') ?? validateSlug(values.slug)
  if (slugErr) e.slug = slugErr
  const statusErr = validateIn(values.content_status, CONTENT_STATUS_OPTIONS, 'Status')
  if (statusErr) e.content_status = statusErr
  const validMediaIds = await validateReusableReadyMediaIds(supabase, [values.cover_image_id, values.og_image_id])
  if (values.cover_image_id && !validMediaIds.has(values.cover_image_id)) {
    e.cover_image_id = 'Selected cover image is not valid.'
  }
  if (values.og_image_id && !validMediaIds.has(values.og_image_id)) {
    e.og_image_id = 'Selected OG image is not valid.'
  }

  errors = e

  if (Object.keys(errors).length === 0) {
    const { error } = await supabase
      .from('cities')
      .update({
        name:           values.name,
        slug:           values.slug,
        country_id:     values.country_id,
        content_status: values.content_status,
        cover_image_id: values.cover_image_id || null,
        og_image_id:    values.og_image_id || null,
      })
      .eq('id', id)

    if (error) {
      if (error.code === '23505') {
        serverError = 'A city with this slug already exists in that country.'
      } else {
        serverError = 'Could not save. Please try again.'
      }
    } else {
      return Astro.redirect('/admin/cities')
    }
  }
}
---
<AdminLayout title={`Edit ${record.name} — DegreeWiki Admin`} activePath="/admin/cities" userEmail={user.email ?? ''}>
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-bold text-gray-900">Edit City</h1>
    <a href="/admin/cities" class="text-sm text-gray-500 hover:underline">← Back to Cities</a>
  </div>

  {serverError && (
    <div class="mb-4 px-4 py-3 rounded-md bg-red-50 border border-red-200 text-sm text-red-700">{serverError}</div>
  )}

  <form method="post" class="max-w-xl space-y-4">
    <div>
      <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
      <input type="text" id="name" name="name" value={values.name} required
        class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" />
      {errors.name && <p class="mt-1 text-xs text-red-600">{errors.name}</p>}
    </div>

    <div>
      <label for="slug" class="block text-sm font-medium text-gray-700 mb-1">Slug *</label>
      <input type="text" id="slug" name="slug" value={values.slug}
        class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 font-mono" />
      {errors.slug && <p class="mt-1 text-xs text-red-600">{errors.slug}</p>}
    </div>

    <div>
      <label for="country_id" class="block text-sm font-medium text-gray-700 mb-1">Country *</label>
      <select id="country_id" name="country_id"
        class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
        <option value="">— select a country —</option>
        {countries.map(c => (
          <option value={c.id} selected={values.country_id === c.id}>{c.name}</option>
        ))}
      </select>
      {errors.country_id && <p class="mt-1 text-xs text-red-600">{errors.country_id}</p>}
    </div>

    <div>
      <label for="content_status" class="block text-sm font-medium text-gray-700 mb-1">Status *</label>
      <select id="content_status" name="content_status"
        class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
        {CONTENT_STATUS_OPTIONS.map(s => (
          <option value={s} selected={values.content_status === s}>{s}</option>
        ))}
      </select>
      {errors.content_status && <p class="mt-1 text-xs text-red-600">{errors.content_status}</p>}
    </div>

    <fieldset class="border border-gray-200 rounded-md p-4 space-y-4">
      <legend class="text-sm font-medium text-gray-700 px-1">Images</legend>
      <div>
        <MediaPicker
          fieldName="cover_image_id"
          label="Cover Image"
          currentId={values.cover_image_id || null}
          assets={mediaAssets}
          cloudName={cloudName}
          defaultSubfolder="cities"
        />
        {errors.cover_image_id && <p class="mt-1 text-xs text-red-600">{errors.cover_image_id}</p>}
      </div>
      <div>
        <MediaPicker
          fieldName="og_image_id"
          label="OG Image"
          currentId={values.og_image_id || null}
          assets={mediaAssets}
          cloudName={cloudName}
          defaultSubfolder="cities"
          copyFromField="cover_image_id"
          copyFromLabel="Cover Image"
        />
        {errors.og_image_id && <p class="mt-1 text-xs text-red-600">{errors.og_image_id}</p>}
      </div>
    </fieldset>

    <div class="flex gap-3 pt-2">
      <button type="submit"
        class="px-4 py-2 text-sm font-medium bg-blue-600 text-white rounded-md hover:bg-blue-700">
        Save Changes
      </button>
      <a href="/admin/cities" class="px-4 py-2 text-sm text-gray-600 hover:underline">Cancel</a>
    </div>
  </form>
</AdminLayout>
