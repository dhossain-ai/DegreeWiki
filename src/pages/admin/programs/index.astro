---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import { forbiddenAdminResponse, requireSuperAdmin } from '../../../lib/admin/guard'
import { CONTENT_STATUS_BADGE, FALLBACK_BADGE } from '../../../lib/admin/badges'

const guard = await requireSuperAdmin(Astro.cookies, Astro.request, Astro.url.pathname)
if (guard.type === 'redirect') return Astro.redirect(guard.to)
if (guard.type === 'forbidden') return forbiddenAdminResponse()

const { user, supabase } = guard

const [programsRes, degreeLevelsRes, universitiesRes] = await Promise.all([
  supabase
    .from('programs')
    .select('id, title, slug, content_status, degree_level_id, university_id, created_at')
    .order('created_at', { ascending: false })
    .limit(100),
  supabase.from('degree_levels').select('id, code'),
  supabase.from('universities').select('id, name'),
])

type ProgramRow = {
  id: string
  title: string
  slug: string
  content_status: string
  degree_level_id: string
  university_id: string
  created_at: string
}

const rows = (programsRes.data ?? []) as ProgramRow[]
const degreeLevelMap = new Map(
  ((degreeLevelsRes.data ?? []) as { id: string; code: string }[]).map(d => [d.id, d.code])
)
const universityMap = new Map(
  ((universitiesRes.data ?? []) as { id: string; name: string }[]).map(u => [u.id, u.name])
)
const error = programsRes.error
---
<AdminLayout title="Programs — DegreeWiki Admin" activePath="/admin/programs" userEmail={user.email ?? ''}>
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-bold text-gray-900">Programs</h1>
    <a href="/admin/programs/new"
      class="px-3 py-1.5 text-sm font-medium bg-blue-600 text-white rounded-md hover:bg-blue-700">
      + New Program
    </a>
  </div>

  {error && (
    <p class="text-sm text-red-600 py-4">Could not load data.</p>
  )}

  {!error && rows.length === 0 && (
    <p class="text-sm text-gray-500 py-4">
      No programs yet.{' '}
      <a href="/admin/programs/new" class="text-blue-600 hover:underline">Add the first one.</a>
    </p>
  )}

  {!error && rows.length > 0 && (
    <div class="overflow-x-auto rounded-lg border border-gray-200">
      <table class="w-full text-sm text-left">
        <thead class="bg-gray-50 border-b border-gray-200 text-xs text-gray-500 uppercase tracking-wide">
          <tr>
            <th class="px-4 py-3">Title</th>
            <th class="px-4 py-3">University</th>
            <th class="px-4 py-3">Level</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Created</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody>
          {rows.map(row => (
            <tr class="border-b border-gray-100 hover:bg-gray-50">
              <td class="px-4 py-3 font-medium text-gray-900">{row.title}</td>
              <td class="px-4 py-3 text-gray-600 text-xs">{universityMap.get(row.university_id) ?? '—'}</td>
              <td class="px-4 py-3 text-gray-500 text-xs font-mono">{degreeLevelMap.get(row.degree_level_id) ?? '—'}</td>
              <td class="px-4 py-3">
                <span class={`inline-flex items-center rounded px-2 py-0.5 text-xs font-medium ${CONTENT_STATUS_BADGE[row.content_status] ?? FALLBACK_BADGE}`}>
                  {row.content_status}
                </span>
              </td>
              <td class="px-4 py-3 text-gray-400 text-xs">{new Date(row.created_at).toLocaleDateString()}</td>
              <td class="px-4 py-3">
                <a href={`/admin/programs/${row.id}`} class="text-xs text-blue-600 hover:underline">Edit</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</AdminLayout>
