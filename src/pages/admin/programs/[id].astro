---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import { forbiddenAdminResponse, requireSuperAdmin } from '../../../lib/admin/guard'
import { toSlug } from '../../../lib/admin/slug'
import { CONTENT_STATUS_BADGE, VERIFICATION_STATUS_BADGE, FALLBACK_BADGE } from '../../../lib/admin/badges'
import { hardDeleteProgramById, preflightProgramHardDelete, userIsSuperAdmin } from '../../../lib/admin/programCleanup'
import {
  type FormErrors,
  validateRequired,
  validateIn,
  validateSlug,
  validateNumeric,
  validateUrl,
} from '../../../lib/admin/validate'

const guard = await requireSuperAdmin(Astro.cookies, Astro.request, Astro.url.pathname)
if (guard.type === 'redirect') return Astro.redirect(guard.to)
if (guard.type === 'forbidden') return forbiddenAdminResponse()

const { user, supabase } = guard
const isSuperAdmin = await userIsSuperAdmin(supabase)
const { id } = Astro.params
if (!id) return new Response('Not found.', { status: 404 })

const normalizeReturnTo = (value: string | null) => {
  const trimmed = (value ?? '').trim()
  if (!trimmed || trimmed.startsWith('//') || trimmed.includes('\r') || trimmed.includes('\n')) return ''
  if (!trimmed.startsWith('/admin/programs')) return ''

  const suffix = trimmed.slice('/admin/programs'.length)
  if (suffix && !suffix.startsWith('?') && !suffix.startsWith('/')) return ''

  return trimmed
}

const formatEnumLabel = (value: string) =>
  value
    .split('_')
    .filter(Boolean)
    .map(part => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ')

const formatDateValue = (value: string | null) => {
  if (!value) return 'Not yet set'
  const parsed = new Date(value)
  return Number.isNaN(parsed.getTime()) ? 'Not yet set' : parsed.toLocaleDateString()
}

const clampPercent = (value: number | null | undefined) => Math.min(100, Math.max(0, Number(value ?? 0)))

const CONTENT_STATUS_OPTIONS = ['draft', 'in_review', 'published', 'unpublished', 'archived'] as const
const VERIFICATION_OPTIONS = ['unverified', 'partially_verified', 'verified', 'source_conflict', 'outdated', 'needs_review'] as const
const SOURCE_TYPE_OPTIONS = ['official_university', 'government', 'third_party', 'aggregator', 'user_submitted'] as const
const CONFIDENCE_OPTIONS = ['high', 'medium', 'low', 'unknown'] as const
const SOURCE_STATUS_OPTIONS = ['active', 'broken', 'redirected', 'archived'] as const
const STUDY_MODE_OPTIONS = ['full_time', 'part_time', 'online', 'hybrid'] as const
const DELIVERY_MODE_OPTIONS = ['on_campus', 'online', 'hybrid', 'distance'] as const
const TUITION_PERIOD_OPTIONS = ['per_year', 'per_semester', 'total', 'per_credit'] as const
const WORKFLOW_ACTIONS = ['save', 'publish', 'mark_in_review', 'mark_partially_verified', 'mark_verified'] as const

type WorkflowAction = (typeof WORKFLOW_ACTIONS)[number]
type ReviewState = 'ready' | 'needs_attention' | 'missing'

const CHECK_STATE_BADGE: Record<ReviewState, string> = {
  ready: 'bg-green-100 text-green-700',
  needs_attention: 'bg-yellow-100 text-yellow-700',
  missing: 'bg-red-100 text-red-600',
}

const CHECK_STATE_LABELS: Record<ReviewState, string> = {
  ready: 'Ready',
  needs_attention: 'Needs attention',
  missing: 'Missing',
}

const CONTENT_STATUS_LABELS: Record<string, string> = {
  draft: 'Draft',
  in_review: 'In Review',
  published: 'Published',
  unpublished: 'Unpublished',
  archived: 'Archived',
}

const VERIFICATION_LABELS: Record<string, string> = {
  unverified: 'Unverified',
  partially_verified: 'Partially Verified',
  verified: 'Verified',
  source_conflict: 'Source Conflict',
  outdated: 'Outdated',
  needs_review: 'Needs Review',
}

const REVIEW_ACTION_LABELS: Record<WorkflowAction, string> = {
  save: 'Save changes',
  publish: 'Save and publish',
  mark_in_review: 'Mark in review',
  mark_partially_verified: 'Mark partially verified',
  mark_verified: 'Mark verified',
}

const confidenceScoreLabel = (score: number) => {
  if (score >= 75) return 'High'
  if (score >= 40) return 'Medium'
  if (score > 0) return 'Low'
  return 'Not scored'
}

const reviewStateFromScore = (score: number) => {
  if (score >= 75) return 'ready'
  if (score > 0) return 'needs_attention'
  return 'missing'
}

const reviewStateFromVerification = (status: string): ReviewState => {
  if (status === 'verified') return 'ready'
  if (status === 'partially_verified' || status === 'needs_review') return 'needs_attention'
  return 'missing'
}

const reviewStateFromContentStatus = (status: string): ReviewState => {
  if (status === 'published') return 'ready'
  if (status === 'in_review') return 'needs_attention'
  return 'missing'
}

let returnTo = normalizeReturnTo(Astro.url.searchParams.get('returnTo'))
let actionNotice = Astro.url.searchParams.get('notice')?.trim() ?? ''
let actionNoticeLevel = Astro.url.searchParams.get('noticeLevel')?.trim() ?? 'success'

const { data: existing, error: loadError } = await supabase
  .from('programs')
  .select(`
    id, title, slug, university_id, degree_level_id, degree_award, primary_subject_id,
    duration_months, study_mode, delivery_mode, language_of_instruction,
    tuition_min_amount, tuition_max_amount, tuition_currency, tuition_period, tuition_notes,
    application_fee_amount, application_fee_currency, application_fee_notes,
    official_url, application_url, admission_requirements, gpa_requirements,
    curriculum_summary, career_outcomes, content_status, verification_status,
    data_completeness_score, source_confidence_score, last_verified_at, next_review_due_at
  `)
  .eq('id', id)
  .single()

if (loadError || !existing) {
  return new Response('Program not found.', { status: 404 })
}

type ProgramRecord = {
  id: string
  title: string
  slug: string
  university_id: string
  degree_level_id: string
  degree_award: string | null
  primary_subject_id: string | null
  duration_months: number | null
  study_mode: string | null
  delivery_mode: string | null
  language_of_instruction: string | null
  tuition_min_amount: number | null
  tuition_max_amount: number | null
  tuition_currency: string | null
  tuition_period: string | null
  tuition_notes: string | null
  application_fee_amount: number | null
  application_fee_currency: string | null
  application_fee_notes: string | null
  official_url: string | null
  application_url: string | null
  admission_requirements: string | null
  gpa_requirements: string | null
  curriculum_summary: string | null
  career_outcomes: string | null
  content_status: string
  verification_status: string
  data_completeness_score: number
  source_confidence_score: number
  last_verified_at: string | null
  next_review_due_at: string | null
}

const record = existing as ProgramRecord

type UniversityOption = { id: string; name: string; country_id: string; city_id: string | null }
type DegreeLevelOption = { id: string; code: string; name: string }
type SubjectOption = { id: string; name: string }
type DataSourceRow = {
  id: string
  source_url: string
  source_title: string | null
  source_type: string
  confidence_level: string
  source_status: string
  is_primary_source: boolean
}
type IntakeRow = {
  id: string
  intake_name: string | null
  application_deadline_date: string | null
  deadline_text: string | null
  deadline_status: string | null
  is_rolling: boolean
}

const [{ data: uniData }, { data: dlData }, { data: subData }, { data: sourcesData }, { data: intakesData }] = await Promise.all([
  supabase.from('universities').select('id, name, country_id, city_id').order('name', { ascending: true }),
  supabase.from('degree_levels').select('id, code, name').order('display_order', { ascending: true }),
  supabase.from('subjects').select('id, name').order('name', { ascending: true }).limit(500),
  supabase
    .from('data_sources')
    .select('id, source_url, source_title, source_type, confidence_level, source_status, is_primary_source')
    .eq('entity_type', 'program')
    .eq('entity_id', id)
    .order('is_primary_source', { ascending: false }),
  supabase
    .from('program_intakes')
    .select('id, intake_name, application_deadline_date, deadline_text, deadline_status, is_rolling')
    .eq('program_id', id)
    .order('application_deadline_date', { ascending: true, nullsFirst: false }),
])

const universities = (uniData ?? []) as UniversityOption[]
const degreeLevels = (dlData ?? []) as DegreeLevelOption[]
const subjects = (subData ?? []) as SubjectOption[]
const sources = (sourcesData ?? []) as DataSourceRow[]
const intakes = (intakesData ?? []) as IntakeRow[]

type Values = {
  title: string
  slug: string
  university_id: string
  degree_level_id: string
  degree_award: string
  primary_subject_id: string
  duration_months: string
  study_mode: string
  delivery_mode: string
  language_of_instruction: string
  tuition_min_amount: string
  tuition_max_amount: string
  tuition_currency: string
  tuition_period: string
  tuition_notes: string
  application_fee_amount: string
  application_fee_currency: string
  application_fee_notes: string
  official_url: string
  application_url: string
  admission_requirements: string
  gpa_requirements: string
  curriculum_summary: string
  career_outcomes: string
  content_status: string
  verification_status: string
}

let values: Values = {
  title: record.title,
  slug: record.slug,
  university_id: record.university_id,
  degree_level_id: record.degree_level_id,
  degree_award: record.degree_award ?? '',
  primary_subject_id: record.primary_subject_id ?? '',
  duration_months: record.duration_months !== null ? String(record.duration_months) : '',
  study_mode: record.study_mode ?? '',
  delivery_mode: record.delivery_mode ?? '',
  language_of_instruction: record.language_of_instruction ?? '',
  tuition_min_amount: record.tuition_min_amount !== null ? String(record.tuition_min_amount) : '',
  tuition_max_amount: record.tuition_max_amount !== null ? String(record.tuition_max_amount) : '',
  tuition_currency: record.tuition_currency ?? '',
  tuition_period: record.tuition_period ?? '',
  tuition_notes: record.tuition_notes ?? '',
  application_fee_amount: record.application_fee_amount !== null ? String(record.application_fee_amount) : '',
  application_fee_currency: record.application_fee_currency ?? '',
  application_fee_notes: record.application_fee_notes ?? '',
  official_url: record.official_url ?? '',
  application_url: record.application_url ?? '',
  admission_requirements: record.admission_requirements ?? '',
  gpa_requirements: record.gpa_requirements ?? '',
  curriculum_summary: record.curriculum_summary ?? '',
  career_outcomes: record.career_outcomes ?? '',
  content_status: record.content_status,
  verification_status: record.verification_status,
}

let errors: FormErrors = {}
let serverError = ''
let sourceError = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  returnTo = normalizeReturnTo(String(form.get('returnTo') ?? '')) || returnTo
  const cleanupAction = String(form.get('_action') ?? '').trim()

  if (cleanupAction === 'archive_program') {
    const { error } = await supabase
      .from('programs')
      .update({ content_status: 'archived', indexing_status: 'draft' })
      .eq('id', id)

    if (error) {
      serverError = 'Could not archive this program right now.'
    } else {
      const redirectHref = returnTo
        ? `${Astro.url.pathname}?returnTo=${encodeURIComponent(returnTo)}&notice=${encodeURIComponent('Program archived.')}&noticeLevel=success`
        : `${Astro.url.pathname}?notice=${encodeURIComponent('Program archived.')}&noticeLevel=success`
      return Astro.redirect(redirectHref)
    }
  } else if (cleanupAction === 'restore_program') {
    const { error } = await supabase
      .from('programs')
      .update({ content_status: 'draft', indexing_status: 'draft' })
      .eq('id', id)

    if (error) {
      serverError = 'Could not restore this program to draft right now.'
    } else {
      const redirectHref = returnTo
        ? `${Astro.url.pathname}?returnTo=${encodeURIComponent(returnTo)}&notice=${encodeURIComponent('Program restored to draft.')}&noticeLevel=success`
        : `${Astro.url.pathname}?notice=${encodeURIComponent('Program restored to draft.')}&noticeLevel=success`
      return Astro.redirect(redirectHref)
    }
  } else if (cleanupAction === 'hard_delete_program') {
    const deleteConfirmed = form.get('hard_delete_confirm') === 'on'
    const typedConfirmation = String(form.get('hard_delete_text') ?? '').trim()

    if (!isSuperAdmin) {
      serverError = 'Hard delete is limited to super admins.'
    } else if (!deleteConfirmed || typedConfirmation !== 'DELETE') {
      serverError = 'Tick the permanent-delete checkbox and type DELETE before trying again.'
    } else {
      const preflight = await preflightProgramHardDelete(supabase, [id])
      const current = preflight[0]

      if (!current) {
        serverError = 'Could not verify delete safety for this program right now.'
      } else if (current.blockingReasons.length > 0) {
        serverError = current.blockingReasons.join(' ')
      } else {
        const result = await hardDeleteProgramById(supabase, id)
        if (!result.ok) {
          serverError = result.message
        } else {
          const destination = returnTo || '/admin/programs'
          const separator = destination.includes('?') ? '&' : '?'
          return Astro.redirect(`${destination}${separator}notice=${encodeURIComponent('Program permanently deleted.')}&noticeLevel=success`)
        }
      }
    }
  } else if (cleanupAction === 'add_source') {
    const srcUrl = String(form.get('source_url') ?? '').trim()
    const sourceType = String(form.get('source_type') ?? 'third_party').trim() || 'third_party'
    const confidenceLevel = String(form.get('confidence_level') ?? 'unknown').trim() || 'unknown'
    const sourceStatus = String(form.get('source_status') ?? 'active').trim() || 'active'
    const sourceTitle = String(form.get('source_title') ?? '').trim()

    const srcUrlErr = validateRequired(srcUrl, 'Source URL') ?? validateUrl(srcUrl, 'Source URL')
    const sourceTypeErr = validateIn(sourceType, SOURCE_TYPE_OPTIONS, 'Source Type')
    const confidenceErr = validateIn(confidenceLevel, CONFIDENCE_OPTIONS, 'Source Confidence')
    const sourceStatusErr = validateIn(sourceStatus, SOURCE_STATUS_OPTIONS, 'Source Status')

    sourceError = srcUrlErr ?? sourceTypeErr ?? confidenceErr ?? sourceStatusErr ?? ''

    if (!sourceError) {
      const { error: srcErr } = await supabase.from('data_sources').insert({
        entity_type: 'program',
        entity_id: id,
        source_url: srcUrl,
        source_type: sourceType,
        confidence_level: confidenceLevel,
        source_status: sourceStatus,
        source_title: sourceTitle || null,
        is_primary_source: form.get('is_primary_source') === 'true',
      })

      if (srcErr) {
        sourceError = 'Could not add source.'
      } else {
        const editHref = returnTo
          ? `${Astro.url.pathname}?returnTo=${encodeURIComponent(returnTo)}`
          : Astro.url.pathname
        return Astro.redirect(editHref)
      }
    }
  } else {
    const actionValue = String(form.get('action') ?? 'save').trim()
    const action = WORKFLOW_ACTIONS.find(option => option === actionValue) ?? null
    const g = (key: string) => String(form.get(key) ?? '').trim()

    values = {
      title: g('title'),
      slug: g('slug'),
      university_id: g('university_id'),
      degree_level_id: g('degree_level_id'),
      degree_award: g('degree_award'),
      primary_subject_id: g('primary_subject_id'),
      duration_months: g('duration_months'),
      study_mode: g('study_mode'),
      delivery_mode: g('delivery_mode'),
      language_of_instruction: g('language_of_instruction'),
      tuition_min_amount: g('tuition_min_amount'),
      tuition_max_amount: g('tuition_max_amount'),
      tuition_currency: g('tuition_currency'),
      tuition_period: g('tuition_period'),
      tuition_notes: g('tuition_notes'),
      application_fee_amount: g('application_fee_amount'),
      application_fee_currency: g('application_fee_currency'),
      application_fee_notes: g('application_fee_notes'),
      official_url: g('official_url'),
      application_url: g('application_url'),
      admission_requirements: g('admission_requirements'),
      gpa_requirements: g('gpa_requirements'),
      curriculum_summary: g('curriculum_summary'),
      career_outcomes: g('career_outcomes'),
      content_status: g('content_status') || 'draft',
      verification_status: g('verification_status') || 'unverified',
    }

    if (action === 'publish') values.content_status = 'published'
    if (action === 'mark_in_review') values.content_status = 'in_review'
    if (action === 'mark_partially_verified') values.verification_status = 'partially_verified'
    if (action === 'mark_verified') values.verification_status = 'verified'

    if (!values.slug && values.title) values.slug = toSlug(values.title)

    const e: FormErrors = {}

    if (!action) {
      serverError = 'Invalid action.'
    }

    const titleErr = validateRequired(values.title, 'Title')
    if (titleErr) e.title = titleErr

    const slugErr = validateRequired(values.slug, 'Slug') ?? validateSlug(values.slug)
    if (slugErr) e.slug = slugErr

    const uniErr = validateRequired(values.university_id, 'University')
    if (uniErr) e.university_id = uniErr

    const dlErr = validateRequired(values.degree_level_id, 'Degree Level')
    if (dlErr) e.degree_level_id = dlErr

    const statusErr = validateIn(values.content_status, CONTENT_STATUS_OPTIONS, 'Status')
    if (statusErr) e.content_status = statusErr

    const verErr = validateIn(values.verification_status, VERIFICATION_OPTIONS, 'Verification Status')
    if (verErr) e.verification_status = verErr

    if (values.study_mode) {
      const err = validateIn(values.study_mode, STUDY_MODE_OPTIONS, 'Study Mode')
      if (err) e.study_mode = err
    }

    if (values.delivery_mode) {
      const err = validateIn(values.delivery_mode, DELIVERY_MODE_OPTIONS, 'Delivery Mode')
      if (err) e.delivery_mode = err
    }

    if (values.tuition_period) {
      const err = validateIn(values.tuition_period, TUITION_PERIOD_OPTIONS, 'Tuition Period')
      if (err) e.tuition_period = err
    }

    if (values.duration_months) {
      const duration = Number(values.duration_months)
      if (!Number.isFinite(duration) || duration < 1 || !Number.isInteger(duration)) {
        e.duration_months = 'Duration must be a positive whole number of months.'
      }
    }

    const minErr = validateNumeric(values.tuition_min_amount, 'Minimum Tuition', { min: 0 })
    if (minErr) e.tuition_min_amount = minErr

    const maxErr = validateNumeric(values.tuition_max_amount, 'Maximum Tuition', { min: 0 })
    if (maxErr) e.tuition_max_amount = maxErr

    if (!e.tuition_min_amount && !e.tuition_max_amount && values.tuition_min_amount && values.tuition_max_amount) {
      if (Number(values.tuition_max_amount) < Number(values.tuition_min_amount)) {
        e.tuition_max_amount = 'Maximum tuition must be greater than or equal to minimum tuition.'
      }
    }

    const feeErr = validateNumeric(values.application_fee_amount, 'Application Fee', { min: 0 })
    if (feeErr) e.application_fee_amount = feeErr

    const offErr = validateUrl(values.official_url, 'Official URL')
    if (offErr) e.official_url = offErr

    const appUrlErr = validateUrl(values.application_url, 'Application URL')
    if (appUrlErr) e.application_url = appUrlErr

    if (!e.university_id) {
      const found = universities.find(option => option.id === values.university_id)
      if (!found) e.university_id = 'Selected university not found.'
    }

    errors = e

    if (Object.keys(errors).length === 0 && action) {
      const selectedUniversity = universities.find(option => option.id === values.university_id)!
      const verificationStamp =
        action === 'mark_partially_verified' || action === 'mark_verified'
          ? new Date().toISOString()
          : undefined

      const updatePayload: Record<string, unknown> = {
        title: values.title,
        slug: values.slug,
        university_id: values.university_id,
        country_id: selectedUniversity.country_id,
        city_id: selectedUniversity.city_id ?? null,
        degree_level_id: values.degree_level_id,
        degree_award: values.degree_award || null,
        primary_subject_id: values.primary_subject_id || null,
        duration_months: values.duration_months ? parseInt(values.duration_months, 10) : null,
        study_mode: values.study_mode || null,
        delivery_mode: values.delivery_mode || null,
        language_of_instruction: values.language_of_instruction || null,
        tuition_min_amount: values.tuition_min_amount ? parseFloat(values.tuition_min_amount) : null,
        tuition_max_amount: values.tuition_max_amount ? parseFloat(values.tuition_max_amount) : null,
        tuition_currency: values.tuition_currency || null,
        tuition_period: values.tuition_period || null,
        tuition_notes: values.tuition_notes || null,
        application_fee_amount: values.application_fee_amount ? parseFloat(values.application_fee_amount) : null,
        application_fee_currency: values.application_fee_currency || null,
        application_fee_notes: values.application_fee_notes || null,
        official_url: values.official_url || null,
        application_url: values.application_url || null,
        admission_requirements: values.admission_requirements || null,
        gpa_requirements: values.gpa_requirements || null,
        curriculum_summary: values.curriculum_summary || null,
        career_outcomes: values.career_outcomes || null,
        content_status: values.content_status,
        verification_status: values.verification_status,
      }

      if (verificationStamp) updatePayload.last_verified_at = verificationStamp

      const { error } = await supabase
        .from('programs')
        .update(updatePayload)
        .eq('id', id)

      if (error) {
        serverError = error.code === '23505'
          ? 'A program with this slug already exists.'
          : `Could not ${REVIEW_ACTION_LABELS[action].toLowerCase()}. Please try again.`
      } else {
        return Astro.redirect(returnTo || '/admin/programs')
      }
    }
  }
}

type ReviewItem = {
  label: string
  state: ReviewState
  detail: string
}

type ReviewSection = {
  title: string
  items: ReviewItem[]
}

const hasTuition = values.tuition_min_amount !== '' || values.tuition_max_amount !== ''
const hasDuration = values.duration_months !== ''
const hasLanguage = values.language_of_instruction !== ''
const hasOfficialUrl = values.official_url !== ''
const hasApplicationUrl = values.application_url !== ''
const hasPrimarySubject = values.primary_subject_id !== ''
const hasSources = sources.length > 0
const hasIntakes = intakes.length > 0

const importantMissingFields: string[] = []
if (!hasTuition) importantMissingFields.push('Tuition')
if (!hasDuration) importantMissingFields.push('Duration')
if (!hasLanguage) importantMissingFields.push('Language')
if (!hasOfficialUrl) importantMissingFields.push('Official URL')
if (!hasApplicationUrl) importantMissingFields.push('Application URL')
if (!hasSources) importantMissingFields.push('Source link')
if (!hasIntakes) importantMissingFields.push('Intake or deadline')

const selectedUniversityLabel = universities.find(option => option.id === values.university_id)?.name ?? 'No university selected'
const selectedDegreeLevelLabel = (() => {
  const option = degreeLevels.find(level => level.id === values.degree_level_id)
  return option ? `${option.name} (${option.code})` : 'No degree level selected'
})()
const selectedSubjectLabel = subjects.find(option => option.id === values.primary_subject_id)?.name ?? ''
const firstIntake = intakes[0] ?? null
const firstIntakeLabel = firstIntake
  ? firstIntake.intake_name
    ?? (firstIntake.is_rolling ? 'Rolling intake' : firstIntake.application_deadline_date ?? firstIntake.deadline_text ?? 'Unnamed intake')
  : 'No intake listed'

const completenessWidth = clampPercent(record.data_completeness_score)
const confidenceWidth = clampPercent(record.source_confidence_score)
const primarySourceCount = sources.filter(source => source.is_primary_source).length

const reviewSections: ReviewSection[] = [
  {
    title: 'Core identity',
    items: [
      { label: 'Title', state: values.title ? 'ready' : 'missing', detail: values.title || 'Title is required.' },
      { label: 'Slug', state: values.slug ? 'ready' : 'missing', detail: values.slug || 'Slug is required.' },
      { label: 'University', state: values.university_id ? 'ready' : 'missing', detail: selectedUniversityLabel },
      { label: 'Degree level', state: values.degree_level_id ? 'ready' : 'missing', detail: selectedDegreeLevelLabel },
      {
        label: 'Primary subject',
        state: hasPrimarySubject ? 'ready' : 'needs_attention',
        detail: hasPrimarySubject ? selectedSubjectLabel : 'Optional, but helpful for search and review.',
      },
    ],
  },
  {
    title: 'Student decision fields',
    items: [
      { label: 'Tuition', state: hasTuition ? 'ready' : 'missing', detail: hasTuition ? 'At least one tuition amount is listed.' : 'No tuition amount listed.' },
      { label: 'Duration', state: hasDuration ? 'ready' : 'missing', detail: hasDuration ? `${values.duration_months} month${values.duration_months === '1' ? '' : 's'}` : 'No duration listed.' },
      { label: 'Language', state: hasLanguage ? 'ready' : 'missing', detail: hasLanguage ? values.language_of_instruction : 'No language listed.' },
      { label: 'Official URL', state: hasOfficialUrl ? 'ready' : 'missing', detail: hasOfficialUrl ? values.official_url : 'No official program URL linked.' },
      { label: 'Application URL', state: hasApplicationUrl ? 'ready' : 'missing', detail: hasApplicationUrl ? values.application_url : 'No application URL linked.' },
    ],
  },
  {
    title: 'Intake and deadline',
    items: [
      {
        label: 'Program intakes',
        state: hasIntakes ? 'ready' : 'missing',
        detail: hasIntakes
          ? `${intakes.length} intake${intakes.length === 1 ? '' : 's'} linked. First listed: ${firstIntakeLabel}.`
          : 'No intake or deadline listed.',
      },
    ],
  },
  {
    title: 'Source and trust',
    items: [
      {
        label: 'Linked sources',
        state: hasSources ? 'ready' : 'missing',
        detail: hasSources
          ? `${sources.length} source${sources.length === 1 ? '' : 's'} linked${primarySourceCount > 0 ? `, ${primarySourceCount} primary` : ''}.`
          : 'No linked sources yet.',
      },
      {
        label: 'Source confidence',
        state: reviewStateFromScore(record.source_confidence_score),
        detail: `${record.source_confidence_score} / 100 · ${confidenceScoreLabel(record.source_confidence_score)}`,
      },
      {
        label: 'Verification status',
        state: reviewStateFromVerification(values.verification_status),
        detail: VERIFICATION_LABELS[values.verification_status] ?? formatEnumLabel(values.verification_status),
      },
      {
        label: 'Last verified',
        state: record.last_verified_at ? 'ready' : 'needs_attention',
        detail: formatDateValue(record.last_verified_at),
      },
    ],
  },
  {
    title: 'Public readiness',
    items: [
      {
        label: 'Content status',
        state: reviewStateFromContentStatus(values.content_status),
        detail: CONTENT_STATUS_LABELS[values.content_status] ?? formatEnumLabel(values.content_status),
      },
      {
        label: 'Data completeness',
        state: reviewStateFromScore(record.data_completeness_score),
        detail: `${record.data_completeness_score} / 100`,
      },
      {
        label: 'Missing important fields',
        state: importantMissingFields.length === 0 ? 'ready' : 'needs_attention',
        detail: importantMissingFields.length === 0 ? 'No major review gaps detected.' : importantMissingFields.join(', '),
      },
    ],
  },
]

const checklistItems = reviewSections.flatMap(section => section.items)
const readyCount = checklistItems.filter(item => item.state === 'ready').length
const needsAttentionCount = checklistItems.filter(item => item.state === 'needs_attention').length
const missingCount = checklistItems.filter(item => item.state === 'missing').length

const inputClass = 'w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500'
const selectClass = inputClass + ' bg-white'
const labelClass = 'block text-sm font-medium text-gray-700 mb-1'
const errorClass = 'mt-1 text-xs text-red-600'
const sectionHeadClass = 'text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3 pb-1 border-b border-gray-200'
const cardClass = 'rounded-lg border border-gray-200 bg-white p-4'
const backToProgramsHref = returnTo || '/admin/programs'
const noticeToneClass = actionNoticeLevel === 'danger'
  ? 'border-red-200 bg-red-50 text-red-800'
  : actionNoticeLevel === 'warning'
    ? 'border-amber-200 bg-amber-50 text-amber-900'
    : 'border-green-200 bg-green-50 text-green-800'
---
<AdminLayout title={`Edit ${record.title} — DegreeWiki Admin`} activePath="/admin/programs" userEmail={user.email ?? ''}>
  <div class="flex items-center justify-between mb-6 gap-3">
    <div>
      <h1 class="text-xl font-bold text-gray-900">Edit Program</h1>
      <p class="text-sm text-gray-500 mt-1">Review imported program details, check gaps, then publish or verify when ready.</p>
    </div>
    <a href={backToProgramsHref} class="text-sm text-gray-500 hover:underline">← Back to Programs</a>
  </div>

  {actionNotice && (
    <div class={`mb-4 rounded-md border px-4 py-3 text-sm ${noticeToneClass}`}>{actionNotice}</div>
  )}

  {serverError && (
    <div class="mb-4 px-4 py-3 rounded-md bg-red-50 border border-red-200 text-sm text-red-700">{serverError}</div>
  )}

  <form method="post" class="space-y-8">
    <input type="hidden" name="returnTo" value={returnTo} />

    <div class="grid gap-8 xl:grid-cols-[minmax(0,1fr)_20rem] items-start">
      <div class="space-y-6">
        <div class={cardClass}>
          <h2 class={sectionHeadClass}>Identity</h2>
          <div class="space-y-4">
            <div>
              <label for="title" class={labelClass}>Title *</label>
              <input type="text" id="title" name="title" value={values.title} required class={inputClass} />
              {errors.title && <p class={errorClass}>{errors.title}</p>}
            </div>

            <div>
              <label for="slug" class={labelClass}>Slug *</label>
              <input type="text" id="slug" name="slug" value={values.slug} class={inputClass + ' font-mono'} />
              {errors.slug && <p class={errorClass}>{errors.slug}</p>}
            </div>

            <div>
              <label for="university_id" class={labelClass}>University *</label>
              <select id="university_id" name="university_id" class={selectClass}>
                <option value="">— select a university —</option>
                {universities.map(option => (
                  <option value={option.id} selected={values.university_id === option.id}>{option.name}</option>
                ))}
              </select>
              {errors.university_id && <p class={errorClass}>{errors.university_id}</p>}
              <p class="mt-1 text-xs text-gray-400">Country and city are derived from the selected university.</p>
            </div>

            <div>
              <label for="degree_level_id" class={labelClass}>Degree Level *</label>
              <select id="degree_level_id" name="degree_level_id" class={selectClass}>
                <option value="">— select a degree level —</option>
                {degreeLevels.map(option => (
                  <option value={option.id} selected={values.degree_level_id === option.id}>{option.name} ({option.code})</option>
                ))}
              </select>
              {errors.degree_level_id && <p class={errorClass}>{errors.degree_level_id}</p>}
            </div>

            <div>
              <label for="content_status" class={labelClass}>Status *</label>
              <select id="content_status" name="content_status" class={selectClass}>
                {CONTENT_STATUS_OPTIONS.map(option => (
                  <option value={option} selected={values.content_status === option}>{CONTENT_STATUS_LABELS[option] ?? option}</option>
                ))}
              </select>
              {errors.content_status && <p class={errorClass}>{errors.content_status}</p>}
            </div>
          </div>
        </div>

        <div class={cardClass}>
          <h2 class={sectionHeadClass}>Academic Details</h2>
          <div class="space-y-4">
            <div>
              <label for="degree_award" class={labelClass}>Degree Award</label>
              <input
                type="text"
                id="degree_award"
                name="degree_award"
                value={values.degree_award}
                placeholder="e.g. Bachelor of Science, Master of Arts"
                class={inputClass}
              />
            </div>

            <div>
              <label for="primary_subject_id" class={labelClass}>Primary Subject</label>
              <select id="primary_subject_id" name="primary_subject_id" class={selectClass}>
                <option value="">— none —</option>
                {subjects.map(option => (
                  <option value={option.id} selected={values.primary_subject_id === option.id}>{option.name}</option>
                ))}
              </select>
            </div>

            <div class="grid gap-4 md:grid-cols-2">
              <div>
                <label for="study_mode" class={labelClass}>Study Mode</label>
                <select id="study_mode" name="study_mode" class={selectClass}>
                  <option value="">— none —</option>
                  {STUDY_MODE_OPTIONS.map(option => (
                    <option value={option} selected={values.study_mode === option}>{formatEnumLabel(option)}</option>
                  ))}
                </select>
                {errors.study_mode && <p class={errorClass}>{errors.study_mode}</p>}
              </div>

              <div>
                <label for="delivery_mode" class={labelClass}>Delivery Mode</label>
                <select id="delivery_mode" name="delivery_mode" class={selectClass}>
                  <option value="">— none —</option>
                  {DELIVERY_MODE_OPTIONS.map(option => (
                    <option value={option} selected={values.delivery_mode === option}>{formatEnumLabel(option)}</option>
                  ))}
                </select>
                {errors.delivery_mode && <p class={errorClass}>{errors.delivery_mode}</p>}
              </div>
            </div>

            <div class="grid gap-4 md:grid-cols-2">
              <div>
                <label for="language_of_instruction" class={labelClass}>Language of Instruction</label>
                <input
                  type="text"
                  id="language_of_instruction"
                  name="language_of_instruction"
                  value={values.language_of_instruction}
                  placeholder="e.g. English"
                  class={inputClass}
                />
              </div>

              <div>
                <label for="duration_months" class={labelClass}>Duration (months)</label>
                <input
                  type="number"
                  id="duration_months"
                  name="duration_months"
                  value={values.duration_months}
                  min="1"
                  step="1"
                  placeholder="e.g. 24"
                  class={inputClass}
                />
                {errors.duration_months && <p class={errorClass}>{errors.duration_months}</p>}
              </div>
            </div>
          </div>
        </div>

        <div class={cardClass}>
          <h2 class={sectionHeadClass}>Tuition</h2>
          <div class="space-y-4">
            <div class="grid gap-4 md:grid-cols-3">
              <div>
                <label for="tuition_min_amount" class={labelClass}>Min Amount</label>
                <input
                  type="number"
                  id="tuition_min_amount"
                  name="tuition_min_amount"
                  value={values.tuition_min_amount}
                  min="0"
                  step="any"
                  placeholder="0"
                  class={inputClass}
                />
                {errors.tuition_min_amount && <p class={errorClass}>{errors.tuition_min_amount}</p>}
              </div>

              <div>
                <label for="tuition_max_amount" class={labelClass}>Max Amount</label>
                <input
                  type="number"
                  id="tuition_max_amount"
                  name="tuition_max_amount"
                  value={values.tuition_max_amount}
                  min="0"
                  step="any"
                  placeholder="0"
                  class={inputClass}
                />
                {errors.tuition_max_amount && <p class={errorClass}>{errors.tuition_max_amount}</p>}
              </div>

              <div>
                <label for="tuition_currency" class={labelClass}>Currency</label>
                <input
                  type="text"
                  id="tuition_currency"
                  name="tuition_currency"
                  value={values.tuition_currency}
                  placeholder="USD"
                  class={inputClass + ' font-mono'}
                />
              </div>
            </div>

            <div>
              <label for="tuition_period" class={labelClass}>Tuition Period</label>
              <select id="tuition_period" name="tuition_period" class={selectClass}>
                <option value="">— none —</option>
                {TUITION_PERIOD_OPTIONS.map(option => (
                  <option value={option} selected={values.tuition_period === option}>{formatEnumLabel(option)}</option>
                ))}
              </select>
              {errors.tuition_period && <p class={errorClass}>{errors.tuition_period}</p>}
            </div>

            <div>
              <label for="tuition_notes" class={labelClass}>Tuition Notes</label>
              <textarea id="tuition_notes" name="tuition_notes" rows={2} class={inputClass}>{values.tuition_notes}</textarea>
            </div>
          </div>
        </div>

        <div class={cardClass}>
          <h2 class={sectionHeadClass}>Application Fees</h2>
          <div class="space-y-4">
            <div class="grid gap-4 md:grid-cols-2">
              <div>
                <label for="application_fee_amount" class={labelClass}>Fee Amount</label>
                <input
                  type="number"
                  id="application_fee_amount"
                  name="application_fee_amount"
                  value={values.application_fee_amount}
                  min="0"
                  step="any"
                  placeholder="0"
                  class={inputClass}
                />
                {errors.application_fee_amount && <p class={errorClass}>{errors.application_fee_amount}</p>}
              </div>

              <div>
                <label for="application_fee_currency" class={labelClass}>Fee Currency</label>
                <input
                  type="text"
                  id="application_fee_currency"
                  name="application_fee_currency"
                  value={values.application_fee_currency}
                  placeholder="USD"
                  class={inputClass + ' font-mono'}
                />
              </div>
            </div>

            <div>
              <label for="application_fee_notes" class={labelClass}>Fee Notes</label>
              <textarea id="application_fee_notes" name="application_fee_notes" rows={2} class={inputClass}>{values.application_fee_notes}</textarea>
            </div>
          </div>
        </div>

        <div class={cardClass}>
          <h2 class={sectionHeadClass}>URLs</h2>
          <div class="space-y-4">
            <div>
              <label for="official_url" class={labelClass}>Official Program URL</label>
              <input
                type="url"
                id="official_url"
                name="official_url"
                value={values.official_url}
                placeholder="https://university.edu/programs/..."
                class={inputClass}
              />
              {errors.official_url && <p class={errorClass}>{errors.official_url}</p>}
            </div>

            <div>
              <label for="application_url" class={labelClass}>Application URL</label>
              <input
                type="url"
                id="application_url"
                name="application_url"
                value={values.application_url}
                placeholder="https://apply.university.edu/..."
                class={inputClass}
              />
              {errors.application_url && <p class={errorClass}>{errors.application_url}</p>}
            </div>
          </div>
        </div>

        <div class={cardClass}>
          <h2 class={sectionHeadClass}>Admissions</h2>
          <div class="space-y-4">
            <div>
              <label for="admission_requirements" class={labelClass}>Admission Requirements</label>
              <textarea id="admission_requirements" name="admission_requirements" rows={4} class={inputClass}>{values.admission_requirements}</textarea>
            </div>

            <div>
              <label for="gpa_requirements" class={labelClass}>GPA Requirements</label>
              <input
                type="text"
                id="gpa_requirements"
                name="gpa_requirements"
                value={values.gpa_requirements}
                placeholder="e.g. Minimum 3.0 GPA on a 4.0 scale"
                class={inputClass}
              />
            </div>
          </div>
        </div>

        <div class={cardClass}>
          <h2 class={sectionHeadClass}>Content</h2>
          <div class="space-y-4">
            <div>
              <label for="curriculum_summary" class={labelClass}>Curriculum Summary</label>
              <textarea id="curriculum_summary" name="curriculum_summary" rows={4} class={inputClass}>{values.curriculum_summary}</textarea>
            </div>

            <div>
              <label for="career_outcomes" class={labelClass}>Career Outcomes</label>
              <textarea id="career_outcomes" name="career_outcomes" rows={4} class={inputClass}>{values.career_outcomes}</textarea>
            </div>
          </div>
        </div>

        <div class={cardClass}>
          <h2 class={sectionHeadClass}>Verification</h2>
          <div>
            <label for="verification_status" class={labelClass}>Verification Status</label>
            <select id="verification_status" name="verification_status" class={selectClass}>
              {VERIFICATION_OPTIONS.map(option => (
                <option value={option} selected={values.verification_status === option}>{VERIFICATION_LABELS[option] ?? option}</option>
              ))}
            </select>
            {errors.verification_status && <p class={errorClass}>{errors.verification_status}</p>}
          </div>
        </div>

        <div class="flex gap-3 pt-1">
          <button
            type="submit"
            name="action"
            value="save"
            class="px-4 py-2 text-sm font-medium bg-blue-600 text-white rounded-md hover:bg-blue-700"
          >
            Save Changes
          </button>
          <a href={backToProgramsHref} class="px-4 py-2 text-sm text-gray-600 hover:underline">Cancel</a>
        </div>
      </div>

      <aside class="space-y-4 xl:sticky xl:top-6">
        <div class={cardClass}>
          <div class="flex items-start justify-between gap-3 mb-3">
            <div>
              <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Review Checklist</h2>
              <p class="text-xs text-gray-400 mt-1">Advisory only. Publish still follows existing validation and RLS.</p>
            </div>
            <span class={`inline-flex items-center rounded px-2 py-0.5 text-xs font-medium ${CONTENT_STATUS_BADGE[values.content_status] ?? FALLBACK_BADGE}`}>
              {CONTENT_STATUS_LABELS[values.content_status] ?? formatEnumLabel(values.content_status)}
            </span>
          </div>

          <div class="grid grid-cols-3 gap-2 mb-4 text-center">
            <div class="rounded border border-green-200 bg-green-50 px-2 py-2">
              <div class="text-base font-semibold text-green-700">{readyCount}</div>
              <div class="text-[11px] uppercase tracking-wide text-green-600">Ready</div>
            </div>
            <div class="rounded border border-yellow-200 bg-yellow-50 px-2 py-2">
              <div class="text-base font-semibold text-yellow-700">{needsAttentionCount}</div>
              <div class="text-[11px] uppercase tracking-wide text-yellow-600">Attention</div>
            </div>
            <div class="rounded border border-red-200 bg-red-50 px-2 py-2">
              <div class="text-base font-semibold text-red-700">{missingCount}</div>
              <div class="text-[11px] uppercase tracking-wide text-red-600">Missing</div>
            </div>
          </div>

          {importantMissingFields.length > 0 ? (
            <div class="mb-4 rounded border border-yellow-200 bg-yellow-50 px-3 py-2 text-xs text-yellow-800">
              Missing important fields: {importantMissingFields.join(', ')}
            </div>
          ) : (
            <div class="mb-4 rounded border border-green-200 bg-green-50 px-3 py-2 text-xs text-green-700">
              No major review gaps detected from the current program, source, and intake data.
            </div>
          )}

          <div class="space-y-4">
            {reviewSections.map(section => (
              <div>
                <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-2">{section.title}</h3>
                <div class="space-y-2">
                  {section.items.map(item => (
                    <div class="rounded border border-gray-200 px-3 py-2">
                      <div class="flex items-start justify-between gap-3">
                        <div class="min-w-0">
                          <p class="text-sm font-medium text-gray-800">{item.label}</p>
                          <p class="text-xs text-gray-500 mt-0.5 break-words">{item.detail}</p>
                        </div>
                        <span class={`shrink-0 inline-flex items-center rounded px-2 py-0.5 text-[11px] font-medium ${CHECK_STATE_BADGE[item.state]}`}>
                          {CHECK_STATE_LABELS[item.state]}
                        </span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class={`${cardClass} space-y-3`}>
          <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Data Quality</h2>
          <div class="space-y-2 text-xs text-gray-600">
            <div class="flex items-center justify-between">
              <span>Completeness</span>
              <span class="font-mono font-medium">{record.data_completeness_score} / 100</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-1.5">
              <div class="bg-blue-500 h-1.5 rounded-full" style={`width: ${completenessWidth}%`}></div>
            </div>
            <div class="flex items-center justify-between pt-1">
              <span>Source Confidence</span>
              <span class="font-mono font-medium">{record.source_confidence_score} / 100</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-1.5">
              <div class="bg-green-500 h-1.5 rounded-full" style={`width: ${confidenceWidth}%`}></div>
            </div>
            <p class="text-xs text-gray-400 pt-1">Existing quality scores are read-only and advisory.</p>
          </div>

          <div class="pt-2 border-t border-gray-100 space-y-2 text-xs text-gray-600">
            <div class="flex items-center justify-between gap-3">
              <span>Verification</span>
              <span class={`inline-flex items-center rounded px-2 py-0.5 text-xs font-medium ${VERIFICATION_STATUS_BADGE[values.verification_status] ?? FALLBACK_BADGE}`}>
                {VERIFICATION_LABELS[values.verification_status] ?? formatEnumLabel(values.verification_status)}
              </span>
            </div>
            <div class="flex items-center justify-between gap-3">
              <span>Last verified</span>
              <span class="text-gray-500">{formatDateValue(record.last_verified_at)}</span>
            </div>
            <div class="flex items-center justify-between gap-3">
              <span>Next review due</span>
              <span class="text-gray-500">{formatDateValue(record.next_review_due_at)}</span>
            </div>
            <div class="flex items-center justify-between gap-3">
              <span>Sources linked</span>
              <span class="text-gray-500">{sources.length}</span>
            </div>
            <div class="flex items-center justify-between gap-3">
              <span>Intakes listed</span>
              <span class="text-gray-500">{intakes.length}</span>
            </div>
          </div>
        </div>

        <div class={`${cardClass} space-y-3`}>
          <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Workflow Actions</h2>
          <p class="text-xs text-gray-500">These actions update only existing workflow fields. Verification buttons also stamp <code>last_verified_at</code>.</p>
          <div class="space-y-2">
            <button
              type="submit"
              name="action"
              value="save"
              class="w-full px-4 py-2 text-sm font-medium bg-blue-600 text-white rounded-md hover:bg-blue-700"
            >
              Save Changes
            </button>
            <button
              type="submit"
              name="action"
              value="mark_in_review"
              class="w-full px-4 py-2 text-sm font-medium bg-yellow-600 text-white rounded-md hover:bg-yellow-700"
            >
              Mark In Review
            </button>
            <button
              type="submit"
              name="action"
              value="publish"
              class="w-full px-4 py-2 text-sm font-medium bg-green-600 text-white rounded-md hover:bg-green-700"
            >
              Save and Publish
            </button>
            <button
              type="submit"
              name="action"
              value="mark_partially_verified"
              class="w-full px-4 py-2 text-sm font-medium bg-amber-600 text-white rounded-md hover:bg-amber-700"
            >
              Mark Partially Verified
            </button>
            <button
              type="submit"
              name="action"
              value="mark_verified"
              class="w-full px-4 py-2 text-sm font-medium bg-emerald-600 text-white rounded-md hover:bg-emerald-700"
            >
              Mark Verified
            </button>
          </div>
          <a href={backToProgramsHref} class="block text-center text-sm text-gray-500 hover:underline pt-1">Cancel</a>
        </div>

      </aside>
    </div>
  </form>

  <div class="mt-8 max-w-6xl">
    <div class={`${cardClass} space-y-4`}>
      <div>
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Cleanup Actions</h2>
        <p class="mt-1 text-sm text-gray-500">Archive is the safe default. Hard delete is pre-launch only, super-admin only, and never removes shared university rows or shared media assets.</p>
      </div>

      <div class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.2fr)]">
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
          {values.content_status === 'archived' ? (
            <form method="post" class="space-y-3">
              <input type="hidden" name="_action" value="restore_program" />
              <input type="hidden" name="returnTo" value={returnTo} />
              <p class="text-sm font-medium text-gray-900">Restore to draft</p>
              <p class="text-xs text-gray-600">Bring this archived record back as a draft without publishing it.</p>
              <button
                type="submit"
                class="w-full px-4 py-2 text-sm font-medium bg-slate-700 text-white rounded-md hover:bg-slate-800"
              >
                Restore To Draft
              </button>
            </form>
          ) : (
            <form method="post" class="space-y-3">
              <input type="hidden" name="_action" value="archive_program" />
              <input type="hidden" name="returnTo" value={returnTo} />
              <p class="text-sm font-medium text-gray-900">Archive this program</p>
              <p class="text-xs text-gray-600">Sets <code>content_status</code> to archived and resets <code>indexing_status</code> to draft while keeping verification status unchanged.</p>
              <button
                type="submit"
                class="w-full px-4 py-2 text-sm font-medium bg-amber-600 text-white rounded-md hover:bg-amber-700"
              >
                Archive Program
              </button>
            </form>
          )}
        </div>

        <div class="rounded-lg border border-red-200 bg-red-50 p-4">
          {isSuperAdmin ? (
            <form method="post" class="space-y-3">
              <input type="hidden" name="_action" value="hard_delete_program" />
              <input type="hidden" name="returnTo" value={returnTo} />
              <p class="text-sm font-medium text-red-900">Permanent delete</p>
              <p class="text-xs text-red-800">Use only for obvious duplicate or test records before launch. AI Finder history and immutable analytics references will block deletion and should be archived instead.</p>
              <label class="flex items-start gap-2 text-xs text-red-800">
                <input type="checkbox" name="hard_delete_confirm" class="mt-0.5 h-4 w-4 rounded border-red-300 text-red-600" />
                <span>I understand this permanently deletes selected programs and is intended for pre-launch duplicate/test cleanup.</span>
              </label>
              <div>
                <label for="hard_delete_text" class="block text-xs font-medium text-red-800 mb-1">Type DELETE to confirm</label>
                <input id="hard_delete_text" name="hard_delete_text" type="text" class="w-full rounded-md border border-red-300 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-red-500" />
              </div>
              <button
                type="submit"
                class="w-full px-4 py-2 text-sm font-medium bg-red-700 text-white rounded-md hover:bg-red-800"
              >
                Permanently Delete Program
              </button>
            </form>
          ) : (
            <div class="space-y-2">
              <p class="text-sm font-medium text-red-900">Permanent delete</p>
              <p class="text-xs text-red-800">Hard delete is only available to super admins.</p>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>

  <div class="mt-8 max-w-6xl">
    <div class={`${cardClass} border-t-0`}>
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-4">Data Sources</h2>

      {sources.length > 0 ? (
        <div class="space-y-2 mb-6">
          {sources.map(source => (
            <div class="px-3 py-2 bg-gray-50 rounded border border-gray-200 text-sm">
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                  <div class="flex items-start gap-2">
                    {source.is_primary_source && (
                      <span class="shrink-0 inline-block px-1.5 py-0.5 text-xs bg-green-100 text-green-700 rounded">primary</span>
                    )}
                    <a
                      href={source.source_url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-blue-600 hover:underline break-all font-mono text-xs"
                    >
                      {source.source_url}
                    </a>
                  </div>
                  <p class="text-xs text-gray-500 mt-1">
                    {formatEnumLabel(source.source_type)} · {formatEnumLabel(source.confidence_level)} confidence · {formatEnumLabel(source.source_status)}
                    {source.source_title ? ` · ${source.source_title}` : ''}
                  </p>
                </div>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-sm text-gray-400 mb-6">No sources linked yet.</p>
      )}

      <form method="post" class="space-y-3">
        <input type="hidden" name="_action" value="add_source" />
        <input type="hidden" name="returnTo" value={returnTo} />
        <p class="text-xs font-semibold text-gray-600 mb-2">Add a source</p>
        {sourceError && <p class="text-xs text-red-600 mb-2">{sourceError}</p>}
        <div class="space-y-3 bg-gray-50 p-4 rounded border border-gray-200">
          <div>
            <label for="source_url" class="block text-sm font-medium text-gray-700 mb-1">URL *</label>
            <input
              type="url"
              id="source_url"
              name="source_url"
              placeholder="https://..."
              class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
            />
          </div>

          <div class="grid gap-3 md:grid-cols-3">
            <div>
              <label for="source_type" class="block text-sm font-medium text-gray-700 mb-1">Type</label>
              <select
                id="source_type"
                name="source_type"
                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white"
              >
                {SOURCE_TYPE_OPTIONS.map(option => <option value={option}>{formatEnumLabel(option)}</option>)}
              </select>
            </div>

            <div>
              <label for="confidence_level" class="block text-sm font-medium text-gray-700 mb-1">Confidence</label>
              <select
                id="confidence_level"
                name="confidence_level"
                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white"
              >
                {CONFIDENCE_OPTIONS.map(option => <option value={option}>{formatEnumLabel(option)}</option>)}
              </select>
            </div>

            <div>
              <label for="source_status_input" class="block text-sm font-medium text-gray-700 mb-1">Status</label>
              <select
                id="source_status_input"
                name="source_status"
                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white"
              >
                {SOURCE_STATUS_OPTIONS.map(option => <option value={option}>{formatEnumLabel(option)}</option>)}
              </select>
            </div>
          </div>

          <div>
            <label for="source_title" class="block text-sm font-medium text-gray-700 mb-1">Title (optional)</label>
            <input
              type="text"
              id="source_title"
              name="source_title"
              placeholder="e.g. Official program page"
              class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
            />
          </div>

          <div class="flex items-center gap-2">
            <input type="checkbox" id="is_primary_source" name="is_primary_source" value="true" class="h-4 w-4 text-blue-600 rounded border-gray-300" />
            <label for="is_primary_source" class="text-sm text-gray-700">Primary source</label>
          </div>

          <div>
            <button
              type="submit"
              class="px-3 py-1.5 text-xs font-medium bg-gray-700 text-white rounded-md hover:bg-gray-800"
            >
              Add Source
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>
