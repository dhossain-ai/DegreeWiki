---
import AdminLayout from '../../layouts/AdminLayout.astro'
import { forbiddenAdminResponse, requireAdminPermission } from '../../lib/admin/guard'
import {
  AI_KNOWLEDGE_AUDIENCES,
  AI_KNOWLEDGE_MATCH_TYPES,
  AI_KNOWLEDGE_STATUSES,
  listKnowledgeAnswers,
  loadKnowledgeCategories,
} from '../../lib/ai/admin/knowledge-base'

const guard = await requireAdminPermission(
  Astro.cookies,
  Astro.request,
  Astro.url.pathname,
  'manage_ai_settings',
)
if (guard.type === 'redirect') return Astro.redirect(guard.to)
if (guard.type === 'forbidden') return forbiddenAdminResponse()

const { user, supabase } = guard

const selectedStatus = Astro.url.searchParams.get('status')?.trim() ?? ''
const selectedCategory = Astro.url.searchParams.get('category')?.trim() ?? ''
const selectedLocale = Astro.url.searchParams.get('locale')?.trim() ?? ''
const selectedAudience = Astro.url.searchParams.get('audience')?.trim() ?? ''
const selectedSearch = Astro.url.searchParams.get('search')?.trim() ?? ''

const [answers, categories] = await Promise.all([
  listKnowledgeAnswers(supabase, {
    status: selectedStatus,
    category: selectedCategory,
    locale: selectedLocale,
    audience: selectedAudience,
    search: selectedSearch,
  }),
  loadKnowledgeCategories(supabase),
])

const locales = [...new Set(answers.map((row) => row.locale).filter(Boolean))].sort((left, right) => left.localeCompare(right))

function lines(values: string[]): string {
  return values.join('\n')
}

function formatDate(value: string | null): string {
  if (!value) return '—'
  return new Date(value).toLocaleString('en-GB', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  })
}
---
<AdminLayout title="AI Knowledge Base — DegreeWiki Admin" activePath="/admin/ai-knowledge" userEmail={user.email ?? ''}>
  <div class="mb-6 flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-blue-600">AI Knowledge Base</p>
      <h1 class="mt-1 text-2xl font-bold text-gray-900">Preset Q&A Admin</h1>
      <p class="mt-2 max-w-4xl text-sm text-gray-600">
        Reviewed plain-text answers are checked after hardcoded safety routes and before anonymous fallback or logged-in AI.
        This keeps common questions deterministic and avoids unnecessary AI calls.
      </p>
    </div>
    <div class="rounded-xl border border-blue-200 bg-blue-50 px-4 py-3 text-sm text-blue-900">
      <div class="font-medium">Plain text only</div>
      <div class="mt-1">No Markdown rendering</div>
      <div>No HTML rendering</div>
      <div>No live AI generation here</div>
    </div>
  </div>

  <div id="ai-knowledge-banner" class="mb-6 hidden rounded-md border px-4 py-3 text-sm"></div>

  <div class="mb-8 grid gap-4 xl:grid-cols-[1.15fr_1fr]">
    <section class="rounded-xl border border-blue-200 bg-blue-50 p-5">
      <h2 class="text-base font-semibold text-blue-950">Site Chat Order</h2>
      <ol class="mt-4 space-y-3 text-sm text-blue-950">
        <li class="rounded-lg bg-white/70 px-4 py-3">1. Hardcoded safety and refusal routes</li>
        <li class="rounded-lg bg-white/70 px-4 py-3">2. Published preset answers from this knowledge base</li>
        <li class="rounded-lg bg-white/70 px-4 py-3">3. Anonymous sign-in / Fit Finder prompt</li>
        <li class="rounded-lg bg-white/70 px-4 py-3">4. Logged-in AI via the existing gateway</li>
      </ol>
    </section>

    <section class="rounded-xl border border-gray-200 bg-white p-5">
      <h2 class="text-base font-semibold text-gray-900">Current Library</h2>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
          <div class="text-xs uppercase tracking-wide text-gray-500">Rows</div>
          <div class="mt-2 text-2xl font-semibold text-gray-900">{answers.length}</div>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
          <div class="text-xs uppercase tracking-wide text-gray-500">Categories</div>
          <div class="mt-2 text-2xl font-semibold text-gray-900">{categories.length}</div>
        </div>
      </div>
      <p class="mt-4 text-sm text-gray-600">
        Imported JSON always lands as <code>draft</code>. Publishing remains a separate reviewed action.
      </p>
    </section>
  </div>

  <div class="mb-8 grid gap-6 xl:grid-cols-[1.1fr_1fr]">
    <section class="rounded-xl border border-gray-200 bg-white p-5">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h2 class="text-lg font-semibold text-gray-900">Create Answer</h2>
          <p class="mt-1 text-sm text-gray-500">
            Create a reviewed preset answer. Answers must stay plain text and safe for public study-planning guidance.
          </p>
        </div>
      </div>

      <form class="js-api-form mt-4 grid gap-4 md:grid-cols-2" data-endpoint="/api/admin/ai-knowledge/answers" data-success="Knowledge answer saved." data-reload="true">
        <input type="hidden" name="action" value="create" />
        <div class="md:col-span-2">
          <label class="mb-1 block text-sm font-medium text-gray-700">Question</label>
          <input name="question" required maxlength="300" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
        </div>
        <div class="md:col-span-2">
          <label class="mb-1 block text-sm font-medium text-gray-700">Answer</label>
          <textarea name="answer" required rows="6" maxlength="3000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm"></textarea>
          <p class="mt-1 text-xs text-gray-500">Plain text only. No Markdown rendering. No HTML.</p>
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Category</label>
          <input name="category" required maxlength="80" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Locale</label>
          <input name="locale" value="en" required maxlength="20" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Audience</label>
          <select name="audience" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm">
            {AI_KNOWLEDGE_AUDIENCES.map((value) => <option value={value}>{value}</option>)}
          </select>
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Status</label>
          <select name="status" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm">
            {AI_KNOWLEDGE_STATUSES.map((value) => <option value={value} selected={value === 'draft'}>{value}</option>)}
          </select>
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Priority</label>
          <input name="priority" type="number" min="1" value="100" required class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Match Type</label>
          <select name="match_type" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm">
            {AI_KNOWLEDGE_MATCH_TYPES.map((value) => <option value={value} selected={value === 'hybrid'}>{value}</option>)}
          </select>
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Intent Code</label>
          <input name="intent_code" data-nullable="true" maxlength="80" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Source Note</label>
          <input name="source_note" data-nullable="true" maxlength="500" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Keywords</label>
          <textarea name="keywords" data-array-field="true" rows="5" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm"></textarea>
          <p class="mt-1 text-xs text-gray-500">One per line. Up to 30.</p>
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Aliases</label>
          <textarea name="aliases" data-array-field="true" rows="5" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm"></textarea>
          <p class="mt-1 text-xs text-gray-500">One per line. Up to 30.</p>
        </div>
        <div class="md:col-span-2 flex flex-wrap gap-3">
          <button type="submit" class="rounded-md bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-black">
            Save Answer
          </button>
        </div>
      </form>
    </section>

    <section class="rounded-xl border border-gray-200 bg-white p-5">
      <h2 class="text-lg font-semibold text-gray-900">Bulk JSON Import</h2>
      <p class="mt-1 text-sm text-gray-500">
        Import up to 100 rows at once. Validation runs before insert. Imported rows always default to <code>draft</code>.
      </p>

      <form id="ai-knowledge-import-form" class="mt-4">
        <label class="mb-1 block text-sm font-medium text-gray-700">Import JSON</label>
        <textarea
          name="json_input"
          rows="18"
          class="w-full rounded-md border border-gray-300 px-3 py-2 font-mono text-xs"
          placeholder={`[\n  {\n    "question": "What is IELTS?",\n    "answer": "IELTS is an English-language proficiency test commonly used by universities.",\n    "category": "english_tests",\n    "keywords": ["ielts", "english test"],\n    "aliases": ["what is ielts"]\n  }\n]`}
        ></textarea>
        <div class="mt-4 flex flex-wrap gap-3">
          <button type="submit" id="ai-knowledge-import-submit" class="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
            Import Draft Answers
          </button>
        </div>
      </form>

      <div id="ai-knowledge-import-result" class="mt-4 hidden rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-700"></div>
    </section>
  </div>

  <section class="mb-6 rounded-xl border border-gray-200 bg-white px-5 py-5">
    <div class="flex flex-col gap-4 xl:flex-row xl:items-end xl:justify-between">
      <div>
        <h2 class="text-lg font-semibold text-gray-900">Answer Library</h2>
        <p class="mt-1 text-sm text-gray-500">
          Filter, search, edit, publish, or archive reviewed Q&A rows. Preview is plain text only.
        </p>
      </div>
      <span class="text-sm text-gray-400">{answers.length} shown</span>
    </div>

    <form method="get" class="mt-4 flex flex-wrap items-end gap-3 rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
      <div>
        <label class="mb-1 block text-xs font-medium text-gray-600">Status</label>
        <select name="status" class="rounded-md border border-gray-300 bg-white px-3 py-2 text-sm">
          <option value="">All statuses</option>
          {AI_KNOWLEDGE_STATUSES.map((value) => <option value={value} selected={selectedStatus === value}>{value}</option>)}
        </select>
      </div>
      <div>
        <label class="mb-1 block text-xs font-medium text-gray-600">Category</label>
        <select name="category" class="rounded-md border border-gray-300 bg-white px-3 py-2 text-sm">
          <option value="">All categories</option>
          {categories.map((value) => <option value={value} selected={selectedCategory === value}>{value}</option>)}
        </select>
      </div>
      <div>
        <label class="mb-1 block text-xs font-medium text-gray-600">Locale</label>
        <select name="locale" class="rounded-md border border-gray-300 bg-white px-3 py-2 text-sm">
          <option value="">All locales</option>
          {locales.map((value) => <option value={value} selected={selectedLocale === value}>{value}</option>)}
        </select>
      </div>
      <div>
        <label class="mb-1 block text-xs font-medium text-gray-600">Audience</label>
        <select name="audience" class="rounded-md border border-gray-300 bg-white px-3 py-2 text-sm">
          <option value="">All audiences</option>
          {AI_KNOWLEDGE_AUDIENCES.map((value) => <option value={value} selected={selectedAudience === value}>{value}</option>)}
        </select>
      </div>
      <div class="min-w-[16rem] flex-1">
        <label class="mb-1 block text-xs font-medium text-gray-600">Search</label>
        <input name="search" value={selectedSearch} class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" placeholder="Question, keyword, alias, answer..." />
      </div>
      <button type="submit" class="rounded bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">Apply</button>
      <a href="/admin/ai-knowledge" class="rounded border border-gray-300 px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50">Clear</a>
    </form>

    {answers.length === 0 ? (
      <div class="mt-6 rounded-lg border border-dashed border-gray-200 py-10 text-center text-sm text-gray-500">
        No knowledge-base answers match these filters yet.
      </div>
    ) : (
      <div class="mt-6 space-y-4">
        {answers.map((row) => (
          <details class="rounded-xl border border-gray-200">
            <summary class="cursor-pointer list-none px-4 py-4">
              <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                <div class="min-w-0">
                  <div class="flex flex-wrap gap-2">
                    <span class="inline-flex rounded-full bg-gray-100 px-2.5 py-1 text-xs font-medium text-gray-700">{row.status}</span>
                    <span class="inline-flex rounded-full bg-blue-100 px-2.5 py-1 text-xs font-medium text-blue-700">{row.category}</span>
                    <span class="inline-flex rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-medium text-emerald-700">{row.audience}</span>
                    <span class="inline-flex rounded-full bg-amber-100 px-2.5 py-1 text-xs font-medium text-amber-700">{row.matchType}</span>
                    <span class="inline-flex rounded-full bg-violet-100 px-2.5 py-1 text-xs font-medium text-violet-700">{row.locale}</span>
                  </div>
                  <h3 class="mt-3 text-base font-semibold text-gray-900">{row.question}</h3>
                  <p class="mt-2 whitespace-pre-wrap text-sm text-gray-600">{row.answer}</p>
                </div>
                <div class="shrink-0 text-xs text-gray-500">
                  <div>Priority {row.priority}</div>
                  <div class="mt-1">Updated {formatDate(row.updatedAt)}</div>
                  <div class="mt-1">Reviewed {formatDate(row.reviewedAt)}</div>
                </div>
              </div>
            </summary>

            <div class="border-t border-gray-200 p-4">
              <div class="mb-4 grid gap-3 md:grid-cols-2">
                <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
                  <div class="text-xs uppercase tracking-wide text-gray-500">Keywords</div>
                  <p class="mt-2 whitespace-pre-wrap text-sm text-gray-700">{row.keywords.length > 0 ? row.keywords.join('\n') : '—'}</p>
                </div>
                <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
                  <div class="text-xs uppercase tracking-wide text-gray-500">Aliases</div>
                  <p class="mt-2 whitespace-pre-wrap text-sm text-gray-700">{row.aliases.length > 0 ? row.aliases.join('\n') : '—'}</p>
                </div>
              </div>

              <form class="js-api-form grid gap-4 md:grid-cols-2" data-endpoint="/api/admin/ai-knowledge/answers" data-success="Knowledge answer updated." data-reload="true">
                <input type="hidden" name="action" value="update" />
                <input type="hidden" name="id" value={row.id} />
                <div class="md:col-span-2">
                  <label class="mb-1 block text-sm font-medium text-gray-700">Question</label>
                  <input name="question" value={row.question} required maxlength="300" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
                </div>
                <div class="md:col-span-2">
                  <label class="mb-1 block text-sm font-medium text-gray-700">Answer</label>
                  <textarea name="answer" rows="6" required maxlength="3000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm">{row.answer}</textarea>
                </div>
                <div>
                  <label class="mb-1 block text-sm font-medium text-gray-700">Category</label>
                  <input name="category" value={row.category} required maxlength="80" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
                </div>
                <div>
                  <label class="mb-1 block text-sm font-medium text-gray-700">Locale</label>
                  <input name="locale" value={row.locale} required maxlength="20" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
                </div>
                <div>
                  <label class="mb-1 block text-sm font-medium text-gray-700">Audience</label>
                  <select name="audience" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm">
                    {AI_KNOWLEDGE_AUDIENCES.map((value) => <option value={value} selected={row.audience === value}>{value}</option>)}
                  </select>
                </div>
                <div>
                  <label class="mb-1 block text-sm font-medium text-gray-700">Status</label>
                  <select name="status" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm">
                    {AI_KNOWLEDGE_STATUSES.map((value) => <option value={value} selected={row.status === value}>{value}</option>)}
                  </select>
                </div>
                <div>
                  <label class="mb-1 block text-sm font-medium text-gray-700">Priority</label>
                  <input name="priority" type="number" min="1" value={row.priority} required class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
                </div>
                <div>
                  <label class="mb-1 block text-sm font-medium text-gray-700">Match Type</label>
                  <select name="match_type" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm">
                    {AI_KNOWLEDGE_MATCH_TYPES.map((value) => <option value={value} selected={row.matchType === value}>{value}</option>)}
                  </select>
                </div>
                <div>
                  <label class="mb-1 block text-sm font-medium text-gray-700">Intent Code</label>
                  <input name="intent_code" value={row.intentCode ?? ''} data-nullable="true" maxlength="80" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
                </div>
                <div>
                  <label class="mb-1 block text-sm font-medium text-gray-700">Source Note</label>
                  <input name="source_note" value={row.sourceNote ?? ''} data-nullable="true" maxlength="500" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
                </div>
                <div>
                  <label class="mb-1 block text-sm font-medium text-gray-700">Keywords</label>
                  <textarea name="keywords" data-array-field="true" rows="5" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm">{lines(row.keywords)}</textarea>
                </div>
                <div>
                  <label class="mb-1 block text-sm font-medium text-gray-700">Aliases</label>
                  <textarea name="aliases" data-array-field="true" rows="5" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm">{lines(row.aliases)}</textarea>
                </div>
                <div class="md:col-span-2 flex flex-wrap gap-3">
                  <button type="submit" class="rounded-md bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-black">
                    Save Changes
                  </button>
                </div>
              </form>

              <div class="mt-4 flex flex-wrap gap-3">
                <form class="js-api-form" data-endpoint="/api/admin/ai-knowledge/answers" data-success="Knowledge answer published." data-reload="true">
                  <input type="hidden" name="action" value="publish" />
                  <input type="hidden" name="id" value={row.id} />
                  <button type="submit" class="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
                    Publish
                  </button>
                </form>

                <form class="js-api-form" data-endpoint="/api/admin/ai-knowledge/answers" data-success="Knowledge answer archived." data-reload="true">
                  <input type="hidden" name="action" value="archive" />
                  <input type="hidden" name="id" value={row.id} />
                  <button type="submit" class="rounded-md border border-amber-300 bg-amber-50 px-4 py-2 text-sm font-medium text-amber-800 hover:bg-amber-100">
                    Archive
                  </button>
                </form>

                <form class="js-api-form" data-endpoint="/api/admin/ai-knowledge/answers" data-success="Draft answer deleted." data-reload="true">
                  <input type="hidden" name="action" value="delete" />
                  <input type="hidden" name="id" value={row.id} />
                  <button type="submit" class="rounded-md border border-red-200 bg-red-50 px-4 py-2 text-sm font-medium text-red-700 hover:bg-red-100">
                    Delete Draft
                  </button>
                </form>
              </div>
            </div>
          </details>
        ))}
      </div>
    )}
  </section>
</AdminLayout>

<script>
  const banner = document.getElementById('ai-knowledge-banner')
  const importForm = document.getElementById('ai-knowledge-import-form')
  const importSubmit = document.getElementById('ai-knowledge-import-submit')
  const importResult = document.getElementById('ai-knowledge-import-result')

  function showBanner(kind, message) {
    if (!banner) return
    banner.textContent = message
    banner.classList.remove('hidden', 'border-red-200', 'bg-red-50', 'text-red-700', 'border-green-200', 'bg-green-50', 'text-green-700')

    if (kind === 'error') {
      banner.classList.add('border-red-200', 'bg-red-50', 'text-red-700')
      return
    }

    banner.classList.add('border-green-200', 'bg-green-50', 'text-green-700')
  }

  function parseArrayField(raw) {
    const items = []
    const seen = new Set()
    for (const part of raw.split(/\r?\n/)) {
      const trimmed = part.trim()
      if (!trimmed || seen.has(trimmed)) continue
      seen.add(trimmed)
      items.push(trimmed)
    }
    return items
  }

  function formToJson(form) {
    const data = {}
    const elements = Array.from(form.elements)

    for (const element of elements) {
      if (!(element instanceof HTMLInputElement || element instanceof HTMLSelectElement || element instanceof HTMLTextAreaElement)) {
        continue
      }
      if (!element.name || element.disabled) continue

      const raw = element.value.trim()

      if (element.dataset.arrayField === 'true') {
        data[element.name] = parseArrayField(raw)
        continue
      }

      if (element.dataset.nullable === 'true' && raw === '') {
        data[element.name] = null
        continue
      }

      if (element instanceof HTMLInputElement && element.type === 'number') {
        data[element.name] = raw === '' ? null : Number(raw)
        continue
      }

      data[element.name] = raw
    }

    return data
  }

  async function handleApiFormSubmit(event) {
    event.preventDefault()
    const form = event.currentTarget
    const endpoint = form.dataset.endpoint
    const successMessage = form.dataset.success || 'Saved.'
    const shouldReload = form.dataset.reload === 'true'
    const submitButton = form.querySelector('button[type="submit"]')

    if (!endpoint) return
    if (submitButton instanceof HTMLButtonElement) submitButton.disabled = true

    try {
      const response = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formToJson(form)),
      })
      const data = await response.json()
      if (!response.ok || !data.ok) {
        showBanner('error', data.message || 'Request failed. Please review the values and try again.')
        return
      }

      showBanner('success', successMessage)
      if (shouldReload) {
        window.setTimeout(() => window.location.reload(), 500)
      }
    } catch {
      showBanner('error', 'Request failed. Please try again.')
    } finally {
      if (submitButton instanceof HTMLButtonElement) submitButton.disabled = false
    }
  }

  document.querySelectorAll('.js-api-form').forEach((form) => {
    form.addEventListener('submit', handleApiFormSubmit)
  })

  importForm?.addEventListener('submit', async (event) => {
    event.preventDefault()
    if (!(importForm instanceof HTMLFormElement)) return
    if (importSubmit instanceof HTMLButtonElement) importSubmit.disabled = true

    try {
      const response = await fetch('/api/admin/ai-knowledge/import', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formToJson(importForm)),
      })
      const data = await response.json()
      if (!response.ok || !data.ok) {
        if (importResult) {
          const details = Array.isArray(data.details) && data.details.length > 0
            ? '\n' + data.details.slice(0, 10).map((item) => `Row ${Number(item.index) + 1} (${item.field}): ${item.message}`).join('\n')
            : ''
          importResult.textContent = (data.message || 'Import failed.') + details
          importResult.classList.remove('hidden')
        }
        showBanner('error', data.message || 'Import failed.')
        return
      }

      if (importResult) {
        importResult.textContent = `Imported ${data.inserted_count} draft answers.`
        importResult.classList.remove('hidden')
      }
      showBanner('success', `Imported ${data.inserted_count} draft answers.`)
      window.setTimeout(() => window.location.reload(), 600)
    } catch {
      if (importResult) {
        importResult.textContent = 'Import failed. Please try again.'
        importResult.classList.remove('hidden')
      }
      showBanner('error', 'Import failed. Please try again.')
    } finally {
      if (importSubmit instanceof HTMLButtonElement) importSubmit.disabled = false
    }
  })
</script>
