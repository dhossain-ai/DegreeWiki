---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import { requireSuperAdmin } from '../../../lib/admin/guard'
import { CONTENT_STATUS_BADGE, FALLBACK_BADGE } from '../../../lib/admin/badges'

const guard = await requireSuperAdmin(Astro.cookies, Astro.request, Astro.url.pathname)
if (guard.type === 'redirect') return Astro.redirect(guard.to)
if (guard.type === 'forbidden') return new Response('403 Forbidden: admin role required.', { status: 403 })

const { user, supabase } = guard

const { data, error } = await supabase
  .from('countries')
  .select('id, name, slug, iso2, iso3, content_status, is_origin_enabled, is_destination_enabled, created_at')
  .order('created_at', { ascending: false })
  .limit(100)

type CountryRow = {
  id: string
  name: string
  slug: string
  iso2: string
  iso3: string
  content_status: string
  is_origin_enabled: boolean
  is_destination_enabled: boolean
  created_at: string
}

function roleBadge(row: CountryRow): string {
  if (row.is_origin_enabled && row.is_destination_enabled) return 'Both'
  if (row.is_origin_enabled) return 'Origin'
  if (row.is_destination_enabled) return 'Destination'
  return 'None'
}

function roleBadgeClass(row: CountryRow): string {
  if (row.is_origin_enabled && row.is_destination_enabled) return 'bg-purple-100 text-purple-700'
  if (row.is_origin_enabled) return 'bg-green-100 text-green-700'
  if (row.is_destination_enabled) return 'bg-blue-100 text-blue-700'
  return 'bg-gray-100 text-gray-500'
}
const rows = (data ?? []) as CountryRow[]
---
<AdminLayout title="Countries — DegreeWiki Admin" activePath="/admin/countries" userEmail={user.email ?? ''}>
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-bold text-gray-900">Countries</h1>
    <a href="/admin/countries/new" class="inline-flex items-center px-3 py-1.5 text-sm font-medium bg-blue-600 text-white rounded-md hover:bg-blue-700">
      + New Country
    </a>
  </div>

  {error ? (
    <p class="text-sm text-red-600 py-4">Could not load data.</p>
  ) : rows.length === 0 ? (
    <p class="text-sm text-gray-500 py-4">No countries found. <a href="/admin/countries/new" class="text-blue-600 hover:underline">Add the first one.</a></p>
  ) : (
    <div class="overflow-x-auto rounded-lg border border-gray-200">
      <table class="w-full text-sm text-left">
        <thead class="bg-gray-50 border-b border-gray-200 text-xs text-gray-500 uppercase tracking-wide">
          <tr>
            <th class="px-4 py-3">Name</th>
            <th class="px-4 py-3">Slug</th>
            <th class="px-4 py-3">ISO2</th>
            <th class="px-4 py-3">ISO3</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Role</th>
            <th class="px-4 py-3">Created</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody>
          {rows.map(row => (
            <tr class="border-b border-gray-100 hover:bg-gray-50">
              <td class="px-4 py-3 font-medium text-gray-900">{row.name}</td>
              <td class="px-4 py-3 text-gray-500 font-mono text-xs">{row.slug}</td>
              <td class="px-4 py-3 text-gray-600 font-mono text-xs uppercase">{row.iso2}</td>
              <td class="px-4 py-3 text-gray-600 font-mono text-xs uppercase">{row.iso3}</td>
              <td class="px-4 py-3">
                <span class={`inline-flex items-center rounded px-2 py-0.5 text-xs font-medium ${CONTENT_STATUS_BADGE[row.content_status] ?? FALLBACK_BADGE}`}>
                  {row.content_status}
                </span>
              </td>
              <td class="px-4 py-3">
                <span class={`inline-flex items-center rounded px-2 py-0.5 text-xs font-medium ${roleBadgeClass(row)}`}>
                  {roleBadge(row)}
                </span>
              </td>
              <td class="px-4 py-3 text-gray-400 text-xs">{new Date(row.created_at).toLocaleDateString()}</td>
              <td class="px-4 py-3">
                <a href={`/admin/countries/${row.id}`} class="text-xs text-blue-600 hover:underline">Edit</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</AdminLayout>
