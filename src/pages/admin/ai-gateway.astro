                        <div>
                          <label class="mb-1 block text-sm font-medium text-gray-700">Model</label>
                          <select name="model_id" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm">
                            {models.map((model) => (
                              <option value={model.id} selected={policy.model_id === model.id}>
                                {model.display_name} ({model.model_name})
                              </option>
                            ))}
                          </select>
                        </div>
                        <div>
                          <label class="mb-1 block text-sm font-medium text-gray-700">Priority</label>
                          <input name="priority" type="number" min="1" value={policy.priority} required class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
                        </div>
                        <div>
                          <label class="mb-1 block text-sm font-medium text-gray-700">Max Attempts</label>
                          <input name="max_attempts" type="number" min="1" value={policy.max_attempts} required class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
                        </div>
                        <div>
                          <label class="mb-1 block text-sm font-medium text-gray-700">Timeout (ms)</label>
                          <input name="timeout_ms" type="number" min="1000" max="120000" value={policy.timeout_ms ?? ''} data-nullable="true" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
                        </div>
                        <div>
                          <label class="mb-1 block text-sm font-medium text-gray-700">Notes</label>
                          <input name="notes" value={policy.notes ?? ''} data-nullable="true" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
                        </div>
                        <div class="md:col-span-2 flex flex-wrap gap-4 text-sm text-gray-700">
                          <label class="flex items-center gap-2"><input name="is_active" type="checkbox" checked={policy.is_active === true} /><span>Active</span></label>
                          <label class="flex items-center gap-2"><input name="fallback_enabled" type="checkbox" checked={policy.fallback_enabled === true} /><span>Fallback enabled</span></label>
                          <label class="flex items-center gap-2"><input name="allow_env_fallback" type="checkbox" checked={policy.allow_env_fallback === true} /><span>Allow env fallback</span></label>
                        </div>
                        <div class="md:col-span-2 flex flex-wrap gap-3">
                          <button type="submit" class="rounded-md bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-black">
                            Save Routing Policy
                          </button>
                        </div>
                      </form>
                      <form class="js-api-form mt-3" data-endpoint="/api/admin/ai-gateway/policies" data-success="Routing policy deleted." data-reload="true">
                        <input type="hidden" name="action" value="delete" />
                        <input type="hidden" name="id" value={policy.id} />
                        <button type="submit" class="rounded-md border border-red-200 bg-red-50 px-4 py-2 text-sm font-medium text-red-700 hover:bg-red-100">
                          Delete Policy Row
                        </button>
                      </form>
                    </div>
                  </details>
                ))}
              </div>
            </div>
          )}
        </section>
      ))}
    </div>
  </section>
  )}

  {activeTab === 'health' && (
  <section class="mb-10">
    <div class="mb-4 flex items-center justify-between">
      <div>
        <h2 class="text-lg font-semibold text-gray-900">Health and Cooldowns</h2>
        <p class="mt-1 text-sm text-gray-500">Reset clears failures, last error, and cooldown only.</p>
      </div>
    </div>

    <div class="overflow-x-auto rounded-xl border border-gray-200 bg-white">
      <table class="w-full text-left text-sm">
        <thead class="border-b border-gray-200 bg-gray-50 text-xs uppercase tracking-wide text-gray-500">
          <tr>
            <th class="px-4 py-3">Provider / Model</th>
            <th class="px-4 py-3">Failures</th>
            <th class="px-4 py-3">Last Success</th>
            <th class="px-4 py-3">Last Failure</th>
            <th class="px-4 py-3">Last Error</th>
            <th class="px-4 py-3">Cooldown</th>
            <th class="px-4 py-3">Action</th>
          </tr>
        </thead>
        <tbody>
          {healthRows.length === 0 ? (
            <tr>
              <td colspan="7" class="px-4 py-6 text-sm text-gray-500">No provider health issues yet. Health rows appear after production gateway attempts.</td>
            </tr>
          ) : healthRows.map((row) => (
            <tr class="border-b border-gray-100 align-top">
              <td class="px-4 py-3">
                <div class="font-medium text-gray-900">{row.ai_provider_accounts?.display_name ?? 'Unknown provider'}</div>
                <div class="text-xs text-gray-500">
                  {row.ai_provider_accounts?.provider_code ?? '—'} · {row.ai_models?.display_name ?? row.ai_models?.model_name ?? 'Unknown model'}
                </div>
              </td>
              <td class="px-4 py-3 text-gray-700">{row.consecutive_failures ?? 0}</td>
              <td class="px-4 py-3 text-xs text-gray-600">{formatDate(row.last_success_at)}</td>
              <td class="px-4 py-3 text-xs text-gray-600">{formatDate(row.last_failure_at)}</td>
              <td class="px-4 py-3 text-xs text-gray-600">{row.last_error_type ?? '—'}</td>
              <td class="px-4 py-3">
                <div class="text-xs text-gray-600">{formatDate(row.cooldown_until)}</div>
                <div class={cooldownActive(row.cooldown_until) ? badgeClass(true) : badgeClass(false)}>
                  {cooldownActive(row.cooldown_until) ? 'cooldown active' : 'no active cooldown'}
                </div>
              </td>
              <td class="px-4 py-3">
                <form class="js-api-form" data-endpoint="/api/admin/ai-gateway/health" data-success="Provider health reset." data-reload="true">
                  <input type="hidden" name="action" value="reset" />
                  <input type="hidden" name="id" value={row.id} />
                  <button type="submit" class="rounded-md border border-gray-300 px-3 py-2 text-xs font-medium text-gray-700 hover:bg-gray-50">
                    Reset Health
                  </button>
                </form>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
  )}

  {activeTab === 'testing' && (
  <section>
    <div class="mb-4 flex items-center justify-between">
      <div>
        <h2 class="text-lg font-semibold text-gray-900">Provider and Model Testing</h2>
        <p class="mt-1 text-sm text-gray-500">Preset-only safe tests. No real student data and no health mutation.</p>
      </div>
    </div>

    <div class="rounded-xl border border-gray-200 bg-white p-4">
      <form id="ai-gateway-test-form" class="grid gap-4 md:grid-cols-2">
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Preset Test</label>
          <select name="preset_id" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm">
            {AI_GATEWAY_TEST_PRESETS.map((preset) => (
              <option value={preset.id}>{preset.label}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Target Mode</label>
          <select name="target_mode" id="test-target-mode" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm">
            <option value="use_case">Route by use case</option>
            <option value="model">Direct model</option>
          </select>
        </div>
        <div id="test-use-case-wrap">
          <label class="mb-1 block text-sm font-medium text-gray-700">Use Case</label>
          <select name="use_case" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm">
            {AI_GATEWAY_USE_CASES.map((useCase) => (
              <option value={useCase}>{useCase}</option>
            ))}
          </select>
        </div>
        <div id="test-model-wrap" class="hidden">
          <label class="mb-1 block text-sm font-medium text-gray-700">Model</label>
          <select name="model_id" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm">
            {models.map((model) => (
              <option value={model.id}>{model.display_name} ({model.model_name})</option>
            ))}
          </select>
        </div>
        <div class="md:col-span-2">
          <button type="submit" id="ai-gateway-test-submit" class="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
            Run Admin Test
          </button>
        </div>
      </form>

      <div id="ai-gateway-test-result" class="mt-6 hidden rounded-xl border border-gray-200 bg-gray-50 p-4">
        <div class="mb-3 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
          <div class="text-sm font-semibold text-gray-900">Latest Test Result</div>
          <div id="test-result-recommendation" class="rounded-full bg-white px-3 py-1 text-xs font-medium text-gray-700">—</div>
        </div>
        <dl class="grid gap-3 text-sm text-gray-700 md:grid-cols-2">
          <div><dt class="text-xs uppercase tracking-wide text-gray-500">Status</dt><dd id="test-result-status">—</dd></div>
          <div><dt class="text-xs uppercase tracking-wide text-gray-500">Preset</dt><dd id="test-result-preset">—</dd></div>
          <div><dt class="text-xs uppercase tracking-wide text-gray-500">Provider</dt><dd id="test-result-provider">—</dd></div>
          <div><dt class="text-xs uppercase tracking-wide text-gray-500">Model</dt><dd id="test-result-model">—</dd></div>
          <div><dt class="text-xs uppercase tracking-wide text-gray-500">Latency</dt><dd id="test-result-latency">—</dd></div>
          <div><dt class="text-xs uppercase tracking-wide text-gray-500">Tokens</dt><dd id="test-result-tokens">—</dd></div>
          <div><dt class="text-xs uppercase tracking-wide text-gray-500">Normalized Error</dt><dd id="test-result-error">—</dd></div>
          <div><dt class="text-xs uppercase tracking-wide text-gray-500">Env Fallback</dt><dd id="test-result-fallback">—</dd></div>
        </dl>
        <div class="mt-4">
          <div class="text-xs uppercase tracking-wide text-gray-500">Safe Response Preview</div>
          <p id="test-result-preview" class="mt-1 whitespace-pre-wrap text-sm text-gray-700">—</p>
        </div>
      </div>
    </div>
  </section>
  )}
</AdminLayout>

<script>
  const banner = document.getElementById('ai-gateway-banner')

  function showBanner(kind, message) {
    if (!banner) return
    banner.textContent = message
    banner.classList.remove('hidden', 'border-red-200', 'bg-red-50', 'text-red-700', 'border-green-200', 'bg-green-50', 'text-green-700')

    if (kind === 'error') {
      banner.classList.add('border-red-200', 'bg-red-50', 'text-red-700')
      return
    }

    banner.classList.add('border-green-200', 'bg-green-50', 'text-green-700')
  }

  function formToJson(form) {
    const data = {}
    const elements = Array.from(form.elements)

    for (const element of elements) {
      if (!(element instanceof HTMLInputElement || element instanceof HTMLSelectElement || element instanceof HTMLTextAreaElement)) {
        continue
      }
      if (!element.name || element.disabled) continue

      if (element instanceof HTMLInputElement && element.type === 'checkbox') {
        data[element.name] = element.checked
        continue
      }

      const raw = element.value.trim()
      if (element.dataset.nullable === 'true' && raw === '') {
        data[element.name] = null
        continue
      }

      if (element instanceof HTMLInputElement && element.type === 'number') {
        data[element.name] = raw === '' ? null : Number(raw)
        continue
      }

      data[element.name] = raw
    }

    return data
  }

  async function handleApiFormSubmit(event) {
    event.preventDefault()
    const form = event.currentTarget
    const endpoint = form.dataset.endpoint
    const successMessage = form.dataset.success || 'Saved.'
    const shouldReload = form.dataset.reload === 'true'
    const submitButton = form.querySelector('button[type="submit"]')

    if (!endpoint) return
    if (submitButton instanceof HTMLButtonElement) submitButton.disabled = true

    try {
      const response = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formToJson(form)),
      })
      const data = await response.json()
      if (!response.ok || !data.ok) {
        showBanner('error', 'Request failed. Please review the form values and try again.')
        return
      }

      showBanner('success', successMessage)
      if (shouldReload) {
        window.setTimeout(() => window.location.reload(), 500)
      }
    } catch {
      showBanner('error', 'Request failed. Please try again.')
    } finally {
      if (submitButton instanceof HTMLButtonElement) submitButton.disabled = false
    }
  }

  document.querySelectorAll('.js-api-form').forEach((form) => {
    form.addEventListener('submit', handleApiFormSubmit)
  })

  const targetMode = document.getElementById('test-target-mode')
  const testUseCaseWrap = document.getElementById('test-use-case-wrap')
  const testModelWrap = document.getElementById('test-model-wrap')
  const testForm = document.getElementById('ai-gateway-test-form')
  const testSubmit = document.getElementById('ai-gateway-test-submit')
  const testResult = document.getElementById('ai-gateway-test-result')

  function syncTestMode() {
    if (!(targetMode instanceof HTMLSelectElement)) return
    const useCaseMode = targetMode.value === 'use_case'
    testUseCaseWrap?.classList.toggle('hidden', !useCaseMode)
    testModelWrap?.classList.toggle('hidden', useCaseMode)
  }

  targetMode?.addEventListener('change', syncTestMode)
  syncTestMode()

  function setText(id, value) {
    const element = document.getElementById(id)
    if (element) element.textContent = value
  }

  function getTestRecommendation(result) {
    if (result.success) return 'Good candidate for routing.'

    const errorType = String(result.normalizedErrorType || '').toLowerCase()
    if (errorType === 'rate_limit') {
      return 'Keep inactive or lower priority until quota/rate limit is resolved.'
    }
    if (errorType === 'invalid_provider_response') {
      return 'Check model name, endpoint, or provider compatibility.'
    }
    if (errorType.includes('timeout') || errorType.includes('network')) {
      return 'Use as lower-priority fallback only after retest.'
    }

    return 'Retest before using this model in a live priority slot.'
  }

  testForm?.addEventListener('submit', async (event) => {
    event.preventDefault()
    if (!(testForm instanceof HTMLFormElement)) return
    if (testSubmit instanceof HTMLButtonElement) testSubmit.disabled = true

    try {
      const response = await fetch('/api/admin/ai-gateway/test', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formToJson(testForm)),
      })
      const data = await response.json()
      if (!response.ok || !data.ok || !data.result) {
        showBanner('error', 'Admin test failed to start. Please check the selected target and try again.')
        return
      }

      const result = data.result
      testResult?.classList.remove('hidden')
      setText('test-result-status', result.success ? 'success' : 'failure')
      setText('test-result-preset', result.presetId)
      setText('test-result-provider', result.providerDisplayName || result.providerCode || '—')
      setText('test-result-model', result.modelDisplayName || result.modelName || '—')
      setText('test-result-latency', result.latencyMs == null ? '—' : `${result.latencyMs} ms`)
      setText('test-result-tokens', `${result.promptTokens} prompt / ${result.completionTokens} completion / ${result.totalTokens} total`)
      setText('test-result-error', result.normalizedErrorType || '—')
      setText('test-result-fallback', result.usedEnvFallback ? 'yes' : 'no')
      setText('test-result-preview', result.responsePreview || 'No preview available for this failure.')
      setText('test-result-recommendation', getTestRecommendation(result))
      showBanner('success', 'Admin test completed without changing production health.')
    } catch {
      showBanner('error', 'Admin test request failed. Please try again.')
    } finally {
      if (testSubmit instanceof HTMLButtonElement) testSubmit.disabled = false
    }
  })
</script>
