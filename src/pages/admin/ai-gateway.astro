              </div>
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Max Output Tokens</label>
                <input name="max_output_tokens" type="number" min="1" value={model.max_output_tokens ?? ''} data-nullable="true" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
              </div>
              <div class="grid grid-cols-2 gap-4">
                <div>
