---
import AdminLayout from '../../layouts/AdminLayout.astro'
import { forbiddenAdminResponse, requireAdminPermission } from '../../lib/admin/guard'
import {
  AI_GATEWAY_DB_PROVIDER_PROTOCOLS,
  AI_GATEWAY_LIVE_USE_CASES,
  AI_GATEWAY_PLANNED_PROVIDER_PROTOCOLS,
  AI_GATEWAY_TEST_PRESETS,
  AI_GATEWAY_USE_CASES,
} from '../../lib/ai/admin/constants'
import { isAIGatewayEnvFallbackEnabled } from '../../lib/ai/admin/store'
import { getAIEnv } from '../../lib/ai/env'

const guard = await requireAdminPermission(
  Astro.cookies,
  Astro.request,
  Astro.url.pathname,
  'manage_ai_settings',
)
if (guard.type === 'redirect') return Astro.redirect(guard.to)
if (guard.type === 'forbidden') return forbiddenAdminResponse()

const { user, supabase } = guard
const aiEnv = getAIEnv(Astro.locals as Record<string, unknown>)
const envFallbackEnabled = isAIGatewayEnvFallbackEnabled(aiEnv)

const [providersRes, modelsRes, policiesRes, healthRes] = await Promise.all([
  supabase
    .from('ai_provider_accounts')
    .select(`
      id,
      provider_code,
      display_name,
      adapter_type,
      base_url,
      endpoint_path,
      auth_type,
      api_key_last4,
      api_key_fingerprint,
      api_key_key_version,
      timeout_ms,
      is_active,
      privacy_level,
      allows_student_data,
      allows_chat,
      allows_fit_finder,
      created_at,
      updated_at
    `)
    .order('provider_code', { ascending: true }),
  supabase
    .from('ai_models')
    .select(`
      id,
      provider_account_id,
      model_name,
      display_name,
      is_active,
      supports_text,
      supports_json_mode,
      supports_streaming,
      supports_tool_calling,
      max_output_tokens,
      input_cost_per_million,
      output_cost_per_million,
      cost_tier,
      created_at,
      updated_at,
      ai_provider_accounts (
        provider_code,
        display_name
      )
    `)
    .order('display_name', { ascending: true }),
  supabase
    .from('ai_routing_policies')
    .select(`
      id,
      use_case,
      model_id,
      priority,
      is_active,
      fallback_enabled,
      max_attempts,
      timeout_ms,
      allow_env_fallback,
      notes,
      created_at,
      updated_at,
      ai_models (
        model_name,
        display_name,
        ai_provider_accounts (
          provider_code,
          display_name
        )
      )
    `)
    .order('use_case', { ascending: true })
    .order('priority', { ascending: true }),
  supabase
    .from('ai_provider_health')
    .select(`
      id,
      provider_account_id,
      model_id,
      consecutive_failures,
      last_success_at,
      last_failure_at,
      last_error_type,
      cooldown_until,
      ai_provider_accounts (
        provider_code,
        display_name
      ),
      ai_models (
        model_name,
        display_name
      )
    `)
    .order('updated_at', { ascending: false }),
])

const providers = (providersRes.data ?? []) as any[]
const models = (modelsRes.data ?? []) as any[]
const policies = (policiesRes.data ?? []) as any[]
const healthRows = (healthRes.data ?? []) as any[]

const loadError = providersRes.error || modelsRes.error || policiesRes.error || healthRes.error

function formatDate(value: string | null | undefined): string {
  if (!value) return '—'
  return new Date(value).toLocaleString('en-GB', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  })
}

function shortFingerprint(value: string | null | undefined): string {
  if (!value) return '—'
  if (value.length <= 18) return value
  return `${value.slice(0, 10)}...${value.slice(-6)}`
}

function numberText(value: number | null | undefined): string {
  if (value == null) return '—'
  return String(value)
}

function badgeClass(active: boolean): string {
  return active
    ? 'inline-flex rounded bg-green-100 px-2 py-0.5 text-xs font-medium text-green-700'
    : 'inline-flex rounded bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-500'
}

function cooldownActive(cooldownUntil: string | null | undefined): boolean {
  if (!cooldownUntil) return false
  return new Date(cooldownUntil).getTime() > Date.now()
}
---
<AdminLayout title="AI Gateway — DegreeWiki Admin" activePath="/admin/ai-gateway" userEmail={user.email ?? ''}>
  <div class="flex items-start justify-between gap-4 mb-6">
    <div>
      <h1 class="text-xl font-bold text-gray-900">AI Gateway</h1>
      <p class="mt-2 max-w-3xl text-sm text-gray-600">
        Manage DB-backed provider accounts, models, routing policies, health state, and admin-only
        preset tests. Only <span class="font-medium text-gray-800">fit_finder_summary</span> and
        <span class="font-medium text-gray-800"> chat_answer</span> are actively wired in product
        behavior today.
      </p>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm text-gray-600">
      <div>Env fallback:</div>
      <div class={envFallbackEnabled ? badgeClass(true) : badgeClass(false)}>
        {envFallbackEnabled ? 'enabled' : 'disabled'}
      </div>
    </div>
  </div>

  <div id="ai-gateway-banner" class="hidden mb-6 rounded-md border px-4 py-3 text-sm"></div>

  {loadError && (
    <div class="mb-6 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
      Some AI Gateway data could not be loaded. The page may be incomplete until the next refresh.
    </div>
  )}

  <div class="mb-6 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <div class="rounded-lg border border-gray-200 bg-white p-4">
      <div class="text-xs uppercase tracking-wide text-gray-500">Provider Accounts</div>
      <div class="mt-2 text-2xl font-semibold text-gray-900">{providers.length}</div>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-4">
      <div class="text-xs uppercase tracking-wide text-gray-500">Models</div>
      <div class="mt-2 text-2xl font-semibold text-gray-900">{models.length}</div>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-4">
      <div class="text-xs uppercase tracking-wide text-gray-500">Routing Policies</div>
      <div class="mt-2 text-2xl font-semibold text-gray-900">{policies.length}</div>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-4">
      <div class="text-xs uppercase tracking-wide text-gray-500">Health Rows</div>
      <div class="mt-2 text-2xl font-semibold text-gray-900">{healthRows.length}</div>
    </div>
  </div>

  <div class="mb-8 rounded-lg border border-blue-200 bg-blue-50 p-4 text-sm text-blue-900">
    <p class="font-medium">DB-managed support in Phase 69C</p>
    <p class="mt-1">
      Provider accounts created here support <code>openai_compatible</code> only. Planned options
      <code> gemini</code>, <code>openrouter_legacy</code>, and <code>disabled</code> are shown as
      notes only. Gemini and OpenRouter still remain env-fallback only for now.
    </p>
    <p class="mt-2 text-blue-800">
      Live product use cases today: {AI_GATEWAY_LIVE_USE_CASES.join(', ')}.
    </p>
  </div>

  <section class="mb-10">
    <div class="mb-4 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-gray-900">Provider Accounts</h2>
      <span class="text-xs text-gray-500">Masked key metadata only. Decrypted keys are never shown.</span>
    </div>

    <div class="mb-6 rounded-lg border border-gray-200 bg-white p-4">
      <h3 class="mb-4 text-sm font-semibold text-gray-800">Create Provider Account</h3>
      <form class="js-api-form grid gap-4 md:grid-cols-2" data-endpoint="/api/admin/ai-gateway/providers" data-success="Provider account saved." data-reload="true">
        <input type="hidden" name="action" value="create" />
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Provider Code</label>
          <input name="provider_code" required class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Display Name</label>
          <input name="display_name" required class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Provider Protocol</label>
          <select name="adapter_type" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm bg-white">
            {AI_GATEWAY_DB_PROVIDER_PROTOCOLS.map((protocol) => (
              <option value={protocol}>{protocol}</option>
            ))}
          </select>
          <p class="mt-1 text-xs text-gray-500">
            Planned only: {AI_GATEWAY_PLANNED_PROVIDER_PROTOCOLS.join(', ')}
          </p>
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Auth Type</label>
          <select name="auth_type" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm bg-white">
            <option value="bearer">bearer</option>
          </select>
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Base URL</label>
          <input name="base_url" type="url" required placeholder="https://api.example.com/v1" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Endpoint Path</label>
          <input name="endpoint_path" placeholder="/chat/completions" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Timeout (ms)</label>
          <input name="timeout_ms" type="number" min="1000" max="120000" value="30000" required class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Privacy Level</label>
          <select name="privacy_level" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm bg-white">
            <option value="standard">standard</option>
            <option value="restricted">restricted</option>
          </select>
        </div>
        <div class="md:col-span-2">
          <label class="mb-1 block text-sm font-medium text-gray-700">API Key</label>
          <input name="api_key" type="password" required class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
        </div>
        <div class="md:col-span-2 flex flex-wrap gap-4 text-sm text-gray-700">
          <label class="flex items-center gap-2">
            <input name="is_active" type="checkbox" checked />
            <span>Active</span>
          </label>
          <label class="flex items-center gap-2">
            <input name="allows_student_data" type="checkbox" />
            <span>Allows student data</span>
          </label>
          <label class="flex items-center gap-2">
            <input name="allows_chat" type="checkbox" />
            <span>Allows chat</span>
          </label>
          <label class="flex items-center gap-2">
            <input name="allows_fit_finder" type="checkbox" />
            <span>Allows Fit Finder</span>
          </label>
        </div>
        <div class="md:col-span-2">
          <button type="submit" class="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
            Create Provider Account
          </button>
        </div>
      </form>
    </div>

    <div class="space-y-4">
      {providers.length === 0 ? (
        <div class="rounded-lg border border-gray-200 bg-white p-6 text-sm text-gray-500">
          No provider accounts configured yet.
        </div>
      ) : providers.map((provider) => (
        <details class="rounded-lg border border-gray-200 bg-white" open>
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-4 py-3">
            <div>
              <div class="text-sm font-semibold text-gray-900">{provider.display_name}</div>
              <div class="text-xs text-gray-500">
                {provider.provider_code} · {provider.adapter_type} · {provider.base_url ?? 'no base URL'}
              </div>
            </div>
            <div class="flex items-center gap-2">
              <span class={badgeClass(provider.is_active === true)}>
                {provider.is_active ? 'active' : 'inactive'}
              </span>
              <span class="text-xs text-gray-400">Updated {formatDate(provider.updated_at)}</span>
            </div>
          </summary>
          <div class="border-t border-gray-200 p-4">
            <div class="mb-4 grid gap-3 rounded-md bg-gray-50 p-3 text-xs text-gray-600 md:grid-cols-4">
              <div>
                <div class="font-medium text-gray-700">Stored key</div>
                <div>{provider.api_key_last4 ? `••••${provider.api_key_last4}` : 'not set'}</div>
              </div>
              <div>
                <div class="font-medium text-gray-700">Fingerprint</div>
                <div>{shortFingerprint(provider.api_key_fingerprint)}</div>
              </div>
              <div>
                <div class="font-medium text-gray-700">Key version</div>
                <div>{provider.api_key_key_version ?? '—'}</div>
              </div>
              <div>
                <div class="font-medium text-gray-700">Privacy / access</div>
                <div>{provider.privacy_level} · student={provider.allows_student_data ? 'yes' : 'no'}</div>
              </div>
            </div>

            <form class="js-api-form grid gap-4 md:grid-cols-2" data-endpoint="/api/admin/ai-gateway/providers" data-success="Provider account updated." data-reload="true">
              <input type="hidden" name="action" value="update" />
              <input type="hidden" name="id" value={provider.id} />
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Provider Code</label>
                <input name="provider_code" value={provider.provider_code} required class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
              </div>
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Display Name</label>
                <input name="display_name" value={provider.display_name} required class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
              </div>
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Provider Protocol</label>
                <select name="adapter_type" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm bg-white">
                  <option value="openai_compatible" selected={provider.adapter_type === 'openai_compatible'}>openai_compatible</option>
                </select>
              </div>
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Auth Type</label>
                <select name="auth_type" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm bg-white">
                  <option value="bearer" selected={provider.auth_type === 'bearer'}>bearer</option>
                </select>
              </div>
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Base URL</label>
                <input name="base_url" type="url" value={provider.base_url ?? ''} required class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
              </div>
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Endpoint Path</label>
                <input name="endpoint_path" value={provider.endpoint_path ?? ''} class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
              </div>
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Timeout (ms)</label>
                <input name="timeout_ms" type="number" min="1000" max="120000" value={provider.timeout_ms} required class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
              </div>
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Privacy Level</label>
                <select name="privacy_level" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm bg-white">
                  <option value="standard" selected={provider.privacy_level === 'standard'}>standard</option>
                  <option value="restricted" selected={provider.privacy_level === 'restricted'}>restricted</option>
                </select>
              </div>
              <div class="md:col-span-2 flex flex-wrap gap-4 text-sm text-gray-700">
                <label class="flex items-center gap-2">
                  <input name="is_active" type="checkbox" checked={provider.is_active === true} />
                  <span>Active</span>
                </label>
                <label class="flex items-center gap-2">
                  <input name="allows_student_data" type="checkbox" checked={provider.allows_student_data === true} />
                  <span>Allows student data</span>
                </label>
                <label class="flex items-center gap-2">
                  <input name="allows_chat" type="checkbox" checked={provider.allows_chat === true} />
                  <span>Allows chat</span>
                </label>
                <label class="flex items-center gap-2">
                  <input name="allows_fit_finder" type="checkbox" checked={provider.allows_fit_finder === true} />
                  <span>Allows Fit Finder</span>
                </label>
              </div>
              <div class="md:col-span-2">
                <button type="submit" class="rounded-md bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-black">
                  Save Provider Metadata
                </button>
              </div>
            </form>

            <form class="js-api-form mt-4 grid gap-3 rounded-lg border border-gray-200 p-4 md:grid-cols-[1fr_auto]" data-endpoint="/api/admin/ai-gateway/providers" data-success="Provider API key replaced." data-reload="true">
              <input type="hidden" name="action" value="replace_key" />
              <input type="hidden" name="id" value={provider.id} />
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Replace API Key</label>
                <input name="api_key" type="password" required class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
              </div>
              <div class="flex items-end">
                <button type="submit" class="rounded-md bg-amber-600 px-4 py-2 text-sm font-medium text-white hover:bg-amber-700">
                  Replace Key
                </button>
              </div>
            </form>
          </div>
        </details>
      ))}
    </div>
  </section>

  <section class="mb-10">
    <div class="mb-4 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-gray-900">Models</h2>
      <span class="text-xs text-gray-500">Attach models to provider accounts and mark capabilities.</span>
    </div>

    <div class="mb-6 rounded-lg border border-gray-200 bg-white p-4">
      <h3 class="mb-4 text-sm font-semibold text-gray-800">Create Model</h3>
      <form class="js-api-form grid gap-4 md:grid-cols-2" data-endpoint="/api/admin/ai-gateway/models" data-success="Model saved." data-reload="true">
        <input type="hidden" name="action" value="create" />
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Provider Account</label>
          <select name="provider_account_id" required class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm bg-white">
            {providers.map((provider) => (
              <option value={provider.id}>{provider.display_name} ({provider.provider_code})</option>
            ))}
          </select>
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Model Name</label>
          <input name="model_name" required class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Display Name</label>
          <input name="display_name" required class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Cost Tier</label>
          <input name="cost_tier" data-nullable="true" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">Max Output Tokens</label>
          <input name="max_output_tokens" type="number" min="1" data-nullable="true" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="mb-1 block text-sm font-medium text-gray-700">Input Cost / 1M</label>
            <input name="input_cost_per_million" type="number" min="0" step="0.000001" data-nullable="true" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
          </div>
          <div>
            <label class="mb-1 block text-sm font-medium text-gray-700">Output Cost / 1M</label>
            <input name="output_cost_per_million" type="number" min="0" step="0.000001" data-nullable="true" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
          </div>
        </div>
        <div class="md:col-span-2 flex flex-wrap gap-4 text-sm text-gray-700">
          <label class="flex items-center gap-2"><input name="is_active" type="checkbox" checked /><span>Active</span></label>
          <label class="flex items-center gap-2"><input name="supports_text" type="checkbox" checked /><span>Supports text</span></label>
          <label class="flex items-center gap-2"><input name="supports_json_mode" type="checkbox" /><span>JSON mode</span></label>
          <label class="flex items-center gap-2"><input name="supports_streaming" type="checkbox" /><span>Streaming</span></label>
          <label class="flex items-center gap-2"><input name="supports_tool_calling" type="checkbox" /><span>Tool calling</span></label>
        </div>
        <div class="md:col-span-2">
          <button type="submit" class="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
            Create Model
          </button>
        </div>
      </form>
    </div>

    <div class="space-y-4">
      {models.length === 0 ? (
        <div class="rounded-lg border border-gray-200 bg-white p-6 text-sm text-gray-500">
          No models configured yet.
        </div>
      ) : models.map((model) => (
        <details class="rounded-lg border border-gray-200 bg-white">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-4 py-3">
            <div>
              <div class="text-sm font-semibold text-gray-900">{model.display_name}</div>
              <div class="text-xs text-gray-500">
                {model.model_name} · {model.ai_provider_accounts?.display_name ?? 'Unknown provider'}
              </div>
            </div>
            <span class={badgeClass(model.is_active === true)}>
              {model.is_active ? 'active' : 'inactive'}
            </span>
          </summary>
          <div class="border-t border-gray-200 p-4">
            <form class="js-api-form grid gap-4 md:grid-cols-2" data-endpoint="/api/admin/ai-gateway/models" data-success="Model updated." data-reload="true">
              <input type="hidden" name="action" value="update" />
              <input type="hidden" name="id" value={model.id} />
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Provider Account</label>
                <select name="provider_account_id" required class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm bg-white">
                  {providers.map((provider) => (
                    <option value={provider.id} selected={provider.id === model.provider_account_id}>
                      {provider.display_name} ({provider.provider_code})
                    </option>
                  ))}
                </select>
              </div>
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Model Name</label>
                <input name="model_name" value={model.model_name} required class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
              </div>
              <div>
                <label class="mb-1 block text-sm font-medium text-gray-700">Display Name</label>
