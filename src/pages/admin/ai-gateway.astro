      </form>

      <div id="ai-gateway-test-result" class="mt-6 hidden rounded-lg border border-gray-200 bg-gray-50 p-4">
        <div class="mb-3 text-sm font-semibold text-gray-900">Latest Test Result</div>
        <dl class="grid gap-3 text-sm text-gray-700 md:grid-cols-2">
          <div><dt class="text-xs uppercase tracking-wide text-gray-500">Status</dt><dd id="test-result-status">—</dd></div>
          <div><dt class="text-xs uppercase tracking-wide text-gray-500">Preset</dt><dd id="test-result-preset">—</dd></div>
          <div><dt class="text-xs uppercase tracking-wide text-gray-500">Provider</dt><dd id="test-result-provider">—</dd></div>
          <div><dt class="text-xs uppercase tracking-wide text-gray-500">Model</dt><dd id="test-result-model">—</dd></div>
          <div><dt class="text-xs uppercase tracking-wide text-gray-500">Latency</dt><dd id="test-result-latency">—</dd></div>
          <div><dt class="text-xs uppercase tracking-wide text-gray-500">Tokens</dt><dd id="test-result-tokens">—</dd></div>
          <div><dt class="text-xs uppercase tracking-wide text-gray-500">Normalized Error</dt><dd id="test-result-error">—</dd></div>
