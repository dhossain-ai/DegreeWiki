                  <label class="mb-1 block text-sm font-medium text-gray-700">Output Cost / 1M</label>
                  <input name="output_cost_per_million" type="number" min="0" step="0.000001" value={model.output_cost_per_million ?? ''} data-nullable="true" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
