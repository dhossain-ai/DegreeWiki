---
import AdminLayout from '../../layouts/AdminLayout.astro'
import { forbiddenAdminResponse, requireAdminPermission } from '../../lib/admin/guard'
import {
  AI_GATEWAY_DB_PROVIDER_PROTOCOLS,
  AI_GATEWAY_LIVE_USE_CASES,
  AI_GATEWAY_PLANNED_PROVIDER_PROTOCOLS,
  AI_GATEWAY_TEST_PRESETS,
  AI_GATEWAY_USE_CASES,
} from '../../lib/ai/admin/constants'
import { isAIGatewayEnvFallbackEnabled } from '../../lib/ai/admin/store'
import { getAIEnv } from '../../lib/ai/env'

const guard = await requireAdminPermission(
  Astro.cookies,
  Astro.request,
  Astro.url.pathname,
  'manage_ai_settings',
)
if (guard.type === 'redirect') return Astro.redirect(guard.to)
if (guard.type === 'forbidden') return forbiddenAdminResponse()

const { user, supabase } = guard
const aiEnv = getAIEnv(Astro.locals as Record<string, unknown>)
const envFallbackEnabled = isAIGatewayEnvFallbackEnabled(aiEnv)

const [providersRes, modelsRes, policiesRes, healthRes] = await Promise.all([
  supabase
    .from('ai_provider_accounts')
    .select(`
      id,
      provider_code,
      display_name,
      adapter_type,
      base_url,
      endpoint_path,
      auth_type,
      api_key_last4,
      api_key_fingerprint,
      api_key_key_version,
      timeout_ms,
      is_active,
      privacy_level,
      allows_student_data,
      allows_chat,
      allows_fit_finder,
      created_at,
      updated_at
    `)
    .order('provider_code', { ascending: true }),
  supabase
    .from('ai_models')
    .select(`
      id,
      provider_account_id,
      model_name,
      display_name,
      is_active,
      supports_text,
      supports_json_mode,
      supports_streaming,
      supports_tool_calling,
      max_output_tokens,
      input_cost_per_million,
      output_cost_per_million,
      cost_tier,
      created_at,
      updated_at,
      ai_provider_accounts (
        provider_code,
        display_name
      )
    `)
    .order('display_name', { ascending: true }),
  supabase
    .from('ai_routing_policies')
    .select(`
      id,
      use_case,
      model_id,
      priority,
      is_active,
      fallback_enabled,
      max_attempts,
      timeout_ms,
      allow_env_fallback,
      notes,
      created_at,
      updated_at,
      ai_models (
        model_name,
        display_name,
        ai_provider_accounts (
          provider_code,
          display_name
        )
      )
    `)
    .order('use_case', { ascending: true })
    .order('priority', { ascending: true }),
  supabase
    .from('ai_provider_health')
    .select(`
      id,
      provider_account_id,
      model_id,
      consecutive_failures,
      last_success_at,
      last_failure_at,
      last_error_type,
      cooldown_until,
      ai_provider_accounts (
        provider_code,
        display_name
      ),
      ai_models (
        model_name,
        display_name
      )
    `)
    .order('updated_at', { ascending: false }),
])

const providers = (providersRes.data ?? []) as any[]
const models = (modelsRes.data ?? []) as any[]
const policies = (policiesRes.data ?? []) as any[]
const healthRows = (healthRes.data ?? []) as any[]

const loadError = providersRes.error || modelsRes.error || policiesRes.error || healthRes.error

function formatDate(value: string | null | undefined): string {
  if (!value) return '—'
  return new Date(value).toLocaleString('en-GB', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  })
}

function shortFingerprint(value: string | null | undefined): string {
  if (!value) return '—'
  if (value.length <= 18) return value
  return `${value.slice(0, 10)}...${value.slice(-6)}`
}

function numberText(value: number | null | undefined): string {
  if (value == null) return '—'
  return String(value)
}

function badgeClass(active: boolean): string {
  return active
    ? 'inline-flex rounded-full bg-green-100 px-2.5 py-1 text-xs font-medium text-green-700'
    : 'inline-flex rounded-full bg-gray-100 px-2.5 py-1 text-xs font-medium text-gray-600'
}

function cooldownActive(cooldownUntil: string | null | undefined): boolean {
  if (!cooldownUntil) return false
  return new Date(cooldownUntil).getTime() > Date.now()
}

function formatMoney(value: number | null | undefined): string {
  if (value == null) return '—'
  return `$${Number(value).toFixed(4)}`
}

function capabilityList(model: any): string[] {
  const capabilities: string[] = []
  if (model.supports_text) capabilities.push('text')
  if (model.supports_json_mode) capabilities.push('json')
  if (model.supports_streaming) capabilities.push('streaming')
  if (model.supports_tool_calling) capabilities.push('tool-calling')
  return capabilities
}

function accessFlags(provider: any): string[] {
  const flags: string[] = []
  flags.push(`privacy:${provider.privacy_level ?? 'standard'}`)
  flags.push(`student:${provider.allows_student_data ? 'yes' : 'no'}`)
  flags.push(`chat:${provider.allows_chat ? 'yes' : 'no'}`)
  flags.push(`fit_finder:${provider.allows_fit_finder ? 'yes' : 'no'}`)
  return flags
}

const modelCountByProviderId = new Map<string, number>()
for (const model of models) {
  if (!model.provider_account_id) continue
  modelCountByProviderId.set(
    model.provider_account_id,
    (modelCountByProviderId.get(model.provider_account_id) ?? 0) + 1,
  )
}

const policyCountByModelId = new Map<string, number>()
for (const policy of policies) {
  if (!policy.model_id) continue
  policyCountByModelId.set(policy.model_id, (policyCountByModelId.get(policy.model_id) ?? 0) + 1)
}

const policyCountByProviderCode = new Map<string, number>()
for (const policy of policies) {
  const providerCode = policy.ai_models?.ai_provider_accounts?.provider_code
  if (!providerCode) continue
  policyCountByProviderCode.set(
    providerCode,
    (policyCountByProviderCode.get(providerCode) ?? 0) + 1,
  )
}

const activeProviderCount = providers.filter((provider) => provider.is_active === true).length
const activeModelCount = models.filter((model) => model.is_active === true).length
const activePolicyCount = policies.filter((policy) => policy.is_active === true).length
const healthIssueCount = healthRows.filter(
  (row) =>
    cooldownActive(row.cooldown_until) ||
    (row.consecutive_failures ?? 0) > 0 ||
    Boolean(row.last_error_type),
).length

const groupedPolicies = AI_GATEWAY_USE_CASES.map((useCase) => ({
  useCase,
  isLive: AI_GATEWAY_LIVE_USE_CASES.includes(useCase),
  rows: policies.filter((policy) => policy.use_case === useCase),
}))

const tabs = [
  { id: 'overview', label: 'Overview' },
  { id: 'providers', label: 'Providers' },
  { id: 'models', label: 'Models' },
  { id: 'routing', label: 'Routing' },
  { id: 'testing', label: 'Testing' },
  { id: 'health', label: 'Health' },
] as const

const requestedTab = Astro.url.searchParams.get('tab') ?? 'overview'
const activeTab = tabs.some((tab) => tab.id === requestedTab) ? requestedTab : 'overview'
const liveRouteSummaries = AI_GATEWAY_LIVE_USE_CASES.map((useCase) => ({
  useCase,
  rows: policies.filter((policy) => policy.use_case === useCase),
}))
---
<AdminLayout title="AI Gateway — DegreeWiki Admin" activePath="/admin/ai-gateway" userEmail={user.email ?? ''}>
  <div class="mb-6 flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
    <div>
      <h1 class="text-xl font-bold text-gray-900">AI Gateway</h1>
      <p class="mt-2 max-w-4xl text-sm text-gray-600">
        Manage DB-backed provider accounts, models, routing policies, health state, and admin-only
        preset tests. Only <span class="font-medium text-gray-800">fit_finder_summary</span> and
        <span class="font-medium text-gray-800"> chat_answer</span> are live product routes today.
      </p>
    </div>
    <div class="rounded-xl border border-blue-200 bg-blue-50 px-4 py-3 text-sm text-blue-900">
      <div class="font-medium">Recommended live routing</div>
      <div class="mt-1">1. OpenRouter free</div>
      <div>2. Xiaomi MiMo V2.5</div>
      <div>3. Gemini env fallback</div>
    </div>
  </div>

  <div id="ai-gateway-banner" class="mb-6 hidden rounded-md border px-4 py-3 text-sm"></div>

  {loadError && (
    <div class="mb-6 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
      Some AI Gateway data could not be loaded. The page may be incomplete until the next refresh.
    </div>
  )}

  <nav class="mb-6 overflow-x-auto rounded-xl border border-gray-200 bg-white p-1" aria-label="AI Gateway sections">
    <div class="flex min-w-max gap-1">
      {tabs.map((tab) => (
        <a
          href={`/admin/ai-gateway?tab=${tab.id}`}
          class={activeTab === tab.id
            ? 'rounded-lg bg-gray-900 px-4 py-2 text-sm font-medium text-white'
            : 'rounded-lg px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50 hover:text-gray-900'}
          aria-current={activeTab === tab.id ? 'page' : undefined}
        >
          {tab.label}
        </a>
      ))}
    </div>
  </nav>

  {activeTab === 'overview' && (
    <>
  <div class="mb-8 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
    <div class="rounded-xl border border-gray-200 bg-white p-4">
      <div class="text-xs uppercase tracking-wide text-gray-500">Env Fallback Status</div>
      <div class="mt-3 flex items-center justify-between gap-3">
        <span class={envFallbackEnabled ? badgeClass(true) : badgeClass(false)}>
          {envFallbackEnabled ? 'enabled' : 'disabled'}
        </span>
        <span class="text-xs text-gray-500">Gemini/OpenRouter env paths only</span>
      </div>
    </div>
    <div class="rounded-xl border border-gray-200 bg-white p-4">
      <div class="text-xs uppercase tracking-wide text-gray-500">Active Providers</div>
      <div class="mt-2 text-2xl font-semibold text-gray-900">{activeProviderCount}</div>
      <div class="mt-1 text-xs text-gray-500">{providers.length} total provider accounts</div>
    </div>
    <div class="rounded-xl border border-gray-200 bg-white p-4">
      <div class="text-xs uppercase tracking-wide text-gray-500">Active Models</div>
      <div class="mt-2 text-2xl font-semibold text-gray-900">{activeModelCount}</div>
      <div class="mt-1 text-xs text-gray-500">{models.length} total configured models</div>
    </div>
    <div class="rounded-xl border border-gray-200 bg-white p-4">
      <div class="text-xs uppercase tracking-wide text-gray-500">Active Routing Policies</div>
      <div class="mt-2 text-2xl font-semibold text-gray-900">{activePolicyCount}</div>
      <div class="mt-1 text-xs text-gray-500">{policies.length} total policy rows</div>
    </div>
    <div class="rounded-xl border border-gray-200 bg-white p-4">
      <div class="text-xs uppercase tracking-wide text-gray-500">Health Issues / Cooldowns</div>
      <div class="mt-2 text-2xl font-semibold text-gray-900">{healthIssueCount}</div>
      <div class="mt-1 text-xs text-gray-500">{healthRows.length} total provider health rows</div>
    </div>
    <div class="rounded-xl border border-gray-200 bg-white p-4">
      <div class="text-xs uppercase tracking-wide text-gray-500">Live Use Cases</div>
      <div class="mt-3 flex flex-wrap gap-2">
        {AI_GATEWAY_LIVE_USE_CASES.map((useCase) => (
          <span class="inline-flex rounded-full bg-sky-100 px-2.5 py-1 text-xs font-medium text-sky-700">
            {useCase}
          </span>
        ))}
      </div>
    </div>
  </div>

  <div class="mb-8 grid gap-4 xl:grid-cols-[1.2fr_1fr]">
    <section class="rounded-xl border border-blue-200 bg-blue-50 p-5">
      <div class="flex items-center justify-between gap-3">
        <div>
          <h2 class="text-base font-semibold text-blue-950">Recommended Setup</h2>
          <p class="mt-1 text-sm text-blue-900">
            This is the fastest safe path from empty config to live admin-verified routing.
          </p>
        </div>
        <span class="rounded-full bg-white px-3 py-1 text-xs font-medium text-blue-800">Live routes only: {AI_GATEWAY_LIVE_USE_CASES.join(', ')}</span>
      </div>
      <ol class="mt-4 space-y-3 text-sm text-blue-950">
        <li class="rounded-lg bg-white/70 px-4 py-3">1. Add provider account</li>
        <li class="rounded-lg bg-white/70 px-4 py-3">2. Add model</li>
        <li class="rounded-lg bg-white/70 px-4 py-3">3. Add routing policy for <code>fit_finder_summary</code></li>
        <li class="rounded-lg bg-white/70 px-4 py-3">4. Add routing policy for <code>chat_answer</code></li>
        <li class="rounded-lg bg-white/70 px-4 py-3">5. Run preset admin tests</li>
      </ol>
      <div class="mt-4 grid gap-3 text-sm text-blue-950 md:grid-cols-3">
        <div class="rounded-lg bg-white/70 px-4 py-3">
          <div class="font-medium">Provider account</div>
          <div class="mt-1 text-blue-900">API account/key for a provider.</div>
        </div>
        <div class="rounded-lg bg-white/70 px-4 py-3">
          <div class="font-medium">Model</div>
          <div class="mt-1 text-blue-900">Exact AI model name sent to that provider.</div>
        </div>
        <div class="rounded-lg bg-white/70 px-4 py-3">
          <div class="font-medium">Routing policy</div>
          <div class="mt-1 text-blue-900">Where DegreeWiki uses the model.</div>
        </div>
      </div>
    </section>

    <section class="rounded-xl border border-amber-200 bg-amber-50 p-5 text-sm text-amber-950">
      <h2 class="text-base font-semibold">Scope Notes</h2>
      <div class="mt-3 space-y-2">
        <p>DB-managed providers currently support <code>openai_compatible</code>.</p>
        <p>Gemini/OpenRouter env fallback remains outside the DB-managed provider list.</p>
        <p>
          Recommended live routing: OpenRouter free first, Xiaomi MiMo V2.5 second, Gemini env
          fallback.
        </p>
        <p>Z.ai should stay inactive if tests fail with <code>rate_limit</code> or <code>invalid_provider_response</code>.</p>
      </div>
    </section>
  </div>

  <div class="grid gap-4 xl:grid-cols-[1.2fr_1fr]">
    <section class="rounded-xl border border-gray-200 bg-white p-5">
      <h2 class="text-base font-semibold text-gray-900">Live Routing Summary</h2>
      <div class="mt-4 grid gap-4 md:grid-cols-2">
        {liveRouteSummaries.map((summary) => (
          <div class="rounded-lg border border-gray-200 p-4">
            <div class="flex flex-wrap items-center justify-between gap-2">
              <h3 class="text-sm font-semibold text-gray-900">{summary.useCase}</h3>
              <span class="inline-flex rounded-full bg-sky-100 px-2.5 py-1 text-xs font-medium text-sky-700">live product route</span>
            </div>
            {summary.rows.length === 0 ? (
              <p class="mt-3 text-sm text-gray-500">No DB routing rows configured yet; env fallback remains the practical route if enabled.</p>
            ) : (
              <ol class="mt-3 space-y-2 text-sm text-gray-700">
                {summary.rows.map((policy) => (
                  <li class="rounded-lg bg-gray-50 px-3 py-2">
                    {policy.priority}. {policy.ai_models?.display_name ?? 'Unknown model'}
                    <span class="text-gray-500"> via {policy.ai_models?.ai_provider_accounts?.display_name ?? 'Unknown provider'}</span>
                  </li>
                ))}
              </ol>
            )}
          </div>
        ))}
      </div>
      <p class="mt-4 text-sm text-gray-500">
        Env fallback stays controlled by server environment settings and is not a DB-managed provider account.
      </p>
    </section>

    <section class="rounded-xl border border-gray-200 bg-white p-5">
      <h2 class="text-base font-semibold text-gray-900">Recommendations</h2>
      <div class="mt-4 space-y-3 text-sm text-gray-700">
        <p>OpenRouter free can be primary for live routes after successful admin tests.</p>
        <p>Xiaomi MiMo V2.5 can be fallback if preset tests pass.</p>
        <p>Z.ai should stay inactive when tests return <code>rate_limit</code> or <code>invalid_provider_response</code>.</p>
        <p>DB-managed providers currently support <code>openai_compatible</code> only.</p>
      </div>
    </section>
  </div>
    </>
  )}

  {activeTab === 'providers' && (
  <section class="mb-10">
    <div class="mb-4 flex items-center justify-between gap-4">
      <div>
        <h2 class="text-lg font-semibold text-gray-900">Provider Accounts</h2>
        <p class="mt-1 text-sm text-gray-500">
          Masked key metadata only. Decrypted keys and ciphertext are never shown.
        </p>
      </div>
    </div>

    <details class="mb-6 rounded-xl border border-gray-200 bg-white" open={providers.length === 0}>
      <summary class="cursor-pointer list-none px-4 py-3 text-sm font-semibold text-gray-900">
        Create Provider Account
      </summary>
      <div class="border-t border-gray-200 p-4">
        <form class="js-api-form grid gap-4 md:grid-cols-2" data-endpoint="/api/admin/ai-gateway/providers" data-success="Provider account saved." data-reload="true">
          <input type="hidden" name="action" value="create" />
          <div>
            <label class="mb-1 block text-sm font-medium text-gray-700">Provider Code</label>
            <input name="provider_code" required class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
          </div>
          <div>
            <label class="mb-1 block text-sm font-medium text-gray-700">Display Name</label>
            <input name="display_name" required class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
          </div>
          <div>
            <label class="mb-1 block text-sm font-medium text-gray-700">Provider Protocol</label>
            <select name="adapter_type" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm">
              {AI_GATEWAY_DB_PROVIDER_PROTOCOLS.map((protocol) => (
                <option value={protocol}>{protocol}</option>
              ))}
            </select>
            <p class="mt-1 text-xs text-gray-500">
              Planned only: {AI_GATEWAY_PLANNED_PROVIDER_PROTOCOLS.join(', ')}
            </p>
          </div>
          <div>
            <label class="mb-1 block text-sm font-medium text-gray-700">Auth Type</label>
            <select name="auth_type" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm">
              <option value="bearer">bearer</option>
            </select>
          </div>
          <div>
            <label class="mb-1 block text-sm font-medium text-gray-700">Base URL</label>
            <input name="base_url" type="url" required placeholder="https://api.example.com/v1" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
          </div>
          <div>
            <label class="mb-1 block text-sm font-medium text-gray-700">Endpoint Path</label>
            <input name="endpoint_path" placeholder="/chat/completions" class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
          </div>
          <div>
            <label class="mb-1 block text-sm font-medium text-gray-700">Timeout (ms)</label>
            <input name="timeout_ms" type="number" min="1000" max="120000" value="30000" required class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
          </div>
          <div>
            <label class="mb-1 block text-sm font-medium text-gray-700">Privacy Level</label>
            <select name="privacy_level" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm">
              <option value="standard">standard</option>
              <option value="restricted">restricted</option>
            </select>
          </div>
          <div class="md:col-span-2">
            <label class="mb-1 block text-sm font-medium text-gray-700">API Key</label>
            <input name="api_key" type="password" required class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm" />
          </div>
          <div class="md:col-span-2 flex flex-wrap gap-4 text-sm text-gray-700">
            <label class="flex items-center gap-2">
              <input name="is_active" type="checkbox" checked />
              <span>Active</span>
            </label>
            <label class="flex items-center gap-2">
              <input name="allows_student_data" type="checkbox" />
              <span>Allows student data</span>
            </label>
            <label class="flex items-center gap-2">
              <input name="allows_chat" type="checkbox" />
              <span>Allows chat</span>
            </label>
            <label class="flex items-center gap-2">
              <input name="allows_fit_finder" type="checkbox" />
              <span>Allows Fit Finder</span>
            </label>
          </div>
          <div class="md:col-span-2">
            <button type="submit" class="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
              Create Provider Account
            </button>
          </div>
        </form>
      </div>
    </details>

    <div class="space-y-4">
      {providers.length === 0 ? (
        <div class="rounded-xl border border-dashed border-gray-300 bg-white p-6 text-sm text-gray-500">
          No provider accounts configured yet.
        </div>
      ) : providers.map((provider) => (
        <article class="rounded-xl border border-gray-200 bg-white">
          <div class="flex flex-col gap-3 px-4 py-4 lg:flex-row lg:items-start lg:justify-between">
            <div>
              <div class="flex flex-wrap items-center gap-2">
                <h3 class="text-base font-semibold text-gray-900">{provider.display_name}</h3>
                <span class={badgeClass(provider.is_active === true)}>
                  {provider.is_active ? 'active' : 'inactive'}
                </span>
              </div>
              <div class="mt-1 text-sm text-gray-600">{provider.provider_code}</div>
            </div>
            <div class="grid gap-3 text-xs text-gray-500 sm:grid-cols-2 lg:min-w-[32rem] lg:grid-cols-3">
              <div>
                <div class="font-medium text-gray-700">Protocol / Base URL</div>
                <div>{provider.adapter_type}</div>
                <div class="break-all">{provider.base_url ?? '—'}</div>
              </div>
              <div>
                <div class="font-medium text-gray-700">Masked Key</div>
                <div>{provider.api_key_last4 ? `••••${provider.api_key_last4}` : 'not set'}</div>
                <div>{shortFingerprint(provider.api_key_fingerprint)}</div>
              </div>
              <div>
                <div class="font-medium text-gray-700">Counts</div>
                <div>{modelCountByProviderId.get(provider.id) ?? 0} models</div>
                <div>{policyCountByProviderCode.get(provider.provider_code) ?? 0} routing policies</div>
              </div>
            </div>
          </div>

          <div class="border-t border-gray-200 p-4">
            <div class="mb-4 grid gap-3 rounded-xl bg-gray-50 p-4 text-sm text-gray-700 md:grid-cols-2 xl:grid-cols-4">
              <div>
                <div class="text-xs uppercase tracking-wide text-gray-500">Endpoint Path</div>
                <div class="mt-1 break-all">{provider.endpoint_path ?? '—'}</div>
              </div>
              <div>
                <div class="text-xs uppercase tracking-wide text-gray-500">Timeout / Key Version</div>
                <div class="mt-1">{numberText(provider.timeout_ms)} ms</div>
                <div>{provider.api_key_key_version ?? '—'}</div>
              </div>
              <div>
                <div class="text-xs uppercase tracking-wide text-gray-500">Privacy / Access</div>
                <div class="mt-1 flex flex-wrap gap-2">
                  {accessFlags(provider).map((flag) => (
