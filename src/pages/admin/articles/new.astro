---
import ArticleEditorForm from '../../../components/admin/ArticleEditorForm.astro'
import AdminLayout from '../../../layouts/AdminLayout.astro'
import { forbiddenAdminResponse, requireSuperAdmin } from '../../../lib/admin/guard'
import { loadReusableReadyMediaAssets, validateReusableReadyMediaIds } from '../../../lib/admin/media'
import { toSlug } from '../../../lib/admin/slug'
import {
  type ArticleCategoryOption,
  type ArticleEditorValues,
  CONTENT_STATUS_OPTIONS,
  INDEXING_STATUS_OPTIONS,
  VERIFICATION_OPTIONS,
} from '../../../lib/admin/articleAuthoring'
import {
  type FormErrors,
  validateIn,
  validateRequired,
  validateSlug,
  validateUrl,
} from '../../../lib/admin/validate'

const guard = await requireSuperAdmin(Astro.cookies, Astro.request, Astro.url.pathname)
if (guard.type === 'redirect') return Astro.redirect(guard.to)
if (guard.type === 'forbidden') return forbiddenAdminResponse()

const { user, supabase } = guard
const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME ?? ''

const [{ data: categoriesData }, mediaAssets] = await Promise.all([
  supabase.from('article_categories').select('id, name, slug').order('display_order'),
  loadReusableReadyMediaAssets(supabase),
])

const categories = (categoriesData ?? []) as ArticleCategoryOption[]
const validCategoryIds = new Set(categories.map(category => category.id))

let values: ArticleEditorValues = {
  title: '',
  slug: '',
  content_status: 'draft',
  article_category_id: '',
  summary: '',
  content: '',
  indexing_status: 'draft',
  verification_status: 'unverified',
  featured_image_id: '',
  og_image_id: '',
  seo_title: '',
  seo_description: '',
  seo_h1: '',
  canonical_url: '',
  og_title: '',
  og_description: '',
}

let errors: FormErrors = {}
let serverError = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const getField = (key: string) => String(form.get(key) ?? '').trim()
  const action = getField('action')

  values = {
    title: getField('title'),
    slug: getField('slug'),
    content_status: getField('content_status') || 'draft',
    article_category_id: getField('article_category_id'),
    summary: getField('summary'),
    content: getField('content'),
    indexing_status: getField('indexing_status') || 'draft',
    verification_status: getField('verification_status') || 'unverified',
    featured_image_id: getField('featured_image_id'),
    og_image_id: getField('og_image_id'),
    seo_title: getField('seo_title'),
    seo_description: getField('seo_description'),
    seo_h1: getField('seo_h1'),
    canonical_url: getField('canonical_url'),
    og_title: getField('og_title'),
    og_description: getField('og_description'),
  }

  if (action === 'publish') {
    values.content_status = 'published'
    values.indexing_status = 'index'
  }

  if (!values.slug && values.title) {
    values.slug = toSlug(values.title)
  }

  const nextErrors: FormErrors = {}

  const titleError = validateRequired(values.title, 'Title')
  if (titleError) nextErrors.title = titleError

  const slugError = validateRequired(values.slug, 'Slug') ?? validateSlug(values.slug)
  if (slugError) nextErrors.slug = slugError

  const statusError = validateIn(values.content_status, CONTENT_STATUS_OPTIONS, 'Status')
  if (statusError) nextErrors.content_status = statusError

  const indexingError = validateIn(values.indexing_status, INDEXING_STATUS_OPTIONS, 'Indexing Status')
  if (indexingError) nextErrors.indexing_status = indexingError

  const verificationError = validateIn(values.verification_status, VERIFICATION_OPTIONS, 'Verification Status')
  if (verificationError) nextErrors.verification_status = verificationError

  if (values.article_category_id && !validCategoryIds.has(values.article_category_id)) {
    nextErrors.article_category_id = 'Selected category is not valid.'
  }

  const canonicalError = validateUrl(values.canonical_url, 'Canonical URL')
  if (canonicalError) nextErrors.canonical_url = canonicalError

  const validMediaIds = await validateReusableReadyMediaIds(supabase, [values.featured_image_id, values.og_image_id])
  if (values.featured_image_id && !validMediaIds.has(values.featured_image_id)) {
    nextErrors.featured_image_id = 'Selected featured image is not valid.'
  }
  if (values.og_image_id && !validMediaIds.has(values.og_image_id)) {
    nextErrors.og_image_id = 'Selected OG image is not valid.'
  }

  errors = nextErrors

  if (Object.keys(errors).length === 0) {
    const { error } = await supabase.from('articles').insert({
      title: values.title,
      slug: values.slug,
      content_status: values.content_status,
      article_category_id: values.article_category_id || null,
      summary: values.summary || null,
      content: values.content || null,
      indexing_status: values.indexing_status,
      verification_status: values.verification_status,
      featured_image_id: values.featured_image_id || null,
      og_image_id: values.og_image_id || null,
      seo_title: values.seo_title || null,
      seo_description: values.seo_description || null,
      seo_h1: values.seo_h1 || null,
      canonical_url: values.canonical_url || null,
      og_title: values.og_title || null,
      og_description: values.og_description || null,
      author_user_id: user.id,
      ...(values.content_status === 'published' ? { published_at: new Date().toISOString() } : {}),
    })

    if (error) {
      serverError = error.code === '23505'
        ? 'An article with this slug already exists.'
        : 'Could not save. Please try again.'
    } else {
      return Astro.redirect('/admin/articles')
    }
  }
}
---
<AdminLayout title="New Article — DegreeWiki Admin" activePath="/admin/articles" userEmail={user.email ?? ''}>
  <div class="mb-6 flex items-center justify-between gap-3">
    <div>
      <h1 class="text-xl font-bold text-gray-900">New Article</h1>
      <p class="mt-1 text-sm text-gray-500">Create a guide draft with clearer editorial structure, SEO cues, and publishing readiness checks.</p>
    </div>
    <a href="/admin/articles" class="text-sm text-gray-500 hover:underline">← Back to Articles</a>
  </div>

  {serverError && (
    <div class="mb-4 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">{serverError}</div>
  )}

  <ArticleEditorForm
    mode="create"
    values={values}
    errors={errors}
    categories={categories}
    mediaAssets={mediaAssets}
    cloudName={cloudName}
    backHref="/admin/articles"
  />
</AdminLayout>
