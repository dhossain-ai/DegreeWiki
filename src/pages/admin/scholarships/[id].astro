---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import { requireSuperAdmin } from '../../../lib/admin/guard'
import { toSlug } from '../../../lib/admin/slug'
import {
  type FormErrors,
  validateRequired,
  validateIn,
  validateSlug,
  validateNumeric,
  validateUrl,
} from '../../../lib/admin/validate'

const guard = await requireSuperAdmin(Astro.cookies, Astro.request, Astro.url.pathname)
if (guard.type === 'redirect') return Astro.redirect(guard.to)
if (guard.type === 'forbidden') return new Response('403 Forbidden: admin role required.', { status: 403 })

const { user, supabase } = guard
const { id } = Astro.params
if (!id) return new Response('Not found.', { status: 404 })

const CONTENT_STATUS_OPTIONS    = ['draft', 'in_review', 'published', 'unpublished', 'archived'] as const
const VERIFICATION_OPTIONS      = ['unverified', 'partially_verified', 'verified', 'source_conflict', 'outdated', 'needs_review'] as const
const SOURCE_TYPE_OPTIONS       = ['official_university', 'government', 'third_party', 'aggregator', 'user_submitted'] as const
const CONFIDENCE_OPTIONS        = ['high', 'medium', 'low', 'unknown'] as const
const SOURCE_STATUS_OPTIONS     = ['active', 'broken', 'redirected', 'archived'] as const
const SCHOLARSHIP_TYPE_OPTIONS  = ['full', 'partial', 'merit', 'need_based', 'government', 'institutional', 'other'] as const
const PROVIDER_TYPE_OPTIONS     = ['government', 'university', 'private_foundation', 'corporate', 'ngo', 'other'] as const
const FUNDING_TYPE_OPTIONS      = ['full_tuition', 'partial_tuition', 'living_stipend', 'travel', 'research', 'full_funding', 'other'] as const
const APPLICATION_TYPE_OPTIONS  = ['direct', 'university_portal', 'nomination', 'embassy', 'other'] as const

const { data: existing, error: loadError } = await supabase
  .from('scholarships')
  .select(`
    id, name, slug, scholarship_type, provider_name, provider_type, funding_type,
    application_type, amount_min, amount_max, currency, coverage_notes,
    deadline, deadline_text, official_url, application_url, provider_url,
    overview, eligibility_summary, content_status, verification_status
  `)
  .eq('id', id)
  .single()

if (loadError || !existing) {
  return new Response('Scholarship not found.', { status: 404 })
}

type ScholarshipRecord = {
  id: string; name: string; slug: string
  scholarship_type: string | null; provider_name: string | null; provider_type: string | null
  funding_type: string | null; application_type: string | null
  amount_min: number | null; amount_max: number | null; currency: string | null
  coverage_notes: string | null; deadline: string | null; deadline_text: string | null
  official_url: string | null; application_url: string | null; provider_url: string | null
  overview: string | null; eligibility_summary: string | null
  content_status: string; verification_status: string
}
const record = existing as ScholarshipRecord

type DataSourceRow = {
  id: string
  source_url: string
  source_title: string | null
  source_type: string
  confidence_level: string
  source_status: string
  is_primary_source: boolean
}
const { data: sourcesData } = await supabase
  .from('data_sources')
  .select('id, source_url, source_title, source_type, confidence_level, source_status, is_primary_source')
  .eq('entity_type', 'scholarship')
  .eq('entity_id', id)
  .order('is_primary_source', { ascending: false })
const sources = (sourcesData ?? []) as DataSourceRow[]

type Values = {
  name: string; slug: string; content_status: string
  scholarship_type: string; provider_name: string; provider_type: string
  funding_type: string; application_type: string
  amount_min: string; amount_max: string; currency: string; coverage_notes: string
  deadline: string; deadline_text: string
  official_url: string; application_url: string; provider_url: string
  overview: string; eligibility_summary: string
  verification_status: string
}

let values: Values = {
  name: record.name,
  slug: record.slug,
  content_status: record.content_status,
  scholarship_type: record.scholarship_type ?? '',
  provider_name: record.provider_name ?? '',
  provider_type: record.provider_type ?? '',
  funding_type: record.funding_type ?? '',
  application_type: record.application_type ?? '',
  amount_min: record.amount_min !== null ? String(record.amount_min) : '',
  amount_max: record.amount_max !== null ? String(record.amount_max) : '',
  currency: record.currency ?? '',
  coverage_notes: record.coverage_notes ?? '',
  deadline: record.deadline ?? '',
  deadline_text: record.deadline_text ?? '',
  official_url: record.official_url ?? '',
  application_url: record.application_url ?? '',
  provider_url: record.provider_url ?? '',
  overview: record.overview ?? '',
  eligibility_summary: record.eligibility_summary ?? '',
  verification_status: record.verification_status,
}
let errors: FormErrors = {}
let serverError = ''
let sourceError = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()

  if (form.get('_action') === 'add_source') {
    const srcUrl = String(form.get('source_url') ?? '').trim()
    if (!srcUrl) {
      sourceError = 'Source URL is required.'
    } else {
      const { error: srcErr } = await supabase.from('data_sources').insert({
        entity_type: 'scholarship',
        entity_id: id,
        source_url: srcUrl,
        source_type: String(form.get('source_type') ?? 'third_party').trim() || 'third_party',
        confidence_level: String(form.get('confidence_level') ?? 'unknown').trim() || 'unknown',
        source_status: String(form.get('source_status') ?? 'active').trim() || 'active',
        source_title: String(form.get('source_title') ?? '').trim() || null,
        is_primary_source: form.get('is_primary_source') === 'true',
      })
      if (srcErr) { sourceError = 'Could not add source.' }
      else { return Astro.redirect(Astro.url.pathname) }
    }
  } else {
  const g = (key: string) => String(form.get(key) ?? '').trim()

  values = {
    name: g('name'), slug: g('slug'), content_status: g('content_status') || 'draft',
    scholarship_type: g('scholarship_type'), provider_name: g('provider_name'),
    provider_type: g('provider_type'), funding_type: g('funding_type'),
    application_type: g('application_type'),
    amount_min: g('amount_min'), amount_max: g('amount_max'),
    currency: g('currency'), coverage_notes: g('coverage_notes'),
    deadline: g('deadline'), deadline_text: g('deadline_text'),
    official_url: g('official_url'), application_url: g('application_url'),
    provider_url: g('provider_url'),
    overview: g('overview'), eligibility_summary: g('eligibility_summary'),
    verification_status: g('verification_status') || 'unverified',
  }

  if (!values.slug && values.name) values.slug = toSlug(values.name)

  const e: FormErrors = {}

  const nameErr = validateRequired(values.name, 'Name')
  if (nameErr) e.name = nameErr

  const slugErr = validateRequired(values.slug, 'Slug') ?? validateSlug(values.slug)
  if (slugErr) e.slug = slugErr

  const typeErr = validateRequired(values.scholarship_type, 'Scholarship Type')
    ?? validateIn(values.scholarship_type, SCHOLARSHIP_TYPE_OPTIONS, 'Scholarship Type')
  if (typeErr) e.scholarship_type = typeErr

  if (values.provider_type) {
    const err = validateIn(values.provider_type, PROVIDER_TYPE_OPTIONS, 'Provider Type')
    if (err) e.provider_type = err
  }
  if (values.funding_type) {
    const err = validateIn(values.funding_type, FUNDING_TYPE_OPTIONS, 'Funding Type')
    if (err) e.funding_type = err
  }
  if (values.application_type) {
    const err = validateIn(values.application_type, APPLICATION_TYPE_OPTIONS, 'Application Type')
    if (err) e.application_type = err
  }

  const minErr = validateNumeric(values.amount_min, 'Minimum Amount', { min: 0 })
  if (minErr) e.amount_min = minErr
  const maxErr = validateNumeric(values.amount_max, 'Maximum Amount', { min: 0 })
  if (maxErr) e.amount_max = maxErr
  if (!e.amount_min && !e.amount_max && values.amount_min && values.amount_max) {
    if (Number(values.amount_max) < Number(values.amount_min)) {
      e.amount_max = 'Maximum amount must be greater than or equal to minimum amount.'
    }
  }

  if (values.deadline) {
    if (isNaN(new Date(values.deadline).getTime())) {
      e.deadline = 'Deadline must be a valid date.'
    }
  }

  const offErr = validateUrl(values.official_url, 'Official URL')
  if (offErr) e.official_url = offErr
  const appUrlErr = validateUrl(values.application_url, 'Application URL')
  if (appUrlErr) e.application_url = appUrlErr
  const provUrlErr = validateUrl(values.provider_url, 'Provider URL')
  if (provUrlErr) e.provider_url = provUrlErr

  const statusErr = validateIn(values.content_status, CONTENT_STATUS_OPTIONS, 'Status')
  if (statusErr) e.content_status = statusErr

  const verErr = validateIn(values.verification_status, VERIFICATION_OPTIONS, 'Verification Status')
  if (verErr) e.verification_status = verErr

  errors = e

  if (Object.keys(errors).length === 0) {
    const { error } = await supabase
      .from('scholarships')
      .update({
        name: values.name,
        slug: values.slug,
        scholarship_type: values.scholarship_type,
        provider_name: values.provider_name || null,
        provider_type: values.provider_type || null,
        funding_type: values.funding_type || null,
        application_type: values.application_type || null,
        amount_min: values.amount_min ? parseFloat(values.amount_min) : null,
        amount_max: values.amount_max ? parseFloat(values.amount_max) : null,
        currency: values.currency || null,
        coverage_notes: values.coverage_notes || null,
        deadline: values.deadline || null,
        deadline_text: values.deadline_text || null,
        official_url: values.official_url || null,
        application_url: values.application_url || null,
        provider_url: values.provider_url || null,
        overview: values.overview || null,
        eligibility_summary: values.eligibility_summary || null,
        content_status: values.content_status,
        verification_status: values.verification_status,
      })
      .eq('id', id)

    if (error) {
      serverError = error.code === '23505'
        ? 'A scholarship with this slug already exists.'
        : 'Could not save. Please try again.'
    } else {
      return Astro.redirect('/admin/scholarships')
    }
  }
  } // end else (entity edit)
}

const inputClass = 'w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500'
const selectClass = inputClass + ' bg-white'
const labelClass = 'block text-sm font-medium text-gray-700 mb-1'
const errorClass = 'mt-1 text-xs text-red-600'
const sectionHeadClass = 'text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3 pb-1 border-b border-gray-200'
---
<AdminLayout title={`Edit ${record.name} — DegreeWiki Admin`} activePath="/admin/scholarships" userEmail={user.email ?? ''}>
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-bold text-gray-900">Edit Scholarship</h1>
    <a href="/admin/scholarships" class="text-sm text-gray-500 hover:underline">← Back to Scholarships</a>
  </div>

  {serverError && (
    <div class="mb-4 px-4 py-3 rounded-md bg-red-50 border border-red-200 text-sm text-red-700">{serverError}</div>
  )}

  <form method="post" class="max-w-2xl space-y-6">

    <!-- Identity -->
    <div>
      <h2 class={sectionHeadClass}>Identity</h2>
      <div class="space-y-4">
        <div>
          <label for="name" class={labelClass}>Name *</label>
          <input type="text" id="name" name="name" value={values.name}
            class={inputClass} />
          {errors.name && <p class={errorClass}>{errors.name}</p>}
        </div>

        <div>
          <label for="slug" class={labelClass}>Slug *</label>
          <input type="text" id="slug" name="slug" value={values.slug}
            class={inputClass + ' font-mono'} />
          {errors.slug && <p class={errorClass}>{errors.slug}</p>}
        </div>

        <div>
          <label for="content_status" class={labelClass}>Status *</label>
          <select id="content_status" name="content_status" class={selectClass}>
            {CONTENT_STATUS_OPTIONS.map(s => (
              <option value={s} selected={values.content_status === s}>{s}</option>
            ))}
          </select>
          {errors.content_status && <p class={errorClass}>{errors.content_status}</p>}
        </div>
      </div>
    </div>

    <!-- Classification -->
    <div>
      <h2 class={sectionHeadClass}>Classification</h2>
      <div class="space-y-4">
        <div>
          <label for="scholarship_type" class={labelClass}>Scholarship Type *</label>
          <select id="scholarship_type" name="scholarship_type" class={selectClass}>
            <option value="">— select a type —</option>
            {SCHOLARSHIP_TYPE_OPTIONS.map(t => (
              <option value={t} selected={values.scholarship_type === t}>{t}</option>
            ))}
          </select>
          {errors.scholarship_type && <p class={errorClass}>{errors.scholarship_type}</p>}
        </div>

        <div>
          <label for="provider_name" class={labelClass}>Provider Name</label>
          <input type="text" id="provider_name" name="provider_name" value={values.provider_name}
            class={inputClass} />
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="provider_type" class={labelClass}>Provider Type</label>
            <select id="provider_type" name="provider_type" class={selectClass}>
              <option value="">— none —</option>
              {PROVIDER_TYPE_OPTIONS.map(t => (
                <option value={t} selected={values.provider_type === t}>{t}</option>
              ))}
            </select>
            {errors.provider_type && <p class={errorClass}>{errors.provider_type}</p>}
          </div>
          <div>
            <label for="application_type" class={labelClass}>Application Type</label>
            <select id="application_type" name="application_type" class={selectClass}>
              <option value="">— none —</option>
              {APPLICATION_TYPE_OPTIONS.map(t => (
                <option value={t} selected={values.application_type === t}>{t}</option>
              ))}
            </select>
            {errors.application_type && <p class={errorClass}>{errors.application_type}</p>}
          </div>
        </div>

        <div>
          <label for="funding_type" class={labelClass}>Funding Type</label>
          <select id="funding_type" name="funding_type" class={selectClass}>
            <option value="">— none —</option>
            {FUNDING_TYPE_OPTIONS.map(t => (
              <option value={t} selected={values.funding_type === t}>{t}</option>
            ))}
          </select>
          {errors.funding_type && <p class={errorClass}>{errors.funding_type}</p>}
        </div>
      </div>
    </div>

    <!-- Funding -->
    <div>
      <h2 class={sectionHeadClass}>Funding</h2>
      <div class="space-y-4">
        <div class="grid grid-cols-3 gap-4">
          <div>
            <label for="amount_min" class={labelClass}>Min Amount</label>
            <input type="number" id="amount_min" name="amount_min"
              value={values.amount_min} min="0" step="any" placeholder="0"
              class={inputClass} />
            {errors.amount_min && <p class={errorClass}>{errors.amount_min}</p>}
          </div>
          <div>
            <label for="amount_max" class={labelClass}>Max Amount</label>
            <input type="number" id="amount_max" name="amount_max"
              value={values.amount_max} min="0" step="any" placeholder="0"
              class={inputClass} />
            {errors.amount_max && <p class={errorClass}>{errors.amount_max}</p>}
          </div>
          <div>
            <label for="currency" class={labelClass}>Currency</label>
            <input type="text" id="currency" name="currency" value={values.currency}
              placeholder="EUR, USD, GBP"
              class={inputClass + ' font-mono'} />
          </div>
        </div>

        <div>
          <label for="coverage_notes" class={labelClass}>Coverage Notes</label>
          <textarea id="coverage_notes" name="coverage_notes" rows={3}
            class={inputClass}>{values.coverage_notes}</textarea>
        </div>
      </div>
    </div>

    <!-- Deadline -->
    <div>
      <h2 class={sectionHeadClass}>Deadline</h2>
      <div class="space-y-4">
        <div>
          <label for="deadline" class={labelClass}>Deadline Date</label>
          <input type="date" id="deadline" name="deadline" value={values.deadline}
            class={inputClass} />
          {errors.deadline && <p class={errorClass}>{errors.deadline}</p>}
        </div>

        <div>
          <label for="deadline_text" class={labelClass}>Deadline Note</label>
          <input type="text" id="deadline_text" name="deadline_text" value={values.deadline_text}
            placeholder="e.g. Rolling deadline, check provider website"
            class={inputClass} />
        </div>
      </div>
    </div>

    <!-- URLs -->
    <div>
      <h2 class={sectionHeadClass}>URLs</h2>
      <div class="space-y-4">
        <div>
          <label for="official_url" class={labelClass}>Official URL</label>
          <input type="url" id="official_url" name="official_url" value={values.official_url}
            placeholder="https://..."
            class={inputClass} />
          {errors.official_url && <p class={errorClass}>{errors.official_url}</p>}
        </div>

        <div>
          <label for="application_url" class={labelClass}>Application URL</label>
          <input type="url" id="application_url" name="application_url" value={values.application_url}
            placeholder="https://..."
            class={inputClass} />
          {errors.application_url && <p class={errorClass}>{errors.application_url}</p>}
        </div>

        <div>
          <label for="provider_url" class={labelClass}>Provider URL</label>
          <input type="url" id="provider_url" name="provider_url" value={values.provider_url}
            placeholder="https://..."
            class={inputClass} />
          {errors.provider_url && <p class={errorClass}>{errors.provider_url}</p>}
        </div>
      </div>
    </div>

    <!-- Content -->
    <div>
      <h2 class={sectionHeadClass}>Content</h2>
      <div class="space-y-4">
        <div>
          <label for="overview" class={labelClass}>Overview</label>
          <textarea id="overview" name="overview" rows={5}
            class={inputClass}>{values.overview}</textarea>
        </div>

        <div>
          <label for="eligibility_summary" class={labelClass}>Eligibility Summary</label>
          <textarea id="eligibility_summary" name="eligibility_summary" rows={4}
            class={inputClass}>{values.eligibility_summary}</textarea>
        </div>
      </div>
    </div>

    <!-- Verification -->
    <div>
      <h2 class={sectionHeadClass}>Verification</h2>
      <div>
        <label for="verification_status" class={labelClass}>Verification Status *</label>
        <select id="verification_status" name="verification_status" class={selectClass}>
          {VERIFICATION_OPTIONS.map(s => (
            <option value={s} selected={values.verification_status === s}>{s}</option>
          ))}
        </select>
        {errors.verification_status && <p class={errorClass}>{errors.verification_status}</p>}
      </div>
    </div>

    <div class="flex gap-3 pt-2">
      <button type="submit"
        class="px-4 py-2 text-sm font-medium bg-blue-600 text-white rounded-md hover:bg-blue-700">
        Save Changes
      </button>
      <a href="/admin/scholarships" class="px-4 py-2 text-sm text-gray-600 hover:underline">Cancel</a>
    </div>
  </form>

  <!-- Data Sources Panel -->
  <div class="mt-8 border-t border-gray-200 pt-6 max-w-2xl">
    <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-4">Data Sources</h2>

    {sources.length > 0 ? (
      <div class="space-y-2 mb-6">
        {sources.map(s => (
          <div class="px-3 py-2 bg-gray-50 rounded border border-gray-200 text-sm">
            <div class="flex items-start gap-2">
              {s.is_primary_source && (
                <span class="shrink-0 inline-block px-1.5 py-0.5 text-xs bg-green-100 text-green-700 rounded">primary</span>
              )}
              <a href={s.source_url} target="_blank" rel="noopener noreferrer"
                class="text-blue-600 hover:underline break-all font-mono text-xs">{s.source_url}</a>
            </div>
            <p class="text-xs text-gray-500 mt-1">
              {s.source_type} · {s.confidence_level} confidence · {s.source_status}
              {s.source_title ? ` · ${s.source_title}` : ''}
            </p>
          </div>
        ))}
      </div>
    ) : (
      <p class="text-sm text-gray-400 mb-6">No sources linked yet.</p>
    )}

    <form method="post" class="space-y-3">
      <input type="hidden" name="_action" value="add_source" />
      <p class="text-xs font-semibold text-gray-600 mb-2">Add a source</p>
      {sourceError && <p class="text-xs text-red-600 mb-2">{sourceError}</p>}
      <div class="space-y-3 bg-gray-50 p-4 rounded border border-gray-200">
        <div>
          <label for="source_url" class="block text-sm font-medium text-gray-700 mb-1">URL *</label>
          <input type="url" id="source_url" name="source_url" placeholder="https://..."
            class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div class="grid grid-cols-3 gap-3">
          <div>
            <label for="source_type" class="block text-sm font-medium text-gray-700 mb-1">Type</label>
            <select id="source_type" name="source_type"
              class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
              {SOURCE_TYPE_OPTIONS.map(t => <option value={t}>{t}</option>)}
            </select>
          </div>
          <div>
            <label for="confidence_level" class="block text-sm font-medium text-gray-700 mb-1">Confidence</label>
            <select id="confidence_level" name="confidence_level"
              class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
              {CONFIDENCE_OPTIONS.map(t => <option value={t}>{t}</option>)}
            </select>
          </div>
          <div>
            <label for="source_status_input" class="block text-sm font-medium text-gray-700 mb-1">Status</label>
            <select id="source_status_input" name="source_status"
              class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
              {SOURCE_STATUS_OPTIONS.map(t => <option value={t}>{t}</option>)}
            </select>
          </div>
        </div>
        <div>
          <label for="source_title" class="block text-sm font-medium text-gray-700 mb-1">Title (optional)</label>
          <input type="text" id="source_title" name="source_title" placeholder="e.g. Official scholarship page"
            class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" />
        </div>
        <div class="flex items-center gap-2">
          <input type="checkbox" id="is_primary_source" name="is_primary_source" value="true"
            class="h-4 w-4 text-blue-600 rounded border-gray-300" />
          <label for="is_primary_source" class="text-sm text-gray-700">Primary source</label>
        </div>
        <div>
          <button type="submit"
            class="px-3 py-1.5 text-xs font-medium bg-gray-700 text-white rounded-md hover:bg-gray-800">
            Add Source
          </button>
        </div>
      </div>
    </form>
  </div>
</AdminLayout>
