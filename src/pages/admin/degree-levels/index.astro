---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import { forbiddenAdminResponse, requireSuperAdmin } from '../../../lib/admin/guard'

const guard = await requireSuperAdmin(Astro.cookies, Astro.request, Astro.url.pathname)
if (guard.type === 'redirect') return Astro.redirect(guard.to)
if (guard.type === 'forbidden') return forbiddenAdminResponse()

const { user, supabase } = guard

const { data, error } = await supabase
  .from('degree_levels')
  .select('id, code, name, display_order, is_active')
  .order('display_order', { ascending: true })

type DegreeLevelRow = {
  id: string
  code: string
  name: string
  display_order: number
  is_active: boolean
}
const rows = (data ?? []) as DegreeLevelRow[]
---
<AdminLayout title="Degree Levels — DegreeWiki Admin" activePath="/admin/degree-levels" userEmail={user.email ?? ''}>
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-bold text-gray-900">Degree Levels</h1>
    <span class="text-sm text-gray-400">Seeded values — edit only, no create or delete</span>
  </div>

  {error ? (
    <p class="text-sm text-red-600 py-4">Could not load data.</p>
  ) : rows.length === 0 ? (
    <p class="text-sm text-gray-500 py-4">No degree levels found. Run migration 015 seed data.</p>
  ) : (
    <div class="overflow-x-auto rounded-lg border border-gray-200">
      <table class="w-full text-sm text-left">
        <thead class="bg-gray-50 border-b border-gray-200 text-xs text-gray-500 uppercase tracking-wide">
          <tr>
            <th class="px-4 py-3">Code</th>
            <th class="px-4 py-3">Name</th>
            <th class="px-4 py-3">Order</th>
            <th class="px-4 py-3">Active</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody>
          {rows.map(row => (
            <tr class="border-b border-gray-100 hover:bg-gray-50">
              <td class="px-4 py-3 text-gray-600 font-mono text-xs">{row.code}</td>
              <td class="px-4 py-3 font-medium text-gray-900">{row.name}</td>
              <td class="px-4 py-3 text-gray-600">{row.display_order}</td>
              <td class="px-4 py-3">
                <span class={`inline-flex items-center rounded px-2 py-0.5 text-xs font-medium ${row.is_active ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'}`}>
                  {row.is_active ? 'active' : 'inactive'}
                </span>
              </td>
              <td class="px-4 py-3">
                <a href={`/admin/degree-levels/${row.id}`} class="text-xs text-blue-600 hover:underline">Edit</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</AdminLayout>
