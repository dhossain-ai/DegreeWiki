---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import { forbiddenAdminResponse, requireSuperAdmin } from '../../../lib/admin/guard'
import { IMPORT_STATUS_BADGE, BATCH_TYPE_BADGE, FALLBACK_BADGE } from '../../../lib/admin/badges'
import { parseRawData, validateStagedRecord, type StagedEntityType } from '../../../lib/admin/importValidation'
import { applyReviewAction, applyReviewActionToMatching } from '../../../lib/admin/importReview'
import { bulkMergeApprovedPrograms, bulkPublishMergedPrograms, mergeApprovedRow, type MergeAction } from '../../../lib/admin/importMerge'
import { parseBulkJson, parseResearchPackJson } from '../../../lib/admin/importParse'
import { IMPORT_TEMPLATES, TEMPLATE_FIELD_NOTES, type EntityTemplateType } from '../../../lib/admin/importTemplates'
import { AI_PROMPTS } from '../../../lib/admin/importPrompts'
import {
  detectUniSameBatchDuplicates,
  detectUniProductionMatches,
  detectProgSameBatchDuplicates,
  detectProgProductionMatches,
  detectScholSameBatchDuplicates,
  detectScholProductionMatches,
  detectArtSameBatchDuplicates,
  detectArtProductionMatches,
  type QualityWarning,
} from '../../../lib/admin/importQuality'

const guard = await requireSuperAdmin(Astro.cookies, Astro.request, Astro.url.pathname)
if (guard.type === 'redirect') return Astro.redirect(guard.to)
if (guard.type === 'forbidden') return forbiddenAdminResponse()

const { user, supabase } = guard

const { id } = Astro.params
if (!id || !/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i.test(id)) {
  return new Response('Not found', { status: 404 })
}

type BatchRow = {
  id: string
  batch_type: string
  import_status: string
  total_records: number
  processed_count: number
  error_count: number
  notes: string | null
  data_source_id: string | null
  created_at: string
  updated_at: string
}

const { data: batch, error: batchError } = await supabase
  .from('import_batches')
  .select('id, batch_type, import_status, total_records, processed_count, error_count, notes, data_source_id, created_at, updated_at')
  .eq('id', id)
  .single()

if (batchError || !batch) {
  return new Response('Not found', { status: 404 })
}

const b = batch as BatchRow

type VisibleEntityType = 'universities' | 'programs' | 'scholarships' | 'articles'
type VisibleStatusFilter = 'all' | 'pending' | 'validated' | 'needs_review' | 'approved' | 'rejected' | 'skipped' | 'merged' | 'error'

const FILTERABLE_ENTITY_TYPES: readonly VisibleEntityType[] = ['universities', 'programs', 'scholarships', 'articles']
const FILTERABLE_STATUS_OPTIONS: readonly VisibleStatusFilter[] = [
  'all', 'pending', 'validated', 'needs_review', 'approved', 'rejected', 'skipped', 'merged', 'error',
]
const PAGE_SIZE_OPTIONS = [10, 20, 50, 100] as const
const DEFAULT_PAGE_SIZE = 20
const FLASH_QUERY_KEYS = [
  'mergeWarning',
  'imported',
  'warned',
  'failed',
  'quality',
  'bulkAction',
  'bulkSuccess',
  'bulkFailed',
  'batchAction',
  'batchScope',
  'batchSuccess',
  'batchSkipped',
  'batchFailed',
  'batchWarned',
] as const

function buildBatchHref(
  batchId: string,
  currentSearchParams: URLSearchParams,
  updates: Record<string, string | number | null | undefined> = {},
): string {
  const params = new URLSearchParams(currentSearchParams)
  for (const key of FLASH_QUERY_KEYS) {
    params.delete(key)
  }

  for (const [key, value] of Object.entries(updates)) {
    if (value === null || value === undefined || value === '') {
      params.delete(key)
    } else {
      params.set(key, String(value))
    }
  }

  const query = params.toString()
  return query ? `/admin/imports/${batchId}?${query}` : `/admin/imports/${batchId}`
}

type DataSourceRow = { source_url: string; source_title: string | null; source_type: string }
let dataSource: DataSourceRow | null = null
if (b.data_source_id) {
  const { data: ds } = await supabase
    .from('data_sources')
    .select('source_url, source_title, source_type')
    .eq('id', b.data_source_id)
    .single()
  dataSource = (ds ?? null) as DataSourceRow | null
}

// ---- Manual staged record creation ----
// Form uses entity-type-prefixed field names to avoid collisions in the
// mixed-batch case where all four entity groups are visible at once:
//   uni_*   → staging_universities fields
//   prog_*  → staging_programs fields
//   sch_*   → staging_scholarships fields
//   art_*   → staging_articles fields
//   raw_data → shared for all entity types

const VALID_ENTITY_TYPES: readonly StagedEntityType[] = ['universities', 'programs', 'scholarships', 'articles']

const ENTITY_PREFIX: Record<StagedEntityType, string> = {
  universities: 'uni_',
  programs: 'prog_',
  scholarships: 'sch_',
  articles: 'art_',
}

const STAGING_TABLE_NAME: Record<StagedEntityType, string> = {
  universities: 'staging_universities',
  programs: 'staging_programs',
  scholarships: 'staging_scholarships',
  articles: 'staging_articles',
}

function nullIfEmpty(s: string): string | null {
  const v = s.trim()
  return v || null
}

function numericOrNull(s: string): number | null {
  const v = s.trim()
  if (!v) return null
  const n = Number(v)
  return isNaN(n) ? null : n
}

let formError: string | null = null
let reviewError: string | null = null
let mergeError: string | null = null
let mergeWarningPost: string | null = null
let setMatchError: string | null = null
let bulkImportError: string | null = null
let bulkReviewError: string | null = null
let batchActionError: string | null = null
let qualityError: string | null = null
const BATCH_UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i

type BulkErrorEntry = {
  import_batch_id: string
  staging_table: string
  staging_row_id: string
  error_type: string
  error_message: string
}

function stagedValidationValues(resolvedFields: Record<string, string | number | null>): Record<string, string> {
  return {
    extracted_name: String(resolvedFields.extracted_name ?? ''),
    extracted_country_code: String(resolvedFields.extracted_country_code ?? ''),
    extracted_official_url: String(resolvedFields.extracted_official_url ?? ''),
    extracted_title: String(resolvedFields.extracted_title ?? ''),
    extracted_degree_level_code: String(resolvedFields.extracted_degree_level_code ?? ''),
    extracted_language: String(resolvedFields.extracted_language ?? ''),
    extracted_tuition_amount: resolvedFields.extracted_tuition_amount != null
      ? String(resolvedFields.extracted_tuition_amount) : '',
    extracted_deadline: String(resolvedFields.extracted_deadline ?? ''),
    extracted_amount: resolvedFields.extracted_amount != null
      ? String(resolvedFields.extracted_amount) : '',
    extracted_slug: String(resolvedFields.extracted_slug ?? ''),
    extracted_category: String(resolvedFields.extracted_category ?? ''),
    extracted_content: String(resolvedFields.extracted_content ?? ''),
  }
}

async function resolveCountryCodeFromRaw(rawData: Record<string, unknown>): Promise<string | null> {
  const rawCountry = rawData.country
  if (rawCountry === null || rawCountry === undefined) return null
  const countryText = String(rawCountry).trim()
  if (!countryText) return null
  if (/^[a-z]{2}$/i.test(countryText)) return countryText.toUpperCase()

  const { data } = await supabase
    .from('countries')
    .select('iso2, name')
    .ilike('name', countryText)
    .limit(2)

  const matches = ((data ?? []) as { iso2: string; name: string }[])
    .filter(country => country.name.toLowerCase() === countryText.toLowerCase())
  return matches.length === 1 ? matches[0].iso2.toUpperCase() : null
}

async function runAutomaticQualityChecks(batchId: string, batchType: string): Promise<number> {
  const autoWarnings: QualityWarning[] = []

  if (batchType === 'universities' || batchType === 'mixed') {
    const { data: uniAutoRows } = await supabase
      .from('staging_universities')
      .select('id, extracted_name, extracted_official_url')
      .eq('import_batch_id', batchId)
      .limit(100)
    const uar = (uniAutoRows ?? []) as { id: string; extracted_name: string | null; extracted_official_url: string | null }[]
    autoWarnings.push(...detectUniSameBatchDuplicates(uar))
    autoWarnings.push(...await detectUniProductionMatches(supabase, uar))
  }
  if (batchType === 'programs' || batchType === 'mixed') {
    const { data: progAutoRows } = await supabase
      .from('staging_programs')
      .select('id, extracted_title, extracted_degree_level_code, staging_university_id')
      .eq('import_batch_id', batchId)
      .limit(100)
    const par = (progAutoRows ?? []) as { id: string; extracted_title: string | null; extracted_degree_level_code: string | null; staging_university_id: string | null }[]
    autoWarnings.push(...detectProgSameBatchDuplicates(par))
    autoWarnings.push(...await detectProgProductionMatches(supabase, par))
  }
  if (batchType === 'scholarships' || batchType === 'mixed') {
    const { data: scholAutoRows } = await supabase
      .from('staging_scholarships')
      .select('id, extracted_name')
      .eq('import_batch_id', batchId)
      .limit(100)
    const sar = (scholAutoRows ?? []) as { id: string; extracted_name: string | null }[]
    autoWarnings.push(...detectScholSameBatchDuplicates(sar))
    autoWarnings.push(...await detectScholProductionMatches(supabase, sar))
  }
  if (batchType === 'articles' || batchType === 'mixed') {
    const { data: artAutoRows } = await supabase
      .from('staging_articles')
      .select('id, extracted_title, extracted_slug')
      .eq('import_batch_id', batchId)
      .limit(100)
    const aar = (artAutoRows ?? []) as { id: string; extracted_title: string | null; extracted_slug: string | null }[]
    autoWarnings.push(...detectArtSameBatchDuplicates(aar))
    autoWarnings.push(...await detectArtProductionMatches(supabase, aar))
  }

  await supabase
    .from('staging_errors')
    .delete()
    .eq('import_batch_id', batchId)
    .in('error_type', ['same_batch_duplicate', 'possible_production_match'])

  if (autoWarnings.length > 0) {
    await supabase.from('staging_errors').insert(
      autoWarnings.map(w => ({
        import_batch_id: batchId,
        staging_table: w.stagingTable,
        staging_row_id: w.rowId,
        error_type: w.errorType,
        error_message: w.errorMessage,
      }))
    )
  }

  return autoWarnings.length
}

async function runAutoQualityAfterImport(inserted: number): Promise<number> {
  if (inserted <= 0) return -1
  try {
    return await runAutomaticQualityChecks(b.id, b.batch_type)
  } catch (autoQErr) {
    console.error('[bulk_import] auto quality check failed:', autoQErr instanceof Error ? autoQErr.message : String(autoQErr))
    return -1
  }
}

async function importResearchPack(jsonInput: string): Promise<
  | { ok: true; inserted: number; warned: number; failed: number }
  | { ok: false; error: string }
> {
  if (b.batch_type !== 'mixed') {
    return { ok: false, error: 'Nested university + programs research packs are supported only in mixed batches.' }
  }

  const parseResult = parseResearchPackJson(jsonInput)
  if (!parseResult.ok) return parseResult

  const errorEntries: BulkErrorEntry[] = []
  let inserted = 0
  let warned = 0
  let failed = parseResult.nonObjectCount

  const universityFields = { ...parseResult.university.fields }
  if (!universityFields.extracted_country_code) {
    universityFields.extracted_country_code = await resolveCountryCodeFromRaw(parseResult.university.rawData)
  }
  const universityWarnings = [
    ...parseResult.university.parseWarnings,
    ...validateStagedRecord('universities', stagedValidationValues(universityFields)).warnings,
  ]
  const universityStatus = universityWarnings.length === 0 ? 'validated' : 'pending'

  const { data: uniData, error: uniError } = await supabase
    .from('staging_universities')
    .insert({
      import_batch_id: b.id,
      raw_data: parseResult.university.rawData,
      extracted_name: (universityFields.extracted_name as string | null) ?? null,
      extracted_country_code: (universityFields.extracted_country_code as string | null) ?? null,
      extracted_official_url: (universityFields.extracted_official_url as string | null) ?? null,
      import_status: universityStatus,
    })
    .select('id')
    .single()

  if (uniError || !uniData) {
    console.error('[bulk_import] research pack staging_universities insert failed:', uniError?.code)
    return { ok: false, error: 'Failed to insert the staged university. Please try again.' }
  }

  const stagingUniversityId = (uniData as { id: string }).id
  inserted++
  if (universityWarnings.length > 0) {
    warned++
    for (const warning of universityWarnings) {
      errorEntries.push({
        import_batch_id: b.id,
        staging_table: 'staging_universities',
        staging_row_id: stagingUniversityId,
        error_type: 'validation_warning',
        error_message: warning,
      })
    }
  }

  for (const row of parseResult.programs) {
    const resolvedFields = {
      ...row.fields,
      staging_university_id: stagingUniversityId,
    }
    const rowWarnings = [
      ...row.parseWarnings,
      ...validateStagedRecord('programs', stagedValidationValues(resolvedFields)).warnings,
    ]
    const importStatus = rowWarnings.length === 0 ? 'validated' : 'pending'

    const { data, error } = await supabase
      .from('staging_programs')
      .insert({
        import_batch_id: b.id,
        raw_data: row.rawData,
        extracted_title: (resolvedFields.extracted_title as string | null) ?? null,
        extracted_degree_level_code: (resolvedFields.extracted_degree_level_code as string | null) ?? null,
        extracted_language: (resolvedFields.extracted_language as string | null) ?? null,
        extracted_tuition_amount: (resolvedFields.extracted_tuition_amount as number | null) ?? null,
        extracted_deadline: (resolvedFields.extracted_deadline as string | null) ?? null,
        staging_university_id: stagingUniversityId,
        import_status: importStatus,
      })
      .select('id')
      .single()

    if (error || !data) {
      console.error('[bulk_import] research pack staging_programs insert failed:', error?.code)
      failed++
      continue
    }

    const programId = (data as { id: string }).id
    inserted++
    if (rowWarnings.length > 0) {
      warned++
      for (const warning of rowWarnings) {
        errorEntries.push({
          import_batch_id: b.id,
          staging_table: 'staging_programs',
          staging_row_id: programId,
          error_type: 'validation_warning',
          error_message: warning,
        })
      }
    }
  }

  if (errorEntries.length > 0) {
    await supabase.from('staging_errors').insert(errorEntries)
  }

  const totalReceived = 1 + parseResult.programs.length + parseResult.nonObjectCount
  const { error: countErr } = await supabase
    .from('import_batches')
    .update({
      total_records: b.total_records + totalReceived,
      processed_count: b.processed_count + inserted,
      error_count: b.error_count + failed,
    })
    .eq('id', b.id)
  if (countErr) {
    console.error('[bulk_import] research pack batch count update failed:', countErr.code)
  }

  if (inserted > 0 && b.import_status === 'pending') {
    await supabase.from('import_batches').update({ import_status: 'needs_review' }).eq('id', b.id)
  }

  return { ok: true, inserted, warned, failed }
}

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData()
  const postAction = fd.get('_action')?.toString() ?? ''
  const redirectToBatch = (updates: Record<string, string | number | null | undefined> = {}) =>
    Astro.redirect(buildBatchHref(b.id, Astro.url.searchParams, updates))

  if (postAction === 'review') {
    const result = await applyReviewAction(supabase, {
      entityType: fd.get('entity_type')?.toString().trim() ?? '',
      rowId: fd.get('row_id')?.toString().trim() ?? '',
      batchId: b.id,
      action: fd.get('review_action')?.toString().trim() ?? '',
      reviewNotes: fd.get('review_notes')?.toString() ?? '',
      reviewerUserId: user.id,
    })
    if (result.ok) {
      return redirectToBatch()
    }
    reviewError = result.error
  } else if (postAction === 'bulk_review') {
    const rawEntityType = fd.get('entity_type')?.toString().trim() ?? ''
    const rawAction = fd.get('review_action')?.toString().trim() ?? ''
    const visibleRowIdSet = new Set(
      fd.getAll('visible_row_ids')
        .map(value => value.toString().trim())
        .filter(value => BATCH_UUID_RE.test(value)),
    )
    const selectedRowIds = [
      ...new Set(
        fd.getAll('row_ids')
          .map(value => value.toString().trim())
          .filter(value => BATCH_UUID_RE.test(value)),
      ),
    ]

    if (!(FILTERABLE_ENTITY_TYPES as readonly string[]).includes(rawEntityType)) {
      bulkReviewError = 'Invalid entity type for bulk review.'
    } else if (!['approve', 'reject', 'skip', 'reset'].includes(rawAction)) {
      bulkReviewError = 'Invalid bulk review action.'
    } else if (selectedRowIds.length === 0) {
      bulkReviewError = 'Select at least one visible row first.'
    } else if (visibleRowIdSet.size === 0) {
      bulkReviewError = 'This bulk action requires visible rows from the current page.'
    } else if (selectedRowIds.some(rowId => !visibleRowIdSet.has(rowId))) {
      bulkReviewError = 'Bulk actions can apply only to rows visible on the current page.'
    } else {
      if (rawEntityType === 'universities') {
        const { data: selectedUniversityRows } = await supabase
          .from('staging_universities')
          .select('id, raw_data')
          .in('id', selectedRowIds)
          .eq('import_batch_id', b.id)

        const helperSelected = ((selectedUniversityRows ?? []) as Array<{ id: string; raw_data: Record<string, unknown> | null }>)
          .some((row) => row.raw_data?.helper_kind === 'program_import_selected_university')

        if (helperSelected) {
          bulkReviewError = 'Program-import helper university rows cannot be changed through bulk review.'
        }
      }

      if (!bulkReviewError) {
        let successCount = 0
        let failedCount = 0

        for (const rowId of selectedRowIds) {
          const result = await applyReviewAction(supabase, {
            entityType: rawEntityType,
            rowId,
            batchId: b.id,
            action: rawAction,
            reviewNotes: '',
            reviewerUserId: user.id,
          })

          if (result.ok) successCount += 1
          else failedCount += 1
        }

        return redirectToBatch({
          bulkAction: rawAction,
          bulkSuccess: successCount,
          bulkFailed: failedCount,
        })
      }
    }
  } else if (postAction === 'bulk_review_matching') {
    const confirm = fd.get('confirm_all_matching')?.toString().trim()
    const rawEntityType = fd.get('entity_type')?.toString().trim() ?? ''
    const rawStatusFilter = fd.get('status_filter')?.toString().trim() ?? 'all'

    if (confirm !== 'yes') {
      batchActionError = 'Confirm the all-matching approval before continuing.'
    } else {
      const result = await applyReviewActionToMatching(supabase, {
        entityType: rawEntityType,
        batchId: b.id,
        statusFilter: rawStatusFilter,
        action: 'approve',
        reviewerUserId: user.id,
      })

      if (result.ok) {
        return redirectToBatch({
          batchAction: 'approve_matching',
          batchSuccess: result.approved,
          batchSkipped: result.skipped,
          batchFailed: result.failed,
        })
      }

      batchActionError = result.error
    }
  } else if (postAction === 'bulk_merge_programs') {
    const mergeScope = fd.get('merge_scope')?.toString().trim() ?? 'selected'
    const rawStatusFilter = fd.get('status_filter')?.toString().trim() ?? 'all'
    const visibleRowIdSet = new Set(
      fd.getAll('visible_row_ids')
        .map(value => value.toString().trim())
        .filter(value => BATCH_UUID_RE.test(value)),
    )
    const selectedRowIds = [
      ...new Set(
        fd.getAll('row_ids')
          .map(value => value.toString().trim())
          .filter(value => BATCH_UUID_RE.test(value)),
      ),
    ]

    if (mergeScope === 'selected') {
      if (selectedRowIds.length === 0) {
        batchActionError = 'Select at least one visible approved program row first.'
      } else if (visibleRowIdSet.size === 0) {
        batchActionError = 'This merge action requires visible rows from the current page.'
      } else if (selectedRowIds.some(rowId => !visibleRowIdSet.has(rowId))) {
        batchActionError = 'Bulk merge can apply only to program rows visible on the current page.'
      } else {
        const result = await bulkMergeApprovedPrograms(supabase, {
          batchId: b.id,
          rowIds: selectedRowIds,
        })

        if (result.ok) {
          return redirectToBatch({
            batchAction: 'merge_selected_programs',
            batchScope: 'selected',
            batchSuccess: result.merged,
            batchSkipped: result.skipped,
            batchFailed: result.failed,
            batchWarned: result.warned > 0 ? result.warned : null,
          })
        }

        batchActionError = result.error
      }
    } else if (mergeScope === 'matching') {
      const confirm = fd.get('confirm_merge_matching')?.toString().trim()

      if (confirm !== 'yes') {
        batchActionError = 'Confirm the all-matching merge before continuing.'
      } else {
        const result = await bulkMergeApprovedPrograms(supabase, {
          batchId: b.id,
          statusFilter: rawStatusFilter,
        })

        if (result.ok) {
          return redirectToBatch({
            batchAction: 'merge_matching_programs',
            batchScope: 'matching',
            batchSuccess: result.merged,
            batchSkipped: result.skipped,
            batchFailed: result.failed,
            batchWarned: result.warned > 0 ? result.warned : null,
          })
        }

        batchActionError = result.error
      }
    } else {
      batchActionError = 'Invalid bulk merge scope.'
    }
  } else if (postAction === 'bulk_publish_programs') {
    const confirm = fd.get('confirm_publish_matching')?.toString().trim()
    const rawStatusFilter = fd.get('status_filter')?.toString().trim() ?? 'all'

    if (confirm !== 'yes') {
      batchActionError = 'Confirm the publish action before continuing.'
    } else {
      const result = await bulkPublishMergedPrograms(supabase, {
        batchId: b.id,
        statusFilter: rawStatusFilter,
      })

      if (result.ok) {
        return redirectToBatch({
          batchAction: 'publish_matching_programs',
          batchScope: 'matching',
          batchSuccess: result.published,
          batchSkipped: result.skipped,
          batchFailed: result.failed,
        })
      }

      batchActionError = result.error
    }
  } else if (postAction === 'merge') {
    const confirm = fd.get('confirm')?.toString().trim()
    if (confirm !== 'yes') {
      mergeError = 'Merge confirmation is required.'
    } else {
      const rawEntityType = fd.get('entity_type')?.toString().trim() ?? ''
      const rawRowId = fd.get('row_id')?.toString().trim() ?? ''
      const rawMergeAction = fd.get('merge_action')?.toString().trim() ?? 'create_new'
      const mergeAction: MergeAction = rawMergeAction === 'update_existing' ? 'update_existing' : 'create_new'

      // Batch type must match entity type unless batch is mixed.
      if (b.batch_type !== 'mixed' && b.batch_type !== rawEntityType) {
        mergeError = 'Entity type does not match this batch type.'
      } else {
        const result = await mergeApprovedRow(supabase, {
          entityType: rawEntityType,
          rowId: rawRowId,
          batchId: b.id,
          action: mergeAction,
        })
        if (result.ok) {
          if (result.warning) {
            return redirectToBatch({ mergeWarning: result.warning })
          }
          return redirectToBatch()
        }
        mergeError = result.error
      }
    }
  } else if (postAction === 'bulk_import') {
    const rawEntityType = fd.get('entity_type')?.toString().trim() ?? ''
    const jsonInput = fd.get('bulk_json')?.toString() ?? ''
    const researchPackProbe = parseResearchPackJson(jsonInput)
    const shouldImportResearchPack = rawEntityType === 'research_pack' || researchPackProbe.ok

    if (shouldImportResearchPack) {
      if (b.batch_type !== 'mixed') {
        bulkImportError = 'Nested university + programs research packs are supported only in mixed batches.'
      } else {
        const researchPackResult = await importResearchPack(jsonInput)
        if (!researchPackResult.ok) {
          bulkImportError = researchPackResult.error
        } else {
          const autoQualityCount = await runAutoQualityAfterImport(researchPackResult.inserted)
          return redirectToBatch({
            imported: researchPackResult.inserted,
            warned: researchPackResult.warned,
            failed: researchPackResult.failed,
            quality: autoQualityCount >= 0 ? autoQualityCount : null,
          })
        }
      }
    } else if (!(VALID_ENTITY_TYPES as readonly string[]).includes(rawEntityType)) {
      bulkImportError = 'Invalid entity type.'
    } else if (b.batch_type !== 'mixed' && b.batch_type !== rawEntityType) {
      bulkImportError = 'Entity type does not match this batch type.'
    } else {
      const entityType = rawEntityType as StagedEntityType

      const parseResult = parseBulkJson(jsonInput, entityType)

      if (!parseResult.ok) {
        bulkImportError = parseResult.error
      } else {
        const { rows, nonObjectCount } = parseResult

        // For programs: batch-validate staging_university_ids against this batch.
        // Validation is split from importParse.ts (pure) to keep Supabase calls here.
        const validStagingUniIds = new Set<string>()
        if (entityType === 'programs' && rows.length > 0) {
          const candidateIds = [
            ...new Set(
              rows
                .map(r => r.fields.staging_university_id)
                .filter((v): v is string => typeof v === 'string'),
            ),
          ]
          if (candidateIds.length > 0) {
            const { data: validUnis } = await supabase
              .from('staging_universities')
              .select('id')
              .in('id', candidateIds)
              .eq('import_batch_id', b.id)
            for (const u of validUnis ?? []) {
              validStagingUniIds.add((u as { id: string }).id)
            }
          }
        }

        let inserted = 0
        let warned = 0
        let failed = nonObjectCount

        type ErrorEntry = {
          import_batch_id: string
          staging_table: string
          staging_row_id: string
          error_type: string
          error_message: string
        }
        const errorEntries: ErrorEntry[] = []
        const stagingTableName = STAGING_TABLE_NAME[entityType]

        for (const row of rows) {
          const resolvedFields = { ...row.fields }
          const rowWarnings = [...row.parseWarnings]

          // For programs: reject staging_university_id that is not in this batch.
          if (entityType === 'programs') {
            const stagingUniId = resolvedFields.staging_university_id as string | null
            if (stagingUniId !== null && !validStagingUniIds.has(stagingUniId)) {
              resolvedFields.staging_university_id = null
              rowWarnings.push('staging_university_id does not belong to this batch and was set to null')
            }
          }

          // Convert field values to strings for validateStagedRecord.
          const vals: Record<string, string> = {
            extracted_name: String(resolvedFields.extracted_name ?? ''),
            extracted_country_code: String(resolvedFields.extracted_country_code ?? ''),
            extracted_official_url: String(resolvedFields.extracted_official_url ?? ''),
            extracted_title: String(resolvedFields.extracted_title ?? ''),
            extracted_degree_level_code: String(resolvedFields.extracted_degree_level_code ?? ''),
            extracted_language: String(resolvedFields.extracted_language ?? ''),
            extracted_tuition_amount: resolvedFields.extracted_tuition_amount != null
              ? String(resolvedFields.extracted_tuition_amount) : '',
            extracted_deadline: String(resolvedFields.extracted_deadline ?? ''),
            extracted_amount: resolvedFields.extracted_amount != null
              ? String(resolvedFields.extracted_amount) : '',
            extracted_slug: String(resolvedFields.extracted_slug ?? ''),
            extracted_category: String(resolvedFields.extracted_category ?? ''),
            extracted_content: String(resolvedFields.extracted_content ?? ''),
          }

          const { warnings: validationWarnings } = validateStagedRecord(entityType, vals)
          const allWarnings = [...rowWarnings, ...validationWarnings]
          const importStatus = allWarnings.length === 0 ? 'validated' : 'pending'

          let insertedId: string | null = null
          let insertFailed = false

          if (entityType === 'universities') {
            const { data, error } = await supabase
              .from('staging_universities')
              .insert({
                import_batch_id: b.id,
                raw_data: row.rawData,
                extracted_name: (resolvedFields.extracted_name as string | null) ?? null,
                extracted_country_code: (resolvedFields.extracted_country_code as string | null) ?? null,
                extracted_official_url: (resolvedFields.extracted_official_url as string | null) ?? null,
                import_status: importStatus,
              })
              .select('id')
              .single()
            if (error || !data) {
              console.error('[bulk_import] staging_universities insert failed:', error?.code)
              insertFailed = true
            } else {
              insertedId = (data as { id: string }).id
            }
          } else if (entityType === 'programs') {
            const { data, error } = await supabase
              .from('staging_programs')
              .insert({
                import_batch_id: b.id,
                raw_data: row.rawData,
                extracted_title: (resolvedFields.extracted_title as string | null) ?? null,
                extracted_degree_level_code: (resolvedFields.extracted_degree_level_code as string | null) ?? null,
                extracted_language: (resolvedFields.extracted_language as string | null) ?? null,
                extracted_tuition_amount: (resolvedFields.extracted_tuition_amount as number | null) ?? null,
                extracted_deadline: (resolvedFields.extracted_deadline as string | null) ?? null,
                staging_university_id: (resolvedFields.staging_university_id as string | null) ?? null,
                import_status: importStatus,
              })
              .select('id')
              .single()
            if (error || !data) {
              console.error('[bulk_import] staging_programs insert failed:', error?.code)
              insertFailed = true
            } else {
              insertedId = (data as { id: string }).id
            }
          } else if (entityType === 'scholarships') {
            const { data, error } = await supabase
              .from('staging_scholarships')
              .insert({
                import_batch_id: b.id,
                raw_data: row.rawData,
                extracted_name: (resolvedFields.extracted_name as string | null) ?? null,
                extracted_amount: (resolvedFields.extracted_amount as number | null) ?? null,
                extracted_deadline: (resolvedFields.extracted_deadline as string | null) ?? null,
                import_status: importStatus,
              })
              .select('id')
              .single()
            if (error || !data) {
              console.error('[bulk_import] staging_scholarships insert failed:', error?.code)
              insertFailed = true
            } else {
              insertedId = (data as { id: string }).id
            }
          } else {
            const { data, error } = await supabase
              .from('staging_articles')
              .insert({
                import_batch_id: b.id,
                raw_data: row.rawData,
                extracted_title: (resolvedFields.extracted_title as string | null) ?? null,
                extracted_slug: (resolvedFields.extracted_slug as string | null) ?? null,
                extracted_category: (resolvedFields.extracted_category as string | null) ?? null,
                extracted_content: (resolvedFields.extracted_content as string | null) ?? null,
                import_status: importStatus,
              })
              .select('id')
              .single()
            if (error || !data) {
              console.error('[bulk_import] staging_articles insert failed:', error?.code)
              insertFailed = true
            } else {
              insertedId = (data as { id: string }).id
            }
          }

          if (insertFailed) {
            failed++
          } else if (insertedId) {
            inserted++
            if (allWarnings.length > 0) {
              warned++
              for (const w of allWarnings) {
                errorEntries.push({
                  import_batch_id: b.id,
                  staging_table: stagingTableName,
                  staging_row_id: insertedId,
                  error_type: 'validation_warning',
                  error_message: w,
                })
              }
            }
          }
        }

        // Batch-insert all staging_errors at once.
        if (errorEntries.length > 0) {
          await supabase.from('staging_errors').insert(errorEntries)
        }

        // Update import_batches counts (best-effort; failure is non-fatal).
        // Semantics: total_records = rows received; processed_count = rows inserted
        // into staging (validated or pending); error_count = rows that failed to
        // insert (non-object parse failures + DB insert errors). Validation warnings
        // do not count as errors — warned rows still insert successfully.
        const totalReceived = rows.length + nonObjectCount
        if (totalReceived > 0) {
          const { error: countErr } = await supabase
            .from('import_batches')
            .update({
              total_records: b.total_records + totalReceived,
              processed_count: b.processed_count + inserted,
              error_count: b.error_count + failed,
            })
            .eq('id', b.id)
          if (countErr) {
            console.error('[bulk_import] batch count update failed:', countErr.code)
          }
        }

        // Mark batch as needs_review after first successful staged insert.
        if (inserted > 0 && b.import_status === 'pending') {
          await supabase.from('import_batches').update({ import_status: 'needs_review' }).eq('id', b.id)
        }

        // Auto-run quality checks after successful bulk import (non-fatal).
        let autoQualityCount = -1
        if (inserted > 0) {
          try {
            const bType = b.batch_type
            const autoWarnings: QualityWarning[] = []

            if (bType === 'universities' || bType === 'mixed') {
              const { data: uniAutoRows } = await supabase
                .from('staging_universities')
                .select('id, extracted_name, extracted_official_url')
                .eq('import_batch_id', b.id)
                .limit(100)
              const uar = (uniAutoRows ?? []) as { id: string; extracted_name: string | null; extracted_official_url: string | null }[]
              autoWarnings.push(...detectUniSameBatchDuplicates(uar))
              autoWarnings.push(...await detectUniProductionMatches(supabase, uar))
            }
            if (bType === 'programs' || bType === 'mixed') {
              const { data: progAutoRows } = await supabase
                .from('staging_programs')
                .select('id, extracted_title, extracted_degree_level_code, staging_university_id')
                .eq('import_batch_id', b.id)
                .limit(100)
              const par = (progAutoRows ?? []) as { id: string; extracted_title: string | null; extracted_degree_level_code: string | null; staging_university_id: string | null }[]
              autoWarnings.push(...detectProgSameBatchDuplicates(par))
              autoWarnings.push(...await detectProgProductionMatches(supabase, par))
            }
            if (bType === 'scholarships' || bType === 'mixed') {
              const { data: scholAutoRows } = await supabase
                .from('staging_scholarships')
                .select('id, extracted_name')
                .eq('import_batch_id', b.id)
                .limit(100)
              const sar = (scholAutoRows ?? []) as { id: string; extracted_name: string | null }[]
              autoWarnings.push(...detectScholSameBatchDuplicates(sar))
              autoWarnings.push(...await detectScholProductionMatches(supabase, sar))
            }
            if (bType === 'articles' || bType === 'mixed') {
              const { data: artAutoRows } = await supabase
                .from('staging_articles')
                .select('id, extracted_title, extracted_slug')
                .eq('import_batch_id', b.id)
                .limit(100)
              const aar = (artAutoRows ?? []) as { id: string; extracted_title: string | null; extracted_slug: string | null }[]
              autoWarnings.push(...detectArtSameBatchDuplicates(aar))
              autoWarnings.push(...await detectArtProductionMatches(supabase, aar))
            }

            await supabase
              .from('staging_errors')
              .delete()
              .eq('import_batch_id', b.id)
              .in('error_type', ['same_batch_duplicate', 'possible_production_match'])

            if (autoWarnings.length > 0) {
              await supabase.from('staging_errors').insert(
                autoWarnings.map(w => ({
                  import_batch_id: b.id,
                  staging_table: w.stagingTable,
                  staging_row_id: w.rowId,
                  error_type: w.errorType,
                  error_message: w.errorMessage,
                }))
              )
            }
            autoQualityCount = autoWarnings.length
          } catch (autoQErr) {
            console.error('[bulk_import] auto quality check failed:', autoQErr instanceof Error ? autoQErr.message : String(autoQErr))
          }
        }

            return redirectToBatch({
              imported: inserted,
              warned,
              failed,
              quality: autoQualityCount >= 0 ? autoQualityCount : null,
            })
      }
    }
  } else if (postAction === 'run_quality_checks') {
    try {
      const bType = b.batch_type
      const allWarnings: QualityWarning[] = []

      if (bType === 'universities' || bType === 'mixed') {
        const { data: uniRows } = await supabase
          .from('staging_universities')
          .select('id, extracted_name, extracted_official_url')
          .eq('import_batch_id', b.id)
          .limit(100)
        const rows = (uniRows ?? []) as { id: string; extracted_name: string | null; extracted_official_url: string | null }[]
        allWarnings.push(...detectUniSameBatchDuplicates(rows))
        allWarnings.push(...await detectUniProductionMatches(supabase, rows))
      }

      if (bType === 'programs' || bType === 'mixed') {
        const { data: progRows } = await supabase
          .from('staging_programs')
          .select('id, extracted_title, extracted_degree_level_code, staging_university_id')
          .eq('import_batch_id', b.id)
          .limit(100)
        const rows = (progRows ?? []) as { id: string; extracted_title: string | null; extracted_degree_level_code: string | null; staging_university_id: string | null }[]
        allWarnings.push(...detectProgSameBatchDuplicates(rows))
        allWarnings.push(...await detectProgProductionMatches(supabase, rows))
      }

      if (bType === 'scholarships' || bType === 'mixed') {
        const { data: scholRows } = await supabase
          .from('staging_scholarships')
          .select('id, extracted_name')
          .eq('import_batch_id', b.id)
          .limit(100)
        const rows = (scholRows ?? []) as { id: string; extracted_name: string | null }[]
        allWarnings.push(...detectScholSameBatchDuplicates(rows))
        allWarnings.push(...await detectScholProductionMatches(supabase, rows))
      }

      if (bType === 'articles' || bType === 'mixed') {
        const { data: artRows } = await supabase
          .from('staging_articles')
          .select('id, extracted_title, extracted_slug')
          .eq('import_batch_id', b.id)
          .limit(100)
        const rows = (artRows ?? []) as { id: string; extracted_title: string | null; extracted_slug: string | null }[]
        allWarnings.push(...detectArtSameBatchDuplicates(rows))
        allWarnings.push(...await detectArtProductionMatches(supabase, rows))
      }

      // Remove previous Phase 46 quality warnings for this batch only. Does not
      // touch validation_warning entries from Phase 45 or other batches.
      const { error: deleteErr } = await supabase
        .from('staging_errors')
        .delete()
        .eq('import_batch_id', b.id)
        .in('error_type', ['same_batch_duplicate', 'possible_production_match'])

      if (deleteErr) {
        console.error('[run_quality_checks] delete failed:', deleteErr.code)
        qualityError = 'Failed to reset previous quality warnings. Please try again.'
      } else if (allWarnings.length > 0) {
        const { error: insertErr } = await supabase.from('staging_errors').insert(
          allWarnings.map(w => ({
            import_batch_id: b.id,
            staging_table: w.stagingTable,
            staging_row_id: w.rowId,
            error_type: w.errorType,
            error_message: w.errorMessage,
          }))
        )
        if (insertErr) {
          console.error('[run_quality_checks] insert failed:', insertErr.code)
          qualityError = 'Failed to save quality warnings. Please try again.'
        } else {
          return redirectToBatch({ quality: allWarnings.length })
        }
      } else {
        return redirectToBatch({ quality: 0 })
      }
    } catch (err) {
      console.error('[run_quality_checks] error:', err instanceof Error ? err.message : String(err))
      qualityError = 'Quality check failed. Please try again.'
    }
  } else if (postAction === 'set_match_university_id') {
    // Staging-only: links a staging_universities row to a production university UUID.
    // No production writes. Validates batch membership and production record existence.
    const rawRowId = fd.get('row_id')?.toString().trim() ?? ''
    const rawProdId = fd.get('production_university_id')?.toString().trim() ?? ''
    const uuidPattern = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i

    if (!uuidPattern.test(rawRowId)) {
      setMatchError = 'Invalid staging row ID.'
    } else if (!uuidPattern.test(rawProdId)) {
      setMatchError = 'Invalid production university UUID. Enter a valid UUID.'
    } else {
      const { data: stagingRow, error: stagingErr } = await supabase
        .from('staging_universities')
        .select('id, import_status')
        .eq('id', rawRowId)
        .eq('import_batch_id', b.id)
        .single()

      if (stagingErr || !stagingRow) {
        setMatchError = 'Staging university row not found in this batch.'
      } else if ((stagingRow as { id: string; import_status: string }).import_status !== 'approved') {
        setMatchError = 'Only approved staging rows can be linked to a production university.'
      } else {
        const { data: prodRow, error: prodErr } = await supabase
          .from('universities')
          .select('id')
          .eq('id', rawProdId)
          .single()

        if (prodErr || !prodRow) {
          setMatchError = 'Production university not found. Confirm the UUID is correct.'
        } else {
          const { error: linkErr } = await supabase
            .from('staging_universities')
            .update({ match_university_id: rawProdId })
            .eq('id', rawRowId)
            .eq('import_batch_id', b.id)

          if (linkErr) {
            console.error('[set_match_university_id] staging update failed:', linkErr.code, linkErr.message)
            setMatchError = 'Failed to link staging row to production university. Please try again.'
          } else {
            return redirectToBatch()
          }
        }
      }
    }
  } else if (postAction === 'set_match_scholarship_id') {
    const rawRowId = fd.get('row_id')?.toString().trim() ?? ''
    const rawProdId = fd.get('production_scholarship_id')?.toString().trim() ?? ''

    if (!BATCH_UUID_RE.test(rawRowId)) {
      setMatchError = 'Invalid staging row ID.'
    } else if (!BATCH_UUID_RE.test(rawProdId)) {
      setMatchError = 'Invalid production scholarship UUID. Enter a valid UUID.'
    } else {
      const { data: scholStagingRow, error: scholStagingErr } = await supabase
        .from('staging_scholarships')
        .select('id, import_status')
        .eq('id', rawRowId)
        .eq('import_batch_id', b.id)
        .single()

      if (scholStagingErr || !scholStagingRow) {
        setMatchError = 'Staging scholarship row not found in this batch.'
      } else if ((scholStagingRow as { import_status: string }).import_status !== 'approved') {
        setMatchError = 'Only approved staging rows can be linked to a production scholarship.'
      } else {
        const { data: scholProdRow, error: scholProdErr } = await supabase
          .from('scholarships')
          .select('id')
          .eq('id', rawProdId)
          .single()

        if (scholProdErr || !scholProdRow) {
          setMatchError = 'Production scholarship not found. Confirm the UUID is correct.'
        } else {
          const { error: scholLinkErr } = await supabase
            .from('staging_scholarships')
            .update({ match_scholarship_id: rawProdId })
            .eq('id', rawRowId)
            .eq('import_batch_id', b.id)

          if (scholLinkErr) {
            console.error('[set_match_scholarship_id] update failed:', scholLinkErr.code)
            setMatchError = 'Failed to link staging row to production scholarship. Please try again.'
          } else {
            return redirectToBatch()
          }
        }
      }
    }
  } else if (postAction === 'set_match_article_id') {
    const rawRowId = fd.get('row_id')?.toString().trim() ?? ''
    const rawProdId = fd.get('production_article_id')?.toString().trim() ?? ''

    if (!BATCH_UUID_RE.test(rawRowId)) {
      setMatchError = 'Invalid staging row ID.'
    } else if (!BATCH_UUID_RE.test(rawProdId)) {
      setMatchError = 'Invalid production article UUID. Enter a valid UUID.'
    } else {
      const { data: artStagingRow, error: artStagingErr } = await supabase
        .from('staging_articles')
        .select('id, import_status')
        .eq('id', rawRowId)
        .eq('import_batch_id', b.id)
        .single()

      if (artStagingErr || !artStagingRow) {
        setMatchError = 'Staging article row not found in this batch.'
      } else if ((artStagingRow as { import_status: string }).import_status !== 'approved') {
        setMatchError = 'Only approved staging rows can be linked to a production article.'
      } else {
        const { data: artProdRow, error: artProdErr } = await supabase
          .from('articles')
          .select('id')
          .eq('id', rawProdId)
          .single()

        if (artProdErr || !artProdRow) {
          setMatchError = 'Production article not found. Confirm the UUID is correct.'
        } else {
          const { error: artLinkErr } = await supabase
            .from('staging_articles')
            .update({ match_article_id: rawProdId })
            .eq('id', rawRowId)
            .eq('import_batch_id', b.id)

          if (artLinkErr) {
            console.error('[set_match_article_id] update failed:', artLinkErr.code)
            setMatchError = 'Failed to link staging row to production article. Please try again.'
          } else {
            return redirectToBatch()
          }
        }
      }
    }
  } else {
    const rawEntityType = fd.get('entity_type')?.toString().trim() ?? ''

    if (!(VALID_ENTITY_TYPES as readonly string[]).includes(rawEntityType)) {
      formError = 'Invalid entity type.'
    } else {
      const entityType = rawEntityType as StagedEntityType

      if (b.batch_type !== 'mixed' && b.batch_type !== entityType) {
        formError = 'Entity type does not match this batch type.'
      } else {
        const rawDataStr = fd.get('raw_data')?.toString() ?? ''
        const rawDataResult = parseRawData(rawDataStr)

        if (!rawDataResult.ok) {
          formError = rawDataResult.error
        } else {
          const rawData = rawDataResult.value
          const pfx = ENTITY_PREFIX[entityType]
          const fv = (key: string) => fd.get(`${pfx}${key}`)?.toString() ?? ''

          // Build values for validation (validator expects un-prefixed keys)
          const vals: Record<string, string> = {
            extracted_name: fv('extracted_name'),
            extracted_country_code: fv('extracted_country_code'),
            extracted_official_url: fv('extracted_official_url'),
            extracted_title: fv('extracted_title'),
            extracted_degree_level_code: fv('extracted_degree_level_code'),
            extracted_language: fv('extracted_language'),
            extracted_tuition_amount: fv('extracted_tuition_amount'),
            extracted_deadline: fv('extracted_deadline'),
            extracted_amount: fv('extracted_amount'),
            extracted_slug: fv('extracted_slug'),
            extracted_category: fv('extracted_category'),
            extracted_content: fv('extracted_content'),
          }

          const { warnings } = validateStagedRecord(entityType, vals)
          const importStatus = warnings.length === 0 ? 'validated' : 'pending'

          let insertedId: string | null = null
          let insertFailed = false

          // Resolve staging_university_id for manual program form.
          // Validates batch membership so orphan UUIDs are silently ignored.
          let manualProgStagingUniId: string | null = null
          if (entityType === 'programs') {
            const rawSUId = fv('staging_university_id').trim()
            if (rawSUId && BATCH_UUID_RE.test(rawSUId)) {
              const { data: suRow } = await supabase
                .from('staging_universities')
                .select('id')
                .eq('id', rawSUId)
                .eq('import_batch_id', b.id)
                .single()
              if (suRow) manualProgStagingUniId = rawSUId
            }
          }

          if (entityType === 'universities') {
            const { data, error } = await supabase
              .from('staging_universities')
              .insert({
                import_batch_id: b.id,
                raw_data: rawData,
                extracted_name: nullIfEmpty(vals.extracted_name),
                extracted_country_code: nullIfEmpty(vals.extracted_country_code),
                extracted_official_url: nullIfEmpty(vals.extracted_official_url),
                import_status: importStatus,
              })
              .select('id')
              .single()
            if (error || !data) { insertFailed = true } else { insertedId = (data as { id: string }).id }
          } else if (entityType === 'programs') {
            const { data, error } = await supabase
              .from('staging_programs')
              .insert({
                import_batch_id: b.id,
                raw_data: rawData,
                extracted_title: nullIfEmpty(vals.extracted_title),
                extracted_degree_level_code: nullIfEmpty(vals.extracted_degree_level_code),
                extracted_language: nullIfEmpty(vals.extracted_language),
                extracted_tuition_amount: numericOrNull(vals.extracted_tuition_amount),
                extracted_deadline: nullIfEmpty(vals.extracted_deadline),
                staging_university_id: manualProgStagingUniId,
                import_status: importStatus,
              })
              .select('id')
              .single()
            if (error || !data) { insertFailed = true } else { insertedId = (data as { id: string }).id }
          } else if (entityType === 'scholarships') {
            const { data, error } = await supabase
              .from('staging_scholarships')
              .insert({
                import_batch_id: b.id,
                raw_data: rawData,
                extracted_name: nullIfEmpty(vals.extracted_name),
                extracted_amount: numericOrNull(vals.extracted_amount),
                extracted_deadline: nullIfEmpty(vals.extracted_deadline),
                import_status: importStatus,
              })
              .select('id')
              .single()
            if (error || !data) { insertFailed = true } else { insertedId = (data as { id: string }).id }
          } else {
            const { data, error } = await supabase
              .from('staging_articles')
              .insert({
                import_batch_id: b.id,
                raw_data: rawData,
                extracted_title: nullIfEmpty(vals.extracted_title),
                extracted_slug: nullIfEmpty(vals.extracted_slug),
                extracted_category: nullIfEmpty(vals.extracted_category),
                extracted_content: nullIfEmpty(vals.extracted_content),
                import_status: importStatus,
              })
              .select('id')
              .single()
            if (error || !data) { insertFailed = true } else { insertedId = (data as { id: string }).id }
          }

          if (insertFailed) {
            formError = 'Failed to insert staged record. Please try again.'
          } else if (insertedId) {
            if (warnings.length > 0) {
              const rowId = insertedId
              await supabase.from('staging_errors').insert(
                warnings.map(w => ({
                  import_batch_id: b.id,
                  staging_table: STAGING_TABLE_NAME[entityType],
                  staging_row_id: rowId,
                  error_type: 'validation_warning',
                  error_message: w,
                }))
              )
            }
            // Mark batch as needs_review after first manual staged record.
            if (b.import_status === 'pending') {
              await supabase.from('import_batches').update({ import_status: 'needs_review' }).eq('id', b.id)
            }
            return redirectToBatch()
          }
        }
      }
    }
  }
}

// ---- Merge warning (from PRG redirect query params) ----
const mergeWarningParam = Astro.url.searchParams.get('mergeWarning')

// ---- Bulk import summary (from PRG redirect query params) ----
const importedParam = Astro.url.searchParams.get('imported')
const bulkSummary = importedParam !== null
  ? {
      imported: Math.max(0, parseInt(importedParam, 10) || 0),
      warned: Math.max(0, parseInt(Astro.url.searchParams.get('warned') ?? '0', 10) || 0),
      failed: Math.max(0, parseInt(Astro.url.searchParams.get('failed') ?? '0', 10) || 0),
    }
  : null

const bulkReviewActionParam = Astro.url.searchParams.get('bulkAction')
const bulkReviewSummary = bulkReviewActionParam
  ? {
      action: bulkReviewActionParam,
      success: Math.max(0, parseInt(Astro.url.searchParams.get('bulkSuccess') ?? '0', 10) || 0),
      failed: Math.max(0, parseInt(Astro.url.searchParams.get('bulkFailed') ?? '0', 10) || 0),
    }
  : null

const batchActionParam = Astro.url.searchParams.get('batchAction')
const batchActionSummary = batchActionParam
  ? {
      action: batchActionParam,
      scope: Astro.url.searchParams.get('batchScope') ?? '',
      success: Math.max(0, parseInt(Astro.url.searchParams.get('batchSuccess') ?? '0', 10) || 0),
      skipped: Math.max(0, parseInt(Astro.url.searchParams.get('batchSkipped') ?? '0', 10) || 0),
      failed: Math.max(0, parseInt(Astro.url.searchParams.get('batchFailed') ?? '0', 10) || 0),
      warned: Math.max(0, parseInt(Astro.url.searchParams.get('batchWarned') ?? '0', 10) || 0),
    }
  : null

// ---- Quality check summary (from PRG redirect query params) ----
const qualityParam = Astro.url.searchParams.get('quality')
const qualitySummary = qualityParam !== null
  ? { count: Math.max(0, parseInt(qualityParam, 10) || 0) }
  : null

// ---- GET: load staging data ----

type StagingUniversity = {
  id: string
  extracted_name: string | null
  extracted_country_code: string | null
  extracted_official_url: string | null
  match_university_id: string | null
  import_status: string
  review_notes: string | null
  reviewed_by_user_id: string | null
  reviewed_at: string | null
  raw_data: Record<string, unknown>
  created_at: string
}
type StagingProgram = {
  id: string
  extracted_title: string | null
  extracted_degree_level_code: string | null
  extracted_language: string | null
  extracted_tuition_amount: number | null
  staging_university_id: string | null
  match_program_id: string | null
  import_status: string
  review_notes: string | null
  reviewed_by_user_id: string | null
  reviewed_at: string | null
  raw_data: Record<string, unknown>
  created_at: string
}
type StagingScholarship = {
  id: string
  extracted_name: string | null
  extracted_amount: number | null
  match_scholarship_id: string | null
  import_status: string
  review_notes: string | null
  reviewed_by_user_id: string | null
  reviewed_at: string | null
  raw_data: Record<string, unknown>
  created_at: string
}
type StagingArticle = {
  id: string
  extracted_title: string | null
  extracted_slug: string | null
  extracted_category: string | null
  match_article_id: string | null
  import_status: string
  review_notes: string | null
  reviewed_by_user_id: string | null
  reviewed_at: string | null
  raw_data: Record<string, unknown>
  created_at: string
}
type StagingError = {
  id: string
  staging_table: string
  staging_row_id: string | null
  error_type: string
  error_message: string
  created_at: string
}

function normalizeComparableText(value: string | null | undefined): string {
  return String(value ?? '')
    .trim()
    .toLowerCase()
    .replace(/\s+/g, ' ')
}

function isProgramImportHelperRow(rawData: Record<string, unknown>): boolean {
  return rawData.helper_kind === 'program_import_selected_university'
}

const batchType = b.batch_type
const showUniversities = batchType === 'universities' || batchType === 'mixed'
const showPrograms = batchType === 'programs' || batchType === 'mixed'
const showScholarships = batchType === 'scholarships' || batchType === 'mixed'
const showArticles = batchType === 'articles' || batchType === 'mixed'
type StagingStatusRow = { id: string; import_status: string }
type StagingProgramStatusRow = { id: string; import_status: string; match_program_id: string | null }

const visibleEntityOptions = FILTERABLE_ENTITY_TYPES.filter((entity) =>
  entity === 'universities' ? showUniversities
    : entity === 'programs' ? showPrograms
    : entity === 'scholarships' ? showScholarships
    : showArticles,
)

const rawStatusFilter = Astro.url.searchParams.get('status')?.trim() ?? 'all'
const selectedStatusFilter = (FILTERABLE_STATUS_OPTIONS as readonly string[]).includes(rawStatusFilter)
  ? rawStatusFilter as VisibleStatusFilter
  : 'all'
const rawPageSize = parseInt(Astro.url.searchParams.get('pageSize') ?? '', 10)
const selectedPageSize = PAGE_SIZE_OPTIONS.includes(rawPageSize as 10 | 20 | 50 | 100)
  ? rawPageSize as 10 | 20 | 50 | 100
  : DEFAULT_PAGE_SIZE
const requestedPage = Math.max(1, parseInt(Astro.url.searchParams.get('page') ?? '1', 10) || 1)

const [uniMetaResult, progStatusResult, scholStatusResult, artStatusResult, errResult] = await Promise.all([
  showUniversities
    ? supabase
        .from('staging_universities')
        .select('id, extracted_name, extracted_country_code, extracted_official_url, match_university_id, import_status, review_notes, reviewed_by_user_id, reviewed_at, raw_data, created_at')
        .eq('import_batch_id', id)
        .order('created_at', { ascending: false })
    : Promise.resolve({ data: [] }),
  showPrograms
    ? supabase
        .from('staging_programs')
        .select('id, import_status, match_program_id')
        .eq('import_batch_id', id)
    : Promise.resolve({ data: [] }),
  showScholarships
    ? supabase
        .from('staging_scholarships')
        .select('id, import_status')
        .eq('import_batch_id', id)
    : Promise.resolve({ data: [] }),
  showArticles
    ? supabase
        .from('staging_articles')
        .select('id, import_status')
        .eq('import_batch_id', id)
    : Promise.resolve({ data: [] }),
  supabase
    .from('staging_errors')
    .select('id, staging_table, staging_row_id, error_type, error_message, created_at')
    .eq('import_batch_id', id)
    .order('created_at', { ascending: false })
    .limit(100),
])

const stagingUniversities = (uniMetaResult.data ?? []) as StagingUniversity[]
const allProgramStatusRows = (progStatusResult.data ?? []) as StagingProgramStatusRow[]
const allScholarshipStatusRows = (scholStatusResult.data ?? []) as StagingStatusRow[]
const allArticleStatusRows = (artStatusResult.data ?? []) as StagingStatusRow[]
const stagingErrors = (errResult.data ?? []) as StagingError[]

const entityCounts: Record<VisibleEntityType, number> = {
  universities: stagingUniversities.length,
  programs: allProgramStatusRows.length,
  scholarships: allScholarshipStatusRows.length,
  articles: allArticleStatusRows.length,
}

const defaultEntity: VisibleEntityType =
  showPrograms && entityCounts.programs > 0
    ? 'programs'
    : visibleEntityOptions.find((entity) => entityCounts[entity] > 0)
      ?? visibleEntityOptions[0]
      ?? 'programs'

const rawEntityFilter = Astro.url.searchParams.get('entity')?.trim() ?? ''
const activeEntity = visibleEntityOptions.includes(rawEntityFilter as VisibleEntityType)
  ? rawEntityFilter as VisibleEntityType
  : defaultEntity

async function fetchVisibleEntityRows(page: number) {
  const from = (page - 1) * selectedPageSize
  const to = from + selectedPageSize - 1

  if (activeEntity === 'universities') {
    let query = supabase
      .from('staging_universities')
      .select('id, extracted_name, extracted_country_code, extracted_official_url, match_university_id, import_status, review_notes, reviewed_by_user_id, reviewed_at, raw_data, created_at', { count: 'exact' })
      .eq('import_batch_id', id)
    if (selectedStatusFilter !== 'all') query = query.eq('import_status', selectedStatusFilter)
    return query.order('created_at', { ascending: false }).range(from, to)
  }

  if (activeEntity === 'programs') {
    let query = supabase
      .from('staging_programs')
      .select('id, extracted_title, extracted_degree_level_code, extracted_language, extracted_tuition_amount, staging_university_id, match_program_id, import_status, review_notes, reviewed_by_user_id, reviewed_at, raw_data, created_at', { count: 'exact' })
      .eq('import_batch_id', id)
    if (selectedStatusFilter !== 'all') query = query.eq('import_status', selectedStatusFilter)
    return query.order('created_at', { ascending: false }).range(from, to)
  }

  if (activeEntity === 'scholarships') {
    let query = supabase
      .from('staging_scholarships')
      .select('id, extracted_name, extracted_amount, match_scholarship_id, import_status, review_notes, reviewed_by_user_id, reviewed_at, raw_data, created_at', { count: 'exact' })
      .eq('import_batch_id', id)
    if (selectedStatusFilter !== 'all') query = query.eq('import_status', selectedStatusFilter)
    return query.order('created_at', { ascending: false }).range(from, to)
  }

  let query = supabase
    .from('staging_articles')
    .select('id, extracted_title, extracted_slug, extracted_category, match_article_id, import_status, review_notes, reviewed_by_user_id, reviewed_at, raw_data, created_at', { count: 'exact' })
    .eq('import_batch_id', id)
  if (selectedStatusFilter !== 'all') query = query.eq('import_status', selectedStatusFilter)
  return query.order('created_at', { ascending: false }).range(from, to)
}

const initialVisibleRowsResult = await fetchVisibleEntityRows(requestedPage)
const filteredRowCount = initialVisibleRowsResult.count ?? 0
const totalPages = Math.max(1, Math.ceil(filteredRowCount / selectedPageSize))
const currentPage = Math.min(requestedPage, totalPages)
const visibleRowsResult = currentPage === requestedPage
  ? initialVisibleRowsResult
  : await fetchVisibleEntityRows(currentPage)

const visibleUniversities = activeEntity === 'universities'
  ? (visibleRowsResult.data ?? []) as StagingUniversity[]
  : []
const visiblePrograms = activeEntity === 'programs'
  ? (visibleRowsResult.data ?? []) as StagingProgram[]
  : []
const visibleScholarships = activeEntity === 'scholarships'
  ? (visibleRowsResult.data ?? []) as StagingScholarship[]
  : []
const visibleArticles = activeEntity === 'articles'
  ? (visibleRowsResult.data ?? []) as StagingArticle[]
  : []

const programImportHelperRows = stagingUniversities.filter((row) => isProgramImportHelperRow(row.raw_data))
const helperUniversityRowIds = new Set(programImportHelperRows.map((row) => row.id))
const actionableUniversityRows = stagingUniversities.filter((row) => !helperUniversityRowIds.has(row.id))

const errsByRowId = new Map<string, StagingError[]>()
for (const e of stagingErrors) {
  if (e.staging_row_id) {
    const existing = errsByRowId.get(e.staging_row_id) ?? []
    existing.push(e)
    errsByRowId.set(e.staging_row_id, existing)
  }
}

// Map staging university id → name for programs table display (same-batch unis only).
// For programs-only batches this map will be empty; rows show "Linked (other batch)".
const stagingUniNameMap = new Map<string, string>()
for (const u of stagingUniversities) {
  stagingUniNameMap.set(u.id, u.extracted_name ?? '—')
}

const matchedUniversityIds = [...new Set(
  stagingUniversities
    .map((row) => row.match_university_id)
    .filter((value): value is string => value !== null)
)]
const matchedUniversityNameMap = new Map<string, string>()
if (matchedUniversityIds.length > 0) {
  const { data: matchedUniversities } = await supabase
    .from('universities')
    .select('id, name')
    .in('id', matchedUniversityIds)
  for (const row of matchedUniversities ?? []) {
    matchedUniversityNameMap.set((row as { id: string; name: string }).id, (row as { id: string; name: string }).name)
  }
}

const detectedMatchedUniversityId = matchedUniversityIds.length === 1 ? matchedUniversityIds[0] : null
const detectedMatchedUniversityName = detectedMatchedUniversityId
  ? matchedUniversityNameMap.get(detectedMatchedUniversityId)
    ?? stagingUniversities.find((row) => row.match_university_id === detectedMatchedUniversityId)?.extracted_name
    ?? null
  : null
const detectedProgramImportHelper = programImportHelperRows.length === 1 ? programImportHelperRows[0] : null
const helperSourceUniversityName = detectedProgramImportHelper
  ? String(detectedProgramImportHelper.raw_data.source_university_name ?? '').trim() || null
  : null
const helperSourceMismatch = (
  detectedMatchedUniversityName &&
  helperSourceUniversityName &&
  normalizeComparableText(detectedMatchedUniversityName) !== normalizeComparableText(helperSourceUniversityName)
)
  ? `Source JSON named "${helperSourceUniversityName}", while this batch is linked to "${detectedMatchedUniversityName}".`
  : null

// Batch-resolve program merge eligibility (avoid N+1)
type ProgEligibility = { canMerge: true } | { canMerge: false; reason: string }
const progEligibility = new Map<string, ProgEligibility>()

if (visiblePrograms.length > 0) {
  const mergeCandidates = visiblePrograms.filter(
    r => r.import_status === 'approved' && !r.match_program_id
  )
  const stagingUniIds = [...new Set(
    mergeCandidates.map(r => r.staging_university_id).filter((id): id is string => id != null)
  )]

  // id → match_university_id
  const stagingUniMatchMap = new Map<string, string | null>()
  if (stagingUniIds.length > 0) {
    const { data: stagingUnis } = await supabase
      .from('staging_universities')
      .select('id, match_university_id')
      .in('id', stagingUniIds)
    for (const su of (stagingUnis ?? [])) {
      stagingUniMatchMap.set(
        (su as { id: string; match_university_id: string | null }).id,
        (su as { id: string; match_university_id: string | null }).match_university_id
      )
    }
  }

  for (const prog of mergeCandidates) {
    if (!prog.staging_university_id) {
      progEligibility.set(prog.id, { canMerge: false, reason: 'No linked staging university.' })
      continue
    }
    if (!stagingUniMatchMap.has(prog.staging_university_id)) {
      progEligibility.set(prog.id, { canMerge: false, reason: 'Staging university row not found.' })
      continue
    }
    const matchUniId = stagingUniMatchMap.get(prog.staging_university_id)
    if (!matchUniId) {
      progEligibility.set(prog.id, {
        canMerge: false,
        reason: 'Linked staging university has not been merged yet. Merge the university first.',
      })
      continue
    }
    // FK chain looks complete — degree_level and country_id checked server-side at merge time
    progEligibility.set(prog.id, { canMerge: true })
  }
}

const actionableStaged = actionableUniversityRows.length + allProgramStatusRows.length + allScholarshipStatusRows.length + allArticleStatusRows.length
const helperUniversityCount = programImportHelperRows.length

// Status counts derived from already-fetched arrays — no extra queries.
const allStagedStatuses = [
  ...actionableUniversityRows.map(r => r.import_status),
  ...allProgramStatusRows.map(r => r.import_status),
  ...allScholarshipStatusRows.map(r => r.import_status),
  ...allArticleStatusRows.map(r => r.import_status),
]
const statusCounts = {
  awaitingReview: allStagedStatuses.filter(s => s === 'pending' || s === 'validated').length,
  approved: allStagedStatuses.filter(s => s === 'approved').length,
  rejected: allStagedStatuses.filter(s => s === 'rejected').length,
  skipped: allStagedStatuses.filter(s => s === 'skipped').length,
  merged: allStagedStatuses.filter(s => s === 'merged').length,
  rowErrors: allStagedStatuses.filter(s => s === 'error').length,
}
const qualityIssueCount = stagingErrors.filter(e => e.error_type === 'same_batch_duplicate' || e.error_type === 'possible_production_match').length
const validationWarningCount = stagingErrors.filter(e => e.error_type === 'validation_warning').length
const qualityChecksRun = stagingErrors.some(e => e.error_type === 'same_batch_duplicate' || e.error_type === 'possible_production_match')
const issuesMayBeTruncated = stagingErrors.length === 100
const visibleRowIds =
  activeEntity === 'universities' ? visibleUniversities.map((row) => row.id)
    : activeEntity === 'programs' ? visiblePrograms.map((row) => row.id)
    : activeEntity === 'scholarships' ? visibleScholarships.map((row) => row.id)
    : visibleArticles.map((row) => row.id)
const visibleRowCount = visibleRowIds.length
const pageStart = filteredRowCount === 0 ? 0 : ((currentPage - 1) * selectedPageSize) + 1
const pageEnd = filteredRowCount === 0 ? 0 : pageStart + visibleRowCount - 1
const activeEntityLabel =
  activeEntity === 'universities' ? 'universities'
    : activeEntity === 'programs' ? 'programs'
    : activeEntity === 'scholarships' ? 'scholarships'
    : 'articles'
const currentFilterPath = buildBatchHref(b.id, Astro.url.searchParams)
const buildFilterHref = (updates: Record<string, string | number | null | undefined> = {}) =>
  buildBatchHref(b.id, Astro.url.searchParams, updates)
const isStatusMatch = (status: string) => selectedStatusFilter === 'all' || status === selectedStatusFilter
const blockedBulkReviewStatuses = new Set(['merged', 'processing', 'error'])
const currentEntityMatchingRows =
  activeEntity === 'universities'
    ? actionableUniversityRows.filter((row) => isStatusMatch(row.import_status))
    : activeEntity === 'programs'
      ? allProgramStatusRows.filter((row) => isStatusMatch(row.import_status))
      : activeEntity === 'scholarships'
        ? allScholarshipStatusRows.filter((row) => isStatusMatch(row.import_status))
        : allArticleStatusRows.filter((row) => isStatusMatch(row.import_status))
const approveAllMatchingReadyCount = currentEntityMatchingRows.filter(
  (row) => !blockedBulkReviewStatuses.has(row.import_status) && row.import_status !== 'approved'
).length
const currentFilterApprovedProgramRows = activeEntity === 'programs'
  ? allProgramStatusRows.filter((row) => isStatusMatch(row.import_status) && row.import_status === 'approved' && !row.match_program_id)
  : []
const approvedProgramsReadyToMergeCount = currentFilterApprovedProgramRows.length
const currentFilterMergedProgramIds = activeEntity === 'programs'
  ? [
      ...new Set(
        allProgramStatusRows
          .filter((row) => isStatusMatch(row.import_status) && row.import_status === 'merged' && row.match_program_id)
          .map((row) => row.match_program_id)
          .filter((programId): programId is string => programId !== null)
      ),
    ]
  : []
let mergedDraftProgramsReadyToPublishCount = 0
if (currentFilterMergedProgramIds.length > 0) {
  const { data: publishablePrograms } = await supabase
    .from('programs')
    .select('id')
    .in('id', currentFilterMergedProgramIds)
    .in('content_status', ['draft', 'in_review'])

  mergedDraftProgramsReadyToPublishCount = (publishablePrograms ?? []).length
}

// Guidance message for "what to do next" banner.
let nextStepMessage = ''
if (actionableStaged === 0) {
  nextStepMessage = 'Expand Bulk JSON Import below to paste data, or use Add Staged Record to add one row at a time.'
} else if (!qualityChecksRun) {
  nextStepMessage = `${actionableStaged} row${actionableStaged !== 1 ? 's' : ''} staged. Run quality checks to detect same-batch duplicates and possible existing production records.`
} else if (statusCounts.awaitingReview > 0) {
  nextStepMessage = `${statusCounts.awaitingReview} row${statusCounts.awaitingReview !== 1 ? 's' : ''} awaiting review. Approve, reject, or skip each staged row below.`
} else if (statusCounts.approved > 0) {
  nextStepMessage = `${statusCounts.approved} approved row${statusCounts.approved !== 1 ? 's' : ''} ready to merge. Use the Merge form on each approved row.`
} else if (actionableStaged > 0 && statusCounts.awaitingReview === 0 && statusCounts.approved === 0) {
  nextStepMessage = 'All rows have been processed. This batch is complete.'
}

// needs_review badge supplement — not in the shared IMPORT_STATUS_BADGE map.
const BATCH_STATUS_BADGE: Record<string, string> = {
  ...IMPORT_STATUS_BADGE,
  needs_review: 'bg-amber-100 text-amber-700',
}

// Friendly error type labels for the staging errors section.
const ERROR_TYPE_LABEL: Record<string, string> = {
  validation_warning: 'Validation warning',
  same_batch_duplicate: 'Duplicate in this batch',
  possible_production_match: 'Possible existing record',
}
const REVIEW_ACTION_LABEL: Record<string, string> = {
  approve: 'approved',
  reject: 'rejected',
  skip: 'skipped',
  reset: 'reset',
}
const BATCH_ACTION_LABEL: Record<string, string> = {
  approve_matching: 'Approve all matching',
  merge_selected_programs: 'Merge approved programs',
  merge_matching_programs: 'Merge approved programs',
  publish_matching_programs: 'Publish merged drafts as unverified',
}
const BATCH_ACTION_RESULT_LABEL: Record<string, string> = {
  approve_matching: 'approved',
  merge_selected_programs: 'merged',
  merge_matching_programs: 'merged',
  publish_matching_programs: 'published',
}

const INPUT_CLS = 'block w-full rounded border border-gray-300 px-3 py-1.5 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500'
const LABEL_CLS = 'block text-xs font-medium text-gray-600 mb-1'

// Templates & prompts context — filtered to batch type
const ENTITY_TEMPLATE_TYPES: readonly EntityTemplateType[] = ['universities', 'programs', 'scholarships', 'articles', 'research_pack']
const templateEntityTypes: EntityTemplateType[] = ENTITY_TEMPLATE_TYPES.filter(
  t => (t === 'research_pack' ? b.batch_type === 'mixed' : b.batch_type === 'mixed' || b.batch_type === t)
)
const templateDownloadLinks: Partial<Record<EntityTemplateType, string>> = {}
for (const t of templateEntityTypes) {
  templateDownloadLinks[t] = `data:application/json;charset=utf-8,${encodeURIComponent(IMPORT_TEMPLATES[t])}`
}
const TEMPLATE_LABEL: Record<EntityTemplateType, string> = {
  universities: 'universities',
  programs: 'programs',
  scholarships: 'scholarships',
  articles: 'articles',
  research_pack: 'Research Pack',
}
---
<AdminLayout title={`Import Batch — DegreeWiki Admin`} activePath="/admin/imports" userEmail={user.email ?? ''}>
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-bold text-gray-900">Import Batch</h1>
    <a href="/admin/imports" class="text-sm text-gray-500 hover:underline">← Back to Imports</a>
  </div>

  <div class="mb-6 rounded-lg border border-gray-200 bg-white divide-y divide-gray-100">
    <div class="px-4 py-3 flex items-center gap-3">
      <span class="text-sm font-medium text-gray-500 w-32">Type</span>
      <span class={`inline-flex items-center rounded px-2 py-0.5 text-xs font-medium ${BATCH_TYPE_BADGE[b.batch_type] ?? FALLBACK_BADGE}`}>
        {b.batch_type}
      </span>
    </div>
    <div class="px-4 py-3 flex items-center gap-3">
      <span class="text-sm font-medium text-gray-500 w-32">Status</span>
      <span class={`inline-flex items-center rounded px-2 py-0.5 text-xs font-medium ${BATCH_STATUS_BADGE[b.import_status] ?? FALLBACK_BADGE}`}>
        {b.import_status}
