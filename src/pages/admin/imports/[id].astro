              Clear selection
            </button>
            <button type="submit" class="rounded bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
              Apply to selected
            </button>
            <span data-selection-count class="text-xs text-gray-500">0 selected</span>
          </form>
        )}
      </div>
      {visibleArticles.length > 0 ? (
      <div class="overflow-x-auto rounded-lg border border-gray-200">
        <table class="w-full text-sm text-left">
          <thead class="bg-gray-50 border-b border-gray-200 text-xs text-gray-500 uppercase tracking-wide">
            <tr>
              <th class="px-4 py-3">Select</th>
              <th class="px-4 py-3">Title</th>
              <th class="px-4 py-3">Slug</th>
              <th class="px-4 py-3">Category</th>
              <th class="px-4 py-3">Status</th>
              <th class="px-4 py-3">Notes</th>
              <th class="px-4 py-3">Actions</th>
              <th class="px-4 py-3">Raw Data</th>
            </tr>
          </thead>
          <tbody>
            {visibleArticles.map(row => (
              <tr class="border-b border-gray-100 hover:bg-gray-50 align-top">
                <td class="px-4 py-3">
                  <input
                    form="bulk-review-form"
                    type="checkbox"
                    name="row_ids"
                    value={row.id}
                    data-visible-row-checkbox
                    disabled={row.import_status === 'merged' || row.import_status === 'processing' || row.import_status === 'error'}
                    class="h-4 w-4 rounded border-gray-300 text-blue-600"
                  />
                </td>
                <td class="px-4 py-3 text-gray-700">{row.extracted_title ?? <span class="text-gray-400">—</span>}</td>
                <td class="px-4 py-3 text-xs text-gray-500 font-mono">{row.extracted_slug ?? '—'}</td>
                <td class="px-4 py-3 text-xs text-gray-500">{row.extracted_category ?? '—'}</td>
                <td class="px-4 py-3">
                  <span class={`inline-flex items-center rounded px-2 py-0.5 text-xs font-medium ${IMPORT_STATUS_BADGE[row.import_status] ?? FALLBACK_BADGE}`}>
                    {row.import_status}
                  </span>
                  {(errsByRowId.get(row.id) ?? []).some(e => e.error_type === 'validation_warning') && (
                    <span class="ml-1 inline-flex items-center rounded px-1.5 py-0.5 text-xs font-medium bg-orange-100 text-orange-700">warnings</span>
                  )}
                  {(errsByRowId.get(row.id) ?? []).some(e => e.error_type === 'same_batch_duplicate' || e.error_type === 'possible_production_match') && (
                    <span class="ml-1 inline-flex items-center rounded px-1.5 py-0.5 text-xs font-medium bg-amber-100 text-amber-700">quality</span>
                  )}
                </td>
                <td class="px-4 py-3 text-xs text-gray-500 max-w-[140px]">{row.review_notes ?? '—'}</td>
                <td class="px-3 py-3 text-xs min-w-[200px]">
                  {(errsByRowId.get(row.id) ?? []).length > 0 && (
                    <div class="mb-1.5 space-y-0.5">
                      {(errsByRowId.get(row.id) ?? []).map(e => (
                        <p class={e.error_type === 'validation_warning' ? 'text-orange-600' : 'text-amber-700'}>{e.error_message}</p>
                      ))}
                    </div>
                  )}
                  {row.reviewed_at && (
                    <p class="text-gray-400 mb-1.5">Reviewed {new Date(row.reviewed_at).toLocaleString()}</p>
                  )}
                  {row.import_status !== 'merged' && (
                    <form method="POST" class="space-y-1.5">
                      <input type="hidden" name="_action" value="review" />
                      <input type="hidden" name="entity_type" value="articles" />
                      <input type="hidden" name="row_id" value={row.id} />
                      <div class="flex flex-wrap gap-1">
                        <button name="review_action" value="approve" class="rounded bg-green-600 px-2 py-1 text-xs font-medium text-white hover:bg-green-700">Approve</button>
                        <button name="review_action" value="reject" class="rounded bg-red-600 px-2 py-1 text-xs font-medium text-white hover:bg-red-700">Reject</button>
                        <button name="review_action" value="skip" class="rounded bg-yellow-500 px-2 py-1 text-xs font-medium text-white hover:bg-yellow-600">Skip</button>
                        <button name="review_action" value="reset" class="rounded border border-gray-300 px-2 py-1 text-xs font-medium text-gray-600 hover:bg-gray-50">Reset</button>
                      </div>
                      <details class="mt-0.5">
                        <summary class="text-xs text-gray-400 cursor-pointer hover:text-gray-600">{row.review_notes ? 'Edit note…' : 'Add note…'}</summary>
                        <textarea name="review_notes" rows={2} placeholder="Note…" class="mt-1 block w-full rounded border border-gray-200 px-2 py-1 text-xs text-gray-700 placeholder-gray-300 focus:outline-none focus:border-blue-400">{row.review_notes ?? ''}</textarea>
                      </details>
                    </form>
                  )}
                  {row.import_status === 'approved' && !row.match_article_id && (
                    <div class="mt-2 border-t border-gray-100 pt-2 space-y-3">
                      <details>
                        <summary class="cursor-pointer text-blue-600 hover:text-blue-800 text-xs">Link to existing production article…</summary>
                        <form method="POST" class="mt-2 space-y-1.5">
                          <input type="hidden" name="_action" value="set_match_article_id" />
                          <input type="hidden" name="row_id" value={row.id} />
                          <p class="text-gray-600 text-xs">Paste the production article UUID to enable update-existing merge. No production write occurs until you use Merge.</p>
                          <input
                            type="text"
                            name="production_article_id"
                            placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                            pattern="[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}"
                            required
                            class="block w-full rounded border border-gray-200 px-2 py-1 text-xs font-mono text-gray-700 placeholder-gray-300 focus:outline-none focus:border-blue-400"
                          />
                          <button type="submit" class="rounded bg-blue-600 px-2 py-1 text-xs font-medium text-white hover:bg-blue-700">Link</button>
                        </form>
                      </details>
                      <form method="POST" class="space-y-1.5">
                        <input type="hidden" name="_action" value="merge" />
                        <input type="hidden" name="entity_type" value="articles" />
                        <input type="hidden" name="row_id" value={row.id} />
                        <input type="hidden" name="merge_action" value="create_new" />
                        <p class="text-amber-700 font-medium">This will create a new draft production record.</p>
                        <label class="flex items-start gap-1.5 text-gray-600">
                          <input type="checkbox" name="confirm" value="yes" required class="mt-0.5 shrink-0" />
                          <span>I confirm this creates a production record.</span>
                        </label>
                        <button type="submit" class="rounded bg-amber-600 px-2 py-1 text-xs font-medium text-white hover:bg-amber-700">
                          Merge to Production
                        </button>
                      </form>
                    </div>
                  )}
                  {row.import_status === 'approved' && row.match_article_id && (
                    <form method="POST" class="mt-2 border-t border-gray-100 pt-2 space-y-1.5">
                      <input type="hidden" name="_action" value="merge" />
                      <input type="hidden" name="entity_type" value="articles" />
                      <input type="hidden" name="row_id" value={row.id} />
                      <input type="hidden" name="merge_action" value="update_existing" />
                      <p class="text-amber-700 font-medium">Update existing production article.</p>
                      <p class="text-gray-500">Will patch <code>content</code> only if currently empty in production.</p>
                      <label class="flex items-start gap-1.5 text-gray-600">
                        <input type="checkbox" name="confirm" value="yes" required class="mt-0.5 shrink-0" />
                        <span>I confirm this writes to a production record.</span>
                      </label>
                      <button type="submit" class="rounded bg-orange-600 px-2 py-1 text-xs font-medium text-white hover:bg-orange-700">
                        Update Existing
                      </button>
                    </form>
                  )}
                  {row.import_status === 'merged' && (
                    <p class="mt-2 text-emerald-700 font-medium">Merged to production.</p>
                  )}
                </td>
                <td class="px-4 py-3">
                  <details class="text-xs">
                    <summary class="cursor-pointer text-gray-400 hover:text-gray-600">show</summary>
                    <pre class="mt-1 text-xs text-gray-600 bg-gray-50 p-2 rounded overflow-x-auto max-w-[240px]">{JSON.stringify(row.raw_data, null, 2)}</pre>
                  </details>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      ) : (
        <div class="rounded-lg border border-dashed border-gray-200 bg-white px-4 py-6 text-sm text-gray-500">
          No articles match the current filters.
        </div>
      )}
    </div>
  )}

  {stagingErrors.length > 0 && (
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-3">
        <h2 class="text-base font-semibold text-gray-800">
          Issues ({stagingErrors.length})
        </h2>
        {validationWarningCount > 0 && (
          <span class="text-xs text-orange-700 bg-orange-50 border border-orange-200 rounded px-2 py-0.5">
            {validationWarningCount} validation warning{validationWarningCount !== 1 ? 's' : ''}
          </span>
        )}
        {qualityIssueCount > 0 && (
          <span class="text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded px-2 py-0.5">
            {qualityIssueCount} quality issue{qualityIssueCount !== 1 ? 's' : ''}
          </span>
        )}
      </div>
      <div class="overflow-x-auto rounded-lg border border-orange-200">
        <table class="w-full text-sm text-left">
          <thead class="bg-orange-50 border-b border-orange-200 text-xs text-gray-500 uppercase tracking-wide">
            <tr>
              <th class="px-4 py-3">Type</th>
              <th class="px-4 py-3">Message</th>
              <th class="px-4 py-3">When</th>
              <th class="px-4 py-3">Debug</th>
            </tr>
          </thead>
          <tbody>
            {stagingErrors.map(row => (
              <tr class="border-b border-orange-100 hover:bg-orange-50 align-top">
                <td class="px-4 py-3 text-xs font-medium text-orange-800 whitespace-nowrap">
                  {ERROR_TYPE_LABEL[row.error_type] ?? row.error_type}
                </td>
                <td class="px-4 py-3 text-xs text-gray-700">{row.error_message}</td>
                <td class="px-4 py-3 text-xs text-gray-400 whitespace-nowrap">{new Date(row.created_at).toLocaleString()}</td>
                <td class="px-4 py-3">
                  <details class="text-xs">
                    <summary class="cursor-pointer text-gray-400 hover:text-gray-600">raw</summary>
                    <p class="mt-1 font-mono text-gray-400">{row.staging_table}</p>
                    <p class="mt-0.5 font-mono text-gray-400 break-all">{row.staging_row_id ?? '—'}</p>
                  </details>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  )}

  <script is:inline>
(function () {
  // Tab switching for templates section
  var tabContainer = document.getElementById('tpl-tabs');
  if (tabContainer) {
    var tabs = tabContainer.querySelectorAll('[data-tab]');
    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        var target = tab.getAttribute('data-tab');
        tabs.forEach(function (t) {
          var active = t.getAttribute('data-tab') === target;
          t.classList.toggle('border-indigo-500', active);
          t.classList.toggle('text-indigo-700', active);
          t.classList.toggle('bg-indigo-50', active);
          t.classList.toggle('border-transparent', !active);
          t.classList.toggle('text-gray-500', !active);
        });
        document.querySelectorAll('[data-panel]').forEach(function (panel) {
          panel.classList.toggle('hidden', panel.getAttribute('data-panel') !== target);
        });
      });
    });
  }

  // Copy-to-clipboard for templates and prompts
  document.querySelectorAll('[data-copy-from]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var srcId = btn.getAttribute('data-copy-from');
      var src = document.getElementById(srcId);
      if (!src) return;
      var text = src.value !== undefined ? src.value : (src.textContent || '');
      navigator.clipboard.writeText(text).then(function () {
        var orig = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(function () { btn.textContent = orig; }, 1800);
      }).catch(function () {
        if (src.select) {
          src.select();
          try { document.execCommand('copy'); } catch (_) {}
          var orig2 = btn.textContent;
          btn.textContent = 'Copied!';
          setTimeout(function () { btn.textContent = orig2; }, 1800);
        }
      });
    });
  });

  // JSON preview for bulk import textarea
  var ta = document.getElementById('bulk-json-input');
  var box = document.getElementById('json-preview');
  var statusEl = document.getElementById('json-preview-status');
  var detailEl = document.getElementById('json-preview-detail');
  var noteEl = document.getElementById('json-preview-note');

  if (ta && box && statusEl && detailEl && noteEl) {
    ta.addEventListener('input', function () {
      var val = ta.value.trim();
      if (!val) { box.style.display = 'none'; return; }
      box.style.display = 'block';

      var parsed;
      try { parsed = JSON.parse(val); } catch (e) {
        box.style.borderColor = '#fca5a5';
        box.style.backgroundColor = '#fef2f2';
        statusEl.textContent = 'Invalid JSON';
        statusEl.style.color = '#b91c1c';
        detailEl.textContent = String(e && e.message ? e.message : 'Check for missing commas, brackets, or quotes.');
        detailEl.style.color = '#6b7280';
        noteEl.textContent = '';
        return;
      }

      if (!Array.isArray(parsed)) {
        if (
          parsed &&
          typeof parsed === 'object' &&
          !Array.isArray(parsed) &&
          parsed.university &&
          typeof parsed.university === 'object' &&
          !Array.isArray(parsed.university) &&
          Array.isArray(parsed.programs)
        ) {
          var programObjects = parsed.programs.filter(function (x) {
            return x !== null && typeof x === 'object' && !Array.isArray(x);
          });
          var programSamples = programObjects.slice(0, 3).map(function (item) {
            return String(item.title || '—');
          });
          var universityName = String(parsed.university.name || '1 university');

          box.style.borderColor = '#86efac';
          box.style.backgroundColor = '#f0fdf4';
          statusEl.textContent = 'Valid research pack — 1 university, ' + parsed.programs.length + (parsed.programs.length === 1 ? ' program' : ' programs');
          statusEl.style.color = '#15803d';
          detailEl.textContent = universityName + (programSamples.length > 0 ? ' · Programs: ' + programSamples.join(', ') + (parsed.programs.length > 3 ? '…' : '') : '');
          detailEl.style.color = '#4b5563';
          noteEl.textContent = 'Mixed batches stage the university first and automatically link each program to it.';
          noteEl.style.color = '#9ca3af';
          return;
        }

        box.style.borderColor = '#fca5a5';
        box.style.backgroundColor = '#fef2f2';
        statusEl.textContent = 'Not a supported JSON shape';
        statusEl.style.color = '#b91c1c';
        detailEl.textContent = 'Use a JSON array, or in mixed batches use { "university": { ... }, "programs": [ ... ] }.';
        detailEl.style.color = '#6b7280';
        noteEl.textContent = '';
        return;
      }

      var count = parsed.length;
      var objects = parsed.filter(function (x) {
        return x !== null && typeof x === 'object' && !Array.isArray(x);
      });
      var samples = objects.slice(0, 3).map(function (item) {
        return String(item.name || item.title || item.slug || '—');
      });
      var skipped = count - objects.length;

      box.style.borderColor = '#86efac';
      box.style.backgroundColor = '#f0fdf4';
      statusEl.textContent = 'Valid JSON — ' + count + (count === 1 ? ' item' : ' items') + (skipped > 0 ? ' (' + skipped + ' non-object skipped)' : '');
      statusEl.style.color = '#15803d';
      detailEl.textContent = samples.length > 0 ? 'Sample: ' + samples.join(', ') + (count > 3 ? '…' : '') : '';
      detailEl.style.color = '#4b5563';
      noteEl.textContent = 'Preview does not save data. Final validation happens after import.';
      noteEl.style.color = '#9ca3af';
    });
  }

  var bulkForm = document.getElementById('bulk-review-form');
  if (bulkForm) {
    var rowCheckboxes = bulkForm.ownerDocument.querySelectorAll('[data-visible-row-checkbox]');
    var selectVisibleBtn = bulkForm.querySelector('[data-select-visible]');
    var clearSelectionBtn = bulkForm.querySelector('[data-clear-selection]');
    var selectionCount = bulkForm.querySelector('[data-selection-count]');
    var mirroredForms = bulkForm.ownerDocument.querySelectorAll('[data-mirror-selected-rows]');

    function updateSelectionCount() {
      if (!selectionCount) return;
      var checked = 0;
      rowCheckboxes.forEach(function (checkbox) {
        if (checkbox.checked) checked += 1;
      });
      selectionCount.textContent = checked + ' selected';
    }

    function syncMirroredRowIds(targetForm) {
      targetForm.querySelectorAll('[data-mirrored-row-id]').forEach(function (input) {
        input.remove();
      });

      rowCheckboxes.forEach(function (checkbox) {
        if (!checkbox.checked || checkbox.disabled) return;
        var hidden = document.createElement('input');
        hidden.type = 'hidden';
        hidden.name = 'row_ids';
        hidden.value = checkbox.value;
        hidden.setAttribute('data-mirrored-row-id', 'true');
        targetForm.appendChild(hidden);
      });
    }

    if (selectVisibleBtn) {
      selectVisibleBtn.addEventListener('click', function () {
        rowCheckboxes.forEach(function (checkbox) {
          if (checkbox.disabled) return;
          checkbox.checked = true;
        });
        updateSelectionCount();
      });
    }

    if (clearSelectionBtn) {
      clearSelectionBtn.addEventListener('click', function () {
        rowCheckboxes.forEach(function (checkbox) {
          checkbox.checked = false;
        });
        updateSelectionCount();
      });
    }

    rowCheckboxes.forEach(function (checkbox) {
      checkbox.addEventListener('change', updateSelectionCount);
    });

    mirroredForms.forEach(function (form) {
      form.addEventListener('submit', function () {
        syncMirroredRowIds(form);
      });
    });

    updateSelectionCount();
  }
})();
  </script>
</AdminLayout>
