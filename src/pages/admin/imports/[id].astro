    <div class="px-4 py-3 flex items-center gap-3">
      <span class="text-sm font-medium text-gray-500 w-32">Created</span>
      <span class="text-sm text-gray-400">{new Date(b.created_at).toLocaleString()}</span>
    </div>
    <div class="px-4 py-3 flex items-center gap-3">
      <span class="text-sm font-medium text-gray-500 w-32">Updated</span>
      <span class="text-sm text-gray-400">{new Date(b.updated_at).toLocaleString()}</span>
    </div>
    <div class="px-4 py-3 flex items-center gap-3">
      <span class="text-sm font-medium text-gray-500 w-32">Batch ID</span>
      <span class="text-xs text-gray-400 font-mono">{b.id}</span>
    </div>
  </div>

  <!-- Status summary cards -->
  <div class="mb-4 grid grid-cols-3 sm:grid-cols-6 gap-2">
    <div class="rounded-lg border border-gray-200 bg-white px-3 py-2.5 text-center">
