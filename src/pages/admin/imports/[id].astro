---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import { forbiddenAdminResponse, requireSuperAdmin } from '../../../lib/admin/guard'
import { IMPORT_STATUS_BADGE, BATCH_TYPE_BADGE, FALLBACK_BADGE } from '../../../lib/admin/badges'
import { parseRawData, validateStagedRecord, type StagedEntityType } from '../../../lib/admin/importValidation'
import { applyReviewAction } from '../../../lib/admin/importReview'
import { mergeApprovedRow, type MergeAction } from '../../../lib/admin/importMerge'
import { parseBulkJson } from '../../../lib/admin/importParse'
import {
  detectUniSameBatchDuplicates,
  detectUniProductionMatches,
  detectProgSameBatchDuplicates,
  detectProgProductionMatches,
  detectScholSameBatchDuplicates,
  detectScholProductionMatches,
  detectArtSameBatchDuplicates,
  detectArtProductionMatches,
  type QualityWarning,
} from '../../../lib/admin/importQuality'

const guard = await requireSuperAdmin(Astro.cookies, Astro.request, Astro.url.pathname)
if (guard.type === 'redirect') return Astro.redirect(guard.to)
if (guard.type === 'forbidden') return forbiddenAdminResponse()

const { user, supabase } = guard

const { id } = Astro.params
if (!id || !/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i.test(id)) {
  return new Response('Not found', { status: 404 })
}

type BatchRow = {
  id: string
  batch_type: string
  import_status: string
  total_records: number
  processed_count: number
  error_count: number
  notes: string | null
  data_source_id: string | null
  created_at: string
  updated_at: string
}

const { data: batch, error: batchError } = await supabase
  .from('import_batches')
  .select('id, batch_type, import_status, total_records, processed_count, error_count, notes, data_source_id, created_at, updated_at')
  .eq('id', id)
  .single()

if (batchError || !batch) {
  return new Response('Not found', { status: 404 })
}

const b = batch as BatchRow

type DataSourceRow = { source_url: string; source_title: string | null; source_type: string }
let dataSource: DataSourceRow | null = null
if (b.data_source_id) {
  const { data: ds } = await supabase
    .from('data_sources')
    .select('source_url, source_title, source_type')
    .eq('id', b.data_source_id)
    .single()
  dataSource = (ds ?? null) as DataSourceRow | null
}

// ---- Manual staged record creation ----
// Form uses entity-type-prefixed field names to avoid collisions in the
// mixed-batch case where all four entity groups are visible at once:
//   uni_*   → staging_universities fields
//   prog_*  → staging_programs fields
//   sch_*   → staging_scholarships fields
//   art_*   → staging_articles fields
//   raw_data → shared for all entity types

const VALID_ENTITY_TYPES: readonly StagedEntityType[] = ['universities', 'programs', 'scholarships', 'articles']

const ENTITY_PREFIX: Record<StagedEntityType, string> = {
  universities: 'uni_',
  programs: 'prog_',
  scholarships: 'sch_',
  articles: 'art_',
}

const STAGING_TABLE_NAME: Record<StagedEntityType, string> = {
  universities: 'staging_universities',
  programs: 'staging_programs',
  scholarships: 'staging_scholarships',
  articles: 'staging_articles',
}

function nullIfEmpty(s: string): string | null {
  const v = s.trim()
  return v || null
}

function numericOrNull(s: string): number | null {
  const v = s.trim()
  if (!v) return null
  const n = Number(v)
  return isNaN(n) ? null : n
}

let formError: string | null = null
let reviewError: string | null = null
let mergeError: string | null = null
let mergeWarningPost: string | null = null
let setMatchError: string | null = null
let bulkImportError: string | null = null
let qualityError: string | null = null

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData()
  const postAction = fd.get('_action')?.toString() ?? ''

  if (postAction === 'review') {
    const result = await applyReviewAction(supabase, {
      entityType: fd.get('entity_type')?.toString().trim() ?? '',
      rowId: fd.get('row_id')?.toString().trim() ?? '',
      batchId: b.id,
      action: fd.get('review_action')?.toString().trim() ?? '',
      reviewNotes: fd.get('review_notes')?.toString() ?? '',
      reviewerUserId: user.id,
    })
    if (result.ok) {
      return Astro.redirect(`/admin/imports/${b.id}`)
    }
    reviewError = result.error
  } else if (postAction === 'merge') {
    const confirm = fd.get('confirm')?.toString().trim()
    if (confirm !== 'yes') {
      mergeError = 'Merge confirmation is required.'
    } else {
      const rawEntityType = fd.get('entity_type')?.toString().trim() ?? ''
      const rawRowId = fd.get('row_id')?.toString().trim() ?? ''
      const rawMergeAction = fd.get('merge_action')?.toString().trim() ?? 'create_new'
      const mergeAction: MergeAction = rawMergeAction === 'update_existing' ? 'update_existing' : 'create_new'

      // Batch type must match entity type unless batch is mixed.
      if (b.batch_type !== 'mixed' && b.batch_type !== rawEntityType) {
        mergeError = 'Entity type does not match this batch type.'
      } else {
        const result = await mergeApprovedRow(supabase, {
          entityType: rawEntityType,
          rowId: rawRowId,
          batchId: b.id,
          action: mergeAction,
        })
        if (result.ok) {
          if (result.warning) {
            return Astro.redirect(`/admin/imports/${b.id}?mergeWarning=${encodeURIComponent(result.warning)}`)
          }
          return Astro.redirect(`/admin/imports/${b.id}`)
        }
        mergeError = result.error
      }
    }
  } else if (postAction === 'bulk_import') {
    const rawEntityType = fd.get('entity_type')?.toString().trim() ?? ''

    if (!(VALID_ENTITY_TYPES as readonly string[]).includes(rawEntityType)) {
      bulkImportError = 'Invalid entity type.'
    } else if (b.batch_type !== 'mixed' && b.batch_type !== rawEntityType) {
      bulkImportError = 'Entity type does not match this batch type.'
    } else {
      const entityType = rawEntityType as StagedEntityType
      const jsonInput = fd.get('bulk_json')?.toString() ?? ''

      const parseResult = parseBulkJson(jsonInput, entityType)

      if (!parseResult.ok) {
        bulkImportError = parseResult.error
      } else {
        const { rows, nonObjectCount } = parseResult

        // For programs: batch-validate staging_university_ids against this batch.
        // Validation is split from importParse.ts (pure) to keep Supabase calls here.
        const validStagingUniIds = new Set<string>()
        if (entityType === 'programs' && rows.length > 0) {
          const candidateIds = [
            ...new Set(
              rows
                .map(r => r.fields.staging_university_id)
                .filter((v): v is string => typeof v === 'string'),
            ),
          ]
          if (candidateIds.length > 0) {
            const { data: validUnis } = await supabase
              .from('staging_universities')
              .select('id')
              .in('id', candidateIds)
              .eq('import_batch_id', b.id)
            for (const u of validUnis ?? []) {
              validStagingUniIds.add((u as { id: string }).id)
            }
          }
        }

        let inserted = 0
        let warned = 0
        let failed = nonObjectCount

        type ErrorEntry = {
          import_batch_id: string
          staging_table: string
          staging_row_id: string
          error_type: string
          error_message: string
        }
        const errorEntries: ErrorEntry[] = []
        const stagingTableName = STAGING_TABLE_NAME[entityType]

        for (const row of rows) {
          const resolvedFields = { ...row.fields }
          const rowWarnings = [...row.parseWarnings]

          // For programs: reject staging_university_id that is not in this batch.
          if (entityType === 'programs') {
            const stagingUniId = resolvedFields.staging_university_id as string | null
            if (stagingUniId !== null && !validStagingUniIds.has(stagingUniId)) {
              resolvedFields.staging_university_id = null
              rowWarnings.push('staging_university_id does not belong to this batch and was set to null')
            }
          }

          // Convert field values to strings for validateStagedRecord.
          const vals: Record<string, string> = {
            extracted_name: String(resolvedFields.extracted_name ?? ''),
            extracted_country_code: String(resolvedFields.extracted_country_code ?? ''),
            extracted_official_url: String(resolvedFields.extracted_official_url ?? ''),
            extracted_title: String(resolvedFields.extracted_title ?? ''),
            extracted_degree_level_code: String(resolvedFields.extracted_degree_level_code ?? ''),
            extracted_language: String(resolvedFields.extracted_language ?? ''),
            extracted_tuition_amount: resolvedFields.extracted_tuition_amount != null
              ? String(resolvedFields.extracted_tuition_amount) : '',
            extracted_deadline: String(resolvedFields.extracted_deadline ?? ''),
            extracted_amount: resolvedFields.extracted_amount != null
              ? String(resolvedFields.extracted_amount) : '',
            extracted_slug: String(resolvedFields.extracted_slug ?? ''),
            extracted_category: String(resolvedFields.extracted_category ?? ''),
            extracted_content: String(resolvedFields.extracted_content ?? ''),
          }

          const { warnings: validationWarnings } = validateStagedRecord(entityType, vals)
          const allWarnings = [...rowWarnings, ...validationWarnings]
          const importStatus = allWarnings.length === 0 ? 'validated' : 'pending'

          let insertedId: string | null = null
          let insertFailed = false

          if (entityType === 'universities') {
            const { data, error } = await supabase
              .from('staging_universities')
              .insert({
                import_batch_id: b.id,
                raw_data: row.rawData,
                extracted_name: (resolvedFields.extracted_name as string | null) ?? null,
                extracted_country_code: (resolvedFields.extracted_country_code as string | null) ?? null,
                extracted_official_url: (resolvedFields.extracted_official_url as string | null) ?? null,
                import_status: importStatus,
              })
              .select('id')
              .single()
            if (error || !data) {
              console.error('[bulk_import] staging_universities insert failed:', error?.code)
              insertFailed = true
            } else {
              insertedId = (data as { id: string }).id
            }
          } else if (entityType === 'programs') {
            const { data, error } = await supabase
              .from('staging_programs')
              .insert({
                import_batch_id: b.id,
                raw_data: row.rawData,
                extracted_title: (resolvedFields.extracted_title as string | null) ?? null,
                extracted_degree_level_code: (resolvedFields.extracted_degree_level_code as string | null) ?? null,
                extracted_language: (resolvedFields.extracted_language as string | null) ?? null,
                extracted_tuition_amount: (resolvedFields.extracted_tuition_amount as number | null) ?? null,
                extracted_deadline: (resolvedFields.extracted_deadline as string | null) ?? null,
                staging_university_id: (resolvedFields.staging_university_id as string | null) ?? null,
                import_status: importStatus,
              })
              .select('id')
              .single()
            if (error || !data) {
              console.error('[bulk_import] staging_programs insert failed:', error?.code)
              insertFailed = true
            } else {
              insertedId = (data as { id: string }).id
            }
          } else if (entityType === 'scholarships') {
            const { data, error } = await supabase
              .from('staging_scholarships')
              .insert({
                import_batch_id: b.id,
                raw_data: row.rawData,
                extracted_name: (resolvedFields.extracted_name as string | null) ?? null,
                extracted_amount: (resolvedFields.extracted_amount as number | null) ?? null,
                extracted_deadline: (resolvedFields.extracted_deadline as string | null) ?? null,
                import_status: importStatus,
              })
              .select('id')
              .single()
            if (error || !data) {
              console.error('[bulk_import] staging_scholarships insert failed:', error?.code)
              insertFailed = true
            } else {
              insertedId = (data as { id: string }).id
            }
          } else {
            const { data, error } = await supabase
              .from('staging_articles')
              .insert({
                import_batch_id: b.id,
                raw_data: row.rawData,
                extracted_title: (resolvedFields.extracted_title as string | null) ?? null,
                extracted_slug: (resolvedFields.extracted_slug as string | null) ?? null,
                extracted_category: (resolvedFields.extracted_category as string | null) ?? null,
                extracted_content: (resolvedFields.extracted_content as string | null) ?? null,
                import_status: importStatus,
              })
              .select('id')
              .single()
            if (error || !data) {
              console.error('[bulk_import] staging_articles insert failed:', error?.code)
              insertFailed = true
            } else {
              insertedId = (data as { id: string }).id
            }
          }

          if (insertFailed) {
            failed++
          } else if (insertedId) {
            inserted++
            if (allWarnings.length > 0) {
              warned++
              for (const w of allWarnings) {
                errorEntries.push({
                  import_batch_id: b.id,
                  staging_table: stagingTableName,
                  staging_row_id: insertedId,
                  error_type: 'validation_warning',
                  error_message: w,
                })
              }
            }
          }
        }

        // Batch-insert all staging_errors at once.
        if (errorEntries.length > 0) {
          await supabase.from('staging_errors').insert(errorEntries)
        }

        // Update import_batches counts (best-effort; failure is non-fatal).
        // Semantics: total_records = rows received; processed_count = rows inserted
        // into staging (validated or pending); error_count = rows that failed to
        // insert (non-object parse failures + DB insert errors). Validation warnings
        // do not count as errors — warned rows still insert successfully.
        const totalReceived = rows.length + nonObjectCount
        if (totalReceived > 0) {
          const { error: countErr } = await supabase
            .from('import_batches')
            .update({
              total_records: b.total_records + totalReceived,
              processed_count: b.processed_count + inserted,
              error_count: b.error_count + failed,
            })
            .eq('id', b.id)
          if (countErr) {
            console.error('[bulk_import] batch count update failed:', countErr.code)
          }
        }

        // Mark batch as needs_review after first successful staged insert.
        if (inserted > 0 && b.import_status === 'pending') {
          await supabase.from('import_batches').update({ import_status: 'needs_review' }).eq('id', b.id)
        }

        return Astro.redirect(
          `/admin/imports/${b.id}?imported=${inserted}&warned=${warned}&failed=${failed}`,
        )
      }
    }
  } else if (postAction === 'run_quality_checks') {
    try {
      const bType = b.batch_type
      const allWarnings: QualityWarning[] = []

      if (bType === 'universities' || bType === 'mixed') {
        const { data: uniRows } = await supabase
          .from('staging_universities')
          .select('id, extracted_name, extracted_official_url')
          .eq('import_batch_id', b.id)
          .limit(100)
        const rows = (uniRows ?? []) as { id: string; extracted_name: string | null; extracted_official_url: string | null }[]
        allWarnings.push(...detectUniSameBatchDuplicates(rows))
        allWarnings.push(...await detectUniProductionMatches(supabase, rows))
      }

      if (bType === 'programs' || bType === 'mixed') {
        const { data: progRows } = await supabase
          .from('staging_programs')
          .select('id, extracted_title, extracted_degree_level_code, staging_university_id')
          .eq('import_batch_id', b.id)
          .limit(100)
        const rows = (progRows ?? []) as { id: string; extracted_title: string | null; extracted_degree_level_code: string | null; staging_university_id: string | null }[]
        allWarnings.push(...detectProgSameBatchDuplicates(rows))
        allWarnings.push(...await detectProgProductionMatches(supabase, rows))
      }

      if (bType === 'scholarships' || bType === 'mixed') {
        const { data: scholRows } = await supabase
          .from('staging_scholarships')
          .select('id, extracted_name')
          .eq('import_batch_id', b.id)
          .limit(100)
        const rows = (scholRows ?? []) as { id: string; extracted_name: string | null }[]
        allWarnings.push(...detectScholSameBatchDuplicates(rows))
        allWarnings.push(...await detectScholProductionMatches(supabase, rows))
      }

      if (bType === 'articles' || bType === 'mixed') {
        const { data: artRows } = await supabase
          .from('staging_articles')
          .select('id, extracted_title, extracted_slug')
          .eq('import_batch_id', b.id)
          .limit(100)
        const rows = (artRows ?? []) as { id: string; extracted_title: string | null; extracted_slug: string | null }[]
        allWarnings.push(...detectArtSameBatchDuplicates(rows))
        allWarnings.push(...await detectArtProductionMatches(supabase, rows))
      }

      // Remove previous Phase 46 quality warnings for this batch only. Does not
      // touch validation_warning entries from Phase 45 or other batches.
      const { error: deleteErr } = await supabase
        .from('staging_errors')
        .delete()
        .eq('import_batch_id', b.id)
        .in('error_type', ['same_batch_duplicate', 'possible_production_match'])

      if (deleteErr) {
        console.error('[run_quality_checks] delete failed:', deleteErr.code)
        qualityError = 'Failed to reset previous quality warnings. Please try again.'
      } else if (allWarnings.length > 0) {
        const { error: insertErr } = await supabase.from('staging_errors').insert(
          allWarnings.map(w => ({
            import_batch_id: b.id,
            staging_table: w.stagingTable,
            staging_row_id: w.rowId,
            error_type: w.errorType,
            error_message: w.errorMessage,
          }))
        )
        if (insertErr) {
          console.error('[run_quality_checks] insert failed:', insertErr.code)
          qualityError = 'Failed to save quality warnings. Please try again.'
        } else {
          return Astro.redirect(`/admin/imports/${b.id}?quality=${allWarnings.length}`)
        }
      } else {
        return Astro.redirect(`/admin/imports/${b.id}?quality=0`)
      }
    } catch (err) {
      console.error('[run_quality_checks] error:', err instanceof Error ? err.message : String(err))
      qualityError = 'Quality check failed. Please try again.'
    }
  } else if (postAction === 'set_match_university_id') {
    // Staging-only: links a staging_universities row to a production university UUID.
    // No production writes. Validates batch membership and production record existence.
    const rawRowId = fd.get('row_id')?.toString().trim() ?? ''
    const rawProdId = fd.get('production_university_id')?.toString().trim() ?? ''
    const uuidPattern = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i

    if (!uuidPattern.test(rawRowId)) {
      setMatchError = 'Invalid staging row ID.'
    } else if (!uuidPattern.test(rawProdId)) {
      setMatchError = 'Invalid production university UUID. Enter a valid UUID.'
    } else {
      const { data: stagingRow, error: stagingErr } = await supabase
        .from('staging_universities')
        .select('id, import_status')
        .eq('id', rawRowId)
        .eq('import_batch_id', b.id)
        .single()

      if (stagingErr || !stagingRow) {
        setMatchError = 'Staging university row not found in this batch.'
      } else if ((stagingRow as { id: string; import_status: string }).import_status !== 'approved') {
        setMatchError = 'Only approved staging rows can be linked to a production university.'
      } else {
        const { data: prodRow, error: prodErr } = await supabase
          .from('universities')
          .select('id')
          .eq('id', rawProdId)
          .single()

        if (prodErr || !prodRow) {
          setMatchError = 'Production university not found. Confirm the UUID is correct.'
        } else {
          const { error: linkErr } = await supabase
            .from('staging_universities')
            .update({ match_university_id: rawProdId })
            .eq('id', rawRowId)
            .eq('import_batch_id', b.id)

          if (linkErr) {
            console.error('[set_match_university_id] staging update failed:', linkErr.code, linkErr.message)
            setMatchError = 'Failed to link staging row to production university. Please try again.'
          } else {
            return Astro.redirect(`/admin/imports/${b.id}`)
          }
        }
      }
    }
  } else {
    const rawEntityType = fd.get('entity_type')?.toString().trim() ?? ''

    if (!(VALID_ENTITY_TYPES as readonly string[]).includes(rawEntityType)) {
      formError = 'Invalid entity type.'
    } else {
      const entityType = rawEntityType as StagedEntityType

      if (b.batch_type !== 'mixed' && b.batch_type !== entityType) {
        formError = 'Entity type does not match this batch type.'
      } else {
        const rawDataStr = fd.get('raw_data')?.toString() ?? ''
        const rawDataResult = parseRawData(rawDataStr)

        if (!rawDataResult.ok) {
          formError = rawDataResult.error
        } else {
          const rawData = rawDataResult.value
          const pfx = ENTITY_PREFIX[entityType]
          const fv = (key: string) => fd.get(`${pfx}${key}`)?.toString() ?? ''

          // Build values for validation (validator expects un-prefixed keys)
          const vals: Record<string, string> = {
            extracted_name: fv('extracted_name'),
            extracted_country_code: fv('extracted_country_code'),
            extracted_official_url: fv('extracted_official_url'),
            extracted_title: fv('extracted_title'),
            extracted_degree_level_code: fv('extracted_degree_level_code'),
            extracted_language: fv('extracted_language'),
            extracted_tuition_amount: fv('extracted_tuition_amount'),
            extracted_deadline: fv('extracted_deadline'),
            extracted_amount: fv('extracted_amount'),
            extracted_slug: fv('extracted_slug'),
            extracted_category: fv('extracted_category'),
            extracted_content: fv('extracted_content'),
          }

          const { warnings } = validateStagedRecord(entityType, vals)
          const importStatus = warnings.length === 0 ? 'validated' : 'pending'

          let insertedId: string | null = null
          let insertFailed = false

          if (entityType === 'universities') {
            const { data, error } = await supabase
              .from('staging_universities')
              .insert({
                import_batch_id: b.id,
                raw_data: rawData,
                extracted_name: nullIfEmpty(vals.extracted_name),
                extracted_country_code: nullIfEmpty(vals.extracted_country_code),
                extracted_official_url: nullIfEmpty(vals.extracted_official_url),
                import_status: importStatus,
              })
              .select('id')
              .single()
            if (error || !data) { insertFailed = true } else { insertedId = (data as { id: string }).id }
          } else if (entityType === 'programs') {
            const { data, error } = await supabase
              .from('staging_programs')
              .insert({
                import_batch_id: b.id,
                raw_data: rawData,
                extracted_title: nullIfEmpty(vals.extracted_title),
                extracted_degree_level_code: nullIfEmpty(vals.extracted_degree_level_code),
                extracted_language: nullIfEmpty(vals.extracted_language),
                extracted_tuition_amount: numericOrNull(vals.extracted_tuition_amount),
                extracted_deadline: nullIfEmpty(vals.extracted_deadline),
                import_status: importStatus,
              })
              .select('id')
              .single()
            if (error || !data) { insertFailed = true } else { insertedId = (data as { id: string }).id }
          } else if (entityType === 'scholarships') {
            const { data, error } = await supabase
              .from('staging_scholarships')
              .insert({
                import_batch_id: b.id,
                raw_data: rawData,
                extracted_name: nullIfEmpty(vals.extracted_name),
                extracted_amount: numericOrNull(vals.extracted_amount),
                extracted_deadline: nullIfEmpty(vals.extracted_deadline),
                import_status: importStatus,
              })
              .select('id')
              .single()
            if (error || !data) { insertFailed = true } else { insertedId = (data as { id: string }).id }
          } else {
            const { data, error } = await supabase
              .from('staging_articles')
              .insert({
                import_batch_id: b.id,
                raw_data: rawData,
                extracted_title: nullIfEmpty(vals.extracted_title),
                extracted_slug: nullIfEmpty(vals.extracted_slug),
                extracted_category: nullIfEmpty(vals.extracted_category),
                extracted_content: nullIfEmpty(vals.extracted_content),
                import_status: importStatus,
              })
              .select('id')
              .single()
            if (error || !data) { insertFailed = true } else { insertedId = (data as { id: string }).id }
          }

          if (insertFailed) {
            formError = 'Failed to insert staged record. Please try again.'
          } else if (insertedId) {
            if (warnings.length > 0) {
              const rowId = insertedId
              await supabase.from('staging_errors').insert(
                warnings.map(w => ({
                  import_batch_id: b.id,
                  staging_table: STAGING_TABLE_NAME[entityType],
                  staging_row_id: rowId,
                  error_type: 'validation_warning',
                  error_message: w,
                }))
              )
            }
            // Mark batch as needs_review after first manual staged record.
            if (b.import_status === 'pending') {
              await supabase.from('import_batches').update({ import_status: 'needs_review' }).eq('id', b.id)
            }
            return Astro.redirect(`/admin/imports/${b.id}`)
          }
        }
      }
    }
  }
}

// ---- Merge warning (from PRG redirect query params) ----
const mergeWarningParam = Astro.url.searchParams.get('mergeWarning')

// ---- Bulk import summary (from PRG redirect query params) ----
const importedParam = Astro.url.searchParams.get('imported')
const bulkSummary = importedParam !== null
  ? {
      imported: Math.max(0, parseInt(importedParam, 10) || 0),
      warned: Math.max(0, parseInt(Astro.url.searchParams.get('warned') ?? '0', 10) || 0),
      failed: Math.max(0, parseInt(Astro.url.searchParams.get('failed') ?? '0', 10) || 0),
    }
  : null

// ---- Quality check summary (from PRG redirect query params) ----
const qualityParam = Astro.url.searchParams.get('quality')
const qualitySummary = qualityParam !== null
  ? { count: Math.max(0, parseInt(qualityParam, 10) || 0) }
  : null

// ---- GET: load staging data ----

type StagingUniversity = {
  id: string
  extracted_name: string | null
  extracted_country_code: string | null
  extracted_official_url: string | null
  match_university_id: string | null
  import_status: string
  review_notes: string | null
  reviewed_by_user_id: string | null
  reviewed_at: string | null
  raw_data: Record<string, unknown>
  created_at: string
}
type StagingProgram = {
  id: string
  extracted_title: string | null
  extracted_degree_level_code: string | null
  staging_university_id: string | null
  match_program_id: string | null
  import_status: string
  review_notes: string | null
  reviewed_by_user_id: string | null
  reviewed_at: string | null
  raw_data: Record<string, unknown>
  created_at: string
}
type StagingScholarship = {
  id: string
  extracted_name: string | null
  extracted_amount: number | null
  match_scholarship_id: string | null
  import_status: string
  review_notes: string | null
  reviewed_by_user_id: string | null
  reviewed_at: string | null
  raw_data: Record<string, unknown>
  created_at: string
}
type StagingArticle = {
  id: string
  extracted_title: string | null
  extracted_slug: string | null
  extracted_category: string | null
  match_article_id: string | null
  import_status: string
  review_notes: string | null
  reviewed_by_user_id: string | null
  reviewed_at: string | null
  raw_data: Record<string, unknown>
  created_at: string
}
type StagingError = {
  id: string
  staging_table: string
  staging_row_id: string | null
  error_type: string
  error_message: string
  created_at: string
}

const batchType = b.batch_type
const showUniversities = batchType === 'universities' || batchType === 'mixed'
const showPrograms = batchType === 'programs' || batchType === 'mixed'
const showScholarships = batchType === 'scholarships' || batchType === 'mixed'
const showArticles = batchType === 'articles' || batchType === 'mixed'

const [uniResult, progResult, scholResult, artResult, errResult] = await Promise.all([
  showUniversities
    ? supabase
        .from('staging_universities')
        .select('id, extracted_name, extracted_country_code, extracted_official_url, match_university_id, import_status, review_notes, reviewed_by_user_id, reviewed_at, raw_data, created_at')
        .eq('import_batch_id', id)
        .order('created_at', { ascending: false })
        .limit(50)
    : Promise.resolve({ data: [] }),
  showPrograms
    ? supabase
        .from('staging_programs')
        .select('id, extracted_title, extracted_degree_level_code, staging_university_id, match_program_id, import_status, review_notes, reviewed_by_user_id, reviewed_at, raw_data, created_at')
        .eq('import_batch_id', id)
        .order('created_at', { ascending: false })
        .limit(50)
    : Promise.resolve({ data: [] }),
  showScholarships
    ? supabase
        .from('staging_scholarships')
        .select('id, extracted_name, extracted_amount, match_scholarship_id, import_status, review_notes, reviewed_by_user_id, reviewed_at, raw_data, created_at')
        .eq('import_batch_id', id)
        .order('created_at', { ascending: false })
        .limit(50)
    : Promise.resolve({ data: [] }),
  showArticles
    ? supabase
        .from('staging_articles')
        .select('id, extracted_title, extracted_slug, extracted_category, match_article_id, import_status, review_notes, reviewed_by_user_id, reviewed_at, raw_data, created_at')
        .eq('import_batch_id', id)
        .order('created_at', { ascending: false })
        .limit(50)
    : Promise.resolve({ data: [] }),
  supabase
    .from('staging_errors')
    .select('id, staging_table, staging_row_id, error_type, error_message, created_at')
    .eq('import_batch_id', id)
    .order('created_at', { ascending: false })
    .limit(100),
])

const stagingUniversities = (uniResult.data ?? []) as StagingUniversity[]
const stagingPrograms = (progResult.data ?? []) as StagingProgram[]
const stagingScholarships = (scholResult.data ?? []) as StagingScholarship[]
const stagingArticles = (artResult.data ?? []) as StagingArticle[]
const stagingErrors = (errResult.data ?? []) as StagingError[]

const errsByRowId = new Map<string, StagingError[]>()
for (const e of stagingErrors) {
  if (e.staging_row_id) {
    const existing = errsByRowId.get(e.staging_row_id) ?? []
    existing.push(e)
    errsByRowId.set(e.staging_row_id, existing)
  }
}

// Map staging university id → name for programs table display (same-batch unis only).
// For programs-only batches this map will be empty; rows show "Linked (other batch)".
const stagingUniNameMap = new Map<string, string>()
for (const u of stagingUniversities) {
  stagingUniNameMap.set(u.id, u.extracted_name ?? '—')
}

// Batch-resolve program merge eligibility (avoid N+1)
type ProgEligibility = { canMerge: true } | { canMerge: false; reason: string }
const progEligibility = new Map<string, ProgEligibility>()

if (stagingPrograms.length > 0) {
  const mergeCandidates = stagingPrograms.filter(
    r => r.import_status === 'approved' && !r.match_program_id
  )
  const stagingUniIds = [...new Set(
    mergeCandidates.map(r => r.staging_university_id).filter((id): id is string => id != null)
  )]

  // id → match_university_id
  const stagingUniMatchMap = new Map<string, string | null>()
  if (stagingUniIds.length > 0) {
    const { data: stagingUnis } = await supabase
      .from('staging_universities')
      .select('id, match_university_id')
      .in('id', stagingUniIds)
    for (const su of (stagingUnis ?? [])) {
      stagingUniMatchMap.set(
        (su as { id: string; match_university_id: string | null }).id,
        (su as { id: string; match_university_id: string | null }).match_university_id
      )
    }
  }

  for (const prog of mergeCandidates) {
    if (!prog.staging_university_id) {
      progEligibility.set(prog.id, { canMerge: false, reason: 'No linked staging university.' })
      continue
    }
    if (!stagingUniMatchMap.has(prog.staging_university_id)) {
      progEligibility.set(prog.id, { canMerge: false, reason: 'Staging university row not found.' })
      continue
    }
    const matchUniId = stagingUniMatchMap.get(prog.staging_university_id)
    if (!matchUniId) {
      progEligibility.set(prog.id, {
        canMerge: false,
        reason: 'Linked staging university has not been merged yet. Merge the university first.',
      })
      continue
    }
    // FK chain looks complete — degree_level and country_id checked server-side at merge time
    progEligibility.set(prog.id, { canMerge: true })
  }
}

const totalStaged = stagingUniversities.length + stagingPrograms.length + stagingScholarships.length + stagingArticles.length

// Status counts derived from already-fetched arrays — no extra queries.
const allStagedStatuses = [
  ...stagingUniversities.map(r => r.import_status),
  ...stagingPrograms.map(r => r.import_status),
  ...stagingScholarships.map(r => r.import_status),
  ...stagingArticles.map(r => r.import_status),
]
const statusCounts = {
  awaitingReview: allStagedStatuses.filter(s => s === 'pending' || s === 'validated').length,
  approved: allStagedStatuses.filter(s => s === 'approved').length,
  rejectedOrSkipped: allStagedStatuses.filter(s => s === 'rejected' || s === 'skipped').length,
  merged: allStagedStatuses.filter(s => s === 'merged').length,
}
const qualityIssueCount = stagingErrors.filter(e => e.error_type === 'same_batch_duplicate' || e.error_type === 'possible_production_match').length
const validationWarningCount = stagingErrors.filter(e => e.error_type === 'validation_warning').length
const qualityChecksRun = stagingErrors.some(e => e.error_type === 'same_batch_duplicate' || e.error_type === 'possible_production_match')

// Detect possible display truncation: each entity table is limited to 50 rows.
const DISPLAY_LIMIT = 50
const mayBeTruncated = (
  (showUniversities && stagingUniversities.length === DISPLAY_LIMIT) ||
  (showPrograms && stagingPrograms.length === DISPLAY_LIMIT) ||
  (showScholarships && stagingScholarships.length === DISPLAY_LIMIT) ||
  (showArticles && stagingArticles.length === DISPLAY_LIMIT)
)

// Guidance message for "what to do next" banner.
let nextStepMessage = ''
if (totalStaged === 0) {
  nextStepMessage = 'Expand Bulk JSON Import below to paste data, or use Add Staged Record to add one row at a time.'
} else if (!qualityChecksRun) {
  nextStepMessage = `${totalStaged} row${totalStaged !== 1 ? 's' : ''} staged. Run quality checks to detect same-batch duplicates and possible existing production records.`
} else if (statusCounts.awaitingReview > 0) {
  nextStepMessage = `${statusCounts.awaitingReview} row${statusCounts.awaitingReview !== 1 ? 's' : ''} awaiting review. Approve, reject, or skip each staged row below.`
} else if (statusCounts.approved > 0) {
  nextStepMessage = `${statusCounts.approved} approved row${statusCounts.approved !== 1 ? 's' : ''} ready to merge. Use the Merge form on each approved row.`
} else if (totalStaged > 0 && statusCounts.awaitingReview === 0 && statusCounts.approved === 0) {
  nextStepMessage = 'All rows have been processed. This batch is complete.'
}

// needs_review badge supplement — not in the shared IMPORT_STATUS_BADGE map.
const BATCH_STATUS_BADGE: Record<string, string> = {
  ...IMPORT_STATUS_BADGE,
  needs_review: 'bg-amber-100 text-amber-700',
}

// Friendly error type labels for the staging errors section.
const ERROR_TYPE_LABEL: Record<string, string> = {
  validation_warning: 'Validation warning',
  same_batch_duplicate: 'Duplicate in this batch',
  possible_production_match: 'Possible existing record',
}

const INPUT_CLS = 'block w-full rounded border border-gray-300 px-3 py-1.5 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500'
const LABEL_CLS = 'block text-xs font-medium text-gray-600 mb-1'
---
<AdminLayout title={`Import Batch — DegreeWiki Admin`} activePath="/admin/imports" userEmail={user.email ?? ''}>
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-bold text-gray-900">Import Batch</h1>
    <a href="/admin/imports" class="text-sm text-gray-500 hover:underline">← Back to Imports</a>
  </div>

  <div class="mb-6 rounded-lg border border-gray-200 bg-white divide-y divide-gray-100">
    <div class="px-4 py-3 flex items-center gap-3">
      <span class="text-sm font-medium text-gray-500 w-32">Type</span>
      <span class={`inline-flex items-center rounded px-2 py-0.5 text-xs font-medium ${BATCH_TYPE_BADGE[b.batch_type] ?? FALLBACK_BADGE}`}>
        {b.batch_type}
      </span>
    </div>
    <div class="px-4 py-3 flex items-center gap-3">
      <span class="text-sm font-medium text-gray-500 w-32">Status</span>
      <span class={`inline-flex items-center rounded px-2 py-0.5 text-xs font-medium ${BATCH_STATUS_BADGE[b.import_status] ?? FALLBACK_BADGE}`}>
        {b.import_status}
      </span>
      {b.import_status === 'needs_review' && (
        <span class="text-sm text-amber-700">— rows staged, awaiting review</span>
      )}
    </div>
    <div class="px-4 py-3 flex items-center gap-3">
      <span class="text-sm font-medium text-gray-500 w-32">Records</span>
      <span class="text-sm text-gray-700">
        {b.total_records} total · {b.processed_count} processed · {b.error_count > 0 ? <span class="text-red-600 font-medium">{b.error_count} errors</span> : <span class="text-gray-400">0 errors</span>}
      </span>
    </div>
    {b.notes && (
      <div class="px-4 py-3 flex items-start gap-3">
        <span class="text-sm font-medium text-gray-500 w-32">Notes</span>
        <span class="text-sm text-gray-700">{b.notes}</span>
      </div>
    )}
    {dataSource && (
      <div class="px-4 py-3 flex items-start gap-3">
        <span class="text-sm font-medium text-gray-500 w-32">Data Source</span>
        <span class="text-sm text-gray-700">
          {dataSource.source_title && <span class="font-medium">{dataSource.source_title} · </span>}
          <a href={dataSource.source_url} class="text-blue-600 hover:underline break-all" target="_blank" rel="noopener noreferrer">
            {dataSource.source_url}
          </a>
          <span class="ml-2 text-gray-400 text-xs">({dataSource.source_type})</span>
        </span>
      </div>
    )}
    <div class="px-4 py-3 flex items-center gap-3">
      <span class="text-sm font-medium text-gray-500 w-32">Created</span>
      <span class="text-sm text-gray-400">{new Date(b.created_at).toLocaleString()}</span>
    </div>
    <div class="px-4 py-3 flex items-center gap-3">
      <span class="text-sm font-medium text-gray-500 w-32">Updated</span>
      <span class="text-sm text-gray-400">{new Date(b.updated_at).toLocaleString()}</span>
    </div>
    <div class="px-4 py-3 flex items-center gap-3">
      <span class="text-sm font-medium text-gray-500 w-32">Batch ID</span>
      <span class="text-xs text-gray-400 font-mono">{b.id}</span>
    </div>
  </div>

  <!-- Status summary cards -->
  <div class="mb-4 grid grid-cols-3 sm:grid-cols-6 gap-2">
    <div class="rounded-lg border border-gray-200 bg-white px-3 py-2.5 text-center">
      <div class="text-xl font-bold text-gray-900">{totalStaged}</div>
      <div class="text-xs text-gray-400 mt-0.5">Staged</div>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white px-3 py-2.5 text-center">
      <div class={statusCounts.awaitingReview > 0 ? 'text-xl font-bold text-blue-700' : 'text-xl font-bold text-gray-300'}>
        {statusCounts.awaitingReview}
      </div>
      <div class="text-xs text-gray-400 mt-0.5">Awaiting review</div>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white px-3 py-2.5 text-center">
      <div class={statusCounts.approved > 0 ? 'text-xl font-bold text-green-700' : 'text-xl font-bold text-gray-300'}>
        {statusCounts.approved}
      </div>
      <div class="text-xs text-gray-400 mt-0.5">Approved</div>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white px-3 py-2.5 text-center">
      <div class={statusCounts.rejectedOrSkipped > 0 ? 'text-xl font-bold text-red-600' : 'text-xl font-bold text-gray-300'}>
        {statusCounts.rejectedOrSkipped}
      </div>
      <div class="text-xs text-gray-400 mt-0.5">Rejected / Skipped</div>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white px-3 py-2.5 text-center">
      <div class={statusCounts.merged > 0 ? 'text-xl font-bold text-emerald-700' : 'text-xl font-bold text-gray-300'}>
        {statusCounts.merged}
      </div>
      <div class="text-xs text-gray-400 mt-0.5">Merged</div>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white px-3 py-2.5 text-center">
      <div class={stagingErrors.length > 0 ? 'text-xl font-bold text-orange-600' : 'text-xl font-bold text-gray-300'}>
        {stagingErrors.length}
      </div>
      <div class="text-xs text-gray-400 mt-0.5">Issues</div>
    </div>
  </div>

  <!-- Lifecycle steps -->
  <div class="mb-4 flex items-stretch rounded-lg border border-gray-200 bg-white overflow-hidden text-xs divide-x divide-gray-200">
    {[
      { step: 1, label: 'Import rows', done: totalStaged > 0 },
      { step: 2, label: 'Quality checks', done: qualityChecksRun },
      { step: 3, label: 'Review rows', done: totalStaged > 0 && statusCounts.awaitingReview === 0 },
      { step: 4, label: 'Merge approved', done: statusCounts.merged > 0 && statusCounts.approved === 0 && totalStaged > 0 },
    ].map(({ step, label, done }) => (
      <div class={`flex-1 flex items-center gap-2 px-3 py-3 ${done ? 'bg-green-50' : ''}`}>
        <span class={`flex-shrink-0 flex items-center justify-center w-5 h-5 rounded-full text-xs font-bold ${done ? 'bg-green-600 text-white' : 'bg-gray-200 text-gray-500'}`}>
          {step}
        </span>
        <span class={done ? 'font-medium text-green-800' : 'text-gray-500'}>{label}</span>
        {done && <span class="ml-auto text-green-600 font-bold text-xs">✓</span>}
      </div>
    ))}
  </div>

  <!-- What to do next guidance banner -->
  {nextStepMessage && (
    <div class="mb-4 flex items-start gap-3 rounded-lg border border-blue-200 bg-blue-50 px-4 py-3">
      <span class="text-blue-500 text-sm font-bold mt-0.5 shrink-0">→</span>
      <div class="text-sm text-blue-800">
        <span class="font-medium">Next: </span>{nextStepMessage}
      </div>
    </div>
  )}

  {reviewError && (
    <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
      Review action failed: {reviewError}
    </div>
  )}

  {mergeError && (
    <div class="mb-4 rounded-md bg-amber-50 border border-amber-200 px-4 py-3 text-sm text-amber-800">
      Merge failed: {mergeError}
    </div>
  )}

  {mergeWarningParam && (
    <div class="mb-4 rounded-md bg-yellow-50 border border-yellow-300 px-4 py-3 text-sm text-yellow-800">
      <strong>Merge warning:</strong> {decodeURIComponent(mergeWarningParam)}
    </div>
  )}

  {setMatchError && (
    <div class="mb-4 rounded-md bg-amber-50 border border-amber-200 px-4 py-3 text-sm text-amber-800">
      Link failed: {setMatchError}
    </div>
  )}

  {bulkSummary && (
    <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800">
      Bulk import complete: {bulkSummary.imported} row{bulkSummary.imported !== 1 ? 's' : ''} inserted
      {bulkSummary.warned > 0 && ` (${bulkSummary.warned} with validation warnings)`}
      {bulkSummary.failed > 0
        ? <span class="text-red-700">, {bulkSummary.failed} failed to insert.</span>
        : '.'}
      {bulkSummary.warned > 0 && ' Check the Staging Errors section below for details.'}
    </div>
  )}

  {bulkImportError && (
    <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
      Bulk import error: {bulkImportError}
    </div>
  )}

  {qualitySummary !== null && (
    <div class="mb-4 rounded-md bg-purple-50 border border-purple-200 px-4 py-3 text-sm text-purple-800">
      {qualitySummary.count === 0
        ? 'Quality checks complete. No quality warnings found.'
        : `Quality checks complete. ${qualitySummary.count} warning${qualitySummary.count !== 1 ? 's' : ''} found. Check the Actions column or Staging Errors section below for details.`}
    </div>
  )}

  {qualityError && (
    <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
      Quality check error: {qualityError}
    </div>
  )}

  <!-- Bulk JSON Import form -->
  <details class="mb-4 rounded-lg border border-blue-200 bg-white" {...(bulkImportError !== null ? { open: true } : {})}>
    <summary class="px-4 py-3 cursor-pointer select-none text-sm font-semibold text-gray-700 hover:bg-gray-50 rounded-lg list-none flex items-center gap-2">
      <span class="text-blue-500 text-base leading-none">↑</span>
      Bulk JSON Import
    </summary>
    <div class="px-4 py-4 border-t border-gray-100">
      <form method="POST" class="space-y-4">
        <input type="hidden" name="_action" value="bulk_import" />
        {b.batch_type === 'mixed' ? (
          <div>
            <label class={LABEL_CLS}>Entity Type <span class="text-red-500">*</span></label>
            <select name="entity_type" required class={INPUT_CLS}>
              <option value="">Select type…</option>
              <option value="universities">University</option>
              <option value="programs">Program</option>
              <option value="scholarships">Scholarship</option>
              <option value="articles">Article</option>
            </select>
          </div>
        ) : (
          <input type="hidden" name="entity_type" value={b.batch_type} />
        )}
        <div>
          <label class={LABEL_CLS}>JSON Array <span class="text-red-500">*</span></label>
          <textarea
            name="bulk_json"
            rows={10}
            required
            class={INPUT_CLS + ' font-mono text-xs'}
            placeholder={
              b.batch_type === 'universities'
                ? '[{\n  "name": "University of Example",\n  "country_code": "GB",\n  "official_url": "https://example.ac.uk"\n}]'
                : b.batch_type === 'programs'
                ? '[{\n  "title": "MSc Computer Science",\n  "degree_level_code": "msc",\n  "tuition_amount": 15000,\n  "staging_university_id": "<uuid>"\n}]'
                : b.batch_type === 'scholarships'
                ? '[{\n  "name": "Global Excellence Award",\n  "amount": 5000,\n  "deadline": "2026-05-01"\n}]'
                : b.batch_type === 'articles'
                ? '[{\n  "title": "How to Apply",\n  "slug": "how-to-apply",\n  "content": "Article body..."\n}]'
                : '[{ ... }, { ... }]'
            }
          ></textarea>
          <p class="mt-1 text-xs text-gray-400">
            Paste a JSON array of objects. Maximum 100 rows per paste.
            {b.batch_type === 'universities' && ' Keys: name, country_code, official_url.'}
            {b.batch_type === 'programs' && ' Keys: title, degree_level_code, language, tuition_amount, deadline, staging_university_id.'}
            {b.batch_type === 'scholarships' && ' Keys: name, amount, deadline.'}
            {b.batch_type === 'articles' && ' Keys: title, slug, category, content.'}
          </p>
        </div>
        <div>
          <button
            type="submit"
            class="rounded bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-1"
          >
            Import Rows
          </button>
        </div>
      </form>
    </div>
  </details>

  <!-- Add staged record form -->
  <details class="mb-6 rounded-lg border border-gray-200 bg-white" {...(formError !== null ? { open: true } : {})}>
    <summary class="px-4 py-3 cursor-pointer select-none text-sm font-semibold text-gray-700 hover:bg-gray-50 rounded-lg list-none flex items-center gap-2">
      <span class="text-gray-400 text-base leading-none">+</span>
      Add Staged Record
    </summary>
    <div class="px-4 py-4 border-t border-gray-100">
      {formError && (
