      <div class="text-xs text-gray-400 mt-0.5">Staged</div>
      {helperUniversityCount > 0 && (
        <div class="mt-0.5 text-[11px] text-gray-400">+ {helperUniversityCount} helper</div>
      )}
    </div>
    <div class="rounded-lg border border-gray-200 bg-white px-3 py-2.5 text-center">
      <div class={statusCounts.awaitingReview > 0 ? 'text-xl font-bold text-blue-700' : 'text-xl font-bold text-gray-300'}>
        {statusCounts.awaitingReview}
      </div>
      <div class="text-xs text-gray-400 mt-0.5">Awaiting review</div>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white px-3 py-2.5 text-center">
      <div class={statusCounts.approved > 0 ? 'text-xl font-bold text-green-700' : 'text-xl font-bold text-gray-300'}>
        {statusCounts.approved}
      </div>
      <div class="text-xs text-gray-400 mt-0.5">Approved</div>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white px-3 py-2.5 text-center">
      <div class={statusCounts.skipped > 0 ? 'text-xl font-bold text-yellow-600' : 'text-xl font-bold text-gray-300'}>
        {statusCounts.skipped}
      </div>
      <div class="text-xs text-gray-400 mt-0.5">Skipped</div>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white px-3 py-2.5 text-center">
      <div class={statusCounts.merged > 0 ? 'text-xl font-bold text-emerald-700' : 'text-xl font-bold text-gray-300'}>
        {statusCounts.merged}
      </div>
      <div class="text-xs text-gray-400 mt-0.5">Merged</div>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white px-3 py-2.5 text-center">
      <div class={stagingErrors.length > 0 ? 'text-xl font-bold text-orange-600' : 'text-xl font-bold text-gray-300'}>
        {stagingErrors.length}
      </div>
      <div class="text-xs text-gray-400 mt-0.5">Issues</div>
    </div>
  </div>

  <div class="mb-4 rounded-lg border border-gray-200 bg-white px-4 py-3">
    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-gray-600">
      <span><strong class="text-gray-900">Entity counts:</strong> {entityCounts.universities} universities, {entityCounts.programs} programs, {entityCounts.scholarships} scholarships, {entityCounts.articles} articles</span>
      <span><strong class="text-gray-900">Row outcomes:</strong> {statusCounts.merged} merged, {statusCounts.skipped} skipped, {statusCounts.rejected} rejected, {statusCounts.rowErrors} row errors</span>
    </div>
  </div>

  <div class="mb-4 rounded-lg border border-gray-200 bg-white px-4 py-4">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div class="space-y-3">
        {visibleEntityOptions.length > 1 && (
          <div class="flex flex-wrap gap-2">
            {visibleEntityOptions.map((entity) => (
              <a
                href={buildFilterHref({ entity, page: 1 })}
                class={`inline-flex items-center rounded-full border px-3 py-1 text-xs font-medium ${
                  activeEntity === entity
                    ? 'border-blue-600 bg-blue-50 text-blue-700'
                    : 'border-gray-300 bg-white text-gray-600 hover:bg-gray-50'
                }`}
              >
                {entity}
                <span class="ml-1.5 text-[11px] text-gray-400">{entityCounts[entity]}</span>
              </a>
            ))}
          </div>
        )}

        <form method="get" class="flex flex-wrap items-end gap-3">
          {visibleEntityOptions.length > 1 && <input type="hidden" name="entity" value={activeEntity} />}
          <div>
            <label for="status" class="mb-1 block text-xs font-medium text-gray-600">Status</label>
            <select id="status" name="status" class={INPUT_CLS}>
              {FILTERABLE_STATUS_OPTIONS.map((option) => (
                <option value={option} selected={selectedStatusFilter === option}>
                  {option === 'all' ? 'All statuses' : option}
                </option>
              ))}
            </select>
          </div>
          <div>
            <label for="pageSize" class="mb-1 block text-xs font-medium text-gray-600">Page size</label>
            <select id="pageSize" name="pageSize" class={INPUT_CLS}>
              {PAGE_SIZE_OPTIONS.map((size) => (
                <option value={size} selected={selectedPageSize === size}>{size}</option>
              ))}
            </select>
          </div>
          <input type="hidden" name="page" value="1" />
          <button
            type="submit"
            class="rounded bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700"
          >
            Apply
          </button>
          <a
            href={`/admin/imports/${b.id}`}
            class="rounded border border-gray-300 px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50"
          >
            Clear
          </a>
        </form>
      </div>

      <div class="text-sm text-gray-500">
        Showing {pageStart}-{pageEnd} of {filteredRowCount} {activeEntityLabel}
        {selectedStatusFilter !== 'all' && ` with status "${selectedStatusFilter}"`}.
      </div>
    </div>

    <div class="mt-4 flex flex-wrap items-center justify-between gap-3 border-t border-gray-100 pt-4">
      <p class="text-xs text-gray-500">
        Active view: <span class="font-medium text-gray-700">{activeEntity}</span> · Selected-row actions stay on this page. All-matching actions require explicit confirmation before affecting hidden pages in the current batch/filter.
      </p>
      <div class="flex items-center gap-2">
        <a
          href={buildFilterHref({ page: currentPage > 1 ? currentPage - 1 : 1 })}
          class={`rounded border px-3 py-1.5 text-sm ${currentPage > 1 ? 'border-gray-300 text-gray-700 hover:bg-gray-50' : 'border-gray-200 text-gray-300 pointer-events-none'}`}
        >
          Previous
        </a>
        <span class="text-sm text-gray-500">Page {currentPage} of {totalPages}</span>
        <a
          href={buildFilterHref({ page: currentPage < totalPages ? currentPage + 1 : totalPages })}
          class={`rounded border px-3 py-1.5 text-sm ${currentPage < totalPages ? 'border-gray-300 text-gray-700 hover:bg-gray-50' : 'border-gray-200 text-gray-300 pointer-events-none'}`}
        >
          Next
        </a>
      </div>
    </div>
  </div>

  {detectedMatchedUniversityId && detectedMatchedUniversityName && (
    <div class="mb-4 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <p class="text-sm font-semibold text-emerald-900">Detected university context: {detectedMatchedUniversityName}</p>
          <p class="mt-1 text-sm text-emerald-800">
            This batch is linked to production university <span class="font-medium">{detectedMatchedUniversityName}</span>.
            {helperUniversityCount > 0 && ' Programs in this batch use a batch-local helper staging-university row to keep merge context intact.'}
          </p>
          {helperSourceMismatch && (
            <p class="mt-2 text-xs text-amber-800">{helperSourceMismatch}</p>
          )}
        </div>
        {showPrograms && (
          <a
            href={`/admin/programs?university=${detectedMatchedUniversityId}&status=draft&sort=newest`}
            class="inline-flex shrink-0 items-center rounded-md border border-emerald-300 bg-white px-3 py-2 text-sm font-medium text-emerald-800 hover:bg-emerald-100"
          >
            Review draft programs for this university
          </a>
        )}
      </div>
    </div>
  )}

  <!-- Lifecycle steps -->
  <div class="mb-4 flex items-stretch rounded-lg border border-gray-200 bg-white overflow-hidden text-xs divide-x divide-gray-200">
    {[
      { step: 1, label: 'Import rows', done: actionableStaged > 0 },
      { step: 2, label: 'Quality checks', done: qualityChecksRun },
      { step: 3, label: 'Review rows', done: actionableStaged > 0 && statusCounts.awaitingReview === 0 },
      { step: 4, label: 'Merge approved', done: statusCounts.merged > 0 && statusCounts.approved === 0 && actionableStaged > 0 },
    ].map(({ step, label, done }) => (
      <div class={`flex-1 flex items-center gap-2 px-3 py-3 ${done ? 'bg-green-50' : ''}`}>
        <span class={`flex-shrink-0 flex items-center justify-center w-5 h-5 rounded-full text-xs font-bold ${done ? 'bg-green-600 text-white' : 'bg-gray-200 text-gray-500'}`}>
          {step}
        </span>
        <span class={done ? 'font-medium text-green-800' : 'text-gray-500'}>{label}</span>
        {done && <span class="ml-auto text-green-600 font-bold text-xs">✓</span>}
      </div>
    ))}
  </div>

  <!-- What to do next guidance banner -->
  {nextStepMessage && (
    <div class="mb-4 flex items-start gap-3 rounded-lg border border-blue-200 bg-blue-50 px-4 py-3">
      <span class="text-blue-500 text-sm font-bold mt-0.5 shrink-0">→</span>
      <div class="text-sm text-blue-800">
        <span class="font-medium">Next: </span>{nextStepMessage}
      </div>
    </div>
  )}

  {filteredRowCount > 0 && (
    <div class="mb-4 rounded-lg border border-gray-200 bg-white px-4 py-4">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
        <div class="max-w-3xl">
          <h2 class="text-base font-semibold text-gray-900">Batch actions</h2>
          <p class="mt-1 text-sm text-gray-500">
            These actions stay scoped to batch <span class="font-mono text-xs text-gray-600">{b.id}</span>, entity <span class="font-medium text-gray-700">{activeEntity}</span>, and status filter <span class="font-medium text-gray-700">{selectedStatusFilter}</span>.
          </p>
        </div>
        <div class="text-xs text-gray-500">
          Matching rows: <span class="font-medium text-gray-700">{currentEntityMatchingRows.length}</span>
        </div>
      </div>

      <div class="mt-4 grid gap-4 lg:grid-cols-[minmax(0,1fr),minmax(0,1fr)]">
        <div class="rounded-lg border border-blue-200 bg-blue-50/60 p-4">
          <div class="flex items-start justify-between gap-3">
            <div>
              <h3 class="text-sm font-semibold text-blue-900">Review actions</h3>
              <p class="mt-1 text-xs text-blue-800">
                Approve every matching row in this batch/filter. Merged, processing, error, and helper rows are skipped automatically.
              </p>
            </div>
            <div class="rounded-full bg-white px-3 py-1 text-xs font-medium text-blue-900">
              {approveAllMatchingReadyCount} ready
            </div>
          </div>

          <form method="POST" action={currentFilterPath} class="mt-4 space-y-3">
            <input type="hidden" name="_action" value="bulk_review_matching" />
            <input type="hidden" name="entity_type" value={activeEntity} />
            <input type="hidden" name="status_filter" value={selectedStatusFilter} />
            <label class="flex items-start gap-2 text-sm text-blue-900">
              <input type="checkbox" name="confirm_all_matching" value="yes" required class="mt-0.5 shrink-0" />
              <span>I understand this will approve all matching rows in this batch/filter.</span>
            </label>
            <div class="flex flex-wrap items-center gap-3">
              <button type="submit" class="rounded bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
                Approve all matching
              </button>
              <span class="text-xs text-blue-800">Hidden pages are affected only through this confirmed action.</span>
            </div>
          </form>
        </div>

        {activeEntity === 'programs' ? (
          <div class="space-y-4">
            <div class="rounded-lg border border-emerald-200 bg-emerald-50/70 p-4">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <h3 class="text-sm font-semibold text-emerald-900">Merge actions</h3>
                  <p class="mt-1 text-xs text-emerald-800">
                    Merge approved program rows with the existing `mergeProgram()` flow. New production programs stay draft and unverified until you review them.
                  </p>
                </div>
                <div class="rounded-full bg-white px-3 py-1 text-xs font-medium text-emerald-900">
                  {approvedProgramsReadyToMergeCount} approved ready
                </div>
              </div>

              <div class="mt-4 grid gap-3">
                <form
                  method="POST"
                  action={currentFilterPath}
                  class="rounded border border-emerald-200 bg-white p-3"
                  data-mirror-selected-rows
                >
                  <input type="hidden" name="_action" value="bulk_merge_programs" />
                  <input type="hidden" name="merge_scope" value="selected" />
                  {visibleRowIds.map((rowId) => <input type="hidden" name="visible_row_ids" value={rowId} />)}
                  <p class="text-sm font-medium text-emerald-900">Merge selected approved rows</p>
                  <p class="mt-1 text-xs text-emerald-800">Uses the same visible-row selection as the bulk review controls below.</p>
                  <button type="submit" class="mt-3 rounded bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700">
                    Merge approved programs
                  </button>
                </form>

                <form method="POST" action={currentFilterPath} class="rounded border border-emerald-200 bg-white p-3 space-y-3">
                  <input type="hidden" name="_action" value="bulk_merge_programs" />
                  <input type="hidden" name="merge_scope" value="matching" />
                  <input type="hidden" name="status_filter" value={selectedStatusFilter} />
                  <p class="text-sm font-medium text-emerald-900">Merge all approved rows in this batch/filter</p>
                  <label class="flex items-start gap-2 text-sm text-emerald-900">
                    <input type="checkbox" name="confirm_merge_matching" value="yes" required class="mt-0.5 shrink-0" />
                    <span>I understand this will merge all approved program rows in this batch/filter.</span>
                  </label>
                  <button type="submit" class="rounded border border-emerald-300 bg-emerald-100 px-4 py-2 text-sm font-medium text-emerald-900 hover:bg-emerald-200">
                    Merge all approved programs
                  </button>
                </form>
              </div>
            </div>

            <div class="rounded-lg border border-amber-300 bg-amber-50 p-4">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <h3 class="text-sm font-semibold text-amber-900">Publish actions</h3>
                  <p class="mt-1 text-xs text-amber-800">
                    Publish linked production programs from merged staging rows only. This makes them public, but verification remains manual.
                  </p>
                </div>
                <div class="rounded-full bg-white px-3 py-1 text-xs font-medium text-amber-900">
                  {mergedDraftProgramsReadyToPublishCount} drafts ready
                </div>
              </div>

              <form method="POST" action={currentFilterPath} class="mt-4 rounded border border-amber-200 bg-white p-3 space-y-3">
                <input type="hidden" name="_action" value="bulk_publish_programs" />
                <input type="hidden" name="status_filter" value={selectedStatusFilter} />
                <p class="text-sm font-medium text-amber-900">Publish merged drafts as unverified</p>
                <p class="text-xs text-amber-800">
                  Only linked production programs in <code>draft</code> or <code>in_review</code> are updated. Verification fields stay unchanged.
                </p>
                <label class="flex items-start gap-2 text-sm text-amber-900">
                  <input type="checkbox" name="confirm_publish_matching" value="yes" required class="mt-0.5 shrink-0" />
                  <span>I understand these programs will become public but remain unverified.</span>
                </label>
                <button type="submit" class="rounded bg-amber-600 px-4 py-2 text-sm font-medium text-white hover:bg-amber-700">
                  Publish merged drafts as unverified
                </button>
              </form>
            </div>
          </div>
        ) : (
          <div class="rounded-lg border border-dashed border-gray-200 bg-gray-50 p-4 text-sm text-gray-500">
            Program-only merge and publish actions appear when the active entity filter is set to <span class="font-medium text-gray-700">programs</span>.
          </div>
        )}
      </div>
    </div>
  )}

  {reviewError && (
    <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
      Review action failed: {reviewError}
    </div>
  )}

  {bulkReviewError && (
    <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
      Bulk review failed: {bulkReviewError}
    </div>
  )}

  {batchActionError && (
    <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
      Batch action failed: {batchActionError}
    </div>
  )}

  {mergeError && (
    <div class="mb-4 rounded-md bg-amber-50 border border-amber-200 px-4 py-3 text-sm text-amber-800">
      Merge failed: {mergeError}
    </div>
  )}

  {mergeWarningParam && (
    <div class="mb-4 rounded-md bg-yellow-50 border border-yellow-300 px-4 py-3 text-sm text-yellow-800">
      <strong>Merge warning:</strong> {decodeURIComponent(mergeWarningParam)}
    </div>
  )}

  {setMatchError && (
    <div class="mb-4 rounded-md bg-amber-50 border border-amber-200 px-4 py-3 text-sm text-amber-800">
      Link failed: {setMatchError}
    </div>
  )}

  {bulkSummary && (
    <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800">
      Bulk import complete: {bulkSummary.imported} row{bulkSummary.imported !== 1 ? 's' : ''} inserted
      {bulkSummary.warned > 0 && ` (${bulkSummary.warned} with validation warnings)`}
      {bulkSummary.failed > 0
        ? <span class="text-red-700">, {bulkSummary.failed} failed to insert.</span>
        : '.'}
      {bulkSummary.warned > 0 && ' Check the Staging Errors section below for details.'}
    </div>
  )}

  {bulkReviewSummary && (
    <div class="mb-4 rounded-md bg-blue-50 border border-blue-200 px-4 py-3 text-sm text-blue-800">
      Bulk review {REVIEW_ACTION_LABEL[bulkReviewSummary.action] ?? bulkReviewSummary.action}: {bulkReviewSummary.success} row{bulkReviewSummary.success !== 1 ? 's' : ''} updated.
      {bulkReviewSummary.failed > 0
        ? <span class="text-amber-700"> {bulkReviewSummary.failed} row{bulkReviewSummary.failed !== 1 ? 's' : ''} could not be updated.</span>
        : ''}
    </div>
  )}

  {batchActionSummary && (
    <div class={`mb-4 rounded-md border px-4 py-3 text-sm ${
      batchActionSummary.action === 'publish_matching_programs'
        ? 'border-amber-200 bg-amber-50 text-amber-900'
        : 'border-emerald-200 bg-emerald-50 text-emerald-900'
    }`}>
      {BATCH_ACTION_LABEL[batchActionSummary.action] ?? batchActionSummary.action}
      {batchActionSummary.scope === 'selected' ? ' (selected)' : batchActionSummary.scope === 'matching' ? ' (all matching)' : ''}
      : {batchActionSummary.success} row{batchActionSummary.success !== 1 ? 's' : ''} {BATCH_ACTION_RESULT_LABEL[batchActionSummary.action] ?? 'processed'}.
      {batchActionSummary.skipped > 0 && ` ${batchActionSummary.skipped} skipped.`}
      {batchActionSummary.failed > 0 && ` ${batchActionSummary.failed} failed.`}
      {batchActionSummary.warned > 0 && ` ${batchActionSummary.warned} merged row${batchActionSummary.warned !== 1 ? 's' : ''} need manual follow-up.`}
      {batchActionSummary.action === 'publish_matching_programs' && ' Verification remains manual.'}
    </div>
  )}

  {bulkImportError && (
    <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
      Bulk import error: {bulkImportError}
    </div>
  )}

  {qualitySummary !== null && (
    <div class="mb-4 rounded-md bg-purple-50 border border-purple-200 px-4 py-3 text-sm text-purple-800">
      {qualitySummary.count === 0
        ? 'Quality checks complete. No quality warnings found.'
        : `Quality checks complete. ${qualitySummary.count} warning${qualitySummary.count !== 1 ? 's' : ''} found. Check the Actions column or Staging Errors section below for details.`}
    </div>
  )}

  {qualityError && (
    <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
      Quality check error: {qualityError}
    </div>
  )}

  <!-- Templates & AI Prompts section -->
  {templateEntityTypes.length > 0 && (
    <details class="mb-4 rounded-lg border border-indigo-200 bg-white" id="tpl-section">
      <summary class="px-4 py-3 cursor-pointer select-none text-sm font-semibold text-gray-700 hover:bg-gray-50 rounded-lg list-none flex items-center gap-2">
        <span class="text-indigo-400 font-mono text-base leading-none">{'{}'}</span>
        Templates &amp; AI Prompts
        <span class="ml-auto text-xs font-normal text-gray-400">JSON templates and copyable research prompts</span>
      </summary>
      <div class="border-t border-gray-100">
        <div class="px-4 py-3 bg-gray-50 text-xs text-gray-600 border-b border-gray-100">
          <strong class="text-gray-700">Import workflow:</strong>
          <ol class="mt-1 ml-4 list-decimal space-y-0.5 text-gray-500">
            <li>Copy the template below to understand the expected JSON shape.</li>
            <li>Copy the AI prompt, paste into Perplexity / ChatGPT / Claude, list the items to research.</li>
            <li>Paste the returned JSON into <strong>Bulk JSON Import</strong> below and click Import.</li>
            <li>Or use <strong>Add Staged Record</strong> to add rows one at a time.</li>
          </ol>
          {b.batch_type === 'mixed' && (
            <p class="mt-1.5 text-gray-500">For mixed batches: use the Research Pack tab for a nested university + programs pack, or keep using flat arrays. Research packs automatically link programs to the staged university.</p>
          )}
        </div>

        {templateEntityTypes.length > 1 && (
          <div class="flex border-b border-gray-100 px-4 pt-2 gap-1" id="tpl-tabs">
            {templateEntityTypes.map((t, i) => (
              <button
                type="button"
                data-tab={t}
                class={`px-3 py-1.5 text-xs font-medium rounded-t border-b-2 transition-colors ${i === 0 ? 'border-indigo-500 text-indigo-700 bg-indigo-50' : 'border-transparent text-gray-500 hover:text-gray-700'}`}
              >
                {TEMPLATE_LABEL[t]}
              </button>
            ))}
          </div>
        )}

        {templateEntityTypes.map((t, i) => (
          <div data-panel={t} class={templateEntityTypes.length > 1 && i !== 0 ? 'hidden' : ''}>
            <div class="px-4 py-3 grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <div class="flex items-center justify-between mb-1.5">
                  <p class="text-xs font-semibold text-gray-600">JSON Template — {TEMPLATE_LABEL[t]}</p>
                  <div class="flex gap-3">
                    <button type="button" data-copy-from={`tpl-textarea-${t}`} class="text-xs text-indigo-600 hover:text-indigo-800 underline">Copy</button>
                    <a href={templateDownloadLinks[t]} download={`import-template-${t}.json`} class="text-xs text-gray-500 hover:text-gray-700 underline">Download .json</a>
                  </div>
                </div>
                <textarea
                  id={`tpl-textarea-${t}`}
                  readonly
                  rows={10}
                  class="w-full block rounded border border-gray-200 bg-gray-50 px-3 py-2 text-xs font-mono text-gray-700 focus:outline-none resize-none"
                >{IMPORT_TEMPLATES[t]}</textarea>
                <div class="mt-2 space-y-1">
                  {TEMPLATE_FIELD_NOTES[t].map(fn => (
                    <p class="text-xs text-gray-500">
                      <code class="text-gray-800 bg-gray-100 px-1 rounded">{fn.field}</code>
                      {fn.required && <span class="text-red-500 ml-0.5">*</span>}
                      {' — '}{fn.note}
                    </p>
                  ))}
                  <p class="text-xs text-gray-400 pt-0.5">* required for merge</p>
                </div>
              </div>
              <div>
                <div class="flex items-center justify-between mb-1.5">
                  <p class="text-xs font-semibold text-gray-600">AI / Perplexity Research Prompt</p>
                  <button type="button" data-copy-from={`ai-textarea-${t}`} class="text-xs text-indigo-600 hover:text-indigo-800 underline">Copy</button>
                </div>
                <textarea
                  id={`ai-textarea-${t}`}
                  readonly
                  rows={14}
                  class="w-full block rounded border border-gray-200 bg-gray-50 px-3 py-2 text-xs font-mono text-gray-600 focus:outline-none resize-y"
                >{AI_PROMPTS[t]}</textarea>
                <p class="mt-1 text-xs text-gray-400">Edit the list at the bottom of the prompt, then paste into your AI tool.</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </details>
  )}

  <!-- Bulk JSON Import form -->
  <details class="mb-4 rounded-lg border border-blue-200 bg-white" {...(bulkImportError !== null ? { open: true } : {})}>
    <summary class="px-4 py-3 cursor-pointer select-none text-sm font-semibold text-gray-700 hover:bg-gray-50 rounded-lg list-none flex items-center gap-2">
      <span class="text-blue-500 text-base leading-none">↑</span>
      Bulk JSON Import
    </summary>
    <div class="px-4 py-4 border-t border-gray-100">
      <form method="POST" class="space-y-4">
        <input type="hidden" name="_action" value="bulk_import" />
        {b.batch_type === 'mixed' ? (
          <div>
            <label class={LABEL_CLS}>Entity Type <span class="text-red-500">*</span></label>
            <select name="entity_type" required class={INPUT_CLS}>
              <option value="">Select type…</option>
              <option value="universities">University</option>
              <option value="programs">Program</option>
              <option value="scholarships">Scholarship</option>
              <option value="articles">Article</option>
              <option value="research_pack">Research Pack (nested university + programs)</option>
            </select>
          </div>
        ) : (
          <input type="hidden" name="entity_type" value={b.batch_type} />
        )}
        <div>
          <label class={LABEL_CLS}>JSON {b.batch_type === 'mixed' ? 'Array or Research Pack' : 'Array'} <span class="text-red-500">*</span></label>
          <textarea
            id="bulk-json-input"
            name="bulk_json"
            rows={10}
            required
            class={INPUT_CLS + ' font-mono text-xs'}
            placeholder={
              b.batch_type === 'universities'
                ? '[{\n  "name": "University of Example",\n  "country_code": "GB",\n  "official_url": "https://example.ac.uk"\n}]'
                : b.batch_type === 'programs'
                ? '[{\n  "title": "MSc Computer Science",\n  "degree_level_code": "msc",\n  "tuition_amount": 15000,\n  "staging_university_id": "<uuid>"\n}]'
                : b.batch_type === 'scholarships'
                ? '[{\n  "name": "Global Excellence Award",\n  "amount": 5000,\n  "deadline": "2026-05-01"\n}]'
                : b.batch_type === 'articles'
                ? '[{\n  "title": "How to Apply",\n  "slug": "how-to-apply",\n  "content": "Article body..."\n}]'
                : '{\n  "university": { ... },\n  "programs": [ ... ]\n}'
            }
          ></textarea>
          <div id="json-preview" style="display:none" class="mt-2 rounded-lg border p-3">
            <p id="json-preview-status" class="text-xs font-semibold"></p>
            <p id="json-preview-detail" class="mt-0.5 text-xs"></p>
            <p id="json-preview-note" class="mt-1 text-xs italic"></p>
          </div>
          <p class="mt-1 text-xs text-gray-400">
            Paste a JSON array of objects. Maximum 100 rows per paste.
            {b.batch_type === 'universities' && ' Keys: name, country_code, official_url.'}
            {b.batch_type === 'programs' && ' Keys: title, degree_level_code, language, tuition_amount, deadline, staging_university_id.'}
            {b.batch_type === 'scholarships' && ' Keys: name, amount, deadline.'}
            {b.batch_type === 'articles' && ' Keys: title, slug, category, content.'}
            {b.batch_type === 'mixed' && ' Paste a flat array for the selected type, or paste a nested university + programs research pack.'}
          </p>
          {(b.batch_type === 'programs' || b.batch_type === 'mixed') && (
            <p class="mt-1 text-xs text-amber-700 font-medium">
              Program rows: <span class="font-normal">flat program arrays still need staging_university_id at import time. Research packs do this automatically by staging the university first and linking each program to it.</span>
            </p>
          )}
        </div>
        <div>
          <button
            type="submit"
            class="rounded bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-1"
          >
            Import Rows
          </button>
        </div>
      </form>
    </div>
  </details>

  <!-- Add staged record form -->
  <details class="mb-6 rounded-lg border border-gray-200 bg-white" {...(formError !== null ? { open: true } : {})}>
    <summary class="px-4 py-3 cursor-pointer select-none text-sm font-semibold text-gray-700 hover:bg-gray-50 rounded-lg list-none flex items-center gap-2">
      <span class="text-gray-400 text-base leading-none">+</span>
      Add Staged Record
    </summary>
    <div class="px-4 py-4 border-t border-gray-100">
      {formError && (
        <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
          {formError}
        </div>
      )}
      <form method="POST" class="space-y-4">
        {b.batch_type === 'mixed' ? (
          <div>
            <label class={LABEL_CLS}>Entity Type <span class="text-red-500">*</span></label>
            <select name="entity_type" required class={INPUT_CLS}>
              <option value="">Select type…</option>
              <option value="universities">University</option>
              <option value="programs">Program</option>
              <option value="scholarships">Scholarship</option>
              <option value="articles">Article</option>
            </select>
            <p class="mt-1 text-xs text-gray-400">Fill in the section matching the selected type. Fields from other sections are ignored.</p>
          </div>
        ) : (
          <input type="hidden" name="entity_type" value={b.batch_type} />
        )}

        {/* University fields */}
        {showUniversities && (
          <fieldset class="border border-gray-200 rounded-md p-3">
            <legend class="px-1 text-xs font-semibold text-gray-500 uppercase tracking-wide">University</legend>
            <div class="space-y-3 mt-1">
              <div>
                <label class={LABEL_CLS}>Name</label>
                <input type="text" name="uni_extracted_name" class={INPUT_CLS} placeholder="University of Example" />
              </div>
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label class={LABEL_CLS}>Country Code</label>
                  <input type="text" name="uni_extracted_country_code" maxlength="2" class={INPUT_CLS} placeholder="US" />
                </div>
                <div>
                  <label class={LABEL_CLS}>Official URL</label>
                  <input type="text" name="uni_extracted_official_url" class={INPUT_CLS} placeholder="https://example.edu" />
                </div>
              </div>
            </div>
          </fieldset>
        )}

        {/* Program fields */}
        {showPrograms && (
          <fieldset class="border border-gray-200 rounded-md p-3">
            <legend class="px-1 text-xs font-semibold text-gray-500 uppercase tracking-wide">Program</legend>
            <div class="space-y-3 mt-1">
              <div>
                <label class={LABEL_CLS}>Title</label>
                <input type="text" name="prog_extracted_title" class={INPUT_CLS} placeholder="MSc Computer Science" />
              </div>
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label class={LABEL_CLS}>Degree Level Code</label>
                  <input type="text" name="prog_extracted_degree_level_code" class={INPUT_CLS} placeholder="msc" />
                </div>
                <div>
                  <label class={LABEL_CLS}>Language</label>
                  <input type="text" name="prog_extracted_language" class={INPUT_CLS} placeholder="English" />
                </div>
              </div>
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label class={LABEL_CLS}>Tuition Amount</label>
                  <input type="text" name="prog_extracted_tuition_amount" class={INPUT_CLS} placeholder="15000" />
                </div>
                <div>
                  <label class={LABEL_CLS}>Deadline</label>
                  <input type="text" name="prog_extracted_deadline" class={INPUT_CLS} placeholder="2026-03-01" />
                </div>
              </div>
              <div>
                <label class={LABEL_CLS}>Staging University</label>
                {stagingUniversities.length > 0 ? (
                  <select name="prog_staging_university_id" class={INPUT_CLS}>
                    <option value="">— none —</option>
                    {stagingUniversities.map(u => (
                      <option value={u.id}>{u.extracted_name ?? u.id}</option>
                    ))}
                  </select>
                ) : (
                  <div>
                    <input type="text" name="prog_staging_university_id" class={INPUT_CLS} placeholder="Staging university UUID (optional)" />
                    <p class="mt-1 text-xs text-gray-400">No staged universities in this batch yet. Import universities first, then add programs linking to them.</p>
                  </div>
                )}
              </div>
            </div>
          </fieldset>
        )}

        {/* Scholarship fields */}
        {showScholarships && (
          <fieldset class="border border-gray-200 rounded-md p-3">
            <legend class="px-1 text-xs font-semibold text-gray-500 uppercase tracking-wide">Scholarship</legend>
            <div class="space-y-3 mt-1">
              <div>
                <label class={LABEL_CLS}>Name</label>
                <input type="text" name="sch_extracted_name" class={INPUT_CLS} placeholder="Global Excellence Scholarship" />
              </div>
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label class={LABEL_CLS}>Amount</label>
                  <input type="text" name="sch_extracted_amount" class={INPUT_CLS} placeholder="5000" />
                </div>
                <div>
                  <label class={LABEL_CLS}>Deadline</label>
                  <input type="text" name="sch_extracted_deadline" class={INPUT_CLS} placeholder="2026-05-01" />
                </div>
              </div>
            </div>
          </fieldset>
        )}

        {/* Article fields */}
        {showArticles && (
          <fieldset class="border border-gray-200 rounded-md p-3">
            <legend class="px-1 text-xs font-semibold text-gray-500 uppercase tracking-wide">Article</legend>
            <div class="space-y-3 mt-1">
              <div>
                <label class={LABEL_CLS}>Title</label>
                <input type="text" name="art_extracted_title" class={INPUT_CLS} placeholder="How to Apply for a Scholarship" />
              </div>
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label class={LABEL_CLS}>Slug</label>
                  <input type="text" name="art_extracted_slug" class={INPUT_CLS} placeholder="how-to-apply-for-scholarship" />
                </div>
                <div>
                  <label class={LABEL_CLS}>Category</label>
                  <input type="text" name="art_extracted_category" class={INPUT_CLS} placeholder="scholarships" />
                </div>
              </div>
              <div>
                <label class={LABEL_CLS}>Content</label>
                <textarea name="art_extracted_content" rows="4" class={INPUT_CLS} placeholder="Article body text…"></textarea>
              </div>
            </div>
          </fieldset>
        )}

        <div>
          <label class={LABEL_CLS}>Raw Data (JSON, optional)</label>
          <textarea name="raw_data" rows="3" class={INPUT_CLS} placeholder={'{"source": "manual"}'}></textarea>
          <p class="mt-1 text-xs text-gray-400">Must be a valid JSON object if provided. Leave blank to default to {}.</p>
        </div>

        <div>
          <button type="submit" class="rounded bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-1">
            Add Record
          </button>
        </div>
      </form>
    </div>
  </details>

  {actionableStaged > 0 && (
    <div class="mb-4 flex items-center gap-3">
      <form method="POST">
        <input type="hidden" name="_action" value="run_quality_checks" />
        <button
          type="submit"
          class="rounded border border-purple-300 bg-purple-50 px-4 py-2 text-sm font-medium text-purple-700 hover:bg-purple-100 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-offset-1"
        >
          Run quality checks
        </button>
      </form>
      <span class="text-xs text-gray-400">Checks for same-batch duplicates and possible production matches. Warnings appear in the Actions column below.</span>
    </div>
  )}

  {actionableStaged === 0 && stagingErrors.length === 0 ? (
    <p class="text-sm text-gray-500 py-2">No staged records or errors for this batch yet.</p>
  ) : null}

  {issuesMayBeTruncated && (
    <div class="mb-4 px-4 py-3 rounded-lg border border-amber-200 bg-amber-50 text-sm text-amber-800">
      Only the newest 100 staging issues are shown below. Row pagination now applies to staged rows, but the issues table remains capped for safety in this phase.
    </div>
  )}

  {activeEntity === 'universities' && (
    <div class="mb-6">
      <div class="mb-3 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2 class="text-base font-semibold text-gray-800">Staged Universities</h2>
          <p class="mt-1 text-sm text-gray-500">
            {filteredRowCount === 0
              ? 'No universities match the current filters.'
              : `Showing ${pageStart}-${pageEnd} of ${filteredRowCount} universities.`}
          </p>
        </div>
        {visibleUniversities.length > 0 && (
          <form id="bulk-review-form" method="POST" action={currentFilterPath} class="flex flex-wrap items-center gap-2">
            <input type="hidden" name="_action" value="bulk_review" />
            <input type="hidden" name="entity_type" value="universities" />
            {visibleRowIds.map((rowId) => <input type="hidden" name="visible_row_ids" value={rowId} />)}
            <select name="review_action" class={INPUT_CLS} aria-label="Bulk review action">
              <option value="approve">Approve selected</option>
              <option value="reject">Reject selected</option>
              <option value="skip">Skip selected</option>
              <option value="reset">Reset selected</option>
            </select>
            <button type="button" data-select-visible class="rounded border border-gray-300 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
              Select visible
            </button>
            <button type="button" data-clear-selection class="rounded border border-gray-300 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
              Clear selection
            </button>
            <button type="submit" class="rounded bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
              Apply to selected
            </button>
            <span data-selection-count class="text-xs text-gray-500">0 selected</span>
          </form>
        )}
      </div>
      {visibleUniversities.length > 0 ? (
      <div class="overflow-x-auto rounded-lg border border-gray-200">
        <table class="w-full text-sm text-left">
          <thead class="bg-gray-50 border-b border-gray-200 text-xs text-gray-500 uppercase tracking-wide">
            <tr>
              <th class="px-4 py-3">Select</th>
              <th class="px-4 py-3">Name</th>
              <th class="px-4 py-3">Country</th>
              <th class="px-4 py-3">URL</th>
              <th class="px-4 py-3">Status</th>
              <th class="px-4 py-3">Notes</th>
              <th class="px-4 py-3">Actions</th>
              <th class="px-4 py-3">Raw Data</th>
            </tr>
          </thead>
          <tbody>
            {visibleUniversities.map(row => (
              <tr class="border-b border-gray-100 hover:bg-gray-50 align-top">
                <td class="px-4 py-3">
                  <input
                    form="bulk-review-form"
                    type="checkbox"
                    name="row_ids"
                    value={row.id}
                    data-visible-row-checkbox
                    disabled={isProgramImportHelperRow(row.raw_data) || row.import_status === 'merged' || row.import_status === 'processing' || row.import_status === 'error'}
                    class="h-4 w-4 rounded border-gray-300 text-blue-600"
                  />
                </td>
                <td class="px-4 py-3 text-gray-700">{row.extracted_name ?? <span class="text-gray-400">—</span>}</td>
                <td class="px-4 py-3 text-gray-500 text-xs">{row.extracted_country_code ?? '—'}</td>
                <td class="px-4 py-3 text-xs max-w-[160px] truncate">
                  {row.extracted_official_url
                    ? <a href={row.extracted_official_url} class="text-blue-600 hover:underline" target="_blank" rel="noopener noreferrer">{row.extracted_official_url}</a>
                    : <span class="text-gray-400">—</span>}
                </td>
                <td class="px-4 py-3">
                  <span class={`inline-flex items-center rounded px-2 py-0.5 text-xs font-medium ${IMPORT_STATUS_BADGE[row.import_status] ?? FALLBACK_BADGE}`}>
                    {row.import_status}
                  </span>
                  {(errsByRowId.get(row.id) ?? []).some(e => e.error_type === 'validation_warning') && (
                    <span class="ml-1 inline-flex items-center rounded px-1.5 py-0.5 text-xs font-medium bg-orange-100 text-orange-700">warnings</span>
                  )}
                  {(errsByRowId.get(row.id) ?? []).some(e => e.error_type === 'same_batch_duplicate' || e.error_type === 'possible_production_match') && (
                    <span class="ml-1 inline-flex items-center rounded px-1.5 py-0.5 text-xs font-medium bg-amber-100 text-amber-700">quality</span>
                  )}
                </td>
                <td class="px-4 py-3 text-xs text-gray-500 max-w-[140px]">{row.review_notes ?? '—'}</td>
                <td class="px-3 py-3 text-xs min-w-[200px]">
                  {(errsByRowId.get(row.id) ?? []).length > 0 && (
                    <div class="mb-1.5 space-y-0.5">
                      {(errsByRowId.get(row.id) ?? []).map(e => (
                        <p class={e.error_type === 'validation_warning' ? 'text-orange-600' : 'text-amber-700'}>{e.error_message}</p>
                      ))}
                    </div>
                  )}
                  {row.reviewed_at && (
                    <p class="text-gray-400 mb-1.5">Reviewed {new Date(row.reviewed_at).toLocaleString()}</p>
                  )}
                  {isProgramImportHelperRow(row.raw_data) && (
                    <div class="rounded border border-emerald-200 bg-emerald-50 px-2 py-1.5 text-emerald-800">
                      Helper row linked to {row.match_university_id ? (matchedUniversityNameMap.get(row.match_university_id) ?? 'the selected production university') : 'the selected production university'}. No university merge is required for this row.
                    </div>
                  )}
                  {!isProgramImportHelperRow(row.raw_data) && row.import_status !== 'merged' && (
                    <form method="POST" class="space-y-1.5">
                      <input type="hidden" name="_action" value="review" />
                      <input type="hidden" name="entity_type" value="universities" />
                      <input type="hidden" name="row_id" value={row.id} />
                      <div class="flex flex-wrap gap-1">
                        <button name="review_action" value="approve" class="rounded bg-green-600 px-2 py-1 text-xs font-medium text-white hover:bg-green-700">Approve</button>
                        <button name="review_action" value="reject" class="rounded bg-red-600 px-2 py-1 text-xs font-medium text-white hover:bg-red-700">Reject</button>
                        <button name="review_action" value="skip" class="rounded bg-yellow-500 px-2 py-1 text-xs font-medium text-white hover:bg-yellow-600">Skip</button>
                        <button name="review_action" value="reset" class="rounded border border-gray-300 px-2 py-1 text-xs font-medium text-gray-600 hover:bg-gray-50">Reset</button>
                      </div>
                      <details class="mt-0.5">
                        <summary class="text-xs text-gray-400 cursor-pointer hover:text-gray-600">{row.review_notes ? 'Edit note…' : 'Add note…'}</summary>
                        <textarea name="review_notes" rows={2} placeholder="Note…" class="mt-1 block w-full rounded border border-gray-200 px-2 py-1 text-xs text-gray-700 placeholder-gray-300 focus:outline-none focus:border-blue-400">{row.review_notes ?? ''}</textarea>
                      </details>
                    </form>
                  )}
                  {!isProgramImportHelperRow(row.raw_data) && row.import_status === 'approved' && !row.match_university_id && (
                    <div class="mt-2 border-t border-gray-100 pt-2 space-y-3">
                      <details>
                        <summary class="cursor-pointer text-blue-600 hover:text-blue-800 text-xs">Link to existing production university…</summary>
                        <form method="POST" class="mt-2 space-y-1.5">
                          <input type="hidden" name="_action" value="set_match_university_id" />
                          <input type="hidden" name="row_id" value={row.id} />
                          <p class="text-gray-600 text-xs">Paste the production university UUID to link this staging row for update-existing merge. No production write occurs.</p>
                          <input
                            type="text"
                            name="production_university_id"
                            placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                            pattern="[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}"
                            required
                            class="block w-full rounded border border-gray-200 px-2 py-1 text-xs font-mono text-gray-700 placeholder-gray-300 focus:outline-none focus:border-blue-400"
                          />
                          <button type="submit" class="rounded bg-blue-600 px-2 py-1 text-xs font-medium text-white hover:bg-blue-700">
                            Link
                          </button>
                        </form>
                      </details>
                      <form method="POST" class="space-y-1.5">
