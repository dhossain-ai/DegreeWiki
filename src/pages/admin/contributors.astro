---
import AdminLayout from '../../layouts/AdminLayout.astro'
import { forbiddenAdminResponse, requireAnyAdminPermission } from '../../lib/admin/guard'
import {
  CONTRIBUTOR_STATUS_BADGES,
  CONTRIBUTOR_STATUS_LABELS,
  type ContributorApplicationRecord,
  type ContributorProfileRecord,
} from '../../lib/contributors/application'
import { isContributorProfileApproved } from '../../lib/contributors/status'

const guard = await requireAnyAdminPermission(
  Astro.cookies,
  Astro.request,
  Astro.url.pathname,
  ['edit_content', 'manage_users'],
)
if (guard.type === 'redirect') return Astro.redirect(guard.to)
if (guard.type === 'forbidden') return forbiddenAdminResponse()

const { user, supabase } = guard

const { data: applicationsData, error: applicationsError } = await supabase
  .from('contributor_applications')
  .select(`
    id, user_id, status, requested_contributor_type, headline,
    organization_name, role_title, country_expertise_text,
    university_expertise_text, subject_expertise_text, bio_draft,
    motivation, public_profile_requested, public_attribution_consent,
    external_links, admin_notes, rejection_reason, reviewed_by_user_id,
    reviewed_at, submitted_at, created_at, updated_at
  `)
  .order('updated_at', { ascending: false })
  .limit(100)

const applications = (applicationsData ?? []) as ContributorApplicationRecord[]
const applicantIds = Array.from(new Set(applications.map(application => application.user_id)))

const [{ data: profileRows }, { data: contributorProfileRows }] = applicantIds.length > 0
  ? await Promise.all([
    supabase.from('user_profiles').select('id, display_name').in('id', applicantIds),
    supabase
      .from('contributor_profiles')
      .select(`
        user_id, profile_review_status, public_profile_enabled,
        public_display_name, public_role_label, organization_name,
        headline, joined_at, approved_at
      `)
      .in('user_id', applicantIds),
  ])
  : [{ data: [] }, { data: [] }]

const profileNameById = new Map((profileRows ?? []).map((profile: any) => [profile.id as string, profile.display_name as string | null]))
const contributorProfileById = new Map(
  ((contributorProfileRows ?? []) as ContributorProfileRecord[]).map(profile => [profile.user_id, profile]),
)

const rows = applications.map((application) => {
  const contributorProfile = contributorProfileById.get(application.user_id) ?? null
  return {
    application,
    displayName: profileNameById.get(application.user_id) ?? null,
    contributorProfile,
    isApprovedContributor: isContributorProfileApproved(contributorProfile?.profile_review_status),
  }
})

const awaitingReviewCount = rows.filter(({ application }) => (
  application.status === 'submitted' || application.status === 'pending_review'
)).length
const needsMoreInfoCount = rows.filter(({ application }) => application.status === 'needs_more_info').length
const approvedCount = rows.filter(({ isApprovedContributor }) => isApprovedContributor).length

function formatDate(iso: string | null | undefined): string {
  if (!iso) return '—'
  return new Date(iso).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  })
}
---
<AdminLayout title="Contributors — DegreeWiki Admin" activePath="/admin/contributors" userEmail={user.email ?? ''}>
  <div class="mb-6 flex flex-wrap items-start justify-between gap-3">
    <div>
      <h1 class="text-xl font-bold text-gray-900">Contributors</h1>
      <p class="mt-1 text-sm text-gray-500">
        Review contributor applications, request more information, and approve contributor role access.
      </p>
    </div>
    <span class="text-sm text-gray-400">Recent 100 applications</span>
  </div>

  {!applicationsError && (
    <div class="mb-6 grid gap-4 sm:grid-cols-3">
      <div class="rounded-lg border border-blue-200 bg-blue-50 px-4 py-3">
        <p class="text-xs font-semibold uppercase tracking-wide text-blue-700">Awaiting review</p>
        <p class="mt-2 text-2xl font-bold text-blue-950">{awaitingReviewCount}</p>
      </div>
      <div class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-3">
        <p class="text-xs font-semibold uppercase tracking-wide text-amber-700">Needs more info</p>
        <p class="mt-2 text-2xl font-bold text-amber-950">{needsMoreInfoCount}</p>
      </div>
      <div class="rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3">
        <p class="text-xs font-semibold uppercase tracking-wide text-emerald-700">Approved contributors</p>
        <p class="mt-2 text-2xl font-bold text-emerald-950">{approvedCount}</p>
      </div>
    </div>
  )}

  {applicationsError ? (
    <p class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
      Could not load contributor applications.
    </p>
  ) : rows.length === 0 ? (
    <p class="rounded-lg border border-gray-200 bg-white px-4 py-6 text-sm text-gray-500">
      No contributor applications found yet.
    </p>
  ) : (
    <div class="overflow-x-auto rounded-lg border border-gray-200 bg-white">
      <table class="w-full text-left text-sm">
        <thead class="border-b border-gray-200 bg-gray-50 text-xs uppercase tracking-wide text-gray-500">
          <tr>
            <th class="px-4 py-3">Applicant</th>
            <th class="px-4 py-3">Type</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Submitted</th>
            <th class="px-4 py-3">Updated</th>
            <th class="px-4 py-3">Review</th>
          </tr>
        </thead>
        <tbody>
          {rows.map(({ application, displayName, isApprovedContributor }) => (
            <tr class="border-b border-gray-100 hover:bg-gray-50">
              <td class="px-4 py-3 align-top">
                <p class="font-medium text-gray-900">{displayName ?? 'Unnamed applicant'}</p>
                <p class="mt-1 text-xs text-gray-500">{application.headline ?? application.role_title ?? 'No headline yet'}</p>
                <p class="mt-1 font-mono text-[11px] text-gray-400">{application.user_id}</p>
              </td>
              <td class="px-4 py-3 align-top text-gray-700">
                {application.requested_contributor_type ?? '—'}
              </td>
              <td class="px-4 py-3 align-top">
                <div class="flex flex-col gap-2">
                  <span class={`inline-flex items-center rounded border px-2 py-0.5 text-xs font-medium ${CONTRIBUTOR_STATUS_BADGES[application.status]}`}>
                    {CONTRIBUTOR_STATUS_LABELS[application.status]}
                  </span>
                  {isApprovedContributor && (
                    <span class="inline-flex items-center rounded border border-emerald-200 bg-emerald-50 px-2 py-0.5 text-xs font-medium text-emerald-700">
                      contributor role active
                    </span>
                  )}
                </div>
              </td>
              <td class="px-4 py-3 align-top text-xs text-gray-500">{formatDate(application.submitted_at)}</td>
              <td class="px-4 py-3 align-top text-xs text-gray-500">{formatDate(application.updated_at)}</td>
              <td class="px-4 py-3 align-top">
                <a
                  href={`/admin/contributors/${application.user_id}`}
                  class="inline-flex items-center justify-center rounded-md bg-gray-900 px-3 py-1.5 text-xs font-medium text-white hover:bg-gray-800"
                >
                  Open
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</AdminLayout>

