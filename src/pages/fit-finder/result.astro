---
import PublicLayout from '../../layouts/PublicLayout.astro'
import MediaImage from '../../components/public/MediaImage.astro'
import SavedProgramEnhancement from '../../components/public/SavedProgramEnhancement.astro'
import { createClient } from '../../lib/supabase/server'
import { SITE_URL } from '../../lib/site'
import { getAIEnv } from '../../lib/ai/env'
import { persistFinderResult } from '../../lib/ai/finder/persist'
import { sanitizeAIExplanation } from '../../lib/ai/finder/sanitize'
import { getFitMatchLabel, type FitMatchTone } from '../../lib/fit-finder/matches'

const supabase = createClient(Astro.cookies, Astro.request)

type Profile = {
  id: string
  target_degree_level_id: string | null
  budget_min: number | null
  budget_max: number | null
  budget_currency: string | null
  degree_levels?: { name: string } | null
}

type SubjectPreferenceRow = {
  subject_id?: string
  preference_rank: number | null
  subjects?: { name: string } | null
}

type CountryPreferenceRow = {
  country_id?: string
  preference_rank: number | null
  countries?: { name: string } | null
}

type ProgramSubjectRow = {
  program_id: string
  subject_id: string
  is_primary: boolean
  display_order: number
}

type Match = {
  program: any
  points: number
  percentage: number
  reasons: string[]
  warnings: string[]
}

const DEGREE_POINTS = 35
const SUBJECT_PRIMARY_POINTS = 30
const SUBJECT_SECONDARY_POINTS = 24
const SUBJECT_POSSIBLE_POINTS = 30
const COUNTRY_POINTS = 25
const BUDGET_POINTS = 10
const BUDGET_PARTIAL_POINTS = 5

const { data: { user } } = await supabase.auth.getUser()

let profile: Profile | null = null
let subjectPrefs: SubjectPreferenceRow[] = []
let countryPrefs: CountryPreferenceRow[] = []
let matches: Match[] = []
let possiblePoints = 0
let pageState: 'anonymous' | 'no_profile' | 'sparse_profile' | 'ready' | 'no_matches' | 'error' = 'anonymous'
let pageError = ''
let deviation = ''
let degreeLevelName: string | null = null
let subjectNames: string[] = []
let countryNames: string[] = []
let budgetSummary: string | null = null
let savedSignalCount = 0
let candidatesChecked = 0
let missingSignals: string[] = []
let aiExplanation: string | null = null
let savedResultId: string | null = null
let persistAttempted = false
let savedProgramIds = new Set<string>()

function formatMode(value: string | null | undefined): string {
  return value ? value.replace(/_/g, ' ') : ''
}

function formatTuition(p: any): string | null {
  if (p.tuition_min_amount == null && p.tuition_max_amount == null) return null
  const fmt = (n: number) => Number(n).toLocaleString()
  const range =
    p.tuition_min_amount != null && p.tuition_max_amount != null
      ? `${fmt(p.tuition_min_amount)} - ${fmt(p.tuition_max_amount)}`
      : p.tuition_min_amount != null
        ? fmt(p.tuition_min_amount)
        : `up to ${fmt(p.tuition_max_amount)}`
  const period = p.tuition_period?.replace(/_/g, ' ') ?? ''
  return [p.tuition_currency, range, period].filter(Boolean).join(' ').trim()
}

function formatBudgetRange(min: number | null, max: number | null, currency: string | null): string | null {
  if (!currency) return null
  const prefix = currency.trim().toUpperCase()
  const fmt = (value: number) => `${prefix} ${Number(value).toLocaleString()}`

  if (min != null && max != null) {
    if (min === max) return fmt(max)
    return `${fmt(min)} - ${fmt(max)}`
  }

  if (max != null) return `Up to ${fmt(max)}`
  if (min != null) return `${fmt(min)}+`
  return null
}

function getLabelClasses(tone: FitMatchTone): string {
  if (tone === 'strong') return 'bg-emerald-50 text-emerald-700 border border-emerald-200'
  if (tone === 'good') return 'bg-blue-50 text-blue-700 border border-blue-200'
  if (tone === 'possible') return 'bg-violet-50 text-violet-700 border border-violet-200'
  if (tone === 'ambitious') return 'bg-amber-50 text-amber-800 border border-amber-200'
  return 'bg-slate-100 text-slate-700 border border-slate-200'
}

function hasEnglishRequirements(value: unknown): boolean {
  if (!value) return false
  if (typeof value === 'string') return value.trim().length > 0
  if (typeof value === 'object' && !Array.isArray(value)) return Object.keys(value).length > 0
  return false
}

function uniqueById(rows: any[]): any[] {
  const seen = new Set<string>()
  const unique: any[] = []
  for (const row of rows) {
    if (!row?.id || seen.has(row.id)) continue
    seen.add(row.id)
    unique.push(row)
  }
  return unique
}

if (!user) {
  pageState = 'anonymous'
} else {
  const { data: profileData, error: profileError } = await supabase
    .from('student_profiles')
    .select('id, target_degree_level_id, budget_min, budget_max, budget_currency, degree_levels(name)')
    .eq('user_id', user.id)
    .eq('is_anonymous', false)
    .order('updated_at', { ascending: false })
    .limit(1)
    .maybeSingle()

  if (profileError) {
    console.error('fit finder result profile load error:', profileError.message)
    pageState = 'error'
    pageError = 'Could not load your saved Fit Finder profile. Please try again.'
  } else if (!profileData) {
    pageState = 'no_profile'
  } else {
    profile = profileData as Profile

    const [{ data: subjectRows, error: subjectError }, { data: countryRows, error: countryError }] = await Promise.all([
      supabase
        .from('student_profile_subjects')
        .select('subject_id, preference_rank, subjects(name)')
        .eq('student_profile_id', profile.id)
        .order('preference_rank', { ascending: true }),
      supabase
        .from('student_profile_countries')
        .select('country_id, preference_rank, countries(name)')
        .eq('student_profile_id', profile.id)
        .order('preference_rank', { ascending: true }),
    ])

    if (subjectError || countryError) {
      console.error('fit finder result preference load error:', subjectError?.message ?? countryError?.message)
      pageState = 'error'
      pageError = 'Could not load your saved Fit Finder preferences. Please try again.'
    } else {
      subjectPrefs = (subjectRows ?? []) as SubjectPreferenceRow[]
      countryPrefs = (countryRows ?? []) as CountryPreferenceRow[]

      degreeLevelName = (profile.degree_levels as any)?.name ?? null
      subjectNames = subjectPrefs.map(r => (r.subjects as any)?.name).filter(Boolean) as string[]
      countryNames = countryPrefs.map(r => (r.countries as any)?.name).filter(Boolean) as string[]
      if (profile.budget_max != null && profile.budget_currency) {
        budgetSummary = `Up to ${Number(profile.budget_max).toLocaleString()} ${profile.budget_currency}`
      }

      const preferredSubjectIds = subjectPrefs.map(row => row.subject_id).filter(Boolean) as string[]
      const preferredCountryIds = countryPrefs.map(row => row.country_id).filter(Boolean) as string[]
      const preferredSubjectSet = new Set(preferredSubjectIds)
      const preferredCountrySet = new Set(preferredCountryIds)
      const hasBudgetSignal = profile.budget_max != null && !!profile.budget_currency

      savedSignalCount = [
        !!profile.target_degree_level_id,
        preferredSubjectIds.length > 0,
        preferredCountryIds.length > 0,
        hasBudgetSignal,
      ].filter(Boolean).length

      possiblePoints =
        (profile.target_degree_level_id ? DEGREE_POINTS : 0) +
        (preferredSubjectIds.length > 0 ? SUBJECT_POSSIBLE_POINTS : 0) +
        (preferredCountryIds.length > 0 ? COUNTRY_POINTS : 0) +
        (hasBudgetSignal ? BUDGET_POINTS : 0)

      if (possiblePoints === 0) {
        missingSignals = [
          !profile.target_degree_level_id ? 'target degree level' : '',
          preferredSubjectIds.length === 0 ? 'subjects of interest' : '',
          preferredCountryIds.length === 0 ? 'preferred countries' : '',
          !hasBudgetSignal ? 'budget' : '',
        ].filter(Boolean)
        pageState = 'sparse_profile'
      } else {
        const { data: programRows, error: programError } = await supabase
          .from('programs')
          .select(`
            id, title, slug, university_id, country_id, city_id, degree_level_id,
            primary_subject_id, study_mode, delivery_mode, language_of_instruction,
            tuition_min_amount, tuition_max_amount, tuition_currency, tuition_period,
            official_url, admission_requirements, english_requirements, gpa_requirements,
            verification_status, source_confidence_score,
            universities(
              id, name, slug,
              logo:media_assets!universities_logo_id_fkey(cloudinary_public_id, alt_text, display_name)
            ),
            countries(name),
            cities(name),
            degree_levels(name),
            subjects!programs_primary_subject_id_fkey(name)
          `)
          .eq('content_status', 'published')
          .order('title')
          .limit(200)

        if (programError) {
          console.error('fit finder result program query error:', programError.message)
          pageState = 'error'
          pageError = 'Could not load program matches right now. Please try again.'
        } else {
          const candidates = uniqueById(programRows ?? [])
          candidatesChecked = candidates.length
          const candidateIds = candidates.map(row => row.id).filter(Boolean)
          const subjectsByProgram = new Map<string, ProgramSubjectRow[]>()

          if (candidateIds.length > 0) {
            const { data: programSubjectRows, error: programSubjectError } = await supabase
              .from('program_subjects')
              .select('program_id, subject_id, is_primary, display_order')
              .in('program_id', candidateIds)
              .order('display_order', { ascending: true })

            if (programSubjectError) {
              console.error('fit finder result program_subjects query error:', programSubjectError.message)
              deviation = 'Subject matching used each program primary subject only because additional subject data could not be loaded.'
            } else {
              for (const row of (programSubjectRows ?? []) as ProgramSubjectRow[]) {
                const existing = subjectsByProgram.get(row.program_id) ?? []
                existing.push(row)
                subjectsByProgram.set(row.program_id, existing)
              }
            }
          }

          matches = candidates
            .map((program: any): Match => {
              let points = 0
              const reasons: string[] = []
              const warnings: string[] = []

              if (profile?.target_degree_level_id && program.degree_level_id === profile.target_degree_level_id) {
                points += DEGREE_POINTS
                const levelLabel = degreeLevelName ? `: ${degreeLevelName}` : ''
                reasons.push(`Matches your target degree level${levelLabel}.`)
              }

              if (preferredCountrySet.size > 0 && preferredCountrySet.has(program.country_id)) {
                points += COUNTRY_POINTS
                reasons.push('In one of your preferred countries.')
              }

              if (preferredSubjectSet.size > 0) {
                if (program.primary_subject_id && preferredSubjectSet.has(program.primary_subject_id)) {
                  points += SUBJECT_PRIMARY_POINTS
                  reasons.push('Matches one of your preferred subjects.')
                } else {
                  const programSubjects = subjectsByProgram.get(program.id) ?? []
                  const hasSubjectMatch = programSubjects.some(row => preferredSubjectSet.has(row.subject_id))
                  if (hasSubjectMatch) {
                    points += SUBJECT_SECONDARY_POINTS
                    reasons.push('Matches one of your preferred subjects.')
                  }
                }
              }

              if (hasBudgetSignal && profile?.budget_currency && profile.budget_max != null) {
                const profileCurrency = profile.budget_currency.trim().toUpperCase()
                const tuitionCurrency = String(program.tuition_currency ?? '').trim().toUpperCase()
                const hasTuitionData = program.tuition_min_amount != null || program.tuition_max_amount != null

                if (!hasTuitionData) {
                  warnings.push('Tuition data is missing; confirm costs with the university.')
                } else if (!tuitionCurrency || tuitionCurrency !== profileCurrency) {
                  warnings.push('Tuition currency differs from your saved budget currency.')
                } else if (program.tuition_max_amount != null && Number(program.tuition_max_amount) <= profile.budget_max) {
                  points += BUDGET_POINTS
                  reasons.push('Tuition appears within your saved budget.')
                } else if (program.tuition_min_amount != null && Number(program.tuition_min_amount) <= profile.budget_max) {
                  points += BUDGET_PARTIAL_POINTS
                  reasons.push('Tuition may partially fit your saved budget.')
                  warnings.push('Tuition may be above your saved budget.')
                } else {
                  warnings.push('Tuition may be above your saved budget.')
                }
              }

              if (program.admission_requirements || program.gpa_requirements || hasEnglishRequirements(program.english_requirements)) {
                warnings.push('Admission and language requirements must be verified with the official source.')
              }

              return {
                program,
                points,
                percentage: Math.round((points / possiblePoints) * 100),
                reasons,
                warnings,
              }
            })
            .filter(match => match.points > 0)
            .sort((a, b) =>
              b.points - a.points ||
              b.percentage - a.percentage ||
              b.reasons.length - a.reasons.length ||
              String(a.program.title).localeCompare(String(b.program.title))
            )
            .slice(0, 20)

          pageState = matches.length > 0 ? 'ready' : 'no_matches'

          if (pageState === 'ready' && matches.length > 0) {
            // The AI summary is generated asynchronously by /api/ai/finder-summary
            // after this page loads. Here we only persist (or reuse) the
            // rule-based result row — no provider call happens during render.
            const aiEnv = getAIEnv(Astro.locals as Record<string, unknown>)

            try {
              const sixtySecondsAgo = new Date(Date.now() - 60_000).toISOString()
              const { data: recentResult } = await supabase
                .from('ai_finder_results')
                .select('id, ai_explanation')
                .eq('student_profile_id', profile!.id)
                .eq('result_status', 'complete')
                .gte('created_at', sixtySecondsAgo)
                .order('created_at', { ascending: false })
                .limit(1)
                .maybeSingle()

              if (recentResult?.id) {
                // Reuse the recent result. If it already has a cached summary,
                // show it immediately — the client never calls the provider.
                savedResultId = recentResult.id as string
                const cached = recentResult.ai_explanation as string | null
                if (cached && cached.trim().length > 0) {
                  aiExplanation = sanitizeAIExplanation(cached)
                }
              } else {
                persistAttempted = true
                savedResultId = await persistFinderResult(
                  {
                    studentProfileId:  profile!.id,
                    shortlistCount:    matches.length,
                    aiExplanation:     null,
                    aiModelUsed:       null,
                    promptTokenCount:  0,
                    completionTokenCount: 0,
                    matches: matches.map((m, i) => ({
                      programId:    m.program.id as string,
                      rank:         i + 1,
                      score:        m.points,
                      matchReasons: m.reasons,
                      warnings:     m.warnings,
                    })),
                  },
                  aiEnv,
                )
              }
            } catch {
              // persist failure must never break rule-based matches
            }
          }
        }
      }
    }
  }
}

if (user && matches.length > 0) {
  const programIds = matches.map(match => match.program?.id).filter(Boolean) as string[]
  if (programIds.length > 0) {
    const { data: savedRows, error: savedError } = await supabase
      .from('saved_items')
      .select('entity_id')
      .eq('user_id', user.id)
      .eq('entity_type', 'program')
      .in('entity_id', programIds)

    if (savedError) {
      console.error('fit finder result saved_items error:', savedError.message)
    } else {
      savedProgramIds = new Set((savedRows ?? []).map((row: any) => row.entity_id).filter(Boolean))
    }
  }
}

const pageTitle = 'Possible program matches'
const currentPath = `${Astro.url.pathname}${Astro.url.search}`
const saveLoginHref = `/login?redirect=${encodeURIComponent(currentPath)}`
const budgetRangeLabel = profile
  ? formatBudgetRange(profile.budget_min ?? null, profile.budget_max ?? null, profile.budget_currency ?? null)
  : null
const showDevPersistWarning =
  import.meta.env.DEV &&
  pageState === 'ready' &&
  matches.length > 0 &&
  savedResultId === null
// The AI summary card is shown (with an async-loading placeholder) whenever a
// result row was saved but does not yet have a cached explanation.
const showAISummaryCard = pageState === 'ready' && matches.length > 0 && !!savedResultId
const aiCardPending = showAISummaryCard && !aiExplanation
const initialVisibleMatches = 6
const savedResultHref = savedResultId ? `/fit-finder/results/${savedResultId}` : null
const advisorHref = savedResultId ? `${savedResultHref}#ai-advisor` : null
const matchLegend: Array<{ label: string; tone: FitMatchTone }> = [
  { label: 'Strong match', tone: 'strong' },
  { label: 'Good match', tone: 'good' },
  { label: 'Possible match', tone: 'possible' },
  { label: 'Ambitious', tone: 'ambitious' },
  { label: 'Needs review', tone: 'review' },
]
---
<PublicLayout
  title={`${pageTitle} — DegreeWiki`}
  description="Rule-based DegreeWiki Fit Finder program matches based on saved preferences."
  noindex={true}
  canonical={SITE_URL + '/fit-finder/result'}
>
  <div class="max-w-5xl mx-auto px-4 py-8">
    {pageState === 'anonymous' ? (
      <div class="max-w-2xl">
        <h1 class="text-2xl font-bold text-gray-900 mb-3">Save your Fit Finder preferences</h1>
        <p class="text-gray-600 mb-6">
          Sign in and save your Fit Finder preferences to see rule-based program matches.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/login?redirect=/fit-finder" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700">
            Sign in to continue
          </a>
          <a href="/fit-finder" class="px-4 py-2 text-sm text-gray-600 border border-gray-300 rounded-md hover:bg-gray-50">
            Open Fit Finder
          </a>
        </div>
      </div>
    ) : pageState === 'no_profile' ? (
      <div class="max-w-2xl">
        <h1 class="text-2xl font-bold text-gray-900 mb-3">No saved Fit Finder profile yet.</h1>
        <p class="text-gray-600 mb-6">
          Save your study preferences first, then DegreeWiki can rank possible program matches.
        </p>
        <a href="/fit-finder" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700">
          Save preferences
        </a>
      </div>
    ) : pageState === 'sparse_profile' ? (
      <div class="max-w-2xl">
        <h1 class="text-2xl font-bold text-gray-900 mb-3">Add more preferences to find matches</h1>
        <p class="text-gray-600 mb-3">
          To generate possible program matches, save at least one of the following:
        </p>
        {missingSignals.length > 0 && (
          <ul class="list-disc pl-5 text-sm text-gray-700 mb-5 space-y-0.5">
            {missingSignals.map(s => <li>{s}</li>)}
          </ul>
        )}
        <div class="flex flex-wrap gap-3">
          <a href="/fit-finder" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700">
            Update preferences
          </a>
          <a href="/programs" class="px-4 py-2 text-sm text-gray-600 border border-gray-300 rounded-md hover:bg-gray-50">
            Browse all programs
          </a>
        </div>
      </div>
    ) : pageState === 'error' ? (
      <div class="max-w-2xl">
        <h1 class="text-2xl font-bold text-gray-900 mb-3">Matches are temporarily unavailable</h1>
        <p class="text-gray-600 mb-6">{pageError || 'Something went wrong while loading your matches.'}</p>
        <div class="flex flex-wrap gap-3">
          <a href="/fit-finder" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700">
            Update preferences
          </a>
          <a href="/programs" class="px-4 py-2 text-sm text-gray-600 border border-gray-300 rounded-md hover:bg-gray-50">
            Browse all programs
          </a>
        </div>
      </div>
    ) : (
      <>
        <div class="max-w-4xl mb-6">
          <h1 class="text-3xl font-bold text-gray-900 mb-2">Your Fit Finder matches</h1>
          <p class="text-gray-600">
            Start with the strongest shortlist, then open the saved result when you want AI follow-up.
          </p>
        </div>

        {savedResultId && (
          <div class="max-w-4xl mb-5 flex flex-wrap items-center gap-3 px-4 py-3 rounded-xl bg-green-50 border border-green-100 text-sm text-green-800">
            <span>Your matches have been saved to your account.</span>
            <a href={savedResultHref!} class="font-medium underline hover:text-green-900">
              View saved result →
            </a>
            <a href={advisorHref!} class="font-medium underline hover:text-green-900">
              Open AI advisor →
            </a>
          </div>
        )}

        <div class="max-w-4xl mb-6 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="min-w-0">
              <p class="text-xs font-semibold uppercase tracking-[0.12em] text-blue-700 mb-2">Summary first</p>
              <h2 class="text-xl font-semibold text-gray-900 mb-2">
                {matches.length === 1 ? '1 program matched your profile' : `${matches.length} programs matched your profile`}
              </h2>
              <p class="text-sm text-gray-600">
                {matches.length > 0
                  ? `These labels show how closely each program lines up with the preferences you saved. The top ${Math.min(matches.length, initialVisibleMatches)} appear first so you can review the shortlist quickly.`
                  : 'No programs earned enough matching signals yet. Broaden your preferences or update them to surface more shortlist options.'}
              </p>
              {matches.length > 0 && (
                <div class="mt-4 flex flex-wrap gap-2">
                  {matchLegend.map(item => (
                    <span class={`inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold ${getLabelClasses(item.tone)}`}>
                      {item.label}
                    </span>
                  ))}
                </div>
              )}
            </div>

            <div class="grid grid-cols-2 gap-3 sm:min-w-[240px]">
              <div class="rounded-xl bg-slate-50 px-4 py-3 border border-slate-200">
                <p class="text-xs font-medium uppercase tracking-[0.08em] text-slate-500">Matched</p>
                <p class="mt-1 text-2xl font-bold text-slate-900">{matches.length}</p>
              </div>
              <div class="rounded-xl bg-slate-50 px-4 py-3 border border-slate-200">
                <p class="text-xs font-medium uppercase tracking-[0.08em] text-slate-500">Profile signals used</p>
                <p class="mt-1 text-2xl font-bold text-slate-900">{savedSignalCount}/4</p>
              </div>
            </div>
          </div>

          <dl class="mt-5 grid gap-3 sm:grid-cols-2">
            <div class="rounded-xl bg-slate-50 px-4 py-3 border border-slate-200">
              <dt class="text-xs font-medium uppercase tracking-[0.08em] text-slate-500">Target degree</dt>
              <dd class="mt-1 text-sm font-medium text-slate-900">{degreeLevelName ?? 'Not set yet'}</dd>
            </div>
            <div class="rounded-xl bg-slate-50 px-4 py-3 border border-slate-200">
              <dt class="text-xs font-medium uppercase tracking-[0.08em] text-slate-500">Budget range</dt>
              <dd class="mt-1 text-sm font-medium text-slate-900">{budgetRangeLabel ?? budgetSummary ?? 'Not sure yet'}</dd>
            </div>
            <div class="rounded-xl bg-slate-50 px-4 py-3 border border-slate-200">
              <dt class="text-xs font-medium uppercase tracking-[0.08em] text-slate-500">Preferred subjects</dt>
              <dd class="mt-1 text-sm font-medium text-slate-900">{subjectNames.length > 0 ? subjectNames.join(', ') : 'Not set yet'}</dd>
            </div>
            <div class="rounded-xl bg-slate-50 px-4 py-3 border border-slate-200">
              <dt class="text-xs font-medium uppercase tracking-[0.08em] text-slate-500">Preferred destinations</dt>
              <dd class="mt-1 text-sm font-medium text-slate-900">{countryNames.length > 0 ? countryNames.join(', ') : 'Not set yet'}</dd>
            </div>
          </dl>

          {matches.length > 0 && (
            <p class="mt-4 text-xs text-slate-500">
              Match labels are shortlist guidance only. Verify tuition, deadlines, and eligibility with the official provider before you apply.
            </p>
          )}
        </div>

        <div class="flex flex-wrap items-center gap-3 mb-7">
          <a href="/fit-finder" class="inline-flex w-full items-center justify-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 sm:w-auto">
            Update preferences
          </a>
          <a href="/programs" class="inline-flex w-full items-center justify-center rounded-md border border-gray-300 px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 sm:w-auto">
            Browse all programs
          </a>
          {user && pageState === 'ready' && (
            <a href="/fit-finder/results" class="text-sm text-gray-500 hover:text-gray-700">
              View all saved results →
            </a>
          )}
        </div>
        {persistAttempted && !savedResultId && (
          <p class="max-w-3xl mb-5 text-sm text-gray-400">Results could not be saved this time.</p>
        )}
        {showDevPersistWarning && (
          <div class="max-w-3xl mb-5 px-4 py-3 rounded-md bg-yellow-50 border border-yellow-300 text-sm text-yellow-900">
            <strong>Developer note:</strong> this result displayed but was not saved. Check that <code class="font-mono bg-yellow-100 px-1 rounded">SUPABASE_SERVICE_ROLE_KEY</code> is set in the server/runtime environment.
          </div>
        )}
        {showAISummaryCard && (
          <div
            id="ai-summary-card"
            class="max-w-4xl mb-7 rounded-2xl border border-purple-100 bg-gradient-to-b from-[#faf5ff] to-white px-5 py-5"
            data-result-id={savedResultId}
            data-pending={aiCardPending ? 'true' : 'false'}
          >
            <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase tracking-[0.12em] text-purple-700">AI advisor</p>
                <h2 class="mt-2 text-xl font-semibold text-slate-900">Keep this shortlist moving</h2>
                <p class="mt-2 text-sm text-slate-600">
                  Open the saved-result advisor to compare these matches, ask what to verify, and decide which programs belong in your shortlist.
                </p>
              </div>
              <div class="flex flex-col gap-2 sm:flex-row lg:flex-col">
                <a
                  href={advisorHref!}
                  class="inline-flex items-center justify-center rounded-full bg-purple-700 px-4 py-2 text-sm font-medium text-white hover:bg-purple-800"
                >
                  Open AI advisor
                </a>
                <a
                  href={savedResultHref!}
                  class="inline-flex items-center justify-center rounded-full border border-purple-200 bg-white px-4 py-2 text-sm font-medium text-purple-700 hover:bg-purple-50"
                >
                  Open saved result
                </a>
              </div>
            </div>
            <div class="mt-4 rounded-2xl border border-purple-100 bg-white/80 px-4 py-4">
              <h3 class="text-sm font-semibold text-purple-900">Quick AI overview</h3>
              <p class="mt-1 text-xs text-purple-700">
                This overview is based on your saved preferences and the matched programs shown here. Verify important details with official sources before applying.
              </p>
              <div id="ai-summary-body" class="mt-3 space-y-2">
                {aiExplanation
                  ? aiExplanation.split(/\n\n+/).map(para => (
                      <p class="text-sm text-gray-700 leading-relaxed">{para}</p>
                    ))
                  : (
                    <p id="ai-summary-status" class="text-sm text-gray-500 leading-relaxed">
                      Preparing a short AI overview...
                    </p>
                  )}
              </div>
            </div>
          </div>
        )}

        {deviation && (
          <div class="mb-5 px-4 py-3 rounded-md bg-yellow-50 border border-yellow-200 text-sm text-yellow-900">
            {deviation}
          </div>
        )}

        {pageState === 'no_matches' ? (
          <div class="max-w-2xl border border-gray-200 rounded-lg p-5 bg-gray-50">
            <h2 class="text-base font-semibold text-gray-900 mb-2">No shortlist matches found yet for these preferences</h2>
            {candidatesChecked > 0 && (
              <p class="text-sm text-gray-600 mb-2">
                {candidatesChecked} published program{candidatesChecked === 1 ? '' : 's'} checked against your preferences, and none earned enough signals to appear here yet.
              </p>
            )}
            {candidatesChecked === 0 && (
              <p class="text-sm text-gray-600 mb-2">
                No published programs are available yet. This is expected during early data build-out.
              </p>
            )}
            {degreeLevelName && candidatesChecked > 0 && (
              <p class="text-sm text-gray-600 mb-2">
                DegreeWiki currently has limited or no published programs for{' '}
                <strong class="font-medium text-gray-800">{degreeLevelName}</strong>.
                {' '}If your goal allows it, try selecting a different degree level. Master's programs have the most coverage right now.
              </p>
            )}
            <p class="text-sm text-gray-600 mb-2">
              Things that can help:
            </p>
            <ul class="list-disc pl-5 text-sm text-gray-600 mb-4 space-y-1">
              <li>Add or broaden your target countries — try including Finland.</li>
              <li>Add or change your subjects of interest.</li>
              <li>Try a different degree level if your goals are flexible.</li>
              <li>Remove the budget filter temporarily to see more candidates.</li>
            </ul>
            <p class="text-xs text-gray-500 mb-4">
              DegreeWiki's starter data is strongest for Finland master's programs. More countries, degree levels, and scholarships are being added regularly.
            </p>
            <div class="flex flex-wrap gap-3">
              <a href="/fit-finder" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700">
                Update preferences
              </a>
              <a href="/programs" class="px-4 py-2 text-sm text-gray-600 border border-gray-300 rounded-md hover:bg-white">
                Browse all programs
              </a>
            </div>
          </div>
        ) : (
          <>
            <div class="max-w-4xl mb-4 flex flex-wrap items-center justify-between gap-3">
              <div>
                <h2 class="text-xl font-semibold text-gray-900">Top matches first</h2>
                <p class="text-sm text-gray-600" data-visible-match-summary aria-live="polite">
                  Showing {Math.min(matches.length, initialVisibleMatches)} of {matches.length} matches.
                </p>
              </div>
              {advisorHref && (
                <a
                  href={advisorHref}
                  class="inline-flex items-center rounded-full border border-purple-200 bg-purple-50 px-4 py-2 text-sm font-medium text-purple-700 hover:bg-purple-100"
                >
                  Ask AI about this shortlist
                </a>
              )}
            </div>

            <ul class="space-y-4" data-match-list data-initial-count={initialVisibleMatches} data-batch-size="6">
            {matches.map((match, index) => {
              const p = match.program
              const tuition = formatTuition(p)
              const location = [p.countries?.name, p.cities?.name].filter(Boolean).join(', ')
              const matchLabel = getFitMatchLabel(match.points, match.reasons.length, match.warnings.length)
              const reasons = match.reasons.slice(0, 3)
              const warnings = match.warnings.slice(0, 2)
              const studyDetails = [
                p.study_mode ? formatMode(p.study_mode) : null,
                p.delivery_mode ? formatMode(p.delivery_mode) : null,
              ].filter(Boolean).join(' · ')
              return (
                <li
                  class="rounded-2xl border border-gray-200 bg-white p-4 shadow-sm sm:p-5"
                  data-match-card
                  style={index >= initialVisibleMatches ? 'display:none' : undefined}
                >
                  <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                    <div class="min-w-0 flex-1">
                      <div class="flex flex-wrap items-center gap-2 mb-3">
                        <span class={`inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold ${getLabelClasses(matchLabel.tone)}`}>
                          {matchLabel.label}
                        </span>
                        <span class="inline-flex items-center rounded-full bg-slate-100 border border-slate-200 px-3 py-1 text-xs font-medium text-slate-600">
                          Match #{index + 1}
                        </span>
                      </div>

                      <div class="flex items-start gap-3">
                      {p.universities?.logo?.cloudinary_public_id && (
                        <div class="flex-none w-11 h-11 rounded-xl overflow-hidden border border-gray-200 bg-gray-50">
                          <MediaImage
                            publicId={p.universities.logo.cloudinary_public_id}
                            alt={p.universities.logo.alt_text || p.universities.logo.display_name || p.universities.name}
                            width={44}
                            height={44}
                            crop="fill"
                            loading="lazy"
                            class="w-full h-full object-cover"
                          />
                        </div>
                      )}
                        <div class="min-w-0">
                          <a href={`/programs/${p.slug}`} class="text-lg font-semibold text-blue-600 hover:underline leading-snug">
                            {p.title}
                          </a>
                          <div class="text-sm text-gray-500 mt-1">
                            {p.universities && (
                              <a href={`/universities/${p.universities.slug}`} class="text-gray-700 font-medium hover:underline">
                                {p.universities.name}
                              </a>
                            )}
                            {p.universities && location && <span class="mx-1">·</span>}
                            {location}
                          </div>
                        </div>
                      </div>

                      <div class="mt-4 grid gap-2 text-sm sm:grid-cols-2">
                        {p.degree_levels?.name && (
                          <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2">
                            <p class="text-[11px] font-medium uppercase tracking-[0.08em] text-slate-500">Degree</p>
                            <p class="mt-1 text-sm font-medium text-slate-900">{p.degree_levels.name}</p>
                          </div>
                        )}
                        {p.subjects?.name && (
                          <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2">
                            <p class="text-[11px] font-medium uppercase tracking-[0.08em] text-slate-500">Subject</p>
                            <p class="mt-1 text-sm font-medium text-slate-900">{p.subjects.name}</p>
                          </div>
                        )}
                        {p.language_of_instruction && (
                          <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2">
                            <p class="text-[11px] font-medium uppercase tracking-[0.08em] text-slate-500">Language</p>
                            <p class="mt-1 text-sm font-medium text-slate-900">{p.language_of_instruction}</p>
                          </div>
                        )}
                        {tuition && (
                          <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2">
                            <p class="text-[11px] font-medium uppercase tracking-[0.08em] text-slate-500">Tuition</p>
                            <p class="mt-1 text-sm font-medium text-slate-900">{tuition}</p>
                          </div>
                        )}
                      </div>
                      {studyDetails && (
                        <p class="mt-3 text-xs text-slate-500">Study format: {studyDetails}</p>
                      )}

                      {reasons.length > 0 && (
                        <div class="mt-4">
                          <h2 class="text-sm font-semibold text-gray-900 mb-1">Why it fits</h2>
                          <ul class="list-disc pl-5 text-sm text-gray-700 space-y-0.5">
                            {reasons.map(reason => <li>{reason}</li>)}
                          </ul>
                        </div>
                      )}

                      {warnings.length > 0 && (
                        <div class="mt-4">
                          <h2 class="text-sm font-semibold text-gray-900 mb-1">Things to verify</h2>
                          <ul class="list-disc pl-5 text-sm text-gray-600 space-y-0.5">
                            {warnings.map(warning => <li>{warning}</li>)}
                          </ul>
                        </div>
                      )}
                    </div>

                    <div class="flex w-full shrink-0 flex-col gap-2 lg:w-[230px]">
                      <p class="text-xs text-slate-500">
                        {warnings.length > 0
                          ? 'Promising shortlist option. Check the flagged details before you save or apply.'
                          : 'A cleaner shortlist option based on your saved preferences.'}
                      </p>
                      <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-1">
                        <a
                          href={`/programs/${p.slug}`}
                          class="inline-flex items-center justify-center rounded-full bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700"
                        >
                          View program
                        </a>
                        <button
                          type="button"
                          class={[
                            'inline-flex items-center justify-center gap-1.5 rounded-full border px-4 py-2 text-sm font-medium transition-all',
                            savedProgramIds.has(p.id)
                              ? 'text-primary bg-primary-surface border-primary'
                              : 'text-ink-secondary bg-surface border-edge hover:border-[#cbd5e1] hover:bg-[#f8fafc]',
                          ].join(' ')}
                          aria-pressed={savedProgramIds.has(p.id) ? 'true' : 'false'}
                          aria-label={savedProgramIds.has(p.id) ? 'Remove from shortlist' : 'Save to shortlist'}
                          title={user ? undefined : 'Sign in to save programs'}
                          data-save-program-button={p.id}
                          data-program-id={p.id}
                          data-saved={savedProgramIds.has(p.id) ? 'true' : 'false'}
                          data-save-authenticated={user ? 'true' : 'false'}
                          data-save-login-href={saveLoginHref}
                          data-save-label-idle="Save to shortlist"
                          data-save-label-active="Saved to shortlist"
                          data-save-aria-idle="Save to shortlist"
                          data-save-aria-active="Remove from shortlist"
                        >
                          <svg
                            class="flex-none"
                            width="9"
                            height="12"
                            viewBox="0 0 9 12"
                            fill={savedProgramIds.has(p.id) ? 'currentColor' : 'none'}
                            stroke="currentColor"
                            stroke-width="1.5"
                            stroke-linejoin="round"
                            aria-hidden="true"
                            data-save-icon
                          >
                            <path d="M0.75 0.75h7.5v10.5l-3.75-2.7-3.75 2.7V0.75z"/>
                          </svg>
                          <span data-save-label>{savedProgramIds.has(p.id) ? 'Saved to shortlist' : 'Save to shortlist'}</span>
                        </button>
                        {advisorHref && (
                          <a
                            href={advisorHref}
                            class="inline-flex items-center justify-center rounded-full border border-purple-200 bg-purple-50 px-4 py-2 text-sm font-medium text-purple-700 hover:bg-purple-100"
                          >
                            Ask AI
                          </a>
                        )}
                      </div>

                      {p.official_url && (
                        <a href={p.official_url} target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-blue-600 hover:underline">
                          Official program page
                        </a>
                      )}
                    </div>
                  </div>
                </li>
              )
            })}
            </ul>

            {matches.length > 6 && (
              <div class="mt-5 flex justify-center">
                <button
                  type="button"
                  class="inline-flex items-center rounded-full border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50"
                  data-show-more-matches
                >
                  Show more matches
                </button>
              </div>
            )}
          </>
        )}
      </>
    )}
  </div>

  <SavedProgramEnhancement />

  <script>
    // Async AI summary loader. Fetches the summary once after rule-based matches
    // are already on screen. Renders with textContent only.
    // No automatic retry loop: a single fetch per page load.
    const card = document.getElementById('ai-summary-card')
    if (card && card.getAttribute('data-pending') === 'true') {
      const resultId = card.getAttribute('data-result-id')
      const body = document.getElementById('ai-summary-body')
      const status = document.getElementById('ai-summary-status')

      const showText = (msg: string) => {
        if (status) {
          status.textContent = msg
        } else if (body) {
          const p = document.createElement('p')
          p.className = 'text-sm text-gray-500 leading-relaxed'
          p.textContent = msg
          body.replaceChildren(p)
        }
      }

      const render = (explanation: string) => {
        if (!body) return
        const paragraphs = explanation.split(/\n\n+/).map(s => s.trim()).filter(Boolean)
        const nodes = paragraphs.map(text => {
          const p = document.createElement('p')
          p.className = 'text-sm text-gray-700 leading-relaxed'
          p.textContent = text
          return p
        })
        if (nodes.length === 0) {
          showText('AI overview is unavailable right now. Your saved result and rule-based matches are still available.')
          return
        }
        body.replaceChildren(...nodes)
      }

      if (resultId) {
        fetch('/api/ai/finder-summary', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ finder_result_id: resultId }),
        })
          .then(async (res) => {
            const data = await res.json().catch(() => null)
            if (res.ok && data && data.ok && typeof data.ai_explanation === 'string') {
              render(data.ai_explanation)
            } else {
              showText('AI overview is unavailable right now. Your saved result and rule-based matches are still available.')
            }
        })
          .catch(() => {
            showText('AI overview is unavailable right now. Your saved result and rule-based matches are still available.')
          })
          .finally(() => {
            card.setAttribute('data-pending', 'done')
          })
      }
    }

    const matchList = document.querySelector('[data-match-list]')
    const showMoreBtn = document.querySelector('[data-show-more-matches]')
    const visibleSummary = document.querySelector('[data-visible-match-summary]')
    if (matchList && showMoreBtn) {
      const cards = Array.from(matchList.querySelectorAll('[data-match-card]'))
      const initialCount = Number(matchList.getAttribute('data-initial-count') || '6')
      const batchSize = Number(matchList.getAttribute('data-batch-size') || '6')
      let visibleCount = initialCount

      const updateVisible = () => {
        cards.forEach((card, index) => {
          card.style.display = index < visibleCount ? '' : 'none'
        })

        if (visibleSummary) {
          visibleSummary.textContent = visibleCount >= cards.length
            ? `Showing all ${cards.length} matches.`
            : `Showing ${Math.min(visibleCount, cards.length)} of ${cards.length} matches.`
        }

        if (visibleCount >= cards.length) {
          showMoreBtn.style.display = 'none'
        } else {
          showMoreBtn.style.display = ''
          showMoreBtn.textContent = `Show ${Math.min(batchSize, cards.length - visibleCount)} more matches`
        }
      }

      showMoreBtn.addEventListener('click', () => {
        visibleCount = Math.min(cards.length, visibleCount + batchSize)
        updateVisible()
      })

      updateVisible()
    }
  </script>
</PublicLayout>
