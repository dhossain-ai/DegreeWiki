---
import PublicLayout from '../../../layouts/PublicLayout.astro'
import { createClient } from '../../../lib/supabase/server'
import { SITE_URL } from '../../../lib/site'

const UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i

const supabase = createClient(Astro.cookies, Astro.request)

const { data: { user } } = await supabase.auth.getUser()

if (!user) {
  return Astro.redirect('/login?redirect=/fit-finder/results')
}

let deleteError = ''

// Handle POST (delete) before rendering the list
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData()
  const rawId = formData.get('id')

  if (typeof rawId !== 'string' || !UUID_RE.test(rawId)) {
    deleteError = 'Invalid request.'
  } else {
    const { error } = await supabase
      .from('ai_finder_results')
      .delete()
      .eq('id', rawId)

    if (error) {
      console.error('ai_finder_results delete error:', error.message)
      deleteError = 'Could not delete this result. Please try again.'
    } else {
      return Astro.redirect('/fit-finder/results')
    }
  }
}

type SavedResult = {
  id: string
  created_at: string
  result_status: string
  shortlist_count: number
  ai_explanation: string | null
  ai_model_used: string | null
}

type TopProgram = {
  title: string
  slug: string
  universityName: string | null
  universitySlug: string | null
  countryName: string | null
  cityName: string | null
}

let results: SavedResult[] = []
let pageState: 'list' | 'empty' | 'error' = 'empty'

const { data: rows, error: listError } = await supabase
  .from('ai_finder_results')
  .select('id, created_at, result_status, shortlist_count, ai_explanation, ai_model_used')
  .order('created_at', { ascending: false })

if (listError) {
  console.error('ai_finder_results list error:', listError.message)
  pageState = 'error'
} else if (rows && rows.length > 0) {
  results = rows as SavedResult[]
  pageState = 'list'
} else {
  pageState = 'empty'
}

// Top-program preview: fetch rank-1 match for each result (SSR client, RLS enforced)
const previews = new Map<string, TopProgram>()

if (pageState === 'list' && results.length > 0) {
  const resultIds = results.map(r => r.id)
  const { data: previewRows, error: previewError } = await supabase
    .from('ai_finder_program_matches')
    .select(`
      ai_finder_result_id,
      programs(
        title, slug,
        universities(name, slug),
        countries(name),
        cities(name)
      )
    `)
    .in('ai_finder_result_id', resultIds)
    .eq('rank', 1)

  if (previewError) {
    console.error('ai_finder_program_matches preview error:', previewError.message)
    // List still renders without previews — no user-facing error
  } else {
    for (const row of previewRows ?? []) {
      const p = (row as any).programs
      const resultId = (row as any).ai_finder_result_id
      if (!p || !resultId) continue
      previews.set(resultId, {
        title: p.title ?? '',
        slug: p.slug ?? '',
        universityName: p.universities?.name ?? null,
        universitySlug: p.universities?.slug ?? null,
        countryName: p.countries?.name ?? null,
        cityName: p.cities?.name ?? null,
      })
    }
  }
}

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  })
}

type BadgeVariant = 'ai' | 'no-ai' | 'incomplete' | 'failed'

function getCardBadge(result: SavedResult): BadgeVariant {
  if (result.result_status === 'failed') return 'failed'
  if (result.result_status !== 'complete') return 'incomplete'
  return result.ai_explanation ? 'ai' : 'no-ai'
}
---
<PublicLayout
  title="Saved Fit Finder results — DegreeWiki"
  description="Your saved DegreeWiki Fit Finder program match results."
  noindex={true}
  canonical={SITE_URL + '/fit-finder/results'}
>
  <div class="max-w-5xl mx-auto px-4 py-8">
    <div class="max-w-3xl mb-6">
      <h1 class="text-2xl font-bold text-gray-900 mb-1">Saved Fit Finder results</h1>
      <p class="text-sm text-gray-500">Your saved program match results, newest first.</p>
    </div>

    <div class="flex flex-wrap gap-3 mb-7">
      <a href="/fit-finder/result" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700">
        Run Fit Finder again
      </a>
      <a href="/fit-finder" class="px-4 py-2 text-sm text-gray-600 border border-gray-300 rounded-md hover:bg-gray-50">
        Update preferences
      </a>
      <a href="/programs" class="px-4 py-2 text-sm text-gray-600 border border-gray-300 rounded-md hover:bg-gray-50">
        Browse programs
      </a>
    </div>

    {deleteError && (
      <div class="max-w-3xl mb-5 px-4 py-3 rounded-md bg-red-50 border border-red-200 text-sm text-red-800">
        {deleteError}
      </div>
    )}

    {pageState === 'error' ? (
      <div class="max-w-2xl">
        <p class="text-gray-600 mb-4">Could not load your saved results. Please try again.</p>
        <a href="/fit-finder/result" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700">
          Run Fit Finder
        </a>
      </div>
    ) : pageState === 'empty' ? (
      <div class="max-w-2xl border border-gray-200 rounded-lg p-6 bg-gray-50">
        <h2 class="text-base font-semibold text-gray-900 mb-2">No saved Fit Finder results yet.</h2>
        <p class="text-sm text-gray-600 mb-4">
          Results are saved automatically after you run Fit Finder. Your matched programs and any AI summary are stored so you can review them later.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/fit-finder/result" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700">
            Run Fit Finder
          </a>
          <a href="/fit-finder" class="px-4 py-2 text-sm text-gray-600 border border-gray-300 rounded-md hover:bg-white">
            Update preferences
          </a>
          <a href="/programs" class="px-4 py-2 text-sm text-gray-600 border border-gray-300 rounded-md hover:bg-white">
            Browse programs
          </a>
        </div>
      </div>
    ) : (
      <ul class="space-y-4 max-w-3xl">
        {results.map(r => {
          const badge = getCardBadge(r)
          const preview = previews.get(r.id)
          const location = [preview?.countryName, preview?.cityName].filter(Boolean).join(', ')
          return (
            <li class="border border-gray-200 rounded-lg p-5 bg-white">
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
                <div class="flex-1 min-w-0">

                  {/* Header: date + badges */}
                  <div class="flex flex-wrap items-center gap-2 mb-1">
                    <span class="text-sm font-medium text-gray-900">
                      {formatDate(r.created_at)}
                    </span>
                    {badge === 'ai' && (
                      <span class="text-xs px-2 py-0.5 rounded-full bg-purple-50 text-purple-700 border border-purple-100">
                        AI summary
                      </span>
                    )}
                    {badge === 'no-ai' && (
                      <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 text-gray-500 border border-gray-200">
                        No AI summary
                      </span>
                    )}
                    {badge === 'incomplete' && (
                      <span class="text-xs px-2 py-0.5 rounded-full bg-yellow-50 text-yellow-800 border border-yellow-200">
                        Incomplete
                      </span>
                    )}
                    {badge === 'failed' && (
                      <span class="text-xs px-2 py-0.5 rounded-full bg-red-50 text-red-700 border border-red-200">
                        Failed
                      </span>
                    )}
                  </div>

                  {/* Program count */}
                  <p class="text-sm text-gray-500 mb-2">
                    {r.shortlist_count === 1
                      ? '1 program matched'
                      : `${r.shortlist_count} programs matched`}
                  </p>

                  {/* Top-program preview */}
                  {preview && (
                    <div class="mt-1">
                      <p class="text-sm font-medium text-gray-800 leading-snug">{preview.title}</p>
                      <p class="text-xs text-gray-500 mt-0.5">
                        {[preview.universityName, location].filter(Boolean).join(' · ')}
                      </p>
                    </div>
                  )}
                </div>

                {/* Actions */}
                <div class="flex flex-wrap items-center gap-2 shrink-0">
                  <a
                    href={`/fit-finder/results/${r.id}`}
                    class="px-3 py-1.5 text-sm text-blue-600 border border-blue-200 rounded-md hover:bg-blue-50"
                  >
                    View result
                  </a>
                  <form method="post" action="/fit-finder/results">
                    <input type="hidden" name="id" value={r.id} />
                    <button
                      type="submit"
                      class="px-3 py-1.5 text-sm text-red-600 border border-red-200 rounded-md hover:bg-red-50"
                    >
                      Delete
                    </button>
                  </form>
                </div>
              </div>
            </li>
          )
        })}
      </ul>
    )}
  </div>
</PublicLayout>
