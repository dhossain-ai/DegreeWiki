---
import PublicLayout from '../../layouts/PublicLayout.astro'
import ProgramCard from '../../components/public/cards/ProgramCard.astro'
import Container from '../../components/ui/Container.astro'
import { createClient } from '../../lib/supabase/server'
import { SITE_URL } from '../../lib/site'

const supabase = createClient(Astro.cookies, Astro.request)

const UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i
function parseUUID(v: string | null): string | undefined {
  return v && UUID_RE.test(v) ? v : undefined
}

const STUDY_MODES    = ['full_time', 'part_time', 'online', 'hybrid'] as const
const DELIVERY_MODES = ['on_campus', 'online', 'hybrid', 'distance'] as const

const sp            = Astro.url.searchParams
const q             = sp.get('q')?.trim().slice(0, 100) || undefined
const countryId     = parseUUID(sp.get('country'))
const cityId        = parseUUID(sp.get('city'))
const universityId  = parseUUID(sp.get('university'))
const degreeLevelId = parseUUID(sp.get('degree_level'))
const subjectId     = parseUUID(sp.get('subject'))
const rawSM         = sp.get('study_mode') ?? ''
const studyMode     = (STUDY_MODES as readonly string[]).includes(rawSM) ? rawSM : undefined
const rawDM         = sp.get('delivery_mode') ?? ''
const deliveryMode  = (DELIVERY_MODES as readonly string[]).includes(rawDM) ? rawDM : undefined
const language      = sp.get('language')?.trim().slice(0, 80) || undefined
const rawTM         = parseFloat(sp.get('tuition_max') ?? '')
const tuitionMax    = isFinite(rawTM) && rawTM > 0 ? rawTM : undefined

const hasFilters = !!(q || countryId || cityId || universityId || degreeLevelId ||
  subjectId || studyMode || deliveryMode || language || tuitionMax)

const [
  { data: countriesData },
  { data: citiesData },
  { data: universitiesData },
  { data: degreeLevelsData },
  { data: subjectsData },
] = await Promise.all([
  supabase.from('countries').select('id, name').eq('is_destination_enabled', true).order('name'),
  supabase.from('cities').select('id, name').order('name'),
  supabase.from('universities').select('id, name, slug').order('name'),
  supabase.from('degree_levels').select('id, name, code').order('display_order'),
  supabase.from('subjects').select('id, name').order('name'),
])

const countries    = countriesData ?? []
const cities       = citiesData ?? []
const univs        = universitiesData ?? []
const degreeLevels = degreeLevelsData ?? []
const subjects     = subjectsData ?? []

let query = supabase
  .from('programs')
  .select(
    `id, title, slug,
     study_mode, delivery_mode, language_of_instruction,
     tuition_min_amount, tuition_max_amount, tuition_currency, tuition_period,
     universities(
       name, slug,
       logo:media_assets!universities_logo_id_fkey(cloudinary_public_id, alt_text, display_name)
     ),
     degree_levels(name, code),
     countries(name, iso2),
     cities(name),
     subjects!programs_primary_subject_id_fkey(name)`,
    { count: 'exact' }
  )
  .eq('content_status', 'published')
  .order('title')
  .limit(201)

if (q)              query = query.ilike('title', `%${q}%`)
if (countryId)      query = query.eq('country_id', countryId)
if (cityId)         query = query.eq('city_id', cityId)
if (universityId)   query = query.eq('university_id', universityId)
if (degreeLevelId)  query = query.eq('degree_level_id', degreeLevelId)
if (subjectId)      query = query.eq('primary_subject_id', subjectId)
if (studyMode)      query = query.eq('study_mode', studyMode)
if (deliveryMode)   query = query.eq('delivery_mode', deliveryMode)
if (language)       query = query.ilike('language_of_instruction', `%${language}%`)
if (tuitionMax != null) query = query.lte('tuition_max_amount', tuitionMax)

const { data, count, error } = await query
if (error) console.error('programs list error:', error.message)

const allRows   = data ?? []
const overLimit = (count ?? allRows.length) > 200
const rows      = allRows.slice(0, 200)

function abbreviateDegree(code: string | null | undefined, name: string | null | undefined): string | null {
  if (!code && !name) return null
  const c = (code ?? '').toLowerCase()
  const n = (name ?? '').toLowerCase()
  if (c === 'phd' || c === 'doctorate' || n.includes('phd') || n.includes('doctor')) return 'PhD'
  if (c === 'mba' || n.includes('mba')) return 'MBA'
  if (c === 'master' || n.includes('master')) return 'MSc'
  if (c === 'bachelor' || n.includes('bachelor')) return 'BSc'
  if (c === 'postgraduate' || n.includes('postgraduate')) return 'PG'
  if (name) return name.split(' ')[0] ?? null
  return null
}

function tuitionDisplay(p: any): { display: string | null; per: string | null } {
  const min = p.tuition_min_amount
  const max = p.tuition_max_amount
  if (min == null && max == null) return { display: null, per: null }
  const cur = (p.tuition_currency ?? '').toUpperCase()
  const sym = cur === 'EUR' ? '€' : cur === 'USD' ? '$' : cur === 'GBP' ? '£' : ''
  const prefix = sym || (cur ? `${cur} ` : '')
  const fmt = (n: number) => `${prefix}${Number(n).toLocaleString()}`
  const display = min != null ? fmt(min) : fmt(max)
  const per = p.tuition_period?.replace(/_/g, ' ') ?? 'per year'
  return { display, per }
}

function buildUrlWithout(param: string): string {
  const params = new URLSearchParams(Astro.url.searchParams)
  params.delete(param)
  const qs = params.toString()
  return '/programs' + (qs ? '?' + qs : '')
}

type FilterChip = { key: string; label: string; removeHref: string }
const activeChips: FilterChip[] = []

if (q) activeChips.push({ key: 'q', label: `"${q}"`, removeHref: buildUrlWithout('q') })
if (degreeLevelId) {
  const dl = degreeLevels.find((d: any) => d.id === degreeLevelId)
  activeChips.push({ key: 'degree_level', label: (dl as any)?.name ?? 'Degree level', removeHref: buildUrlWithout('degree_level') })
}
if (subjectId) {
  const sub = subjects.find((s: any) => s.id === subjectId)
  activeChips.push({ key: 'subject', label: (sub as any)?.name ?? 'Subject', removeHref: buildUrlWithout('subject') })
}
if (countryId) {
  const c = countries.find((c: any) => c.id === countryId)
  activeChips.push({ key: 'country', label: (c as any)?.name ?? 'Country', removeHref: buildUrlWithout('country') })
}
if (cityId) {
  const c = cities.find((c: any) => c.id === cityId)
  activeChips.push({ key: 'city', label: (c as any)?.name ?? 'City', removeHref: buildUrlWithout('city') })
}
if (universityId) {
  const u = univs.find((u: any) => u.id === universityId)
  activeChips.push({ key: 'university', label: (u as any)?.name ?? 'University', removeHref: buildUrlWithout('university') })
}
if (language)     activeChips.push({ key: 'language', label: `Language: ${language}`, removeHref: buildUrlWithout('language') })
if (studyMode)    activeChips.push({ key: 'study_mode', label: studyMode.replace(/_/g, ' '), removeHref: buildUrlWithout('study_mode') })
if (deliveryMode) activeChips.push({ key: 'delivery_mode', label: deliveryMode.replace(/_/g, ' '), removeHref: buildUrlWithout('delivery_mode') })
if (tuitionMax != null) activeChips.push({ key: 'tuition_max', label: `Max ${tuitionMax.toLocaleString()}`, removeHref: buildUrlWithout('tuition_max') })

const activeFilterCount = activeChips.length

const flabel = 'block text-[11px] font-semibold uppercase tracking-[0.05em] text-muted mb-1.5'
const fselect = 'w-full rounded-[8px] border border-edge bg-surface px-3 py-2 text-sm text-ink focus:outline-none focus:border-primary'
const finput  = 'w-full rounded-[8px] border border-edge bg-surface px-3 py-2 text-sm text-ink placeholder:text-muted focus:outline-none focus:border-primary'
---

<style>
  details > summary { list-style: none; }
  details > summary::-webkit-details-marker { display: none; }
  details[open] .chevron { transform: rotate(180deg); }
  .chevron { transition: transform 200ms ease; }
</style>

<PublicLayout title="Programs — DegreeWiki" noindex={hasFilters} canonical={SITE_URL + '/programs'}>

  <!-- ── Page header ──────────────────────────────────────── -->
  <div class="bg-surface border-b border-edge">
    <Container width="wide" class="py-7 sm:py-8">
      <h1 class="text-[28px] sm:text-3xl font-bold text-ink tracking-[-0.02em] leading-tight">
        Search Programs
      </h1>
      <p class="mt-1.5 text-base text-muted">
        Bachelor's and master's programs at universities worldwide.
      </p>
    </Container>
  </div>

  <!-- ── Main content ────────────────────────────────────── -->
  <div class="bg-canvas min-h-[60vh]">
    <Container width="wide" class="py-6 sm:py-8">

      <form method="get" action="/programs">

        <!-- ── Keyword search bar ──────────────────────────── -->
        <div class="flex gap-2.5 mb-5">
          <div class="relative flex-1">
            <label for="q" class="sr-only">Search programs</label>
            <svg
              class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted pointer-events-none"
              viewBox="0 0 16 16" fill="none" aria-hidden="true"
            >
              <circle cx="7" cy="7" r="4.5" stroke="currentColor" stroke-width="1.4"/>
              <path d="M10.5 10.5L13.5 13.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            </svg>
            <input
              id="q" name="q" type="search"
              value={q ?? ''}
              placeholder="Search programs, fields of study…"
              class="w-full h-[44px] pl-[38px] pr-4 rounded-[10px] border border-edge bg-surface
                     text-sm text-ink placeholder:text-muted
                     focus:outline-none focus:border-primary"
            />
          </div>
          <button
            type="submit"
            class="h-[44px] px-5 bg-primary text-white text-[13.5px] font-semibold rounded-[10px]
                   hover:bg-primary-hover transition-colors flex-none"
          >
            Search
          </button>
          {hasFilters && (
            <a
              href="/programs"
              class="h-[44px] px-4 inline-flex items-center text-[13.5px] font-medium text-ink-secondary
                     border border-edge rounded-[10px] hover:bg-[#f8fafc] transition-colors flex-none"
            >
              Clear all
            </a>
          )}
        </div>

        <!-- ── Active filter chips ─────────────────────────── -->
        {activeChips.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-5" aria-label="Active filters">
            {activeChips.map(chip => (
              <a
                href={chip.removeHref}
                class="inline-flex items-center gap-1.5 px-3 py-1 bg-primary-surface border border-primary-border
                       text-primary text-sm font-medium rounded-full hover:bg-[#dbe4ff] transition-colors"
              >
                {chip.label}
                <span aria-hidden="true" class="text-base leading-none opacity-60">×</span>
              </a>
            ))}
          </div>
        )}

        <!-- ── Two-column layout ───────────────────────────── -->
        <div class="flex flex-col md:flex-row gap-5 md:gap-8">

          <!-- ── Filter rail ─────────────────────────────────
               Mobile: <details> collapsible, open by default.
               Desktop: summary hidden, content always visible. -->
          <aside
            class="w-full md:w-60 lg:w-64 md:flex-none md:sticky md:top-[80px] md:self-start"
            aria-label="Search filters"
          >
            <details open class="bg-surface border border-edge rounded-xl overflow-hidden">

              <!-- Mobile toggle (hidden on desktop) -->
              <summary class="md:hidden flex items-center justify-between px-4 py-3 cursor-pointer select-none">
                <span class="text-sm font-semibold text-ink">
                  Filters{activeFilterCount > 0 ? ` (${activeFilterCount})` : ''}
                </span>
                <svg
                  class="chevron w-4 h-4 text-muted"
                  viewBox="0 0 16 16" fill="none" aria-hidden="true"
                >
                  <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </summary>

              <!-- Desktop filter header (hidden on mobile) -->
              <div class="hidden md:flex items-center justify-between px-4 py-3 border-b border-edge-subtle">
                <span class="text-[11px] font-semibold uppercase tracking-[0.06em] text-muted">Filters</span>
                {hasFilters && (
                  <a href="/programs" class="text-xs text-primary hover:underline">Clear all</a>
                )}
              </div>

              <!-- Filter groups -->
              <div class="p-4 flex flex-col gap-4">

                <!-- Degree level -->
                <div>
                  <label for="degree_level" class={flabel}>Degree level</label>
                  <select id="degree_level" name="degree_level" class={fselect}>
                    <option value="">All levels</option>
                    {degreeLevels.map((d: any) => (
                      <option value={d.id} selected={degreeLevelId === d.id}>{d.name}</option>
                    ))}
                  </select>
                </div>

                <!-- Subject -->
                <div>
                  <label for="subject" class={flabel}>Subject</label>
                  <select id="subject" name="subject" class={fselect}>
                    <option value="">All subjects</option>
                    {subjects.map((s: any) => (
                      <option value={s.id} selected={subjectId === s.id}>{s.name}</option>
                    ))}
                  </select>
                </div>

                <!-- Country -->
                <div>
                  <label for="country" class={flabel}>Country</label>
                  <select id="country" name="country" class={fselect}>
                    <option value="">All countries</option>
                    {countries.map((c: any) => (
                      <option value={c.id} selected={countryId === c.id}>{c.name}</option>
                    ))}
                  </select>
                </div>

                <!-- Language -->
                <div>
                  <label for="language" class={flabel}>Language of instruction</label>
                  <input
                    id="language" name="language" type="text"
                    value={language ?? ''}
                    placeholder="e.g. English"
                    class={finput}
                  />
                </div>

                <!-- Study mode -->
                <div>
                  <label for="study_mode" class={flabel}>Study mode</label>
                  <select id="study_mode" name="study_mode" class={fselect}>
                    <option value="">Any mode</option>
                    <option value="full_time" selected={studyMode === 'full_time'}>Full time</option>
                    <option value="part_time" selected={studyMode === 'part_time'}>Part time</option>
                    <option value="online"    selected={studyMode === 'online'}>Online</option>
                    <option value="hybrid"    selected={studyMode === 'hybrid'}>Hybrid</option>
                  </select>
                </div>

                <!-- Max tuition -->
                <div>
                  <label for="tuition_max" class={flabel}>Max tuition</label>
                  <input
                    id="tuition_max" name="tuition_max" type="number" min="1" step="any"
                    value={tuitionMax ?? ''}
                    placeholder="e.g. 20000"
                    class={finput}
                  />
                  <p class="text-xs text-muted mt-1">Programs without tuition data may be excluded.</p>
                </div>

              </div>

              <!-- Apply button -->
              <div class="px-4 pb-4">
                <button
                  type="submit"
                  class="w-full h-[40px] bg-primary text-white text-sm font-semibold rounded-[8px]
                         hover:bg-primary-hover transition-colors"
                >
                  Apply filters
                </button>
              </div>

            </details>
          </aside>

          <!-- ── Results column ──────────────────────────────── -->
          <div class="flex-1 min-w-0">

            <!-- Results count -->
            <p class="text-sm text-muted mb-4">
              {rows.length === 0 ? (
                'No programs found'
              ) : overLimit ? (
                <>
                  <span class="font-semibold text-ink">200+</span> programs — narrow your search to see more
                </>
              ) : (
                <>
                  <span class="font-semibold text-ink">{rows.length}</span>
                  {rows.length === 1 ? ' program' : ' programs'} found
                </>
              )}
            </p>

            <!-- Program cards -->
            {rows.length > 0 ? (
              <ul class="flex flex-col gap-4 list-none p-0 m-0">
                {rows.map((p: any) => {
                  const td = tuitionDisplay(p)
                  const location = [p.cities?.name, p.countries?.name].filter(Boolean).join(', ')
                  return (
                    <li>
                      <ProgramCard
                        href={`/programs/${p.slug}`}
                        title={p.title}
                        universityName={p.universities?.name ?? null}
                        universityHref={p.universities?.slug ? `/universities/${p.universities.slug}` : null}
                        degreeLevel={abbreviateDegree(p.degree_levels?.code, p.degree_levels?.name)}
                        field={p.subjects?.name ?? null}
                        countryCode={p.countries?.iso2 ?? null}
                        location={location || null}
                        language={p.language_of_instruction ?? null}
                        tuitionDisplay={td.display}
                        tuitionPer={td.per}
                        logoPublicId={p.universities?.logo?.cloudinary_public_id ?? null}
                        logoAlt={p.universities?.logo?.alt_text || p.universities?.logo?.display_name || p.universities?.name || null}
                      />
                    </li>
                  )
                })}
              </ul>
            ) : (
              <!-- Empty state -->
              <div
                class="flex flex-col items-center justify-center py-16 px-6 text-center
                       bg-surface border border-edge rounded-xl"
              >
                <div class="w-12 h-12 rounded-full bg-canvas flex items-center justify-center mb-4">
                  <svg class="w-6 h-6 text-muted" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M16.5 16.5L21 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                </div>
                {hasFilters ? (
                  <Fragment>
                    <h2 class="text-lg font-semibold text-ink mb-1.5">No programs match your filters</h2>
                    <p class="text-sm text-muted mb-5 max-w-xs leading-relaxed">
                      Try removing some filters or broadening your search to find programs.
                    </p>
                    <a
                      href="/programs"
                      class="inline-flex items-center h-[40px] px-5 bg-primary text-white
                             text-sm font-semibold rounded-[8px] hover:bg-primary-hover transition-colors"
                    >
                      Clear all filters
                    </a>
                  </Fragment>
                ) : (
                  <Fragment>
                    <h2 class="text-lg font-semibold text-ink mb-1.5">No programs published yet</h2>
                    <p class="text-sm text-muted max-w-xs leading-relaxed">
                      We're building our database of international study programs. Check back soon.
                    </p>
                  </Fragment>
                )}
              </div>
            )}

          </div>
        </div>

      </form>
    </Container>
  </div>

</PublicLayout>
