---
import PublicLayout from '../../layouts/PublicLayout.astro'
import { createClient } from '../../lib/supabase/server'

const supabase = createClient(Astro.cookies, Astro.request)
const { data: programs, error } = await supabase
  .from('programs')
  .select('id, title, slug, study_mode, universities(name, slug), degree_levels(name)')
  .eq('content_status', 'published')
  .order('title')
  .limit(100)

if (error) console.error('programs list error:', error.message)
const rows = programs ?? []
---
<PublicLayout title="Programs — DegreeWiki">
  <div class="max-w-5xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">Programs</h1>
    {rows.length === 0 ? (
      <p class="text-gray-500 text-sm">No results yet.</p>
    ) : (
      <div class="overflow-x-auto rounded-lg border border-gray-200">
        <table class="w-full text-sm text-left">
          <thead class="bg-gray-50 border-b border-gray-200 text-xs text-gray-500 uppercase tracking-wide">
            <tr>
              <th class="px-4 py-3">Program</th>
              <th class="px-4 py-3">University</th>
              <th class="px-4 py-3">Degree Level</th>
              <th class="px-4 py-3">Study Mode</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((p: any) => (
              <tr class="border-b border-gray-100 hover:bg-gray-50 last:border-b-0">
                <td class="px-4 py-3">
                  <a href={`/programs/${p.slug}`} class="text-blue-600 hover:underline font-medium">
                    {p.title}
                  </a>
                </td>
                <td class="px-4 py-3 text-gray-600">
                  {p.universities
                    ? <a href={`/universities/${p.universities.slug}`} class="hover:underline">{p.universities.name}</a>
                    : '—'
                  }
                </td>
                <td class="px-4 py-3 text-gray-600">{p.degree_levels?.name ?? '—'}</td>
                <td class="px-4 py-3 text-gray-500 capitalize">
                  {p.study_mode ? p.study_mode.replace(/_/g, ' ') : '—'}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</PublicLayout>
