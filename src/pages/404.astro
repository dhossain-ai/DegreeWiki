---
import PublicLayout from '../layouts/PublicLayout.astro'
---
<PublicLayout title="Page Not Found — DegreeWiki">
  <div class="max-w-xl mx-auto px-4 py-24 text-center">
    <p class="text-7xl font-bold text-gray-100 mb-4 select-none">404</p>
    <h1 class="text-2xl font-bold text-gray-900 mb-2">Page not found</h1>
    <p class="text-gray-500 mb-8">The page you're looking for doesn't exist or has been removed.</p>
    <div class="flex flex-wrap gap-4 justify-center text-sm">
      <a href="/" class="text-blue-600 hover:underline">Home</a>
      <a href="/universities" class="text-blue-600 hover:underline">Universities</a>
      <a href="/programs" class="text-blue-600 hover:underline">Programs</a>
      <a href="/scholarships" class="text-blue-600 hover:underline">Scholarships</a>
      <a href="/guides" class="text-blue-600 hover:underline">Guides</a>
    </div>
  </div>
</PublicLayout>
