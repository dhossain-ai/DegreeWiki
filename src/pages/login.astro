---
import BaseLayout from '../layouts/BaseLayout.astro'
import { sanitizeAuthRedirect } from '../lib/auth/redirect'
import { createClient } from '../lib/supabase/server'

const supabase = createClient(Astro.cookies, Astro.request)
const redirectTo = sanitizeAuthRedirect(Astro.url.searchParams.get('redirect'))
const authMessage = Astro.url.searchParams.get('auth') === 'error'
  ? 'Could not complete sign-in. Please try again.'
  : null

// Redirect already-authenticated users.
const { data: { user } } = await supabase.auth.getUser()
if (user) {
  return Astro.redirect(redirectTo)
}

let errorMessage: string | null = null
let emailValue = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const email = String(form.get('email') ?? '').trim()
  const password = String(form.get('password') ?? '')
  emailValue = email

  const { error } = await supabase.auth.signInWithPassword({ email, password })

  if (error) {
    errorMessage = error.status === 400
      ? 'Invalid email or password.'
      : 'Could not sign you in right now. Please try again.'
  } else {
    return Astro.redirect(redirectTo)
  }
}
---
<BaseLayout title="Sign in — DegreeWiki">
  <main class="max-w-sm mx-auto p-8">
    <h1 class="text-2xl font-bold mb-6">Sign in</h1>
    <p class="text-sm text-gray-600 mb-6">
      Access your DegreeWiki account to save Fit Finder preferences and results. New here?
      <a href={`/signup?redirect=${encodeURIComponent(redirectTo)}`} class="text-blue-600 hover:underline"> Create an account</a>.
    </p>
    {authMessage && (
      <p class="text-blue-700 bg-blue-50 border border-blue-200 rounded mb-4 px-3 py-2 text-sm">{authMessage}</p>
    )}
    {errorMessage && (
      <p class="text-red-700 bg-red-50 border border-red-200 rounded mb-4 px-3 py-2 text-sm">{errorMessage}</p>
    )}
    <form method="post" class="space-y-4">
      <div>
        <label class="block text-sm font-medium mb-1" for="email">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          value={emailValue}
          class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
        />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1" for="password">Password</label>
        <input
          id="password"
          name="password"
          type="password"
          required
          autocomplete="current-password"
          class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
        />
      </div>
      <button
        type="submit"
        class="w-full bg-blue-600 text-white py-2 rounded font-medium hover:bg-blue-700 transition-colors"
      >
        Sign in
      </button>
    </form>
  </main>
</BaseLayout>
