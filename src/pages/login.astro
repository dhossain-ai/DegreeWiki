---
import BaseLayout from '../layouts/BaseLayout.astro'
import { resolveAuthRedirectForUser } from '../lib/auth/dashboard'
import { sanitizeAuthRedirect } from '../lib/auth/redirect'
import { createClient } from '../lib/supabase/server'

const supabase = createClient(Astro.cookies, Astro.request)
const redirectTo = sanitizeAuthRedirect(Astro.url.searchParams.get('redirect'))
const authMessage = Astro.url.searchParams.get('auth') === 'error'
  ? 'Could not complete sign-in. Please try again.'
  : null

const { data: { user } } = await supabase.auth.getUser()
if (user) {
  return Astro.redirect(await resolveAuthRedirectForUser(supabase, redirectTo))
}

function buildAuthCallbackUrl(): string {
  const callbackUrl = new URL('/auth/callback', Astro.url)
  callbackUrl.searchParams.set('redirect', redirectTo)
  return callbackUrl.toString()
}

let errorMessage: string | null = null
let emailValue = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const intent = String(form.get('intent') ?? 'password')

  if (intent === 'google') {
    const { data, error } = await supabase.auth.signInWithOAuth({
      provider: 'google',
      options: {
        redirectTo: buildAuthCallbackUrl(),
      },
    })

    if (error || !data.url) {
      errorMessage = 'Could not start Google sign-in right now. Please try again.'
    } else {
      return Astro.redirect(data.url)
    }
  } else {
    const email = String(form.get('email') ?? '').trim()
    const password = String(form.get('password') ?? '')
    emailValue = email

    const { error } = await supabase.auth.signInWithPassword({ email, password })

    if (error) {
      errorMessage = error.status === 400
        ? 'Invalid email or password.'
        : 'Could not sign you in right now. Please try again.'
    } else {
      return Astro.redirect(await resolveAuthRedirectForUser(supabase, redirectTo))
    }
  }
}

const panelClass = 'rounded-[32px] border border-slate-200/80 shadow-[0_24px_80px_rgba(15,23,42,0.14)]'
const inputClass = 'w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition focus:border-sky-500 focus:ring-4 focus:ring-sky-100'
const primaryButtonClass = 'inline-flex w-full items-center justify-center rounded-2xl bg-sky-600 px-4 py-3 text-sm font-semibold text-white transition hover:bg-sky-700 focus:outline-none focus:ring-4 focus:ring-sky-100'
const secondaryButtonClass = 'inline-flex w-full items-center justify-center gap-3 rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm font-semibold text-slate-800 transition hover:border-slate-400 hover:bg-slate-50 focus:outline-none focus:ring-4 focus:ring-slate-100'
---
<BaseLayout title="Sign in — DegreeWiki" noindex={true}>
  <main class="relative min-h-screen overflow-hidden bg-[radial-gradient(circle_at_top_left,_rgba(14,165,233,0.20),_transparent_34%),linear-gradient(135deg,_#f8fafc_0%,_#eef6ff_48%,_#fff7ed_100%)]">
    <div class="absolute inset-x-0 top-0 h-72 bg-[radial-gradient(circle_at_center,_rgba(15,23,42,0.08),_transparent_68%)]"></div>
    <div class="relative mx-auto flex min-h-screen max-w-6xl items-center px-4 py-10 sm:px-6 lg:px-8">
      <div class="mx-auto w-full max-w-xl">
        <section class:list={[panelClass, 'bg-white/92 backdrop-blur-xl']}>
          <div class="p-6 sm:p-8 lg:p-10">
            <a href="/" class="inline-flex items-center gap-3 no-underline">
              <span class="flex h-10 w-10 items-center justify-center rounded-2xl bg-slate-950 font-mono text-base font-bold tracking-tight text-white">D</span>
              <span>
                <span class="block text-base font-semibold tracking-[-0.01em] text-slate-950">DegreeWiki</span>
                <span class="block text-xs text-slate-500">Study-abroad search, built for clarity.</span>
              </span>
            </a>

            <div class="mb-8 mt-8">
              <h1 class="text-3xl font-semibold tracking-[-0.03em] text-slate-950 sm:text-4xl">Sign in to DegreeWiki</h1>
              <p class="mt-3 text-sm leading-6 text-slate-600">
                Save programs, Fit Finder results, and your study profile in one place.
              </p>
              <p class="mt-3 text-sm leading-6 text-slate-600">
                New to DegreeWiki?
                <a href={`/signup?redirect=${encodeURIComponent(redirectTo)}`} class="font-semibold text-sky-700 underline decoration-sky-200 underline-offset-4 hover:text-sky-800">
                  Create your student account
                </a>.
              </p>
            </div>

            {(authMessage || errorMessage) && (
              <div class="mb-6 space-y-3">
                {authMessage && (
                  <p class="rounded-2xl border border-sky-200 bg-sky-50 px-4 py-3 text-sm text-sky-900">{authMessage}</p>
                )}
                {errorMessage && (
                  <p class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">{errorMessage}</p>
                )}
              </div>
            )}

            <form method="post" class="mb-6">
              <input type="hidden" name="intent" value="google" />
              <button type="submit" class={secondaryButtonClass}>
                <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5">
                  <path fill="#EA4335" d="M12 10.2v3.9h5.5c-.2 1.3-1.5 3.9-5.5 3.9-3.3 0-6-2.8-6-6.2s2.7-6.2 6-6.2c1.9 0 3.2.8 3.9 1.5l2.7-2.7C16.9 2.7 14.7 1.8 12 1.8 6.8 1.8 2.6 6.2 2.6 11.6S6.8 21.4 12 21.4c6.9 0 9.1-5 9.1-7.5 0-.5 0-.9-.1-1.3z" />
                  <path fill="#34A853" d="M2.6 11.6c0 1.8.6 3.5 1.6 4.8l3.3-2.6c-.2-.6-.4-1.3-.4-2.2 0-.8.1-1.5.4-2.2L4.2 6.8C3.2 8.1 2.6 9.8 2.6 11.6z" />
                  <path fill="#4A90E2" d="M12 21.4c2.7 0 4.9-.9 6.6-2.4l-3.1-2.5c-.8.6-1.9 1-3.5 1-2.6 0-4.8-1.8-5.6-4.1L3 15.8c1.7 3.3 5 5.6 9 5.6z" />
                  <path fill="#FBBC05" d="M7.4 13.4c-.2-.6-.4-1.3-.4-1.8 0-.6.1-1.3.4-1.8L4.2 7.2C3.6 8.4 3.2 9.9 3.2 11.6s.4 3.2 1 4.4z" />
                </svg>
                Continue with Google
              </button>
            </form>

            <div class="mb-6 flex items-center gap-4">
              <div class="h-px flex-1 bg-slate-200"></div>
              <span class="text-xs font-medium uppercase tracking-[0.18em] text-slate-400">Or use email</span>
              <div class="h-px flex-1 bg-slate-200"></div>
            </div>

            <form method="post" class="space-y-4">
              <input type="hidden" name="intent" value="password" />
              <div>
                <label class="mb-2 block text-sm font-medium text-slate-800" for="email">Email</label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  required
                  autocomplete="email"
                  value={emailValue}
                  class={inputClass}
                  placeholder="you@example.com"
                />
              </div>
              <div>
                <label class="mb-2 block text-sm font-medium text-slate-800" for="password">Password</label>
                <input
                  id="password"
                  name="password"
                  type="password"
                  required
                  autocomplete="current-password"
                  class={inputClass}
                  placeholder="Enter your password"
                />
              </div>
              <button type="submit" class={primaryButtonClass}>
                Sign in
              </button>
            </form>

            <p class="mt-6 text-xs leading-6 text-slate-500">
              Google sign-in never grants admin access unless an admin role already exists for your account.
            </p>
          </div>
        </section>
      </div>
    </div>
  </main>
</BaseLayout>
