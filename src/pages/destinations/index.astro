---
import PublicLayout from '../../layouts/PublicLayout.astro'
import Container from '../../components/ui/Container.astro'
import DestinationCard from '../../components/public/cards/DestinationCard.astro'
import { createClient } from '../../lib/supabase/server'
import { SITE_URL } from '../../lib/site'

const supabase = createClient(Astro.cookies, Astro.request)

const [
  { data: countriesData, error: countriesError },
  { data: programsData, error: programsError },
  { data: universitiesData, error: universitiesError },
] = await Promise.all([
  supabase
    .from('countries')
    .select(`
      id, name,
      cover_image:media_assets!countries_cover_image_id_fkey(cloudinary_public_id, alt_text, display_name)
    `)
    .eq('content_status', 'published')
    .eq('is_destination_enabled', true)
    .order('name'),
  supabase
    .from('programs')
    .select('country_id')
    .eq('content_status', 'published')
    .limit(10000),
  supabase
    .from('universities')
    .select('country_id')
    .eq('content_status', 'published')
    .limit(10000),
])

if (countriesError) console.error('destinations countries error:', countriesError.message)
if (programsError) console.error('destinations programs count error:', programsError.message)
if (universitiesError) console.error('destinations universities count error:', universitiesError.message)

const countries = countriesData ?? []

function countByCountry(rows: any[] | null): Map<string, number> {
  const counts = new Map<string, number>()
  for (const row of rows ?? []) {
    if (!row.country_id) continue
    counts.set(row.country_id, (counts.get(row.country_id) ?? 0) + 1)
  }
  return counts
}

const programCounts = countByCountry(programsData)
---

<PublicLayout
  title="Study Destinations - DegreeWiki"
  description="Explore countries, universities, programs, scholarships, and guides on DegreeWiki."
  canonical={SITE_URL + '/destinations'}
>
  <div class="bg-surface border-b border-edge">
    <Container width="wide" class="py-8 sm:py-10">
      <p class="text-xs font-semibold uppercase tracking-[0.08em] text-primary mb-3">Where to study</p>
      <h1 class="text-[30px] sm:text-[38px] font-bold text-ink tracking-[-0.03em] leading-tight">
        Study Destinations
      </h1>
      <p class="mt-3 max-w-2xl text-base sm:text-[17px] text-ink-secondary leading-relaxed">
        Explore countries, universities, programs, scholarships, and guides.
      </p>
      <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3">
        <div class="rounded-xl border border-edge bg-canvas px-4 py-3">
          <p class="text-[22px] font-bold text-ink leading-none">{countries.length.toLocaleString()}</p>
          <p class="mt-1 text-xs text-muted">Published destinations</p>
        </div>
        <div class="rounded-xl border border-edge bg-canvas px-4 py-3">
          <p class="text-[22px] font-bold text-ink leading-none">{(programsData?.length ?? 0).toLocaleString()}</p>
          <p class="mt-1 text-xs text-muted">Published programs</p>
        </div>
        <div class="rounded-xl border border-edge bg-canvas px-4 py-3 col-span-2 sm:col-span-1">
          <p class="text-[22px] font-bold text-ink leading-none">{(universitiesData?.length ?? 0).toLocaleString()}</p>
          <p class="mt-1 text-xs text-muted">Published universities</p>
        </div>
      </div>
    </Container>
  </div>

  <div class="bg-canvas min-h-[60vh]">
    <Container width="wide" class="py-7 sm:py-8">
      {countriesError ? (
        <div class="rounded-2xl border border-edge bg-surface p-6">
          <h2 class="text-lg font-semibold text-ink mb-2">Destinations are temporarily unavailable</h2>
          <p class="text-sm text-muted">Please try again shortly, or browse programs directly.</p>
        </div>
      ) : countries.length > 0 ? (
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {countries.map((country: any) => (
            <DestinationCard
              href={`/programs?country=${country.id}`}
              name={country.name}
              programCount={programCounts.get(country.id) ?? 0}
              imagePublicId={country.cover_image?.cloudinary_public_id ?? null}
              imageAlt={country.cover_image?.alt_text || country.cover_image?.display_name || country.name}
            />
          ))}
        </div>
      ) : (
        <div class="rounded-2xl border border-edge bg-surface p-6 text-center">
          <h2 class="text-lg font-semibold text-ink mb-2">No public destinations yet</h2>
          <p class="mx-auto max-w-md text-sm text-muted leading-relaxed mb-5">
            Published study destinations will appear here once country records are enabled for public destination browsing.
          </p>
          <a
            href="/programs"
            class="inline-flex items-center justify-center rounded-[9px] bg-primary px-5 py-2 text-sm font-semibold text-white hover:bg-primary-hover transition-colors"
          >
            Browse programs
          </a>
        </div>
      )}
    </Container>
  </div>
</PublicLayout>
