---
import PublicLayout from '../../layouts/PublicLayout.astro'
import { createClient } from '../../lib/supabase/server'

const supabase = createClient(Astro.cookies, Astro.request)
const { data: scholarships, error } = await supabase
  .from('scholarships')
  .select('id, name, slug, scholarship_type, provider_name, funding_type, amount_min, amount_max, currency, deadline')
  .eq('content_status', 'published')
  .order('name')
  .limit(100)

if (error) console.error('scholarships list error:', error.message)
const rows = scholarships ?? []

function formatAmount(min: any, max: any, currency: string | null): string {
  if (min == null && max == null) return '—'
  const fmt = (n: any) => Number(n).toLocaleString()
  const range = min != null && max != null
    ? `${fmt(min)} – ${fmt(max)}`
    : min != null ? fmt(min) : `up to ${fmt(max)}`
  return [currency, range].filter(Boolean).join(' ')
}

function formatLabel(value: string | null): string {
  if (!value) return '—'
  return value.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase())
}

function formatDate(d: string | null): string {
  if (!d) return '—'
  return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
}
---
<PublicLayout title="Scholarships — DegreeWiki">
  <div class="max-w-5xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">Scholarships</h1>
    {rows.length === 0 ? (
      <p class="text-gray-500 text-sm">No results yet.</p>
    ) : (
      <div class="overflow-x-auto rounded-lg border border-gray-200">
        <table class="w-full text-sm text-left">
          <thead class="bg-gray-50 border-b border-gray-200 text-xs text-gray-500 uppercase tracking-wide">
            <tr>
              <th class="px-4 py-3">Scholarship</th>
              <th class="px-4 py-3">Type</th>
              <th class="px-4 py-3">Provider</th>
              <th class="px-4 py-3">Funding</th>
              <th class="px-4 py-3">Deadline</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((s: any) => (
              <tr class="border-b border-gray-100 hover:bg-gray-50 last:border-b-0">
                <td class="px-4 py-3">
                  <a href={`/scholarships/${s.slug}`} class="text-blue-600 hover:underline font-medium">
                    {s.name}
                  </a>
                </td>
                <td class="px-4 py-3 text-gray-600">{formatLabel(s.scholarship_type)}</td>
                <td class="px-4 py-3 text-gray-600">{s.provider_name ?? '—'}</td>
                <td class="px-4 py-3 text-gray-500">{formatAmount(s.amount_min, s.amount_max, s.currency)}</td>
                <td class="px-4 py-3 text-gray-500">{formatDate(s.deadline)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</PublicLayout>
