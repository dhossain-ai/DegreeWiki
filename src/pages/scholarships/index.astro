---
import PublicLayout from '../../layouts/PublicLayout.astro'
import Container from '../../components/ui/Container.astro'
import Badge from '../../components/ui/Badge.astro'
import { createClient } from '../../lib/supabase/server'
import { SITE_URL } from '../../lib/site'

const supabase = createClient(Astro.cookies, Astro.request)

const SCHOLARSHIP_TYPES = ['full', 'partial', 'merit', 'need_based', 'government', 'institutional', 'other'] as const
const PROVIDER_TYPES    = ['government', 'university', 'private_foundation', 'corporate', 'ngo', 'other'] as const
const FUNDING_TYPES     = ['full_tuition', 'partial_tuition', 'living_stipend', 'travel', 'research', 'full_funding', 'other'] as const
const APPLICATION_TYPES = ['direct', 'university_portal', 'nomination', 'embassy', 'other'] as const

function parseEnum<T extends readonly string[]>(allowed: T, raw: string | null): T[number] | undefined {
  return raw && (allowed as readonly string[]).includes(raw) ? raw as T[number] : undefined
}

const sp = Astro.url.searchParams

const q               = sp.get('q')?.trim().replace(/[,()]/g, '').slice(0, 100) || undefined
const scholarshipType = parseEnum(SCHOLARSHIP_TYPES, sp.get('scholarship_type'))
const providerType    = parseEnum(PROVIDER_TYPES,    sp.get('provider_type'))
const fundingType     = parseEnum(FUNDING_TYPES,     sp.get('funding_type'))
const applicationType = parseEnum(APPLICATION_TYPES, sp.get('application_type'))
const currency        = sp.get('currency')?.trim().toUpperCase().replace(/[^A-Z]/g, '').slice(0, 10) || undefined
const upcomingOnly    = sp.get('deadline') === 'upcoming'

const today    = new Date()
const todayISO = `${today.getUTCFullYear()}-${String(today.getUTCMonth() + 1).padStart(2, '0')}-${String(today.getUTCDate()).padStart(2, '0')}`

const hasFilters = !!(q || scholarshipType || providerType || fundingType || applicationType || currency || upcomingOnly)

let query = supabase
  .from('scholarships')
  .select(
    'id, name, slug, scholarship_type, provider_name, provider_type, funding_type, application_type, amount_min, amount_max, currency, deadline, deadline_text',
    { count: 'exact' }
  )
  .eq('content_status', 'published')
  .order('deadline', { ascending: true, nullsFirst: false })
  .order('name',     { ascending: true })
  .limit(201)

if (q)               query = query.or(`name.ilike.%${q}%,provider_name.ilike.%${q}%`)
if (scholarshipType) query = query.eq('scholarship_type', scholarshipType)
if (providerType)    query = query.eq('provider_type', providerType)
if (fundingType)     query = query.eq('funding_type', fundingType)
if (applicationType) query = query.eq('application_type', applicationType)
if (currency)        query = query.ilike('currency', `%${currency}%`)
if (upcomingOnly)    query = query.gte('deadline', todayISO)

const { data, count, error } = await query
if (error) console.error('scholarships list error:', error.message)

const allRows   = data ?? []
const overLimit = (count ?? allRows.length) > 200
const rows      = allRows.slice(0, 200)

function formatAmount(min: any, max: any, cur: string | null): string | null {
  if (min == null && max == null) return null
  const fmt = (n: any) => Number(n).toLocaleString()
  const range =
    min != null && max != null
      ? `${fmt(min)} – ${fmt(max)}`
      : min != null ? fmt(min) : `up to ${fmt(max)}`
  return [cur, range].filter(Boolean).join(' ')
}

function formatLabel(value: string | null | undefined): string {
  if (!value) return ''
  return value.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase())
}

function formatDeadline(d: string | null, dt: string | null): string | null {
  if (d) return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
  return dt ?? null
}

function buildUrlWithout(param: string): string {
  const params = new URLSearchParams(Astro.url.searchParams)
  params.delete(param)
  const qs = params.toString()
  return '/scholarships' + (qs ? '?' + qs : '')
}

type FilterChip = { key: string; label: string; removeHref: string }
const activeChips: FilterChip[] = []
if (q)               activeChips.push({ key: 'q',               label: `"${q}"`,                               removeHref: buildUrlWithout('q') })
if (scholarshipType) activeChips.push({ key: 'scholarship_type', label: `Type: ${formatLabel(scholarshipType)}`, removeHref: buildUrlWithout('scholarship_type') })
if (providerType)    activeChips.push({ key: 'provider_type',    label: `Provider: ${formatLabel(providerType)}`,removeHref: buildUrlWithout('provider_type') })
if (fundingType)     activeChips.push({ key: 'funding_type',     label: `Funding: ${formatLabel(fundingType)}`,  removeHref: buildUrlWithout('funding_type') })
if (applicationType) activeChips.push({ key: 'application_type', label: `Via: ${formatLabel(applicationType)}`,  removeHref: buildUrlWithout('application_type') })
if (currency)        activeChips.push({ key: 'currency',         label: `Currency: ${currency}`,                 removeHref: buildUrlWithout('currency') })
if (upcomingOnly)    activeChips.push({ key: 'deadline',         label: 'Upcoming only',                         removeHref: buildUrlWithout('deadline') })

const flabel  = 'block text-[11px] font-semibold uppercase tracking-[0.05em] text-muted mb-1.5'
const fselect = 'w-full rounded-[8px] border border-edge bg-surface px-3 py-2 text-sm text-ink focus:outline-none focus:border-primary'
const finput  = 'w-full rounded-[8px] border border-edge bg-surface px-3 py-2 text-sm text-ink placeholder:text-muted focus:outline-none focus:border-primary'
---

<style>
  details > summary { list-style: none; }
  details > summary::-webkit-details-marker { display: none; }
  details[open] .chevron { transform: rotate(180deg); }
  .chevron { transition: transform 200ms ease; }
</style>

<PublicLayout title="Scholarships — DegreeWiki" noindex={hasFilters} canonical={SITE_URL + '/scholarships'}>

  <!-- Page header band -->
  <div class="bg-surface border-b border-edge">
    <Container width="default" class="py-7 sm:py-8">
      <h1 class="text-[28px] sm:text-3xl font-bold text-ink tracking-[-0.02em] leading-tight">
        Scholarships
      </h1>
      <p class="mt-1.5 text-base text-muted">
        Find scholarships and funding opportunities for international students.
      </p>
    </Container>
  </div>

  <!-- Main content -->
  <div class="bg-canvas min-h-[60vh]">
    <Container width="default" class="py-6 sm:py-8">

      <form method="get" action="/scholarships">

        <!-- Keyword search bar -->
        <div class="flex gap-2.5 mb-4">
          <div class="relative flex-1">
            <label for="q" class="sr-only">Search scholarships</label>
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted pointer-events-none"
                 viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="7" cy="7" r="4.5" stroke="currentColor" stroke-width="1.4"/>
              <path d="M10.5 10.5L13.5 13.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            </svg>
            <input
              id="q" name="q" type="search"
              value={q ?? ''}
              placeholder="Search scholarships, e.g. Chevening, Gates, government merit…"
              class="w-full h-[44px] pl-[38px] pr-4 rounded-[10px] border border-edge bg-surface
                     text-sm text-ink placeholder:text-muted focus:outline-none focus:border-primary"
            />
          </div>
          <button type="submit"
                  class="h-[44px] px-5 bg-primary text-white text-[13.5px] font-semibold rounded-[10px]
                         hover:bg-primary-hover transition-colors flex-none">
            Search
          </button>
          {hasFilters && (
            <a href="/scholarships"
               class="h-[44px] px-4 inline-flex items-center text-[13.5px] font-medium text-ink-secondary
                      border border-edge rounded-[10px] hover:bg-surface transition-colors flex-none">
              Clear all
            </a>
          )}
        </div>

        <!-- Filter panel (collapsible) -->
        <details open class="bg-surface border border-edge rounded-xl mb-4 overflow-hidden">
          <summary class="flex items-center justify-between px-4 py-3 cursor-pointer select-none">
            <span class="text-[11px] font-semibold uppercase tracking-[0.06em] text-muted">
              Filters{activeChips.length > 0 ? ` (${activeChips.length})` : ''}
            </span>
            <svg class="chevron w-4 h-4 text-muted" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </summary>
          <div class="border-t border-edge p-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">

            <div>
              <label for="scholarship_type" class={flabel}>Scholarship type</label>
              <select id="scholarship_type" name="scholarship_type" class={fselect}>
                <option value="">Any type</option>
                <option value="full"          selected={scholarshipType === 'full'}>Full</option>
                <option value="partial"       selected={scholarshipType === 'partial'}>Partial</option>
                <option value="merit"         selected={scholarshipType === 'merit'}>Merit</option>
                <option value="need_based"    selected={scholarshipType === 'need_based'}>Need Based</option>
                <option value="government"    selected={scholarshipType === 'government'}>Government</option>
                <option value="institutional" selected={scholarshipType === 'institutional'}>Institutional</option>
                <option value="other"         selected={scholarshipType === 'other'}>Other</option>
              </select>
            </div>

            <div>
              <label for="provider_type" class={flabel}>Provider type</label>
              <select id="provider_type" name="provider_type" class={fselect}>
                <option value="">Any provider</option>
                <option value="government"         selected={providerType === 'government'}>Government</option>
                <option value="university"         selected={providerType === 'university'}>University</option>
                <option value="private_foundation" selected={providerType === 'private_foundation'}>Private Foundation</option>
                <option value="corporate"          selected={providerType === 'corporate'}>Corporate</option>
                <option value="ngo"                selected={providerType === 'ngo'}>NGO</option>
                <option value="other"              selected={providerType === 'other'}>Other</option>
              </select>
            </div>

            <div>
              <label for="funding_type" class={flabel}>Funding type</label>
              <select id="funding_type" name="funding_type" class={fselect}>
                <option value="">Any funding</option>
                <option value="full_tuition"    selected={fundingType === 'full_tuition'}>Full Tuition</option>
                <option value="partial_tuition" selected={fundingType === 'partial_tuition'}>Partial Tuition</option>
                <option value="living_stipend"  selected={fundingType === 'living_stipend'}>Living Stipend</option>
                <option value="travel"          selected={fundingType === 'travel'}>Travel</option>
                <option value="research"        selected={fundingType === 'research'}>Research</option>
                <option value="full_funding"    selected={fundingType === 'full_funding'}>Full Funding</option>
                <option value="other"           selected={fundingType === 'other'}>Other</option>
              </select>
            </div>

            <div>
              <label for="application_type" class={flabel}>How to apply</label>
              <select id="application_type" name="application_type" class={fselect}>
                <option value="">Any method</option>
                <option value="direct"            selected={applicationType === 'direct'}>Direct</option>
                <option value="university_portal" selected={applicationType === 'university_portal'}>University Portal</option>
                <option value="nomination"        selected={applicationType === 'nomination'}>Nomination</option>
                <option value="embassy"           selected={applicationType === 'embassy'}>Embassy</option>
                <option value="other"             selected={applicationType === 'other'}>Other</option>
              </select>
            </div>

            <div>
              <label for="currency" class={flabel}>Currency</label>
              <input id="currency" name="currency" type="text" value={currency ?? ''}
                     placeholder="e.g. USD, GBP, EUR"
                     class={finput} />
            </div>

            <div>
              <label for="deadline" class={flabel}>Deadline</label>
              <select id="deadline" name="deadline" class={fselect}>
                <option value="">Any deadline</option>
                <option value="upcoming" selected={upcomingOnly}>Upcoming only</option>
              </select>
            </div>

            <div class="sm:col-span-2 lg:col-span-3 flex justify-end">
              <button type="submit"
                      class="h-[36px] px-5 bg-primary text-white text-sm font-semibold rounded-[9px]
                             hover:bg-primary-hover transition-colors">
                Apply filters
              </button>
            </div>

          </div>
        </details>

      </form>

      <!-- Active filter chips -->
      {activeChips.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-5" aria-label="Active filters">
          {activeChips.map(chip => (
            <a href={chip.removeHref}
               class="inline-flex items-center gap-1.5 px-3 py-1 bg-primary-surface border border-primary-border
                      text-primary text-sm font-medium rounded-full hover:bg-primary-border transition-colors">
              {chip.label}
              <span aria-hidden="true" class="text-base leading-none opacity-60">×</span>
            </a>
          ))}
        </div>
      )}

      <!-- Results count -->
      {overLimit ? (
        <p class="text-sm text-muted mb-4">
          Showing 200 of {(count ?? 200).toLocaleString()} scholarships. Narrow your search to see more.
        </p>
      ) : rows.length > 0 ? (
        <p class="text-sm text-muted mb-4">
          {rows.length} {rows.length === 1 ? 'scholarship' : 'scholarships'} found.
        </p>
      ) : null}

      <!-- Results -->
      {rows.length === 0 ? (
        <div class="text-center py-16 rounded-xl border border-edge bg-surface">
          <p class="text-base font-medium text-ink mb-2">
            {hasFilters ? 'No scholarships match your filters.' : 'No scholarships have been published yet.'}
          </p>
          {hasFilters && (
            <a href="/scholarships" class="text-sm text-primary hover:text-primary-hover">
              Clear filters and browse all
            </a>
          )}
        </div>
      ) : (
        <ul class="space-y-2.5">
          {rows.map((s: any) => {
            const amount   = formatAmount(s.amount_min, s.amount_max, s.currency)
            const deadline = formatDeadline(s.deadline, s.deadline_text)
            return (
              <li class="rounded-xl border border-edge bg-surface px-4 py-4
                         hover:border-[#cbd5e1] hover:shadow-sm transition-all">

                <div class="flex items-start justify-between gap-4 mb-2">
                  <a href={`/scholarships/${s.slug}`}
                     class="text-[15px] font-semibold text-ink hover:text-primary leading-snug">
                    {s.name}
                  </a>
                  {amount && (
                    <span class="text-sm font-semibold text-verified whitespace-nowrap shrink-0">{amount}</span>
                  )}
                </div>

                {s.provider_name && (
                  <p class="text-sm text-ink-secondary mb-2">{s.provider_name}</p>
                )}

                <div class="flex flex-wrap gap-1.5">
                  {s.scholarship_type && (
                    <Badge variant="neutral">{formatLabel(s.scholarship_type)}</Badge>
                  )}
                  {s.provider_type && (
                    <Badge variant="neutral">{formatLabel(s.provider_type)}</Badge>
                  )}
                  {s.funding_type && (
                    <Badge variant="info">{formatLabel(s.funding_type)}</Badge>
                  )}
                  {s.application_type && (
                    <Badge variant="neutral">Via: {formatLabel(s.application_type)}</Badge>
                  )}
                  {deadline && (
                    <Badge variant="deadline">Deadline: {deadline}</Badge>
                  )}
                </div>

              </li>
            )
          })}
        </ul>
      )}

    </Container>
  </div>

</PublicLayout>
