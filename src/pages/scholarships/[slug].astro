---
import PublicLayout from '../../layouts/PublicLayout.astro'
import Container from '../../components/ui/Container.astro'
import Badge from '../../components/ui/Badge.astro'
import SourceBox from '../../components/public/SourceBox.astro'
import { createClient } from '../../lib/supabase/server'
import { SITE_URL } from '../../lib/site'

const { slug } = Astro.params
const supabase = createClient(Astro.cookies, Astro.request)

const { data: scholarship } = await supabase
  .from('scholarships')
  .select(`
    id, name, slug,
    scholarship_type, provider_name, provider_type, funding_type, application_type,
    overview, eligibility_summary,
    amount_min, amount_max, currency, coverage_notes,
    deadline, deadline_text,
    official_url, application_url, provider_url,
    verification_status, last_verified_at, source_confidence_score, updated_at,
    seo_title, seo_description,
    canonical_url, og_title, og_description
  `)
  .eq('slug', slug!)
  .eq('content_status', 'published')
  .single()

if (!scholarship) {
  return new Response(null, { status: 404 })
}

const s = scholarship as any

const VERIFICATION_MAP: Record<string, { label: string; variant: 'verified' | 'neutral' }> = {
  verified:           { label: 'Verified',           variant: 'verified' },
  partially_verified: { label: 'Partially Verified', variant: 'neutral'  },
  source_conflict:    { label: 'Under Review',       variant: 'neutral'  },
  outdated:           { label: 'Under Review',       variant: 'neutral'  },
  needs_review:       { label: 'Under Review',       variant: 'neutral'  },
}
const verInfo = VERIFICATION_MAP[s.verification_status] ?? null

function formatLabel(value: string | null): string | null {
  if (!value) return null
  return value.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase())
}

function formatAmount(): string | null {
  if (s.amount_min == null && s.amount_max == null) return null
  const fmt = (n: any) => Number(n).toLocaleString()
  const range = s.amount_min != null && s.amount_max != null
    ? `${fmt(s.amount_min)} – ${fmt(s.amount_max)}`
    : s.amount_min != null ? fmt(s.amount_min) : `up to ${fmt(s.amount_max)}`
  return [s.currency, range].filter(Boolean).join(' ')
}

function formatDate(d: string | null): string | null {
  if (!d) return null
  return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
}

const amount         = formatAmount()
const deadline       = formatDate(s.deadline) ?? s.deadline_text ?? null
const lastVerifiedAt = formatDate(s.last_verified_at)
const pageTitle      = s.seo_title || s.name
const pageDesc       = s.seo_description || s.eligibility_summary || undefined
const canonical      = s.canonical_url || `${SITE_URL}/scholarships/${slug}`
const ogTitle        = s.og_title || pageTitle
const ogDesc         = s.og_description || pageDesc
const updatedAt      = formatDate(s.updated_at)
---
<PublicLayout title={`${pageTitle} — DegreeWiki`} description={pageDesc} canonical={canonical} ogTitle={ogTitle} ogDescription={ogDesc}>

  <!-- Page header band -->
  <div class="bg-surface border-b border-edge">
    <Container width="narrow" class="py-7 sm:py-8">
      <a href="/scholarships"
         class="inline-flex items-center gap-1 text-sm text-primary hover:text-primary-hover mb-4">
        ← All Scholarships
      </a>

      {s.provider_name && (
        <p class="text-sm text-muted mb-2">{s.provider_name}</p>
      )}

      <h1 class="text-2xl sm:text-3xl font-bold text-ink tracking-[-0.02em] leading-tight mb-3">
        {s.name}
      </h1>

      <div class="flex flex-wrap items-center gap-2">
        {verInfo && (
          <Badge variant={verInfo.variant}>{verInfo.label}</Badge>
        )}
        {s.scholarship_type && (
          <Badge variant="neutral">{formatLabel(s.scholarship_type)}</Badge>
        )}
        {amount && (
          <Badge variant="scholarship">{amount}</Badge>
        )}
      </div>
    </Container>
  </div>

  <!-- Main content -->
  <div class="bg-canvas">
    <Container width="narrow" class="py-7 sm:py-8">

      <!-- Key facts panel -->
      <div class="bg-surface border border-edge rounded-xl p-5 mb-7">
        <h2 class="text-[11px] font-semibold uppercase tracking-[0.06em] text-muted mb-4">
          Scholarship details
        </h2>
        <dl class="grid grid-cols-2 sm:grid-cols-3 gap-x-6 gap-y-4">
          {s.scholarship_type && (
            <div>
              <dt class="text-[11px] font-semibold uppercase tracking-[0.05em] text-muted mb-0.5">Type</dt>
              <dd class="text-sm font-medium text-ink">{formatLabel(s.scholarship_type)}</dd>
            </div>
          )}
          {s.funding_type && (
            <div>
              <dt class="text-[11px] font-semibold uppercase tracking-[0.05em] text-muted mb-0.5">Funding</dt>
              <dd class="text-sm font-medium text-ink">{formatLabel(s.funding_type)}</dd>
            </div>
          )}
          {s.provider_name && (
            <div>
              <dt class="text-[11px] font-semibold uppercase tracking-[0.05em] text-muted mb-0.5">Provider</dt>
              <dd class="text-sm font-medium text-ink">{s.provider_name}</dd>
            </div>
          )}
          {s.provider_type && (
            <div>
              <dt class="text-[11px] font-semibold uppercase tracking-[0.05em] text-muted mb-0.5">Provider type</dt>
              <dd class="text-sm font-medium text-ink">{formatLabel(s.provider_type)}</dd>
            </div>
          )}
          {s.application_type && (
            <div>
              <dt class="text-[11px] font-semibold uppercase tracking-[0.05em] text-muted mb-0.5">How to apply</dt>
              <dd class="text-sm font-medium text-ink">{formatLabel(s.application_type)}</dd>
            </div>
          )}
          {amount && (
            <div>
              <dt class="text-[11px] font-semibold uppercase tracking-[0.05em] text-muted mb-0.5">Amount</dt>
              <dd class="text-sm font-semibold text-verified">{amount}</dd>
            </div>
          )}
          {deadline && (
            <div class={s.deadline ? 'sm:col-span-2' : undefined}>
              <dt class="text-[11px] font-semibold uppercase tracking-[0.05em] text-muted mb-0.5">Deadline</dt>
              <dd class="text-sm font-medium text-deadline">{deadline}</dd>
            </div>
          )}
        </dl>
      </div>

      <!-- Overview -->
      {s.overview && (
        <div class="mb-6">
          <h2 class="text-lg font-semibold text-ink mb-2">Overview</h2>
          <p class="text-sm text-ink-secondary leading-relaxed whitespace-pre-wrap">{s.overview}</p>
        </div>
      )}

      <!-- Eligibility -->
      {s.eligibility_summary && (
        <div class="mb-6">
          <h2 class="text-lg font-semibold text-ink mb-2">Eligibility</h2>
          <p class="text-sm text-ink-secondary leading-relaxed whitespace-pre-wrap">{s.eligibility_summary}</p>
        </div>
      )}

      <!-- Coverage -->
      {s.coverage_notes && (
        <div class="mb-6">
          <h2 class="text-lg font-semibold text-ink mb-2">What's Covered</h2>
          <p class="text-sm text-ink-secondary leading-relaxed whitespace-pre-wrap">{s.coverage_notes}</p>
        </div>
      )}

      <!-- Deadline notes -->
      {s.deadline_text && s.deadline && (
        <div class="mb-6">
          <h2 class="text-lg font-semibold text-ink mb-2">Deadline Notes</h2>
          <p class="text-sm text-ink-secondary">{s.deadline_text}</p>
        </div>
      )}

      <!-- CTA buttons -->
      {(s.application_url || s.official_url || s.provider_url) && (
        <div class="mt-2 mb-7 flex flex-col sm:flex-row gap-3">
          {s.application_url && (
            <a href={s.application_url} target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-primary text-white
                      text-sm font-semibold rounded-[9px] hover:bg-primary-hover transition-colors">
              Apply Now ↗
            </a>
          )}
          {s.official_url && (
            <a href={s.official_url} target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center justify-center gap-2 px-5 py-2.5 border border-edge bg-surface
                      text-ink-secondary text-sm font-medium rounded-[9px] hover:border-primary/40 hover:text-ink transition-colors">
              Official Scholarship Page ↗
            </a>
          )}
          {s.provider_url && !s.official_url && (
            <a href={s.provider_url} target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center justify-center gap-2 px-5 py-2.5 border border-edge bg-surface
                      text-ink-secondary text-sm font-medium rounded-[9px] hover:border-primary/40 hover:text-ink transition-colors">
              Provider Website ↗
            </a>
          )}
        </div>
      )}

      <!-- Source & verification -->
      <SourceBox
        verificationStatus={s.verification_status}
        lastVerifiedAt={lastVerifiedAt}
        officialUrl={s.official_url ?? s.provider_url ?? null}
        sourceConfidenceScore={s.source_confidence_score ?? null}
      />

      {updatedAt && (
        <p class="text-xs text-muted mb-6">Last updated: {updatedAt}</p>
      )}

      <a href="/scholarships" class="text-sm text-primary hover:text-primary-hover">
        ← All Scholarships
      </a>

    </Container>
  </div>

</PublicLayout>
