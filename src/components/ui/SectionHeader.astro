---
interface Props {
  title: string
  eyebrow?: string
  href?: string
  linkText?: string
  as?: 'h2' | 'h3'
  class?: string
}
const { title, eyebrow, href, linkText = 'View all', as = 'h2', class: className = '' } = Astro.props
const Heading = as as any
---
<div class={`flex items-end justify-between gap-4 mb-5 ${className}`}>
  <div>
    {eyebrow && (
      <p class="text-xs font-semibold uppercase tracking-wide text-muted mb-1">{eyebrow}</p>
    )}
    <Heading class="text-2xl font-bold text-ink leading-tight tracking-[-0.015em]">{title}</Heading>
  </div>
  {href && (
    <a href={href} class="shrink-0 text-sm font-medium text-primary hover:text-primary-hover whitespace-nowrap">
      {linkText} <span aria-hidden="true">&rarr;</span>
    </a>
  )}
</div>
