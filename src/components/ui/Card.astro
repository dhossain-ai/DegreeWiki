---
interface Props {
  href?: string
  class?: string
  padding?: 'sm' | 'md'
  [key: string]: unknown
}
const { href, class: className = '', padding = 'md', ...rest } = Astro.props

const pad = padding === 'sm' ? 'p-4' : 'p-5'
const base = `block rounded-lg border border-edge bg-surface ${pad}`
const interactive = 'transition-colors hover:border-primary/40 hover:shadow-sm'
---
{href ? (
  <a href={href} class={`${base} ${interactive} ${className}`} {...rest}>
    <slot />
  </a>
) : (
  <div class={`${base} ${className}`} {...rest}>
    <slot />
  </div>
)}
