---
interface Props {
  href?: string
  variant?: 'primary' | 'secondary' | 'ghost' | 'soft'
  type?: 'button' | 'submit' | 'reset'
  size?: 'sm' | 'md' | 'lg'
  class?: string
  [key: string]: unknown
}
const {
  href,
  variant = 'primary',
  type = 'button',
  size = 'md',
  class: className = '',
  ...rest
} = Astro.props

const base =
  'inline-flex items-center justify-center gap-2 rounded-[9px] font-semibold transition-colors ' +
  'focus-visible:outline-none disabled:opacity-60 disabled:pointer-events-none'

const sizes: Record<string, string> = {
  sm: 'px-3.5 py-[7px] text-sm',
  md: 'px-4 py-[9px] text-sm',
  lg: 'px-6 py-3 text-base',
}

const variants: Record<string, string> = {
  primary:   'bg-primary text-white border border-primary hover:bg-primary-hover',
  secondary: 'bg-surface text-primary border border-primary hover:bg-primary-surface',
  ghost:     'text-primary bg-surface border border-primary-border hover:bg-primary-surface',
  soft:      'text-primary bg-primary-surface border border-primary-border hover:bg-primary-border',
}

const classes = `${base} ${sizes[size]} ${variants[variant]} ${className}`
---
{href ? (
  <a href={href} class={classes} {...rest}><slot /></a>
) : (
  <button type={type} class={classes} {...rest}><slot /></button>
)}
