---
interface Option { value: string; label: string }
interface Props {
  label: string
  name: string
  id?: string
  type?: 'search' | 'text' | 'number' | 'select'
  placeholder?: string
  value?: string
  options?: Option[]
  hint?: string
  class?: string
}
const {
  label, name, id = name, type = 'text',
  placeholder, value = '', options = [], hint, class: className = '',
} = Astro.props

const field =
  'w-full rounded-md border border-edge bg-surface px-3 py-2 text-sm text-ink ' +
  'placeholder:text-muted focus-visible:outline-none focus-visible:border-primary'
---
<div class={className}>
  <label for={id} class="block text-xs font-medium text-muted mb-1">{label}</label>
  {type === 'select' ? (
    <select id={id} name={name} class={field}>
      <slot>
        {options.map(o => (
          <option value={o.value} selected={o.value === value}>{o.label}</option>
        ))}
      </slot>
    </select>
  ) : (
    <input id={id} name={name} type={type} value={value} placeholder={placeholder} class={field} />
  )}
  {hint && <p class="text-xs text-muted mt-0.5">{hint}</p>}
</div>
