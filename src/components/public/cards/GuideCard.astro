---
import Card from '../../ui/Card.astro'
import Badge from '../../ui/Badge.astro'
import MediaImage from '../MediaImage.astro'

interface Props {
  href: string
  title: string
  category?: string | null
  date?: string | null
  summary?: string | null
  imagePublicId?: string | null
  imageAlt?: string | null
}
const { href, title, category = null, date = null, summary = null, imagePublicId = null, imageAlt = null } = Astro.props
---
<Card href={href} padding="sm" class="group flex h-full flex-col">
  {imagePublicId && (
    <div class="-mx-3 -mt-3 mb-3 overflow-hidden rounded-t-[9px]">
      <MediaImage
        publicId={imagePublicId}
        alt={imageAlt ?? title}
        width={480}
        height={240}
        crop="fill"
        loading="lazy"
        class="h-44 w-full object-cover transition-transform duration-300 group-hover:scale-[1.01]"
      />
    </div>
  )}
  {(category || date) && (
    <div class="mb-2 flex flex-wrap items-center gap-2">
      {category && <Badge variant="info">{category}</Badge>}
      {date && <span class="text-xs text-muted">{date}</span>}
    </div>
  )}
  <h3 class="mb-2 text-base font-semibold leading-snug text-ink line-clamp-2">{title}</h3>
  {summary && <p class="text-sm leading-6 text-muted line-clamp-3">{summary}</p>}
  <div class="mt-auto pt-4 text-sm font-semibold text-primary">
    Read guide →
  </div>
</Card>
