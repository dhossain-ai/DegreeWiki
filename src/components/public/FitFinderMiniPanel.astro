---
import Button from '../ui/Button.astro'

interface Props {
  href?: string
  class?: string
}
const { href = '/fit-finder', class: className = '' } = Astro.props

const steps = [
  'Share your study goal',
  'Add budget and preferences',
  'Get AI-assisted matches from real program data',
]
---
<div class={`rounded-xl border border-edge bg-ink text-white p-6 transition-[transform,box-shadow,border-color] duration-200 hover:-translate-y-0.5 hover:border-white/20 hover:shadow-[0_16px_34px_rgba(11,31,58,0.14)] motion-reduce:transition-none motion-reduce:hover:translate-y-0 ${className}`}>
  <p class="text-xs font-semibold uppercase tracking-wide text-white/60 mb-1">Guided matching</p>
  <h2 class="text-lg font-bold mb-3">Find your best-fit programs</h2>
  <ol class="space-y-2 mb-5">
    {steps.map((step, i) => (
      <li class="flex items-start gap-3 text-sm text-white/85">
        <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-white/15 text-xs font-semibold">
          {i + 1}
        </span>
        {step}
      </li>
    ))}
  </ol>
  <Button href={href} variant="primary">Start Fit Finder</Button>
</div>
