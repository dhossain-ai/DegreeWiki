---
interface Props {
  verificationStatus: string | null
  lastVerifiedAt: string | null
  officialUrl: string | null
  sourceConfidenceScore: number | null
}

const { verificationStatus, lastVerifiedAt, officialUrl, sourceConfidenceScore } = Astro.props

const STATUS_LABELS: Record<string, string> = {
  verified:           'Verified by DegreeWiki',
  partially_verified: 'Partially verified',
  source_conflict:    'Source conflict under review',
  outdated:           'May need updating',
  needs_review:       'Needs review',
  unverified:         'Not yet verified',
}
const statusLabel = verificationStatus ? (STATUS_LABELS[verificationStatus] ?? null) : null

function confidenceLabel(score: number | null): string | null {
  if (!score || score <= 0) return null
  if (score >= 75) return 'High'
  if (score >= 40) return 'Medium'
  return 'Low'
}
const confidence = confidenceLabel(sourceConfidenceScore)
---
<div class="border border-gray-200 rounded-lg bg-gray-50 p-4 text-sm mb-6">
  <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Source &amp; Verification</h2>

  {statusLabel && (
    <p class="text-gray-700 mb-2">
      <span class="font-medium">Status:</span> {statusLabel}
    </p>
  )}

  {lastVerifiedAt && (
    <p class="text-gray-700 mb-2">
      <span class="font-medium">Last verified:</span> {lastVerifiedAt}
    </p>
  )}

  {confidence && (
    <p class="text-gray-700 mb-2">
      <span class="font-medium">Source confidence:</span> {confidence}
    </p>
  )}

  {officialUrl && (
    <p class="mb-3">
      <a href={officialUrl} target="_blank" rel="noopener noreferrer"
         class="text-blue-600 hover:underline">
        Official source ↗
      </a>
    </p>
  )}

  <p class="text-xs text-gray-500 italic">
    Always confirm important details — including deadlines, fees, and eligibility requirements — directly with the official university, scholarship provider, or government/source website before applying.
  </p>
</div>
