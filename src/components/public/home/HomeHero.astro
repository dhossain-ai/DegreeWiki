---
import Container from '../../ui/Container.astro'
import SearchChip from '../SearchChip.astro'

interface Props {
  degreeLevels: { id: string; name: string; code: string | null }[]
  destinations:  { id: string; name: string }[]
  dynamicDestination?: { id: string; name: string } | null
}

const {
  degreeLevels,
  destinations,
  dynamicDestination = null,
} = Astro.props

const bachelorLevel = degreeLevels.find(d => (d.code ?? '').toLowerCase() === 'bachelor')
const masterLevel   = degreeLevels.find(d => (d.code ?? '').toLowerCase() === 'master')
---

<section class="bg-canvas">
  <Container width="wide" class="py-12 sm:py-[52px]">

    <div class="max-w-[760px] mb-8">
      {/* Trust eyebrow badge */}
      <div class="inline-flex items-center gap-[7px] text-[12.5px] font-semibold text-verified bg-verified-surface border border-verified-border px-[11px] py-[5px] rounded-full mb-[18px]">
        <span class="w-1.5 h-1.5 rounded-full bg-verified flex-none" aria-hidden="true"></span>
        Program data verified against official university sources
      </div>
      <h1 class="text-[2.625rem] sm:text-[2.875rem] font-bold text-ink leading-[1.08] tracking-[-0.025em] mb-4">
        Find and compare<br class="hidden sm:inline" />
        degrees abroad
      </h1>
      <p class="text-[18px] text-ink-tertiary leading-relaxed max-w-[620px]">
        Search bachelor's and master's programs, scholarships, universities, and study guides for international students.
      </p>
    </div>

    {/* Search card */}
    <div class="bg-surface border border-edge rounded-2xl p-[18px] shadow-[0_6px_30px_rgba(11,31,58,0.06)] mb-6">
      <form method="GET" action="/programs">
        <div class="flex flex-col md:flex-row gap-3 items-end">
          <div class="flex-[2_1_240px] min-w-0 flex flex-col gap-[7px]">
            <label for="hero-q" class="block text-[11px] font-semibold text-slate-light uppercase tracking-[0.05em]">
              What do you want to study?
            </label>
            <input
              id="hero-q"
              name="q"
              type="search"
              placeholder="e.g. Data Science, Law, Medicine"
              autocomplete="off"
              class="w-full rounded-[10px] border border-edge bg-surface px-[13px] py-[11px] text-sm text-ink
                     placeholder:text-slate-light focus-visible:outline-none focus-visible:border-primary transition-colors"
            />
          </div>
          <div class="md:w-[168px] flex flex-col gap-[7px]">
            <label for="hero-degree" class="block text-[11px] font-semibold text-slate-light uppercase tracking-[0.05em]">
              Degree level
            </label>
            <select
              id="hero-degree"
              name="degree_level"
              class="w-full rounded-[10px] border border-edge bg-surface px-[12px] py-[11px] text-sm text-ink
                     focus-visible:outline-none focus-visible:border-primary transition-colors"
            >
              <option value="">Any level</option>
              {degreeLevels.map(d => (
                <option value={d.id}>{d.name}</option>
              ))}
            </select>
          </div>
          <div class="md:w-[168px] flex flex-col gap-[7px]">
            <label for="hero-country" class="block text-[11px] font-semibold text-slate-light uppercase tracking-[0.05em]">
              Destination
            </label>
            <select
              id="hero-country"
              name="country"
              class="w-full rounded-[10px] border border-edge bg-surface px-[12px] py-[11px] text-sm text-ink
                     focus-visible:outline-none focus-visible:border-primary transition-colors"
            >
              <option value="">Anywhere</option>
              {destinations.map(c => (
                <option value={c.id}>{c.name}</option>
              ))}
            </select>
          </div>
          <div>
            <button
              type="submit"
              class="w-full md:w-auto h-[44px] px-[26px] rounded-[10px] bg-primary text-white text-[14.5px] font-semibold
                     hover:bg-primary-hover transition-colors whitespace-nowrap"
            >
              Search
            </button>
          </div>
        </div>
      </form>
    </div>

    <div class="flex flex-wrap gap-2">
      {bachelorLevel && (
        <SearchChip href={`/programs?degree_level=${bachelorLevel.id}`} label="Bachelor's" />
      )}
      {masterLevel && (
        <SearchChip href={`/programs?degree_level=${masterLevel.id}`} label="Master's" />
      )}
      <SearchChip href="/scholarships" label="Find scholarships" />
      {dynamicDestination && (
        <SearchChip
          href={`/programs?country=${dynamicDestination.id}`}
          label={`Study in ${dynamicDestination.name}`}
        />
      )}
    </div>

  </Container>
</section>
