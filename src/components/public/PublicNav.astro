---
import { createClient } from '../../lib/supabase/server'

const pathname = Astro.url.pathname
const supabase = createClient(Astro.cookies, Astro.request)
const { data: { user } } = await supabase.auth.getUser()

const navLinks = [
  { href: '/universities', label: 'Universities' },
  { href: '/programs',     label: 'Programs'     },
  { href: '/scholarships', label: 'Scholarships' },
  { href: '/fit-finder',   label: 'Fit Finder'   },
  { href: '/guides',       label: 'Guides'       },
]
---
<nav class="bg-white border-b border-gray-200">
  <div class="max-w-5xl mx-auto px-4 py-3 flex flex-wrap items-center gap-4">
    <a href="/" class="text-base font-bold text-gray-900 hover:text-blue-600 shrink-0">DegreeWiki</a>
    <div class="flex flex-1 gap-5 text-sm overflow-x-auto">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`whitespace-nowrap hover:text-gray-900 ${pathname.startsWith(link.href) ? 'text-gray-900 font-medium' : 'text-gray-500'}`}
        >
          {link.label}
        </a>
      ))}
    </div>
    <div class="flex items-center gap-3 text-sm">
      {user ? (
        <>
          <a
            href="/account"
            class={`whitespace-nowrap hover:text-gray-900 ${pathname === '/account' ? 'text-gray-900 font-medium' : 'text-gray-500'}`}
          >
            Dashboard
          </a>
          <form method="post" action="/api/auth/logout">
            <button type="submit" class="whitespace-nowrap text-gray-500 hover:text-red-600">
              Sign out
            </button>
          </form>
        </>
      ) : (
        <>
          <a href="/login" class="whitespace-nowrap text-gray-500 hover:text-gray-900">Sign in</a>
          <a href="/signup" class="whitespace-nowrap rounded border border-blue-600 px-3 py-1.5 font-medium text-blue-600 hover:bg-blue-50">
            Get started
          </a>
        </>
      )}
    </div>
  </div>
</nav>
