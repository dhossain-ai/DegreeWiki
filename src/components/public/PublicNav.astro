---
import { createClient } from '../../lib/supabase/server'
import { getDashboardDestination } from '../../lib/auth/dashboard'
import Button from '../ui/Button.astro'

const pathname = Astro.url.pathname
const supabase = createClient(Astro.cookies, Astro.request)
const { data: { user } } = await supabase.auth.getUser()
const dashboardHref = user ? await getDashboardDestination(supabase) : '/account'

const navLinks = [
  { href: '/programs',      label: 'Programs'      },
  { href: '/universities',  label: 'Universities'  },
  { href: '/scholarships',  label: 'Scholarships'  },
  { href: '/destinations',  label: 'Destinations'  },
  { href: '/guides',        label: 'Guides'        },
]
---

<header class="sticky top-0 z-50 bg-white/92 backdrop-blur-[6px] backdrop-saturate-110 border-b border-edge">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-8 h-[66px] flex items-center justify-between gap-6">

    {/* Logo */}
    <div class="flex items-center gap-[38px]">
      <a href="/" class="flex items-center gap-[10px] shrink-0 no-underline">
        <div class="w-[30px] h-[30px] rounded-[7px] bg-ink text-white flex items-center justify-center font-mono font-bold text-base flex-none">
          D
        </div>
        <span class="text-[18px] font-bold text-ink tracking-[-0.01em]">DegreeWiki</span>
      </a>

      {/* Primary nav links — hidden on mobile */}
      <nav class="hidden md:flex items-center gap-6" aria-label="Primary navigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={[
              'text-sm font-medium no-underline transition-colors whitespace-nowrap',
              pathname.startsWith(link.href)
                ? 'text-ink'
                : 'text-ink-tertiary hover:text-ink',
            ].join(' ')}
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>

    {/* Right side: account actions */}
    <div class="flex items-center gap-[18px]">
      {user ? (
        <>
          <a
            href={dashboardHref}
            class={[
              'hidden sm:block text-sm font-medium no-underline transition-colors whitespace-nowrap',
              pathname === dashboardHref ? 'text-ink' : 'text-ink-tertiary hover:text-ink',
            ].join(' ')}
          >
            Dashboard
          </a>
          <form method="post" action="/api/auth/logout">
            <button
              type="submit"
              class="text-sm font-medium text-ink-tertiary hover:text-deadline transition-colors whitespace-nowrap"
            >
              Sign out
            </button>
          </form>
        </>
      ) : (
        <>
          <a
            href="/login"
            class="hidden sm:block text-sm font-medium text-ink-tertiary hover:text-ink no-underline transition-colors whitespace-nowrap"
          >
            Sign in
          </a>
          <Button href="/signup" variant="primary" size="sm">Get started</Button>
        </>
      )}
    </div>

  </div>
</header>
