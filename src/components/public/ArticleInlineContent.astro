---
import type { InlineNode } from '../../lib/public/markdown'

interface Props {
  nodes: InlineNode[]
}

const { nodes } = Astro.props
---
{nodes.map((node) => (
  node.type === 'text' ? node.text : (
    node.type === 'strong' ? (
      <strong class="font-semibold text-ink">{node.text}</strong>
    ) : node.type === 'em' ? (
      <em class="italic">{node.text}</em>
    ) : (
      <a
        href={node.href}
        target="_blank"
        rel="nofollow noopener noreferrer"
        class="font-medium text-primary underline decoration-primary/30 underline-offset-4 transition-colors hover:text-primary-hover hover:decoration-primary-hover/50"
      >
        {node.text}
      </a>
    )
  )
))}
