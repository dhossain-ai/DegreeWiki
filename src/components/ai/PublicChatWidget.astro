---
interface Props {
  currentPath: string
}

const { currentPath } = Astro.props
---

<div
  class="pointer-events-none fixed bottom-[calc(env(safe-area-inset-bottom)+1rem)] right-3 z-50 flex max-w-[calc(100vw-1.5rem)] flex-col items-end sm:bottom-4 sm:right-4"
  data-site-chat-root
>
  <button
    id="site-chat-launcher"
    type="button"
    aria-expanded="false"
    aria-controls="site-chat-panel"
    class="pointer-events-auto inline-flex items-center gap-2 rounded-full border border-blue-200 bg-white px-4 py-3 text-sm font-medium text-blue-700 shadow-lg transition-[background-color,border-color,transform] hover:border-blue-300 hover:bg-blue-50 active:translate-y-px"
  >
    <span class="inline-flex h-2.5 w-2.5 rounded-full bg-blue-600"></span>
    <span id="site-chat-launcher-label">Ask DegreeWiki</span>
  </button>

  <section
    id="site-chat-panel"
    class="pointer-events-auto mt-3 hidden h-[min(42rem,calc(100dvh-6rem))] w-[calc(100vw-1.5rem)] max-w-[22rem] flex-col overflow-hidden rounded-[1.5rem] border border-slate-200 bg-white shadow-2xl sm:h-[min(38rem,calc(100dvh-6rem))] sm:w-[22rem]"
    style="display: none;"
    aria-label="DegreeWiki chatbot"
  >
    <div class="flex items-start justify-between gap-3 border-b border-slate-100 px-4 py-3">
      <div class="min-w-0">
        <h2 class="text-sm font-semibold text-slate-900">DegreeWiki Chat</h2>
        <p class="mt-1 text-xs text-slate-500">Quick study-planning guidance inside DegreeWiki</p>
      </div>
      <button
        id="site-chat-close"
        type="button"
        class="rounded-full border border-slate-200 px-2.5 py-1 text-xs font-medium text-slate-600 transition hover:bg-slate-50 hover:text-slate-800"
      >
        Close
      </button>
    </div>

    <div class="border-b border-slate-100 bg-slate-50 px-4 py-2 text-[11px] leading-relaxed text-slate-600">
      Check official university or scholarship sources before making important decisions.
    </div>

    <div id="site-chat-body" class="flex-1 overflow-y-auto px-3 py-3 sm:px-4">
      <div id="site-chat-welcome" class="space-y-4">
        <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
          <p class="text-sm font-medium text-slate-900">Start with a quick question</p>
          <p class="mt-1 text-sm leading-6 text-slate-600">
            This chat checks DegreeWiki guidance first, then uses logged-in AI only when needed.
          </p>
        </div>

        <div id="site-chat-chip-list" class="flex flex-wrap gap-2"></div>
      </div>

      <div id="site-chat-login-cta" class="mt-4 hidden rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
        <p class="font-medium">Sign in for logged-in AI chat</p>
        <p class="mt-1 text-xs leading-relaxed text-amber-800">
          Anonymous visitors still get DegreeWiki guidance. Sign in only when you want controlled AI follow-up.
        </p>
        <a
          id="site-chat-login-link"
          href={`/login?redirect=${encodeURIComponent(currentPath)}`}
          class="mt-3 inline-flex rounded-full bg-amber-900 px-3 py-2 text-xs font-medium text-white transition hover:bg-amber-950"
        >
          Sign in
        </a>
      </div>

      <div
        id="site-chat-transcript"
        class="mt-4 hidden space-y-4"
        role="log"
        aria-live="polite"
        aria-relevant="additions text"
        aria-busy="false"
      ></div>

      <div id="site-chat-status" class="mt-4 hidden" role="status" aria-live="polite"></div>
    </div>

    <div id="site-chat-composer" class="border-t border-slate-100 px-3 py-3 sm:px-4" aria-busy="false">
      <label for="site-chat-input" class="block text-sm font-medium text-slate-700">
        Your question
      </label>
      <textarea
        id="site-chat-input"
        rows="1"
        maxlength="1000"
        class="mt-2 min-h-[2.75rem] w-full resize-none rounded-2xl border border-slate-300 px-3 py-2 text-sm leading-6 text-slate-800 focus:outline-none focus:ring-2 focus:ring-blue-500"
        placeholder="Ask a DegreeWiki study-planning question..."
      ></textarea>

      <div class="mt-3 flex items-center justify-between gap-3">
        <button
          id="site-chat-clear"
          type="button"
          class="hidden rounded-full border border-slate-200 px-3 py-2 text-sm text-slate-600 transition hover:bg-slate-50 disabled:cursor-not-allowed disabled:opacity-50"
        >
          Clear chat
        </button>

        <button
          id="site-chat-send"
          type="button"
          class="ml-auto rounded-full bg-blue-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-blue-700 disabled:cursor-not-allowed disabled:bg-blue-300"
        >
          Send
        </button>
      </div>
    </div>
  </section>
</div>

<script define:vars={{ currentPath }}>
  const DEFAULT_WELCOME_OPTIONS = [
    'How can you help?',
    'Find programs',
    'Try Fit Finder',
    'Scholarships',
    'Study guides',
  ]

  const SOURCE_LABELS = {
    knowledge_base: 'DegreeWiki Knowledge Base',
    assistant: 'DegreeWiki Assistant',
    safety_notice: 'Safety Notice',
    system_notice: 'Notice',
  }

  const launcherEl = document.getElementById('site-chat-launcher')
  const launcherLabelEl = document.getElementById('site-chat-launcher-label')
  const panelEl = document.getElementById('site-chat-panel')
  const panelBodyEl = document.getElementById('site-chat-body')
  const closeEl = document.getElementById('site-chat-close')
  const welcomeEl = document.getElementById('site-chat-welcome')
  const chipListEl = document.getElementById('site-chat-chip-list')
  const loginCtaEl = document.getElementById('site-chat-login-cta')
  const loginLinkEl = document.getElementById('site-chat-login-link')
  const transcriptEl = document.getElementById('site-chat-transcript')
  const statusEl = document.getElementById('site-chat-status')
  const composerEl = document.getElementById('site-chat-composer')
  const inputEl = document.getElementById('site-chat-input')
  const sendEl = document.getElementById('site-chat-send')
  const clearEl = document.getElementById('site-chat-clear')

  let isOpen = false
  let busy = false
  let sessionLoaded = false
  let authenticated = false
  let showLoginPrompt = false
  let welcomeOptions = [...DEFAULT_WELCOME_OPTIONS]

  function normalizeAnswerSource(value) {
    if (
      value === 'knowledge_base'
      || value === 'assistant'
      || value === 'safety_notice'
      || value === 'system_notice'
    ) {
      return value
    }

    return 'knowledge_base'
  }

  function updateLauncherLabel() {
    launcherEl.setAttribute('aria-expanded', isOpen ? 'true' : 'false')
    launcherLabelEl.textContent = isOpen ? 'Close chat' : 'Ask DegreeWiki'
  }

  function scrollPanelToLatest(behavior = 'auto') {
    requestAnimationFrame(() => {
      panelBodyEl.scrollTo({
        top: panelBodyEl.scrollHeight,
        behavior,
      })
    })
  }

  function showTranscript() {
    transcriptEl.classList.remove('hidden')
    transcriptEl.style.display = ''
    welcomeEl.style.display = 'none'
  }

  function hideTranscript() {
    transcriptEl.classList.add('hidden')
    transcriptEl.style.display = 'none'
    welcomeEl.style.display = ''
  }

  function setLoginPromptVisible(nextVisible) {
    showLoginPrompt = !authenticated && nextVisible
    loginCtaEl.style.display = showLoginPrompt ? '' : 'none'
    if (showLoginPrompt) {
      scrollPanelToLatest('auto')
    }
  }

  function setStatus(message, tone) {
    statusEl.textContent = message
    statusEl.className = 'mt-4 rounded-2xl border px-3 py-2 text-xs leading-relaxed'
    if (tone === 'error') {
      statusEl.classList.add('border-red-200', 'bg-red-50', 'text-red-700')
    } else if (tone === 'success') {
      statusEl.classList.add('border-green-200', 'bg-green-50', 'text-green-700')
    } else {
      statusEl.classList.add('border-slate-200', 'bg-slate-50', 'text-slate-600')
    }
    statusEl.style.display = ''
    scrollPanelToLatest('auto')
  }

  function clearStatus() {
    statusEl.textContent = ''
    statusEl.style.display = 'none'
  }

  function bubbleClassesForSource(answerSource) {
    if (answerSource === 'assistant') {
      return 'border-emerald-100 bg-emerald-50'
    }
    if (answerSource === 'safety_notice') {
      return 'border-amber-200 bg-amber-50'
    }
    if (answerSource === 'system_notice') {
      return 'border-slate-200 bg-slate-50'
    }
    return 'border-blue-100 bg-blue-50'
  }

  function badgeClassesForSource(answerSource) {
    if (answerSource === 'assistant') {
      return 'border-emerald-200 bg-white text-emerald-700'
    }
    if (answerSource === 'safety_notice') {
      return 'border-amber-200 bg-white text-amber-800'
    }
    if (answerSource === 'system_notice') {
      return 'border-slate-200 bg-white text-slate-700'
    }
    return 'border-blue-200 bg-white text-blue-700'
  }

  function createMessageNode(message) {
    const wrapper = document.createElement('div')

    if (message.role === 'user') {
      wrapper.className = 'flex justify-end'

      const bubble = document.createElement('div')
      bubble.className = 'max-w-[88%] rounded-2xl bg-slate-100 px-4 py-3 text-sm text-slate-900 shadow-sm'

      const body = document.createElement('p')
      body.className = 'whitespace-pre-wrap break-words leading-6'
      body.textContent = message.content

      bubble.appendChild(body)
      wrapper.appendChild(bubble)
      return wrapper
    }

    const answerSource = normalizeAnswerSource(message.answer_source)

    wrapper.className = 'flex justify-start'

    const bubble = document.createElement('div')
    bubble.className = `max-w-[92%] rounded-2xl border px-4 py-3 text-sm text-slate-900 shadow-sm ${bubbleClassesForSource(answerSource)}`

    const badge = document.createElement('span')
    badge.className = `inline-flex rounded-full border px-2 py-1 text-[11px] font-semibold ${badgeClassesForSource(answerSource)}`
    badge.textContent = SOURCE_LABELS[answerSource]

    const body = document.createElement('p')
    body.className = 'mt-2 whitespace-pre-wrap break-words leading-6 text-slate-800'
    body.textContent = message.content

    bubble.appendChild(badge)
    bubble.appendChild(body)
    wrapper.appendChild(bubble)
    return wrapper
  }

  function appendMessage(message, behavior = 'smooth') {
    transcriptEl.appendChild(createMessageNode(message))
    showTranscript()
    updateClearVisibility()
    scrollPanelToLatest(behavior)
  }

  function replaceTranscript(messages) {
    transcriptEl.replaceChildren()

    for (const message of messages) {
      transcriptEl.appendChild(createMessageNode(message))
    }

    if (messages.length === 0) {
      hideTranscript()
    } else {
      showTranscript()
    }

    updateClearVisibility()
    scrollPanelToLatest('auto')
  }

  function renderWelcomeChips() {
    chipListEl.replaceChildren()

    for (const option of welcomeOptions) {
      const chip = document.createElement('button')
      chip.type = 'button'
      chip.className = 'rounded-full border border-slate-200 bg-white px-3 py-1.5 text-xs font-medium text-slate-700 shadow-sm transition hover:border-slate-300 hover:bg-slate-50 disabled:cursor-not-allowed disabled:opacity-50'
      chip.textContent = option
      chip.disabled = busy
      chip.addEventListener('click', () => {
        submitMessage(option)
      })
      chipListEl.appendChild(chip)
    }
  }

  function updateComposerState() {
    sendEl.disabled = busy || inputEl.value.trim().length === 0
  }

  function updateClearVisibility() {
    clearEl.style.display = authenticated ? '' : 'none'
    clearEl.disabled = busy || transcriptEl.childElementCount === 0
  }

  function updateAuthUI() {
    loginLinkEl.href = '/login?redirect=' + encodeURIComponent(currentPath)
    if (authenticated) {
      setLoginPromptVisible(false)
    }
    updateClearVisibility()
  }

  function setBusy(nextBusy, sendLabel, clearLabel) {
    busy = nextBusy
    inputEl.disabled = nextBusy
    sendEl.textContent = sendLabel
    clearEl.textContent = clearLabel
    transcriptEl.setAttribute('aria-busy', nextBusy ? 'true' : 'false')
    composerEl.setAttribute('aria-busy', nextBusy ? 'true' : 'false')

    for (const chip of chipListEl.querySelectorAll('button')) {
      chip.disabled = nextBusy
    }

    updateComposerState()
    updateClearVisibility()
  }

  function adjustTextareaHeight() {
    inputEl.style.height = 'auto'
    const nextHeight = Math.min(Math.max(inputEl.scrollHeight, 44), 144)
    inputEl.style.height = `${nextHeight}px`
    inputEl.style.overflowY = inputEl.scrollHeight > 144 ? 'auto' : 'hidden'
  }

  async function ensureSession() {
    if (sessionLoaded) return true

    try {
      const res = await fetch('/api/ai/site-chat-session', { method: 'GET' })
      let data
      try {
        data = await res.json()
      } catch {
        setStatus('Could not start chat right now. Please try again.', 'error')
        return false
      }

      if (!data.ok) {
        setStatus('Could not start chat right now. Please try again.', 'error')
        return false
      }

      if (Array.isArray(data.welcome_options) && data.welcome_options.length > 0) {
        welcomeOptions = data.welcome_options
          .filter((value) => typeof value === 'string')
          .map((value) => value.trim())
          .filter((value) => value.length > 0)

        if (welcomeOptions.length === 0) {
          welcomeOptions = [...DEFAULT_WELCOME_OPTIONS]
        }
      }

      renderWelcomeChips()

      authenticated = data.authenticated === true
      sessionLoaded = true
      updateAuthUI()

      if (authenticated && Array.isArray(data.messages)) {
        replaceTranscript(data.messages)
      } else {
        hideTranscript()
      }

      scrollPanelToLatest('auto')
      return true
    } catch {
      setStatus('Could not start chat right now. Please try again.', 'error')
      return false
    }
  }

  function openPanel() {
    if (isOpen) return
    panelEl.style.display = 'flex'
    panelEl.classList.remove('hidden')
    isOpen = true
    updateLauncherLabel()
    clearStatus()
    inputEl.focus()
    scrollPanelToLatest('auto')
    void ensureSession()
  }

  function closePanel() {
    if (!isOpen) return
    panelEl.style.display = 'none'
    panelEl.classList.add('hidden')
    isOpen = false
    updateLauncherLabel()
    launcherEl.focus()
  }

  function mapError(data) {
    const err = data && data.error ? data.error : ''

    if (err === 'message_rejected') {
      return {
        mode: 'append',
        message: data && typeof data.answer === 'string' && data.answer.trim().length > 0
          ? data.answer
          : 'That message cannot be processed here.',
        answerSource: normalizeAnswerSource(data && data.answer_source),
      }
    }

    if (err === 'invalid_message') {
      return { mode: 'status', tone: 'error', message: 'Please enter a question between 1 and 1000 characters.' }
    }

    if (err === 'rate_limit_exceeded') {
      return { mode: 'status', tone: 'error', message: "You've reached today's AI usage limit. Please try again tomorrow." }
    }

    if (err === 'ai_setup_unavailable') {
      return { mode: 'status', tone: 'error', message: 'AI chat is not fully available right now. Please try again later.' }
    }

    if (err === 'ai_unavailable') {
      return { mode: 'status', tone: 'error', message: 'AI is temporarily unavailable. Please try again in a few minutes.' }
    }

    if (err === 'unauthenticated') {
      return { mode: 'status', tone: 'error', message: 'Please sign in again to continue.' }
    }

    return { mode: 'status', tone: 'error', message: 'Something went wrong. Please try again.' }
  }

  async function submitMessage(messageOverride) {
    const ready = await ensureSession()
    if (!ready || busy) return

    const message = (messageOverride ?? inputEl.value).trim()
    if (!message) return
    if (message.length > 1000) {
      setStatus('Please enter a question between 1 and 1000 characters.', 'error')
      return
    }

    clearStatus()
    setBusy(true, 'Working...', 'Clearing...')
    setStatus('Checking DegreeWiki guidance first...', 'info')
    appendMessage({ role: 'user', content: message })
    inputEl.value = ''
    adjustTextareaHeight()
    updateComposerState()

    try {
      const res = await fetch('/api/ai/site-chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          message,
          current_path: currentPath,
        }),
      })

      let data
      try {
        data = await res.json()
      } catch {
        clearStatus()
        setStatus('Could not complete that chat reply right now. Please try again.', 'error')
        return
      }

      if (data.ok) {
        clearStatus()

        if (typeof data.answer === 'string' && data.answer.trim().length > 0) {
          appendMessage({
            role: 'assistant',
            content: data.answer,
            answer_source: normalizeAnswerSource(data.answer_source),
          })
        }

        authenticated = data.authenticated === true
        updateAuthUI()
        setLoginPromptVisible(data.requires_login === true)
      } else {
        clearStatus()
        const mapped = mapError(data)

        if (mapped.mode === 'append') {
          appendMessage({
            role: 'assistant',
            content: mapped.message,
            answer_source: mapped.answerSource,
          })
        } else {
          if (data && data.error === 'unauthenticated') {
            setLoginPromptVisible(true)
          }
          setStatus(mapped.message, mapped.tone)
        }
      }
    } catch {
      clearStatus()
      setStatus('Could not complete that chat reply right now. Please try again.', 'error')
    } finally {
      setBusy(false, 'Send', 'Clear chat')
      updateComposerState()
      adjustTextareaHeight()
      inputEl.focus()
    }
  }

  launcherEl.addEventListener('click', () => {
    if (isOpen) {
      closePanel()
    } else {
      openPanel()
    }
  })

  closeEl.addEventListener('click', closePanel)

  sendEl.addEventListener('click', () => {
    submitMessage()
  })

  inputEl.addEventListener('input', () => {
    adjustTextareaHeight()
    updateComposerState()
  })

  inputEl.addEventListener('keydown', (event) => {
    if (event.key === 'Enter' && !event.shiftKey) {
      event.preventDefault()
      submitMessage()
    }
  })

  clearEl.addEventListener('click', async () => {
    if (busy || !authenticated) return

    clearStatus()
    setBusy(true, 'Send', 'Clearing...')

    try {
      const res = await fetch('/api/ai/site-chat-clear', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
      })

      let data
      try {
        data = await res.json()
      } catch {
        setStatus('Could not clear chat. Please try again.', 'error')
        return
      }

      if (!data.ok) {
        setStatus('Could not clear chat. Please try again.', 'error')
        return
      }

      transcriptEl.replaceChildren()
      hideTranscript()
      setLoginPromptVisible(false)
      setStatus('Chat cleared.', 'success')
      updateClearVisibility()
      scrollPanelToLatest('auto')
    } catch {
      setStatus('Could not clear chat. Please try again.', 'error')
    } finally {
      setBusy(false, 'Send', 'Clear chat')
    }
  })

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && isOpen) {
      closePanel()
    }
  })

  const handleViewportChange = () => {
    if (isOpen) {
      scrollPanelToLatest('auto')
    }
  }

  window.addEventListener('resize', handleViewportChange)
  window.visualViewport?.addEventListener('resize', handleViewportChange)

  renderWelcomeChips()
  updateAuthUI()
  updateLauncherLabel()
  updateComposerState()
  adjustTextareaHeight()
</script>
