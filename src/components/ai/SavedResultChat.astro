---
interface Props {
  resultId: string
  initialMessages: Array<{ role: 'user' | 'assistant'; content: string }>
}
const { resultId, initialMessages } = Astro.props
const hasHistory = initialMessages.length > 0

const SUGGESTED_QUESTIONS = [
  'Which 3 programs should I check first?',
  'Which options fit my budget best?',
  'What should I verify before applying?',
  'Compare my top matches.',
]

type InlineSegment = {
  text: string
  bold: boolean
}

type MessageBlock =
  | { type: 'paragraph'; lines: InlineSegment[][] }
  | { type: 'unordered-list'; items: InlineSegment[][][] }
  | { type: 'ordered-list'; items: InlineSegment[][][] }

function parseInlineSegments(text: string): InlineSegment[] {
  const segments: InlineSegment[] = []
  const parts = text.split(/(\*\*[^*]+\*\*)/g)

  for (const part of parts) {
    if (!part) continue
    if (part.startsWith('**') && part.endsWith('**') && part.length > 4) {
      segments.push({ text: part.slice(2, -2), bold: true })
    } else {
      segments.push({ text: part, bold: false })
    }
  }

  return segments.length > 0 ? segments : [{ text, bold: false }]
}

function parseAssistantMessage(content: string): MessageBlock[] {
  const normalized = content.replace(/\r\n?/g, '\n')
  const lines = normalized.split('\n')
  const blocks: MessageBlock[] = []
  let index = 0

  while (index < lines.length) {
    if (!lines[index].trim()) {
      index += 1
      continue
    }

    const orderedMatch = lines[index].match(/^\s*\d+\.\s+(.+)$/)
    if (orderedMatch) {
      const items: InlineSegment[][][] = []
      while (index < lines.length) {
        const match = lines[index].match(/^\s*\d+\.\s+(.+)$/)
        if (!match) break
        items.push([[...parseInlineSegments(match[1])]])
        index += 1
      }
      blocks.push({ type: 'ordered-list', items })
      continue
    }

    const unorderedMatch = lines[index].match(/^\s*[-*]\s+(.+)$/)
    if (unorderedMatch) {
      const items: InlineSegment[][][] = []
      while (index < lines.length) {
        const match = lines[index].match(/^\s*[-*]\s+(.+)$/)
        if (!match) break
        items.push([[...parseInlineSegments(match[1])]])
        index += 1
      }
      blocks.push({ type: 'unordered-list', items })
      continue
    }

    const paragraphLines: InlineSegment[][] = []
    while (index < lines.length) {
      if (!lines[index].trim()) break
      if (/^\s*\d+\.\s+(.+)$/.test(lines[index]) || /^\s*[-*]\s+(.+)$/.test(lines[index])) break
      paragraphLines.push(parseInlineSegments(lines[index]))
      index += 1
    }
    blocks.push({ type: 'paragraph', lines: paragraphLines })
  }

  return blocks
}
---

<div id="ai-advisor" class="max-w-3xl scroll-mt-24 rounded-2xl border border-purple-100 bg-white p-5 shadow-sm">
  <h2 class="text-lg font-semibold text-gray-900 mb-2">AI advisor for this shortlist</h2>
  <p class="text-sm text-gray-600 mb-3">
    Ask follow-up questions about the saved matches on this page. The advisor can compare
    these programs, explain why they fit, and point out what to verify, but it cannot search
    for new options.
  </p>

  <div class="text-xs text-gray-500 bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 mb-4">
    AI answers are guidance only, not admission, visa, or scholarship outcomes. Verify key
    details with official sources before applying.
  </div>

  <div class="mb-4">
    <p class="text-xs font-semibold uppercase tracking-[0.12em] text-purple-700 mb-2">Try a prompt</p>
    <div class="flex flex-wrap gap-2">
      {SUGGESTED_QUESTIONS.map(q => (
        <button type="button" class="chat-suggestion text-xs bg-purple-50 hover:bg-purple-100 border border-purple-100 rounded-full px-3 py-1.5 text-purple-800 text-left">
          {q}
        </button>
      ))}
    </div>
  </div>

  <div id="chat-transcript" class="space-y-3 mb-4" style={hasHistory ? undefined : 'display:none'}>
    {initialMessages.map(msg => (
      <div class={msg.role === 'user'
        ? 'bg-gray-100 rounded-xl px-3 py-2 text-sm'
        : 'bg-purple-50 border border-purple-100 rounded-xl px-3 py-2 text-sm'}>
        <span class={'block text-xs font-medium mb-1 ' + (msg.role === 'user' ? 'text-gray-500' : 'text-purple-700')}>
          {msg.role === 'user' ? 'You' : 'Assistant'}
        </span>
        {msg.role === 'user' ? (
          <p class="text-gray-700 whitespace-pre-wrap">{msg.content}</p>
        ) : (
          <div class="space-y-3 text-gray-700">
            {parseAssistantMessage(msg.content).map(block => (
              block.type === 'paragraph' ? (
                <p class="leading-relaxed">
                  {block.lines.map((line, lineIndex) => (
                    <>
                      {lineIndex > 0 && <br />}
                      {line.map(segment => (
                        segment.bold
                          ? <strong class="font-semibold text-gray-900">{segment.text}</strong>
                          : <>{segment.text}</>
                      ))}
                    </>
                  ))}
                </p>
              ) : block.type === 'ordered-list' ? (
                <ol class="list-decimal space-y-1 pl-5">
                  {block.items.map(item => (
                    <li class="leading-relaxed">
                      {item.map((line, lineIndex) => (
                        <>
                          {lineIndex > 0 && <br />}
                          {line.map(segment => (
                            segment.bold
                              ? <strong class="font-semibold text-gray-900">{segment.text}</strong>
                              : <>{segment.text}</>
                          ))}
                        </>
                      ))}
                    </li>
                  ))}
                </ol>
              ) : (
                <ul class="list-disc space-y-1 pl-5">
                  {block.items.map(item => (
                    <li class="leading-relaxed">
                      {item.map((line, lineIndex) => (
                        <>
                          {lineIndex > 0 && <br />}
                          {line.map(segment => (
                            segment.bold
                              ? <strong class="font-semibold text-gray-900">{segment.text}</strong>
                              : <>{segment.text}</>
                          ))}
                        </>
                      ))}
                    </li>
                  ))}
                </ul>
              )
            ))}
          </div>
        )}
      </div>
    ))}
  </div>

  <div id="chat-empty" class="mb-4" style={hasHistory ? 'display:none' : undefined}>
    <p class="text-sm text-gray-500">No questions yet. Pick a prompt above or ask your own question.</p>
  </div>

  <div id="chat-status" class="text-sm mb-3" style="display:none"></div>

  <label for="chat-input" class="block text-sm font-medium text-gray-700 mb-1">
    Your question
  </label>
  <textarea
    id="chat-input"
    rows="3"
    maxlength="1000"
    class="w-full border border-gray-300 rounded-xl px-3 py-2 text-base sm:text-sm resize-none focus:outline-none focus:ring-2 focus:ring-blue-500"
    placeholder="Ask about this shortlist..."
  ></textarea>

  <div class="mt-2 flex flex-col gap-2 sm:flex-row">
    <button
      id="chat-submit"
      type="button"
      class="inline-flex w-full items-center justify-center rounded-full bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 disabled:cursor-not-allowed disabled:opacity-50 sm:w-auto"
    >
      Ask
    </button>
    <button
      id="chat-clear"
      type="button"
      class="inline-flex w-full items-center justify-center rounded-full border border-gray-200 px-3 py-2 text-sm text-gray-500 hover:bg-gray-50 disabled:cursor-not-allowed disabled:opacity-50 sm:w-auto"
      style={hasHistory ? undefined : 'display:none'}
    >
      Clear chat
    </button>
  </div>
</div>

<script define:vars={{ resultId, hasHistory }}>
  const transcriptEl = document.getElementById('chat-transcript')
  const emptyEl = document.getElementById('chat-empty')
  const statusEl = document.getElementById('chat-status')
  const inputEl = document.getElementById('chat-input')
  const submitBtn = document.getElementById('chat-submit')
  const clearBtn = document.getElementById('chat-clear')

  let busy = false

  function parseInlineSegments(text) {
    const segments = []
    const parts = text.split(/(\*\*[^*]+\*\*)/g)

    for (const part of parts) {
      if (!part) continue
      if (part.startsWith('**') && part.endsWith('**') && part.length > 4) {
        segments.push({ text: part.slice(2, -2), bold: true })
      } else {
        segments.push({ text: part, bold: false })
      }
    }

    return segments.length > 0 ? segments : [{ text, bold: false }]
  }

  function parseAssistantMessage(text) {
    const normalized = String(text ?? '').replace(/\r\n?/g, '\n')
    const lines = normalized.split('\n')
    const blocks = []
    let index = 0

    while (index < lines.length) {
      if (!lines[index].trim()) {
        index += 1
        continue
      }

      let match = lines[index].match(/^\s*\d+\.\s+(.+)$/)
      if (match) {
        const items = []
        while (index < lines.length) {
          match = lines[index].match(/^\s*\d+\.\s+(.+)$/)
          if (!match) break
          items.push([parseInlineSegments(match[1])])
          index += 1
        }
        blocks.push({ type: 'ordered-list', items })
        continue
      }

      match = lines[index].match(/^\s*[-*]\s+(.+)$/)
      if (match) {
        const items = []
        while (index < lines.length) {
          match = lines[index].match(/^\s*[-*]\s+(.+)$/)
          if (!match) break
          items.push([parseInlineSegments(match[1])])
          index += 1
        }
        blocks.push({ type: 'unordered-list', items })
        continue
      }

      const paragraphLines = []
      while (index < lines.length) {
        if (!lines[index].trim()) break
        if (/^\s*\d+\.\s+(.+)$/.test(lines[index]) || /^\s*[-*]\s+(.+)$/.test(lines[index])) break
        paragraphLines.push(parseInlineSegments(lines[index]))
        index += 1
      }
      blocks.push({ type: 'paragraph', lines: paragraphLines })
    }

    return blocks
  }

  function appendInlineSegments(parent, segments) {
    segments.forEach(segment => {
      if (!segment.text) return
      if (segment.bold) {
        const strong = document.createElement('strong')
        strong.className = 'font-semibold text-gray-900'
        strong.textContent = segment.text
        parent.appendChild(strong)
      } else {
        parent.appendChild(document.createTextNode(segment.text))
      }
    })
  }

  function buildAssistantBody(text) {
    const container = document.createElement('div')
    container.className = 'space-y-3 text-gray-700'

    const blocks = parseAssistantMessage(text)
    if (blocks.length === 0) {
      const paragraph = document.createElement('p')
      paragraph.className = 'leading-relaxed'
      paragraph.textContent = text
      container.appendChild(paragraph)
      return container
    }

    blocks.forEach(block => {
      if (block.type === 'paragraph') {
        const paragraph = document.createElement('p')
        paragraph.className = 'leading-relaxed'
        block.lines.forEach((line, lineIndex) => {
          if (lineIndex > 0) paragraph.appendChild(document.createElement('br'))
          appendInlineSegments(paragraph, line)
        })
        container.appendChild(paragraph)
        return
      }

      const list = document.createElement(block.type === 'ordered-list' ? 'ol' : 'ul')
      list.className = block.type === 'ordered-list' ? 'list-decimal space-y-1 pl-5' : 'list-disc space-y-1 pl-5'

      block.items.forEach(item => {
        const listItem = document.createElement('li')
        listItem.className = 'leading-relaxed'
        item.forEach((line, lineIndex) => {
          if (lineIndex > 0) listItem.appendChild(document.createElement('br'))
          appendInlineSegments(listItem, line)
        })
        list.appendChild(listItem)
      })

      container.appendChild(list)
    })

    return container
  }

  function appendTurn(role, text) {
    const wrapper = document.createElement('div')
    wrapper.className = role === 'user'
      ? 'bg-gray-100 rounded-xl px-3 py-2 text-sm'
      : 'bg-purple-50 border border-purple-100 rounded-xl px-3 py-2 text-sm'

    const label = document.createElement('span')
    label.className = 'block text-xs font-medium mb-1 ' +
      (role === 'user' ? 'text-gray-500' : 'text-purple-700')
    label.textContent = role === 'user' ? 'You' : 'Assistant'

    const body = role === 'user'
      ? document.createElement('p')
      : buildAssistantBody(text)

    if (role === 'user') {
      body.className = 'text-gray-700 whitespace-pre-wrap'
      body.textContent = text
    }

    wrapper.appendChild(label)
    wrapper.appendChild(body)
    transcriptEl.appendChild(wrapper)
    transcriptEl.style.display = ''
    emptyEl.style.display = 'none'
    clearBtn.style.display = ''
    wrapper.scrollIntoView({ behavior: 'smooth', block: 'nearest' })
  }

  function showError(msg) {
    statusEl.textContent = msg
    statusEl.style.color = '#dc2626'
    statusEl.style.display = ''
  }

  function hideStatus() {
    statusEl.style.display = 'none'
    statusEl.textContent = ''
  }

  function setBusy(val) {
    busy = val
    submitBtn.disabled = val
    clearBtn.disabled = val
  }

  function mapError(data) {
    const err = data && data.error ? data.error : ''
    if (err === 'invalid_message') return 'Please enter a valid question between 1 and 1000 characters.'
    if (err === 'message_rejected') return data && data.answer ? data.answer : "This question can't be answered here. Please ask about the programs in your saved result."
    if (err === 'unauthenticated') return 'Please sign in again to continue.'
    if (err === 'not_found') return 'This saved result is no longer available or you no longer have access to it.'
    if (err === 'result_not_ready') return 'This saved result is not ready for AI follow-up yet. Run Fit Finder again to refresh it.'
    if (err === 'advisor_context_failed') return 'DegreeWiki AI could not load the context for this shortlist right now. Please try again in a moment.'
    if (err === 'rate_limit_exceeded') return "You've reached today's AI usage limit. Please try again tomorrow."
    if (err === 'ai_unavailable') return 'AI is temporarily unavailable. Please try again in a few minutes.'
    if (err === 'internal_error') return 'Something went wrong. Please try again.'
    return 'Something went wrong. Please try again.'
  }

  // Populate textarea from suggested-question chips — no auto-submit.
  document.querySelectorAll('.chat-suggestion').forEach(btn => {
    btn.addEventListener('click', () => {
      inputEl.value = btn.textContent.trim()
      inputEl.focus()
    })
  })

  // Scroll to latest message on initial load when history exists.
  if (hasHistory) {
    const last = transcriptEl.lastElementChild
    if (last) last.scrollIntoView({ behavior: 'instant', block: 'nearest' })
  }

  submitBtn.addEventListener('click', async () => {
    if (busy) return
    const message = inputEl.value.trim()
    if (!message) return
    if (message.length > 1000) {
      showError('Please enter a valid question between 1 and 1000 characters.')
      return
    }

    setBusy(true)
    submitBtn.textContent = 'Asking...'
    hideStatus()

    appendTurn('user', message)
    inputEl.value = ''

    try {
      const res = await fetch('/api/ai/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ai_finder_result_id: resultId, message }),
      })

      let data
      try { data = await res.json() } catch { showError('Something went wrong. Please try again.'); return }

      if (data.ok) {
        appendTurn('assistant', data.answer)
      } else {
        showError(mapError(data))
      }
    } catch {
      showError('Something went wrong. Please try again.')
    } finally {
      setBusy(false)
      submitBtn.textContent = 'Ask'
    }
  })

  clearBtn.addEventListener('click', async () => {
    if (busy) return

    setBusy(true)
    clearBtn.textContent = 'Clearing...'
    hideStatus()

    try {
      const res = await fetch('/api/ai/chat-clear', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ai_finder_result_id: resultId }),
      })

      let data
      try { data = await res.json() } catch { showError('Could not clear chat. Please try again.'); return }

      if (data.ok) {
        transcriptEl.replaceChildren()
        transcriptEl.style.display = 'none'
        emptyEl.style.display = ''
        clearBtn.style.display = 'none'
        hideStatus()
      } else {
        const err = data && data.error
        showError(err === 'not_found'
          ? 'This saved result is no longer available.'
          : 'Could not clear chat. Please try again.')
      }
    } catch {
      showError('Could not clear chat. Please try again.')
    } finally {
      setBusy(false)
      clearBtn.textContent = 'Clear chat'
    }
  })
</script>
