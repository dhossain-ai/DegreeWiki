---
import '../styles/global.css'
interface Props {
  title?: string
}
const { title = 'DegreeWiki' } = Astro.props
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900">
    <slot />
  </body>
</html>
