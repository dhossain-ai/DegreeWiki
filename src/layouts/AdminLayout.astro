---
import BaseLayout from './BaseLayout.astro'
import AdminSidebar from '../components/admin/AdminSidebar.astro'

interface Props {
  title?: string
  activePath?: string
  userEmail?: string
}
const { title = 'Admin — DegreeWiki', activePath = '', userEmail = '' } = Astro.props
---
<BaseLayout title={title}>
  <div class="flex min-h-screen">
    <AdminSidebar activePath={activePath} />
    <div class="flex-1 flex flex-col min-w-0">
      <header class="bg-white border-b border-gray-200 px-6 py-3 flex items-center justify-between flex-shrink-0">
        <span class="text-sm text-gray-500">
          Signed in as <strong class="text-gray-700">{userEmail || '—'}</strong>
        </span>
        <form method="post" action="/api/auth/logout">
          <button type="submit" class="text-sm text-red-600 hover:underline">
            Logout
          </button>
        </form>
      </header>
      <main class="flex-1 p-6 overflow-auto">
        <slot />
      </main>
    </div>
  </div>
</BaseLayout>
