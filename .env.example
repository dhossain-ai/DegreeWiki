# Copy the names you need into your local `.env.local` or production dashboard.
# Keep secrets out of git. Use real values only in local ignored files or provider dashboards.
# Canonical production site URL: https://degreewiki.com

# Public client-safe
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
PUBLIC_SITE_URL=https://degreewiki.com
PUBLIC_CLOUDINARY_CLOUD_NAME=

# Server-only required
SUPABASE_SERVICE_ROLE_KEY=

# Server-only optional/conditional
# Google OAuth stays in Supabase Auth provider config, not here.
GEMINI_API_KEY=

# AI provider/env fallback
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
AI_RATE_LIMIT_USER_DAILY=20
AI_RATE_LIMIT_ANON_DAILY=5
AI_GATEWAY_ENV_FALLBACK_ENABLED=false
OPENROUTER_API_KEY=

# Cloudinary optional/conditional
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=degreewiki
CLOUDINARY_SIGNATURE_ALGORITHM=sha256

# DB-managed AI Gateway optional/conditional
AI_GATEWAY_MASTER_KEY=
AI_GATEWAY_ACTIVE_KEY_VERSION=
