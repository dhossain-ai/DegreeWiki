PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
PUBLIC_SITE_URL=

# AI Provider
# IMPORTANT: These variables are server-only. They must NEVER use the PUBLIC_ prefix.
# Never expose these to the browser or client-side code.
# Local Astro server development may read these from `.env.local` in server-only code.
# Cloudflare/wrangler local testing should use `.dev.vars` instead.
# Never commit either file.
# In Cloudflare Workers, set GEMINI_API_KEY as a secret via: wrangler secret put GEMINI_API_KEY
GEMINI_API_KEY=
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash

# OpenRouter (alternative provider, for local AI testing)
# Set AI_PROVIDER=openrouter and AI_MODEL to an OpenRouter model id to route AI
# calls through OpenRouter's OpenAI-compatible endpoint instead of Gemini.
# OPENROUTER_API_KEY is server-only — NEVER use the PUBLIC_ prefix.
# Free OpenRouter models have strict rate limits; use for development/testing only,
# not production reliability. Example local config:
#   AI_PROVIDER=openrouter
#   AI_MODEL=openrouter/free
#   OPENROUTER_API_KEY=...
OPENROUTER_API_KEY=

# AI Rate Limits (Phase 25+)
# Maximum AI calls allowed per day per logged-in user (across all session types).
# If absent, the implementation defaults to the conservative values shown here.
AI_RATE_LIMIT_ANON_DAILY=5
AI_RATE_LIMIT_USER_DAILY=20

# Supabase Service Role Key (Phase 25+)
# IMPORTANT: SERVER-ONLY. Must NEVER use the PUBLIC_ prefix.
# Never expose this key to browser code or client-side scripts.
# Used only by server-side AI usage logging and rate-limit enforcement.
# Local Astro server development may read this from `.env.local`; wrangler local testing
# should use `.dev.vars`. Never commit either file.
# In Cloudflare Workers, set via: wrangler secret put SUPABASE_SERVICE_ROLE_KEY
# Without this key, AI calls are blocked (fail-closed) to prevent untracked usage.
SUPABASE_SERVICE_ROLE_KEY=

# ── Cloudinary (Phase 57A) ────────────────────────────────────────────────────
# Cloudinary — PUBLIC, safe for browser/client use (used in MediaImage component
# and direct-upload flows). This value is deliberately client-visible.
PUBLIC_CLOUDINARY_CLOUD_NAME=

# Cloudinary — SERVER-ONLY secrets.
# NEVER use the PUBLIC_ prefix for the API key or secret.
# Never expose these in browser code, client components, or public env vars.
# Local Astro dev: add to .env.local (not committed).
# Cloudflare Workers: set as secrets via:
#   wrangler secret put CLOUDINARY_API_KEY
#   wrangler secret put CLOUDINARY_API_SECRET
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Root folder for all DegreeWiki assets in Cloudinary.
# All uploaded assets will be stored under this folder prefix.
CLOUDINARY_UPLOAD_FOLDER=degreewiki

# Signing algorithm used when generating upload signatures.
# Use sha256 if your Cloudinary account is configured for SHA-256 signatures
# (recommended for new accounts). Use sha1 as a fallback for older accounts.
# Check: Cloudinary Dashboard → Settings → Security → Signature algorithm.
CLOUDINARY_SIGNATURE_ALGORITHM=sha256
