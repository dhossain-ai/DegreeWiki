PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
PUBLIC_SITE_URL=

# AI Provider
# IMPORTANT: These variables are server-only. They must NEVER use the PUBLIC_ prefix.
# Never expose these to the browser or client-side code.
# Local Astro server development may read these from `.env.local` in server-only code.
# Cloudflare/wrangler local testing should use `.dev.vars` instead.
# Never commit either file.
# In Cloudflare Workers, set GEMINI_API_KEY as a secret via: wrangler secret put GEMINI_API_KEY
GEMINI_API_KEY=
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash

# AI Rate Limits (Phase 25+)
# Maximum AI calls allowed per day per logged-in user (across all session types).
# If absent, the implementation defaults to the conservative values shown here.
AI_RATE_LIMIT_ANON_DAILY=5
AI_RATE_LIMIT_USER_DAILY=20

# Supabase Service Role Key (Phase 25+)
# IMPORTANT: SERVER-ONLY. Must NEVER use the PUBLIC_ prefix.
# Never expose this key to browser code or client-side scripts.
# Used only by server-side AI usage logging and rate-limit enforcement.
# Local Astro server development may read this from `.env.local`; wrangler local testing
# should use `.dev.vars`. Never commit either file.
# In Cloudflare Workers, set via: wrangler secret put SUPABASE_SERVICE_ROLE_KEY
# Without this key, AI calls are blocked (fail-closed) to prevent untracked usage.
SUPABASE_SERVICE_ROLE_KEY=
